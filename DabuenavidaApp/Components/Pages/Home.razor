protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender)
    {
        AuthService.MarcarJsDisponible();  // ← primero esto
        await AuthService.LoadTokenAsync();

        _permisos = await FiltrosPermisosService
            .GetPermisosAsync(AuthService.Token ?? "");

        _permisos ??= new FiltrosPermisosDto
        {
            MostrarCentroDeCosto = true,
            MostrarDabuenavida   = true
        };

        await CargarDatos();
        estado = Estado.Permitido;
        StateHasChanged();
    }
}

using Microsoft.JSInterop;
using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage;
using System.Threading.Tasks;
using System.Security.Cryptography;
using System.IdentityModel.Tokens.Jwt;
using Microsoft.AspNetCore.Components;

namespace ManageAdminDMS_UI.Services
{
    public class AuthService
    {
        private readonly ProtectedSessionStorage _storage;
        private bool _jsDisponible = false;

        public string? DisplayName { get; set; }
        public string? Rol         { get; set; }
        public string? Nomenclatura { get; set; }
        public String? Token       { get; set; }
        public bool IsAuthenticated => !string.IsNullOrEmpty(Token);

        public AuthService(ProtectedSessionStorage storage)
        {
            _storage = storage;
        }

        // ── Llamar PRIMERO en OnAfterRenderAsync ──────────────
        public void MarcarJsDisponible() => _jsDisponible = true;

        // ── Guardar token ─────────────────────────────────────
        public async Task SetTokenAsync(string token)
        {
            Token = token;
            await _storage.SetAsync("token", token);
            ParseToken();
        }

        // ── Parsear claims del JWT ────────────────────────────
        public void ParseToken()
        {
            if (string.IsNullOrEmpty(Token)) return;

            var handler = new JwtSecurityTokenHandler();
            var jwt     = handler.ReadJwtToken(Token);

            DisplayName = jwt.Claims
                .FirstOrDefault(c => c.Type == "displayName")?.Value ?? "";

            Rol = jwt.Claims
                .FirstOrDefault(c => c.Type == "rol")?.Value ?? "";

            // Nomenclatura: primera letra nombre + apellido + rol
            var partes         = DisplayName.Split(' ');
            string inicialNombre   = partes.Length > 0 ? partes[0][..1] : "";
            string inicialApellido = partes.Length > 1 ? partes[1][..1] : "";
            string inicialRol      = Rol.Length > 0   ? Rol[..1]        : "";
            Nomenclatura = (inicialNombre + inicialApellido + inicialRol).ToUpper();
        }

        // ── Cargar token desde storage ────────────────────────
        public async Task LoadTokenAsync()
        {
            if (!_jsDisponible) return;  // guard prerender

            try
            {
                var result = await _storage.GetAsync<string>("token");
                Token = result.Value;
                ParseToken();
            }
            catch (CryptographicException)
            {
                await LogoutAsync();
            }
            catch (Exception ex) when (ex.InnerException is CryptographicException)
            {
                await LogoutAsync();
            }
        }

        // ── Cerrar sesión ─────────────────────────────────────
        public async Task LogoutAsync()
        {
            Token = null;
            DisplayName  = null;
            Rol          = null;
            Nomenclatura = null;

            if (_jsDisponible)  // guard prerender
                await _storage.DeleteAsync("token");
        }
    }
}