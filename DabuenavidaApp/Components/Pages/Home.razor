// Controllers/FiltrosPermisosController.cs
using System.Security.Claims;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using Microservices.Models;

namespace Microservices.Controllers
{
    [ApiController]
    [Route("api/[controller]")]
    [Authorize] // 🔒 Requiere JWT válido
    public class FiltrosPermisosController : ControllerBase
    {
        [HttpGet("mis-filtros")]
        public IActionResult GetFiltrosPermitidos()
        {
            // Extraemos el claim "rol" del JWT — el mismo que ya
            // guardas en ActiveDirectoryServices con new Claim("rol", rol)
            var rol = User.FindFirstValue("rol");

            if (string.IsNullOrEmpty(rol))
                return Unauthorized("No se encontró el rol en el token.");

            var permisos = new FiltrosPermisosDto
            {
                MostrarDabuenavida  = true,              // todos lo ven siempre
                MostrarCentroDeCosto = rol != "Asesor",  // solo no-Asesores
            };

            return Ok(permisos);
        }
    }
}