// Services/AuthService.cs
using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage;

namespace LotesApp.Services
{
    public class AuthService
    {
        private readonly ProtectedSessionStorage _storage;
        private bool _loaded = false;

        public string? DisplayName { get; set; }
        public string? Rol { get; set; }
        public string? Nomenclatura { get; set; }
        public string? Token { get; set; }
        public bool IsAuthenticated => !string.IsNullOrEmpty(Token);

        public AuthService(ProtectedSessionStorage storage)
        {
            _storage = storage;
        }

        public async Task SetTokenAsync(string token)
        {
            Token = token;
            _loaded = true;
            await _storage.SetAsync("token", token);
            ParseToken();
        }

        public void ParseToken()
        {
            if (string.IsNullOrEmpty(Token)) return;

            var handler = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
            var jwt = handler.ReadJwtToken(Token);

            DisplayName = jwt.Claims.FirstOrDefault(c => c.Type == "displayName")?.Value ?? "";
            Rol = jwt.Claims.FirstOrDefault(c => c.Type == "rol")?.Value ?? "";

            var partes = DisplayName.Split(' ');
            string inicialNombre = partes.Length > 0 ? partes[0][..1] : "";
            string inicialApellido = partes.Length > 1 ? partes[1][..1] : "";
            string inicialRol = Rol.Length > 0 ? Rol[..1] : "";
            Nomenclatura = (inicialNombre + inicialApellido + inicialRol).ToUpper();
        }

        public async Task LoadTokenAsync()
        {
            if (_loaded) return; // ya cargado, no volver a intentar

            try
            {
                var result = await _storage.GetAsync<string>("token");
                Token = result.Success ? result.Value : null;
                _loaded = true;
                ParseToken();
            }
            catch (InvalidOperationException)
            {
                // Prerendering activo — JS Interop no disponible aún, ignorar
                Token = null;
            }
        }

        public async Task LogoutAsync()
        {
            Token = null;
            _loaded = false;
            await _storage.DeleteAsync("token");
        }
    }
}
// Services/AuthorizationMessageHandler.cs
using System.Net.Http.Headers;

namespace LotesApp.Services
{
    public class AuthorizationMessageHandler : DelegatingHandler
    {
        private readonly AuthService _authService;

        public AuthorizationMessageHandler(AuthService authService)
        {
            _authService = authService;
        }

        protected override Task<HttpResponseMessage> SendAsync(
            HttpRequestMessage request,
            CancellationToken cancellationToken)
        {
            // Solo usa lo que ya está en memoria — nunca llama JS Interop
            if (!string.IsNullOrEmpty(_authService.Token))
            {
                request.Headers.Authorization =
                    new AuthenticationHeaderValue("Bearer", _authService.Token);
            }

            return base.SendAsync(request, cancellationToken);
        }
    }
}