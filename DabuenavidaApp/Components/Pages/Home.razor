using System.Net.Http.Json;
using System.Net.Http.Headers;
using ManageAdminDMS_UI.Models;
using ManageAdminDMS_UI.Services;
using Microsoft.Extensions.Configuration;
using System.Net;  // ← AGREGA ESTO

namespace ManageAdminDMS_UI.Services
{
    public class DabuenavidaService
    {
        private readonly IHttpClientFactory _httpClientFactory;
        private readonly int _pageSize;

        public DabuenavidaService(IHttpClientFactory httpClientFactory, 
                                   IConfiguration configuration)
        {
            _httpClientFactory = httpClientFactory;
            _pageSize = configuration.GetValue<int>("Dabuenavida.PageSize", 20);
        }

        public int PageSize => _pageSize;

        public async Task<PagedResult> ObtenerDatos(int pagina, string token,
                                                     FiltrosBusqueda? filtros = null)
        {
            var client = _httpClientFactory.CreateClient("API");
            client.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);

            var request = new ConsultaRequest
            {
                PageNumber = pagina,
                PageSize = _pageSize
            };

            if (filtros != null)
            {
                if (!string.IsNullOrWhiteSpace(filtros.CentroDeCosto))
                    request.CentroDeCosto = filtros.CentroDeCosto.Trim();

                if (!string.IsNullOrWhiteSpace(filtros.TextoBusqueda))
                {
                    var texto = filtros.TextoBusqueda.Trim();
                    if (texto.Length == 10)
                        request.NumeroDabuenavida = texto;
                    else if (texto.Length == 13)
                        request.DniIdentidad = texto;
                }
            }

            var response = await client.PostAsJsonAsync(
                "api/dabuenavida/consulta", request);

            // ← BLOQUE CORREGIDO
            if (!response.IsSuccessStatusCode)
            {
                if (response.StatusCode == HttpStatusCode.Unauthorized)
                    throw new UnauthorizedAccessException("Sesión expirada");

                throw new HttpRequestException(
                    $"Error al consultar: {response.StatusCode}");
            }

            var consultaResponse = await response.Content
                .ReadFromJsonAsync<ConsultaResponse>();

            var data = consultaResponse?.Registros?.Select(r => new DabuenavidaModel
            {
                NumeroDabuenavida = r.NumeroDaBuenaVida,
                NombreCliente     = r.NombreCliente,
                DNI               = r.DniIdentidad,
                CentroDeCosto     = r.CentroDeCosto,
                FechaCreacion     = DateTime.ParseExact(r.FechaCreacion, "dd/MM/yyyy", null),
                FechaVencimiento  = DateTime.ParseExact(r.FechaVencimiento, "dd/MM/yyyy", null),
                ValorDAB          = decimal.Parse(r.ValorDab.Replace("L","")
                                        .Replace(",","").Trim()),
                NumeroTitulos     = r.NumeroTitulos,
                EstadoImpresion   = r.EstadoImpresion
            }).ToList() ?? [];

            return new PagedResult
            {
                Data             = data,
                TotalRegistros   = consultaResponse?.TotalRegistros ?? 0,
                Pagina           = pagina,
                TamañoPagina     = _pageSize
            };
        }
    }
}
@inject NavigationManager Nav  // ← acá sí va NavigationManager

// En el método de búsqueda:
try
{
    resultado = await _dabuenavidaService.ObtenerDatos(pagina, token, filtros);
}
catch (UnauthorizedAccessException)
{
    Nav.NavigateTo("/unauthorized");
}
catch (Exception ex)
{
    errorMessage = ex.Message;
}