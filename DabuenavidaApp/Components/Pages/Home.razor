@using ManageAdminDMS_UI.Models

<div class="dab-table__container">

    @* TOPBAR *@
    <div class="dab-table__topbar">
        <span class="dab-table__resultados">
            Resultados: <strong>@Resultado?.TotalRegistros registros encontrados</strong>
        </span>
        <div class="dab-table__leyenda">
            <span class="dab-table__leyenda-item dab-table__leyenda-item--impreso">● Impreso</span>
            <span class="dab-table__leyenda-item dab-table__leyenda-item--pendiente">● Pendiente</span>
        </div>
    </div>

    @* TABLA *@
    @if (Cargando)
    {
        <div class="dab-table__loading">
            <span>Cargando...</span>
        </div>
    }
    else
    {
        <div class="dab-table__wrapper">
            <table class="dab-table">
                <thead>
                    <tr>
                        <th>N° DABUENAVIDA</th>
                        <th>NOMBRE DEL CLIENTE</th>
                        <th>DNI / IDENTIDAD</th>
                        <th>CENTRO DE COSTO</th>
                        <th>FECHA CREACIÓN</th>
                        <th>FECHA VENCIMIENTO</th>
                        <th>VALOR DAB</th>
                        <th>N° TÍTULOS</th>
                        <th>ESTADO IMPRESIÓN</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Resultado?.Data ?? new())
                    {
                        <tr>
                            <td class="dab-table__numero">@item.NumeroDabuenavida</td>
                            <td class="dab-table__nombre">@item.NombreCliente</td>
                            <td>@item.DNI</td>
                            <td>@item.CentroDeCosto</td>
                            <td>@item.FechaCreacion.ToString("dd/MM/yyyy")</td>
                            <td>@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                            <td>L @item.ValorDAB.ToString("N2")</td>
                            <td class="dab-table__titulos">@item.NumeroTitulos</td>
                            <td>
                                <span class="@(item.EstadoImpresion == "IMPRESO"
                                    ? "dab-table__estado dab-table__estado--impreso"
                                    : "dab-table__estado dab-table__estado--pendiente")">
                                    ● @item.EstadoImpresion
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* PAGINACIÓN *@
        <div class="dab-table__paginacion">

            <button class="dab-table__pag-btn"
                    disabled="@(PaginaActual <= 1)"
                    @onclick="OnPaginaAnterior">
                ← Anterior
            </button>

            <div class="dab-table__pag-center">
                <span class="dab-table__pag-label">Página</span>
                <div class="dab-table__pag-input-wrapper @(_errorPagina ? "dab-table__pag-input-wrapper--error" : "")">
                    <input class="dab-table__pag-input"
                           value="@_inputPagina"
                           @oninput="OnInputPagina"
                           maxlength="4"
                           inputmode="numeric"
                           placeholder="@PaginaActual" />
                </div>
                <span class="dab-table__pag-label">de <strong>@Resultado?.TotalPaginas</strong></span>
                @if (_errorPagina)
                {
                    <span class="dab-table__pag-error">Página inválida</span>
                }
            </div>

            <button class="dab-table__pag-btn"
                    disabled="@(PaginaActual >= Resultado?.TotalPaginas)"
                    @onclick="OnPaginaSiguiente">
                Siguiente →
            </button>

        </div>
    }

</div>

@code {
    [Parameter] public PagedResult? Resultado { get; set; }
    [Parameter] public bool Cargando { get; set; }
    [Parameter] public int PaginaActual { get; set; }
    [Parameter] public EventCallback OnPaginaAnterior { get; set; }
    [Parameter] public EventCallback OnPaginaSiguiente { get; set; }
    [Parameter] public EventCallback<int> OnIrAPagina { get; set; }

    private string _inputPagina = "";
    private bool _errorPagina = false;
    private System.Threading.CancellationTokenSource? _cts;

    protected override void OnParametersSet()
    {
        // Sincroniza el input cuando cambia la página externamente
        _inputPagina = PaginaActual.ToString();
        _errorPagina = false;
    }

    private async Task OnInputPagina(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";

        // Solo dígitos, sin letras ni especiales
        var limpio = System.Text.RegularExpressions.Regex.Replace(raw, @"[^0-9]", "");
        _inputPagina = limpio;

        if (string.IsNullOrEmpty(limpio))
        {
            _errorPagina = false;
            return;
        }

        if (!int.TryParse(limpio, out int pagina)
            || pagina < 1
            || pagina > (Resultado?.TotalPaginas ?? 1))
        {
            _errorPagina = true;
            return;
        }

        _errorPagina = false;

        // Debounce: espera 500ms desde el último teclazo antes de hacer el request
        _cts?.Cancel();
        _cts = new System.Threading.CancellationTokenSource();
        var token = _cts.Token;

        try
        {
            await Task.Delay(500, token);
            if (!token.IsCancellationRequested)
                await OnIrAPagina.InvokeAsync(pagina);
        }
        catch (TaskCanceledException) { }
    }
}
.dab-table__container {
    margin: 16px 24px 24px 24px;
    background-color: white;
    border-radius: 6px;
    border: 1px solid #e8e8e8;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
    overflow: hidden;
}

.dab-table__topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    border-bottom: 1px solid #f0f0f0;
    background-color: #fafafa;
}

.dab-table__resultados {
    font-size: 13px;
    color: #555555;
}

.dab-table__resultados strong {
    color: #c0392b;
    font-weight: 700;
}

.dab-table__leyenda {
    display: flex;
    gap: 18px;
}

.dab-table__leyenda-item {
    font-size: 12px;
    font-weight: 500;
}

.dab-table__leyenda-item--impreso {
    color: #1a6bbf;
}

.dab-table__leyenda-item--pendiente {
    color: #c0392b;
}

.dab-table__wrapper {
    overflow-x: auto;
}

.dab-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
}

.dab-table thead tr {
    background-color: #f7f7f7;
    border-bottom: 2px solid #e8e8e8;
}

.dab-table th {
    text-align: left;
    padding: 11px 14px;
    font-size: 10px;
    font-weight: 700;
    color: #999999;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    white-space: nowrap;
}

.dab-table tbody tr {
    border-bottom: 1px solid #f5f5f5;
    transition: background-color 0.15s;
}

.dab-table tbody tr:last-child {
    border-bottom: none;
}

.dab-table tbody tr:hover {
    background-color: #fff8f8;
}

.dab-table td {
    padding: 11px 14px;
    color: #444444;
    white-space: nowrap;
}

.dab-table__numero {
    color: #c0392b;
    font-weight: 700;
    font-size: 13px;
}

.dab-table__nombre {
    font-weight: 600;
    color: #222222;
}

.dab-table__titulos {
    color: #1a6bbf;
    font-weight: 700;
    text-align: center;
}

.dab-table__estado {
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
}

.dab-table__estado--impreso {
    color: #1a6bbf;
}

.dab-table__estado--pendiente {
    color: #c0392b;
}

.dab-table__loading {
    text-align: center;
    padding: 60px;
    color: #aaaaaa;
    font-size: 14px;
}

/* ── PAGINACIÓN ── */
.dab-table__paginacion {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border-top: 1px solid #f0f0f0;
    background-color: #fafafa;
    flex-wrap: wrap;
}

.dab-table__pag-btn {
    background-color: #ffffff;
    border: 1px solid #d9d9d9;
    border-radius: 4px;
    padding: 7px 18px;
    font-size: 13px;
    cursor: pointer;
    color: #444444;
    font-weight: 500;
    transition: all 0.2s;
}

.dab-table__pag-btn:hover:not(:disabled) {
    background-color: #c0392b;
    border-color: #c0392b;
    color: white;
}

.dab-table__pag-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
}

/* ── Centro de paginación con input ── */
.dab-table__pag-center {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
}

.dab-table__pag-label {
    font-size: 13px;
    color: #666666;
    font-weight: 500;
}

.dab-table__pag-label strong {
    color: #2c2c2c;
}

.dab-table__pag-input-wrapper {
    border: 1px solid #d9d9d9;
    border-radius: 4px;
    background: white;
    transition: border-color 0.2s, box-shadow 0.2s;
    display: flex;
    align-items: center;
}

.dab-table__pag-input-wrapper:focus-within {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.10);
}

.dab-table__pag-input-wrapper--error {
    border-color: #e53e3e !important;
    box-shadow: 0 0 0 3px rgba(229, 62, 62, 0.12) !important;
}

.dab-table__pag-input {
    width: 52px;
    height: 32px;
    border: none;
    outline: none;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: #c0392b;
    background: transparent;
    padding: 0 6px;
}

.dab-table__pag-input::placeholder {
    color: #bbbbbb;
    font-weight: 400;
}

.dab-table__pag-error {
    font-size: 11px;
    color: #e53e3e;
    font-weight: 500;
    white-space: nowrap;
}

/* ── Responsive ── */
@media (max-width: 768px) {
    .dab-table__container {
        margin: 16px;
    }

    .dab-table__topbar {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }

    .dab-table th,
    .dab-table td {
        padding: 10px 10px;
    }

    .dab-table__paginacion {
        gap: 10px;
    }

    .dab-table__pag-btn {
        padding: 7px 12px;
        font-size: 12px;
    }
}