.lotes-page * { box-sizing: border-box; }
.lotes-page { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; min-height: 100vh; }
.lotes-content { padding: 2rem; max-width: 1200px; margin: 0 auto; }
.lotes-center { text-align: center; padding: 4rem 0; color: #888; }
.lotes-spinner { width: 32px; height: 32px; border: 3px solid #f0f0f0; border-top-color: #C8102E; border-radius: 50%; animation: lotes-spin 0.7s linear infinite; margin: 0 auto 1rem; }
@keyframes lotes-spin { to { transform: rotate(360deg); } }
.lotes-error { background: #fff5f5; border: 0.5px solid #fecaca; border-radius: 8px; padding: 1rem 1.25rem; color: #991b1b; font-size: 14px; }

.det-header { margin-bottom: 1.5rem; }
.btn-volver { background: none; border: none; color: #C8102E; font-size: 13px; cursor: pointer; padding: 0; font-weight: 500; margin-bottom: 12px; display: inline-block; }
.btn-volver:hover { text-decoration: underline; }

/* Filtro por fecha: actualmente comentado en el markup, se deja listo por si se reactiva */
.cron-filtro-row { margin-bottom: 1.25rem; display: flex; align-items: center; gap: 8px; }
.cron-input { padding: 8px 14px; border: 0.5px solid #e0e0e0; border-radius: 6px; font-size: 13px; outline: none; background: #fff; }
.cron-input:focus { border-color: #C8102E; }
.btn-limpiar { background: none; border: 0.5px solid #e0e0e0; border-radius: 6px; padding: 7px 12px; font-size: 12px; cursor: pointer; color: #666; }
.btn-limpiar:hover { border-color: #C8102E; color: #C8102E; }