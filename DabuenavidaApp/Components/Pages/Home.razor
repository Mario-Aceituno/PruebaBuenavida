@* Pages/Unauthorized.razor *@
@page "/unauthorized"
@inject NavigationManager Nav

<div class="unauth-container">
    <div class="unauth-card">
        <div class="unauth-icon">🔒</div>
        <h1 class="unauth-code">401</h1>
        <h2 class="unauth-title">Sesión expirada</h2>
        <p class="unauth-message">
            Tu sesión ha expirado o no tienes autorización para acceder a este recurso.
        </p>
        <button class="unauth-btn" @onclick="IrAlLogin">
            Volver al Login
        </button>
    </div>
</div>

@code {
    private void IrAlLogin() => Nav.NavigateTo("/login", forceLoad: true);
}
/* wwwroot/css/unauthorized.css  — o dentro de Unauthorized.razor.css */
.unauth-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
}

.unauth-card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 3rem 4rem;
    text-align: center;
    color: white;
    box-shadow: 0 25px 45px rgba(0,0,0,0.3);
    animation: fadeIn 0.5s ease;
}

.unauth-icon  { font-size: 4rem; margin-bottom: 0.5rem; }
.unauth-code  { font-size: 5rem; font-weight: 800; margin: 0;
                background: linear-gradient(90deg, #f093fb, #f5576c);
                -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.unauth-title { font-size: 1.5rem; font-weight: 600; margin: 0.5rem 0 1rem; }
.unauth-message { color: rgba(255,255,255,0.65); margin-bottom: 2rem; }

.unauth-btn {
    background: linear-gradient(90deg, #f093fb, #f5576c);
    border: none; border-radius: 10px;
    padding: 0.75rem 2rem;
    color: white; font-size: 1rem; font-weight: 600;
    cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;
}
.unauth-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(245,87,108,0.4);
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}
// Services/AuthorizedHttpHandler.cs
public class AuthorizedHttpHandler : DelegatingHandler
{
    private readonly IAuthService _authService;
    private readonly NavigationManager _nav;

    public AuthorizedHttpHandler(IAuthService authService, NavigationManager nav)
    {
        _authService = authService;
        _nav = nav;
    }

    protected override async Task<HttpResponseMessage> SendAsync(
        HttpRequestMessage request, CancellationToken cancellationToken)
    {
        var response = await base.SendAsync(request, cancellationToken);

        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await _authService.LogoutAsync();
            _nav.NavigateTo("/unauthorized", forceLoad: false);
        }

        return response;
    }
}
builder.Services.AddScoped<AuthorizedHttpHandler>();

builder.Services.AddHttpClient("API", client =>
{
    client.BaseAddress = new Uri(builder.HostEnvironment.BaseAddress);
})
.AddHttpMessageHandler<AuthorizedHttpHandler>();
// Antes (explota con excepción fea):
response.EnsureSuccessStatusCode();

// Después (manejo limpio):
if (!response.IsSuccessStatusCode)
{
    if (response.StatusCode == HttpStatusCode.Unauthorized)
    {
        _nav.NavigateTo("/unauthorized");
        return;
    }
    errorMessage = $"Error al consultar: {response.StatusCode}";
    return;
}