@using ManageAdminDMS_UI.Models

<div class="dab-table__container">

    @* TOPBAR *@
    <div class="dab-table__topbar">
        <span class="dab-table__resultados">
            Resultados: <strong>@Resultado?.TotalRegistros registros encontrados</strong>
        </span>
        <div class="dab-table__leyenda">
            <span class="dab-table__leyenda-item dab-table__leyenda-item--impreso">● Impreso</span>
            <span class="dab-table__leyenda-item dab-table__leyenda-item--pendiente">● Pendiente</span>
        </div>
    </div>

    @* TABLA *@
    @if (Cargando)
    {
        <div class="dab-table__loading">
            <span>Cargando...</span>
        </div>
    }
    else
    {
        <div class="dab-table__wrapper">
            <table class="dab-table">
                <thead>
                    <tr>
                        <th class="col-numero">N° DAB</th>
                        <th class="col-nombre">CLIENTE</th>
                        <th class="col-dni">DNI</th>
                        <th class="col-centro">C. COSTO</th>
                        <th class="col-fecha">F. CREACIÓN</th>
                        <th class="col-fecha">F. VENCIMIENTO</th>
                        <th class="col-valor">VALOR DAB</th>
                        <th class="col-titulos">TÍTULOS</th>
                        <th class="col-estado">ESTADO / IMPRIMIR</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Resultado?.Data ?? new())
                    {
                        <tr>
                            <td class="dab-table__numero">@item.NumeroDabuenavida</td>
                            <td class="dab-table__nombre">@item.NombreCliente</td>
                            <td>@item.DNI</td>
                            <td class="dab-table__centro">@item.CentroDeCosto</td>
                            <td class="dab-table__fecha">@item.FechaCreacion.ToString("dd/MM/yy")</td>
                            <td class="dab-table__fecha">@item.FechaVencimiento.ToString("dd/MM/yy")</td>
                            <td class="dab-table__valor">L @item.ValorDAB.ToString("N2")</td>
                            <td class="dab-table__titulos">@item.NumeroTitulos</td>
                            <td class="dab-table__estado-cell">
                                <span class="@(item.EstadoImpresion == "IMPRESO"
                                    ? "dab-table__estado dab-table__estado--impreso"
                                    : "dab-table__estado dab-table__estado--pendiente")">
                                    ● @item.EstadoImpresion
                                </span>
                                <button class="dab-table__btn-imprimir"
                                        title="Imprimir registro">
                                    🖨
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* PAGINACIÓN *@
        <div class="dab-table__paginacion">

            <button class="dab-table__pag-btn"
                    disabled="@(PaginaActual <= 1)"
                    @onclick="OnPaginaAnterior">
                ← Anterior
            </button>

            <div class="dab-table__pag-center">
                <span class="dab-table__pag-label">Página</span>
                <div class="dab-table__pag-input-wrapper @(_errorPagina ? "dab-table__pag-input-wrapper--error" : "")">
                    <input class="dab-table__pag-input"
                           value="@_inputPagina"
                           @oninput="OnInputPagina"
                           maxlength="4"
                           inputmode="numeric"
                           placeholder="@PaginaActual" />
                </div>
                <span class="dab-table__pag-label">
                    de <strong>@Resultado?.TotalPaginas</strong>
                </span>
                @if (_errorPagina)
                {
                    <span class="dab-table__pag-error">Página inválida</span>
                }
            </div>

            <button class="dab-table__pag-btn"
                    disabled="@(PaginaActual >= Resultado?.TotalPaginas)"
                    @onclick="OnPaginaSiguiente">
                Siguiente →
            </button>

        </div>
    }

</div>

@code {
    [Parameter] public PagedResult? Resultado { get; set; }
    [Parameter] public bool Cargando { get; set; }
    [Parameter] public int PaginaActual { get; set; }
    [Parameter] public EventCallback OnPaginaAnterior { get; set; }
    [Parameter] public EventCallback OnPaginaSiguiente { get; set; }
    [Parameter] public EventCallback<int> OnIrAPagina { get; set; }

    private string _inputPagina = "";
    private bool _errorPagina = false;
    private System.Threading.CancellationTokenSource? _cts;

    protected override void OnParametersSet()
    {
        _inputPagina = PaginaActual.ToString();
        _errorPagina = false;
    }

    private async Task OnInputPagina(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        var limpio = System.Text.RegularExpressions.Regex.Replace(raw, @"[^0-9]", "");
        _inputPagina = limpio;

        if (string.IsNullOrEmpty(limpio)) { _errorPagina = false; return; }

        if (!int.TryParse(limpio, out int pagina)
            || pagina < 1
            || pagina > (Resultado?.TotalPaginas ?? 1))
        {
            _errorPagina = true;
            return;
        }

        _errorPagina = false;
        _cts?.Cancel();
        _cts = new System.Threading.CancellationTokenSource();
        var token = _cts.Token;

        try
        {
            await Task.Delay(500, token);
            if (!token.IsCancellationRequested)
                await OnIrAPagina.InvokeAsync(pagina);
        }
        catch (TaskCanceledException) { }
    }
}
/* ── Contenedor ── */
.dab-table__container {
    margin: 16px 24px 24px 24px;
    background-color: white;
    border-radius: 6px;
    border: 1px solid #e8e8e8;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
    overflow: hidden;
}

/* ── Topbar ── */
.dab-table__topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid #f0f0f0;
    background-color: #fafafa;
}

.dab-table__resultados {
    font-size: 12px;
    color: #555555;
}

.dab-table__resultados strong {
    color: #c0392b;
    font-weight: 700;
}

.dab-table__leyenda {
    display: flex;
    gap: 18px;
}

.dab-table__leyenda-item {
    font-size: 11px;
    font-weight: 500;
}

.dab-table__leyenda-item--impreso  { color: #1a6bbf; }
.dab-table__leyenda-item--pendiente { color: #c0392b; }

/* ── Wrapper scroll horizontal ── */
.dab-table__wrapper {
    overflow-x: auto;
}

/* ── Tabla ── */
.dab-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    table-layout: fixed;   /* anchos controlados */
}

/* ── Anchos de columna ── */
.col-numero  { width: 110px; }
.col-nombre  { width: 180px; }
.col-dni     { width: 120px; }
.col-centro  { width: 80px;  }
.col-fecha   { width: 90px;  }
.col-valor   { width: 100px; }
.col-titulos { width: 62px;  }
.col-estado  { width: 160px; }

/* ── Encabezados ── */
.dab-table thead tr {
    background-color: #f7f7f7;
    border-bottom: 2px solid #e8e8e8;
}

.dab-table th {
    text-align: left;
    padding: 10px 10px;
    font-size: 9px;
    font-weight: 700;
    color: #999999;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* ── Filas ── */
.dab-table tbody tr {
    border-bottom: 1px solid #f5f5f5;
    transition: background-color 0.15s;
}

.dab-table tbody tr:last-child { border-bottom: none; }
.dab-table tbody tr:hover      { background-color: #fff8f8; }

.dab-table td {
    padding: 9px 10px;
    color: #444444;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* ── Celdas específicas ── */
.dab-table__numero {
    color: #c0392b;
    font-weight: 700;
    font-size: 12px;
}

.dab-table__nombre {
    font-weight: 600;
    color: #222222;
}

.dab-table__centro {
    text-align: center;
}

.dab-table__fecha {
    color: #666666;
    font-size: 11px;
}

.dab-table__valor {
    font-weight: 600;
    color: #2c2c2c;
    text-align: right;
}

.dab-table__titulos {
    color: #1a6bbf;
    font-weight: 700;
    text-align: center;
}

/* ── Celda estado + botón imprimir ── */
.dab-table__estado-cell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    padding: 9px 10px;
    overflow: visible !important;
}

.dab-table__estado {
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
}

.dab-table__estado--impreso  { color: #1a6bbf; }
.dab-table__estado--pendiente { color: #c0392b; }

/* ── Botón imprimir ── */
.dab-table__btn-imprimir {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    background-color: #ffffff;
    cursor: pointer;
    font-size: 14px;
    flex-shrink: 0;
    transition: background-color 0.2s, border-color 0.2s, transform 0.1s;
    line-height: 1;
}

.dab-table__btn-imprimir:hover {
    background-color: #fff5f5;
    border-color: #c0392b;
    transform: scale(1.08);
}

.dab-table__btn-imprimir:active {
    transform: scale(0.95);
}

/* ── Loading ── */
.dab-table__loading {
    text-align: center;
    padding: 60px;
    color: #aaaaaa;
    font-size: 14px;
}

/* ── Paginación ── */
.dab-table__paginacion {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    border-top: 1px solid #f0f0f0;
    background-color: #fafafa;
    flex-wrap: wrap;
}

.dab-table__pag-btn {
    background-color: #ffffff;
    border: 1px solid #d9d9d9;
    border-radius: 4px;
    padding: 6px 16px;
    font-size: 12px;
    cursor: pointer;
    color: #444444;
    font-weight: 500;
    transition: all 0.2s;
    white-space: nowrap;
}

.dab-table__pag-btn:hover:not(:disabled) {
    background-color: #c0392b;
    border-color: #c0392b;
    color: white;
}

.dab-table__pag-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
}

.dab-table__pag-center {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
}

.dab-table__pag-label {
    font-size: 12px;
    color: #666666;
    font-weight: 500;
}

.dab-table__pag-label strong {
    color: #2c2c2c;
}

.dab-table__pag-input-wrapper {
    border: 1px solid #d9d9d9;
    border-radius: 4px;
    background: white;
    transition: border-color 0.2s, box-shadow 0.2s;
    display: flex;
    align-items: center;
}

.dab-table__pag-input-wrapper:focus-within {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.10);
}

.dab-table__pag-input-wrapper--error {
    border-color: #e53e3e !important;
    box-shadow: 0 0 0 3px rgba(229, 62, 62, 0.12) !important;
}

.dab-table__pag-input {
    width: 48px;
    height: 30px;
    border: none;
    outline: none;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    color: #c0392b;
    background: transparent;
    padding: 0 6px;
}

.dab-table__pag-input::placeholder {
    color: #bbbbbb;
    font-weight: 400;
}

.dab-table__pag-error {
    font-size: 11px;
    color: #e53e3e;
    font-weight: 500;
    white-space: nowrap;
}

/* ── Responsive ── */
@media (max-width: 1024px) {
    .dab-table {
        table-layout: auto;
    }
}

@media (max-width: 768px) {
    .dab-table__container {
        margin: 16px;
    }

    .dab-table__topbar {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }

    .dab-table th,
    .dab-table td {
        padding: 8px 8px;
    }

    .dab-table__paginacion {
        gap: 10px;
    }

    .dab-table__pag-btn {
        padding: 6px 10px;
        font-size: 11px;
    }
}