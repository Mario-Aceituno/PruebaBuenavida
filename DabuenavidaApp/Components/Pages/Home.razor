namespace CronogramaPagosPrestamos.API.Configuration
{
    public class AmbienteSettings
    {
        private readonly IConfiguration _configuration;
        private readonly string _ambiente;

        public AmbienteSettings(IConfiguration configuration)
        {
            _configuration = configuration;

            _ambiente = _configuration["serviceGlobals:defaultAmbiente"]
                ?? throw new InvalidOperationException(
                    "No se encontró 'serviceGlobals:defaultAmbiente' en appsettings.json. " +
                    "Configura el ambiente activo (DEV, UAT, PROD).");
        }

        public string AmbienteActivo => _ambiente;

        public string GetString(string clave)
            => _configuration[$"{_ambiente}:{clave}"]
               ?? throw new InvalidOperationException(
                   $"No se encontró '{_ambiente}:{clave}' en appsettings.json.");

        public int GetInt(string clave, int valorPorDefecto = 0)
        {
            var valor = _configuration[$"{_ambiente}:{clave}"];
            return int.TryParse(valor, out var resultado) ? resultado : valorPorDefecto;
        }

        public AS400Settings GetAS400Settings()
        {
            return new AS400Settings
            {
                Driver         = GetString("AS400ODBC:driver"),
                Server         = GetString("AS400ODBC:server"),
                UserBase64     = GetString("AS400ODBC:user"),
                PasswordBase64 = GetString("AS400ODBC:password")
            };
        }

        public AppSettings GetAppSettings()
        {
            return new AppSettings
            {
                OutputPath             = GetString("OutputPath"),
                RutaDestino            = GetString("RutaDestino"),
                BatchSize              = GetInt("BatchSize", 5000),
                ProgressUpdateInterval = GetInt("ProgressUpdateInterval", 100)
            };
        }

        public SqlServerSettings GetSqlServerSettings()
        {
            return new SqlServerSettings
            {
                Catalog        = GetString("SQLServer:catalog"),
                Server         = GetString("SQLServer:server"),
                UserBase64     = _configuration[$"{_ambiente}:SQLServer:user"]
                                 ?? string.Empty,
                PasswordBase64 = _configuration[$"{_ambiente}:SQLServer:password"]
                                 ?? string.Empty
            };
        }

        public JwtSettings GetJwtSettings()
        {
            return new JwtSettings
            {
                SecretKey = GetString("Jwt_SecretKey"),
                Issuer    = GetString("Jwt_Issuer"),
                Audience  = GetString("Jwt_Audience"),
                AD_Server = GetString("AD_Server"),
                AD_Domain = GetString("AD_Domain")
            };
        }
    }

    // Solo JwtSettings es nuevo — los demás ya existen en otro archivo
    public class JwtSettings
    {
        public string SecretKey { get; set; } = "";
        public string Issuer    { get; set; } = "";
        public string Audience  { get; set; } = "";
        public string AD_Server { get; set; } = "";
        public string AD_Domain { get; set; } = "";
    }
}