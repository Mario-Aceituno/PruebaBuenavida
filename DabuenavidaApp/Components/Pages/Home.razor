// Services/FiltrosPermisosService.cs
using System.Net.Http.Headers;
using System.Net.Http.Json;
using ManageAdminDMS_UI.Models;
using Microsoft.JSInterop;

namespace ManageAdminDMS_UI.Services
{
    public class FiltrosPermisosService : IFiltrosPermisosService
    {
        private readonly HttpClient _http;
        private readonly IJSRuntime _js;

        public FiltrosPermisosService(HttpClient http, IJSRuntime js)
        {
            _http = http;
            _js   = js;
        }

        public async Task<FiltrosPermisosDto?> GetPermisosAsync()
        {
            try
            {
                // Recuperamos el token JWT del localStorage
                // (igual que lo haces en tus otros servicios)
                var token = await _js.InvokeAsync<string>("localStorage.getItem", "authToken");

                if (string.IsNullOrEmpty(token))
                    return null;

                // Adjuntamos el token al header
                _http.DefaultRequestHeaders.Authorization =
                    new AuthenticationHeaderValue("Bearer", token);

                return await _http.GetFromJsonAsync<FiltrosPermisosDto>(
                    "api/filtrospermiso/mis-filtros"
                );
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error obteniendo permisos: {ex.Message}");
                return null;
            }
        }
    }
}