public void ParseToken()
{
    if (string.IsNullOrEmpty(Token)) return;

    var handler = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
    var jwt = handler.ReadJwtToken(Token);

    DisplayName = jwt.Claims
        .FirstOrDefault(c => c.Type == "displayName")?.Value ?? "";
    
    Rol = jwt.Claims
        .FirstOrDefault(c => c.Type == "rol")?.Value ?? "";

    // Nomenclatura: primera letra nombre + primera letra apellido + primera letra rol
    var partes = DisplayName.Split(' ');
    string inicialNombre = partes.Length > 0 ? partes[0][..1] : "";
    string inicialApellido = partes.Length > 1 ? partes[1][..1] : "";
    string inicialRol = Rol.Length > 0 ? Rol[..1] : "";
    Nomenclatura = (inicialNombre + inicialApellido + inicialRol).ToUpper();
}