// Pages/PageBase.cs
using Microsoft.AspNetCore.Components;
using LotesApp.Services;

namespace LotesApp.Frontend.Pages
{
    public abstract class PageBase : ComponentBase
    {
        [Inject] protected AuthService AuthService { get; set; } = default!;
        [Inject] protected NavigationManager Nav { get; set; } = default!;

        private bool _initialized = false;

        protected override async Task OnAfterRenderAsync(bool firstRender)
        {
            if (!firstRender || _initialized) return;
            _initialized = true;

            await AuthService.LoadTokenAsync();

            if (!AuthService.IsAuthenticated)
            {
                Nav.NavigateTo("/login");
                return;
            }

            await OnPageReadyAsync(); // cada página implementa su carga aquí
            StateHasChanged();
        }

        // Override este método en cada página en lugar de OnAfterRenderAsync
        protected virtual Task OnPageReadyAsync() => Task.CompletedTask;
    }
}