@page "/dashboard"
@inject NavigationManager Nav
@inject AuthService AuthService
@inject DabuenavidaService DabuenavidaService
@inject ApiExceptionHandler ApiExceptionHandler
@inject IFiltrosPermisosService FiltrosPermisosService  @* ← NUEVO *@
@layout EmptyLayout
@rendermode InteractiveServer

@using ManageAdminDMS_UI.Models
@using ManageAdminDMS_UI.Services
@using ManageAdminDMS_UI.Components.FrontendComponents.Navbars
@using ManageAdminDMS_UI.Components.FrontendComponents.Filters
@using ManageAdminDMS_UI.Components.FrontendComponents.Tables
@using ManageAdminDMS_UI.Components.Shared
@using System.Net.Http.Json
@using Microsoft.Extensions.Configuration

@if (estado == Estado.Cargando)
{
    <Loading />
}
else if (estado == Estado.Denegado)
{
    <AccessDenied />
}
else
{
    <DabuenavidaNavbars />

    <DabuenavidaFilters Filtros="filtros"
                        OnBuscar="Buscar"
                        OnLimpiar="Limpiar"
                        Permisos="_permisos!" />  @* ← NUEVO *@

    <DabuenavidaTables Resultado="resultado"
                       Cargando="cargando"
                       PaginaActual="paginaActual"
                       OnPaginaAnterior="PaginaAnterior"
                       OnPaginaSiguiente="PaginaSiguiente"
                       OnIrAPagina="IrAPagina" />
}

Cs

using ManageAdminDMS_UI.Models;
using ManageAdminDMS_UI.Services;

namespace ManageAdminDMS_UI.Components.Pages.Dashboard
{
    public partial class Dashboard
    {
        private string mensaje = "Entrando....";
        private FiltrosBusqueda filtros = new();
        private PagedResult? resultado;
        private bool cargando = false;
        private int paginaActual = 1;
        private int tamañoPagina = 20;

        // ← NUEVO: permisos de filtros
        private FiltrosPermisosDto? _permisos;

        enum Estado { Cargando, Denegado, Permitido }
        Estado estado = Estado.Cargando;

        protected override async Task OnAfterRenderAsync(bool firstRender)
        {
            if (firstRender)
            {
                await AuthService.LoadTokenAsync();

                // ← NUEVO: cargamos permisos junto con los datos
                _permisos = await FiltrosPermisosService.GetPermisosAsync();

                await CargarDatos();
                estado = Estado.Permitido;
                StateHasChanged();
            }
        }

        private async Task IrAPagina(int pagina)
        {
            paginaActual = pagina;
            await CargarDatos();
        }

        private async Task CargarDatos()
        {
            cargando = true;
            StateHasChanged();
            resultado = await DabuenavidaService.ObtenerDatos(
                paginaActual, AuthService.Token ?? "", filtros);
            cargando = false;
            StateHasChanged();
        }

        private async Task PaginaAnterior()
        {
            if (paginaActual > 1)
            {
                paginaActual--;
                await CargarDatos();
            }
        }

        private async Task PaginaSiguiente()
        {
            if (paginaActual < resultado?.TotalPaginas)
            {
                paginaActual++;
                await CargarDatos();
            }
        }

        private async Task Buscar()
        {
            paginaActual = 1;
            await CargarDatos();
        }

        private async Task Limpiar()
        {
            filtros = new();
            paginaActual = 1;
            await CargarDatos();
        }
    }
}

