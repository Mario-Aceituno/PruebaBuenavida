<div class="loading-screen">
    <div class="loading-screen__card">

        <div class="loading-screen__logo-area">
            <div class="loading-screen__pulse-ring"></div>
            <div class="loading-screen__logo-circle">
                <svg viewBox="0 0 24 24" fill="none" class="loading-screen__icon">
                    <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="#c0392b" stroke-width="1.8"
                          stroke-linejoin="round"/>
                    <path d="M2 17l10 5 10-5" stroke="#c0392b" stroke-width="1.8"
                          stroke-linejoin="round"/>
                    <path d="M2 12l10 5 10-5" stroke="#c0392b" stroke-width="1.8"
                          stroke-linejoin="round"/>
                </svg>
            </div>
        </div>

        <div class="loading-screen__text-area">
            <p class="loading-screen__title">@Titulo</p>
            <p class="loading-screen__subtitle">@Subtitulo</p>
        </div>

        <div class="loading-screen__bar-track">
            <div class="loading-screen__bar-fill"></div>
        </div>

        <div class="loading-screen__dots">
            <span></span>
            <span></span>
            <span></span>
        </div>

    </div>
</div>

@code {
    [Parameter] public string Titulo { get; set; } = "Cargando dashboard";
    [Parameter] public string Subtitulo { get; set; } = "Preparando tu información...";
}