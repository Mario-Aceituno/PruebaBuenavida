using LotesApp.Frontend;
using LotesApp.Models;
using LotesApp.Services;

var builder = WebApplication.CreateBuilder(args);

// — Blazor Server
builder.Services.AddRazorComponents()
    .AddInteractiveServerComponents();

builder.Services.AddScoped<AuthService>();

// — Configuración existente (Lotes)
builder.Services.Configure<LotesConfig>(
    builder.Configuration.GetSection("LotesConfig"));

// — HttpClient apuntando a la API de cronogramas (Lotes)
var apiBaseUrl = builder.Configuration["LotesConfig:ApiBaseUrl"]
    ?? "http://localhost:5271";

builder.Services.AddHttpClient<LoteService>(client =>
{
    client.BaseAddress = new Uri(apiBaseUrl.TrimEnd('/') + "/");
    client.Timeout = TimeSpan.FromMinutes(5); // Timeout generoso para operaciones largas
});

builder.Services.AddHttpClient<CronogramaService>(client =>
{
    client.BaseAddress = new Uri(apiBaseUrl.TrimEnd('/') + "/");
    client.Timeout = TimeSpan.FromMinutes(2);
});

// — NUEVO: HttpClient con nombre "API" para el login contra CronogramaPagosPrestamos.API
var cronogramasPagosApiUrl = builder.Configuration["CronogramasConfig:ApiBaseUrl"]
    ?? "http://localhost:5271";

builder.Services.AddHttpClient("API", client =>
{
    client.BaseAddress = new Uri(cronogramasPagosApiUrl.TrimEnd('/') + "/");
    client.Timeout = TimeSpan.FromMinutes(2);
});

var app = builder.Build();

if (!app.Environment.IsDevelopment())
{
    app.UseExceptionHandler("/Error", createScopeForErrors: true);
    app.UseHsts();
}

app.UseHttpsRedirection();
app.UseStaticFiles();
app.UseAntiforgery();

app.MapRazorComponents<App>()
    .AddInteractiveServerRenderMode();

app.Run();