protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (!firstRender) return;
    
    await AuthService.LoadTokenAsync();
    
    // DEBUG TEMPORAL
    Console.WriteLine($"=== DEBUG LOTES ===");
    Console.WriteLine($"Token null: {AuthService.Token == null}");
    Console.WriteLine($"Token vacío: {string.IsNullOrEmpty(AuthService.Token)}");
    Console.WriteLine($"IsAuthenticated: {AuthService.IsAuthenticated}");
    if (AuthService.Token != null && AuthService.Token.Length > 10)
        Console.WriteLine($"Token inicio: {AuthService.Token[..10]}");
    Console.WriteLine($"==================");
    
    if (!AuthService.IsAuthenticated)
    {
        Nav.NavigateTo("/login");
        return;
    }
    
    await CargarDatosIniciales();
    StateHasChanged();
}