using System.Net.Http.Headers;
using System.Net.Http.Json;
using ManageAdminDMS_UI.Models;
using Microsoft.JSInterop;

namespace ManageAdminDMS_UI.Services
{
    public class FiltrosPermisosService : IFiltrosPermisosService
    {
        private readonly HttpClient _http;
        private readonly IJSRuntime _js;

        public FiltrosPermisosService(IHttpClientFactory httpClientFactory, IJSRuntime js)
        {
            _http = httpClientFactory.CreateClient("API");
            _js   = js;
        }

        public async Task<FiltrosPermisosDto?> GetPermisosAsync()
        {
            try
            {
                // Leer el token del sessionStorage
                var token = await _js.InvokeAsync<string?>(
                    "sessionStorage.getItem", "token");

                Console.WriteLine($"[FiltrosPermisos] Token obtenido: {(string.IsNullOrEmpty(token) ? "NULL O VACÍO" : token[..30] + "...")}");

                if (string.IsNullOrEmpty(token))
                {
                    Console.WriteLine("[FiltrosPermisos] Sin token, retornando null");
                    return null;
                }

                // Limpiar header previo y agregar el token
                _http.DefaultRequestHeaders.Authorization = null;
                _http.DefaultRequestHeaders.Authorization =
                    new AuthenticationHeaderValue("Bearer", token);

                var url = "api/filtrospermissos/mis-filtros";
                Console.WriteLine($"[FiltrosPermisos] Llamando a: {_http.BaseAddress}{url}");

                var result = await _http.GetFromJsonAsync<FiltrosPermisosDto>(url);

                Console.WriteLine($"[FiltrosPermisos] Respuesta: CentroCosto={result?.MostrarCentroDeCosto}, Dabuenavida={result?.MostrarDabuenavida}");

                return result;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[FiltrosPermisos] ERROR: {ex.Message}");
                return null;
            }
        }
    }
}