[HttpGet("mis-filtros")]
public IActionResult GetFiltrosPermitidos()
{
    // Intenta estas tres formas y queda con la que devuelva valor
    var rol1 = User.FindFirstValue("rol");
    var rol2 = User.Claims.FirstOrDefault(c => c.Type == "rol")?.Value;
    var rol3 = User.Claims.FirstOrDefault(c => c.Type.EndsWith("rol"))?.Value;

    // Debug temporal — ve la consola del backend
    Console.WriteLine($"rol1: '{rol1}'");
    Console.WriteLine($"rol2: '{rol2}'");
    Console.WriteLine($"rol3: '{rol3}'");
    Console.WriteLine("TODOS LOS CLAIMS:");
    foreach (var claim in User.Claims)
        Console.WriteLine($"  {claim.Type} = {claim.Value}");

    var rol = rol1 ?? rol2 ?? rol3 ?? "";

    var permisos = new FiltrosPermisosDto
    {
        MostrarDabuenavida   = true,
        MostrarCentroDeCosto = rol != "Practicante Universitario"
    };

    return Ok(permisos);
}