@page "/unauthorized"
@layout EmptyLayout
@inject NavigationManager Nav

<div class="davi-container">
    <div class="davi-card">
        <div class="davi-logo">
            <div class="davi-logo-bar"></div>
            <span class="davi-logo-text">DMS</span>
        </div>

        <div class="davi-code">401</div>

        <div class="davi-divider"></div>

        <h2 class="davi-title">Sesión expirada</h2>
        <p class="davi-message">
            Tu sesión ha expirado o no tienes autorización para acceder a este recurso.
            Por favor, inicia sesión nuevamente.
        </p>

        <button class="davi-btn" @onclick="IrAlLogin">
            Volver al Login
        </button>
    </div>
</div>

@code {
    private void IrAlLogin() => Nav.NavigateTo("/login", forceLoad: true);
}
@layout EmptyLayout
@inject NavigationManager Nav

<div class="davi-container">
    <div class="davi-card">
        <div class="davi-logo">
            <div class="davi-logo-bar"></div>
            <span class="davi-logo-text">DMS</span>
        </div>

        <div class="davi-code">404</div>

        <div class="davi-divider"></div>

        <h2 class="davi-title">Página no encontrada</h2>
        <p class="davi-message">
            La página que buscas no existe o fue movida.
            Verifica la dirección o regresa al inicio.
        </p>

        <button class="davi-btn" @onclick="IrAlInicio">
            Ir al Inicio
        </button>
    </div>
</div>

@code {
    private void IrAlInicio() => Nav.NavigateTo("/", forceLoad: true);
}
/* =============================================
   Error Pages - Estética Davivienda
   Usar en: Unauthorized.razor.css y NotFound.razor.css
   ============================================= */

.davi-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
    font-family: 'Segoe UI', Arial, sans-serif;
}

.davi-card {
    background: #ffffff;
    border-radius: 4px;
    padding: 3rem 3.5rem;
    text-align: center;
    width: 100%;
    max-width: 440px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.10);
    border-top: 5px solid #C8102E; /* Rojo Davivienda */
}

/* Logo simulado - reemplaza con tu logo real */
.davi-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 2rem;
}

.davi-logo-bar {
    width: 4px;
    height: 28px;
    background-color: #C8102E;
    border-radius: 2px;
}

.davi-logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: 2px;
    text-transform: uppercase;
}

/* Código de error */
.davi-code {
    font-size: 5rem;
    font-weight: 800;
    color: #C8102E;
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: -2px;
}

/* Línea divisora */
.davi-divider {
    width: 48px;
    height: 3px;
    background-color: #C8102E;
    margin: 1rem auto 1.5rem auto;
    border-radius: 2px;
}

/* Título */
.davi-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.75rem 0;
}

/* Mensaje */
.davi-message {
    font-size: 0.95rem;
    color: #6b6b6b;
    line-height: 1.6;
    margin: 0 0 2rem 0;
}

/* Botón */
.davi-btn {
    display: inline-block;
    background-color: #C8102E;
    color: #ffffff;
    border: none;
    border-radius: 3px;
    padding: 0.75rem 2rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: background-color 0.2s ease;
    width: 100%;
}

.davi-btn:hover {
    background-color: #a50d25;
}

.davi-btn:active {
    background-color: #8a0b1f;
}

.davi-btn:focus-visible {
    outline: 3px solid #C8102E;
    outline-offset: 3px;
}