@using ManageAdminDMS_UI.Models
@using ManageAdminDMS_UI.Services
@inject DabuenavIdaService ServicioDabuenavida

<div class="dab-filters">
    <div class="dab-filters__header">
        <span class="dab-filters__title">CRITERIOS DE BÚSQUEDA</span>
    </div>
    <div class="dab-filters__body">

        <div class="dab-filters__group">
            <label class="dab-filters__label">CENTRO DE COSTO</label>
            <div class="dab-filters__input-wrapper @(_errorCentro != "" ? "dab-filters__input-wrapper--error" : "")">
                <input class="dab-filters__input"
                       value="@Filtros.CentroDeCosto"
                       @oninput="OnCentroDeCostoInput"
                       maxlength="3"
                       placeholder="Ej: 001" />
            </div>
            <div class="dab-filters__feedback-wrapper">
                @if (_errorCentro != "")
                {
                    <span class="dab-filters__error">
                        <span class="dab-filters__error-icon">⚠</span>
                        @_errorCentro
                    </span>
                }
                <span class="dab-filters__counter @(Filtros.CentroDeCosto?.Length == 3 ? "dab-filters__counter--ok" : "")">
                    @(Filtros.CentroDeCosto?.Length ?? 0)/3
                </span>
            </div>
        </div>

        <div class="dab-filters__group dab-filters__group--wide">
            <label class="dab-filters__label">BUSCAR POR DNI O N° DABUENAVIDA</label>
            <div class="dab-filters__input-wrapper @(_errorTexto != "" ? "dab-filters__input-wrapper--error" : _textoValido ? "dab-filters__input-wrapper--ok" : "")">
                <span class="dab-filters__input-icon">🔍</span>
                <input class="dab-filters__input"
                       value="@Filtros.TextoBusqueda"
                       @oninput="OnTextoBusquedaInput"
                       @onkeydown="@(async e => { if (e.Key == "Enter" && _textoValido) await OnBuscar.InvokeAsync(); })"
                       maxlength="13"
                       placeholder="Ingrese DNI (10 dígitos) o N° Dabuenavida (13 dígitos)..." />
                @if (_textoValido)
                {
                    <span class="dab-filters__valid-icon">✓</span>
                }
            </div>
            <div class="dab-filters__feedback-wrapper">
                @if (_errorTexto != "")
                {
                    <span class="dab-filters__error">
                        <span class="dab-filters__error-icon">⚠</span>
                        @_errorTexto
                    </span>
                }
                else if (_textoValido)
                {
                    <span class="dab-filters__success">
                        @(_tipoTexto)
                    </span>
                }
                <span class="dab-filters__counter @(_textoValido ? "dab-filters__counter--ok" : "")">
                    @(Filtros.TextoBusqueda?.Length ?? 0)/13
                </span>
            </div>
        </div>

        <div class="dab-filters__actions">
            <button class="dab-filters__btn dab-filters__btn--limpiar"
                    @onclick="HandleLimpiar">
                Limpiar
            </button>
            <button class="dab-filters__btn dab-filters__btn--buscar"
                    @onclick="OnBuscar"
                    disabled="@(!EsFormularioValido())">
                Buscar
            </button>
        </div>

    </div>
</div>

@code {
    [Parameter] public FiltrosBusqueda Filtros { get; set; } = new();
    [Parameter] public EventCallback OnBuscar { get; set; }
    [Parameter] public EventCallback OnLimpiar { get; set; }

    private string _errorCentro = "";
    private string _errorTexto = "";
    private bool _textoValido = false;
    private string _tipoTexto = "";

    private void OnCentroDeCostoInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";

        // Filtrar en tiempo real: solo dígitos
        var limpio = System.Text.RegularExpressions.Regex
            .Replace(raw, @"[^0-9]", "");

        // Cortar a máximo 3
        if (limpio.Length > 3)
            limpio = limpio[..3];

        Filtros.CentroDeCosto = limpio;

        _errorCentro = limpio.Length switch
        {
            0 => "",
            3 => "",
            _ => $"El centro de costo debe tener exactamente 3 dígitos ({limpio.Length}/3)."
        };
    }

    private void OnTextoBusquedaInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";

        // Filtrar en tiempo real: solo dígitos
        var limpio = System.Text.RegularExpressions.Regex
            .Replace(raw, @"[^0-9]", "");

        // Cortar a máximo 13
        if (limpio.Length > 13)
            limpio = limpio[..13];

        Filtros.TextoBusqueda = limpio;
        _textoValido = false;
        _tipoTexto = "";

        _errorTexto = limpio.Length switch
        {
            0 => "",
            10 => "",
            13 => "",
            < 10 => $"Mínimo 10 dígitos para DNI ({limpio.Length}/10).",
            _ => "Longitud inválida. Use 10 dígitos (DNI) o 13 dígitos (N° Dabuenavida)."
        };

        if (limpio.Length == 10)
        {
            _textoValido = true;
            _tipoTexto = "✓ DNI válido";
        }
        else if (limpio.Length == 13)
        {
            _textoValido = true;
            _tipoTexto = "✓ N° Dabuenavida válido";
        }
    }

    private bool EsFormularioValido()
    {
        var centroOk = string.IsNullOrEmpty(Filtros.CentroDeCosto) ||
                       Filtros.CentroDeCosto.Length == 3;
        var textoOk = string.IsNullOrEmpty(Filtros.TextoBusqueda) || _textoValido;
        var algoIngresado = !string.IsNullOrEmpty(Filtros.CentroDeCosto) ||
                            !string.IsNullOrEmpty(Filtros.TextoBusqueda);

        return centroOk && textoOk && algoIngresado &&
               string.IsNullOrEmpty(_errorCentro) &&
               string.IsNullOrEmpty(_errorTexto);
    }

    private async Task HandleLimpiar()
    {
        Filtros.TextoBusqueda = "";
        Filtros.CentroDeCosto = "";
        _errorCentro = "";
        _errorTexto = "";
        _textoValido = false;
        _tipoTexto = "";
        await OnLimpiar.InvokeAsync();
    }
}
.dab-filters {
    background-color: #ffffff;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    margin: 20px 24px 0 24px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
}

/* ── Header ── */
.dab-filters__header {
    padding: 10px 18px;
    border-bottom: 1px solid #f0f0f0;
    background-color: #fafafa;
    border-radius: 6px 6px 0 0;
}

.dab-filters__title {
    font-size: 10px;
    font-weight: 700;
    color: #888888;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

/* ── Body ── */
.dab-filters__body {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    padding: 18px;
    flex-wrap: wrap;
}

/* ── Groups ── */
.dab-filters__group {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
    min-width: 160px;
}

.dab-filters__group--wide {
    flex: 2;
    min-width: 280px;
}

/* ── Label ── */
.dab-filters__label {
    font-size: 10px;
    font-weight: 700;
    color: #666666;
    letter-spacing: 1px;
    text-transform: uppercase;
}

/* ── Input wrapper ── */
.dab-filters__input-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid #d9d9d9;
    border-radius: 4px;
    background-color: white;
    height: 40px;
    padding: 0 12px;
    gap: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.dab-filters__input-wrapper:focus-within {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.10);
}

/* Estado error */
.dab-filters__input-wrapper--error {
    border-color: #e53e3e !important;
    box-shadow: 0 0 0 3px rgba(229, 62, 62, 0.12) !important;
    background-color: #fff8f8;
}

/* Estado ok */
.dab-filters__input-wrapper--ok {
    border-color: #27ae60 !important;
    box-shadow: 0 0 0 3px rgba(39, 174, 96, 0.10) !important;
}

/* ── Input ── */
.dab-filters__input {
    border: none;
    outline: none;
    font-size: 13px;
    color: #444444;
    width: 100%;
    background: transparent;
}

.dab-filters__input::placeholder {
    color: #bbbbbb;
}

/* ── Icons ── */
.dab-filters__input-icon {
    font-size: 14px;
    color: #aaaaaa;
    flex-shrink: 0;
}

.dab-filters__valid-icon {
    color: #27ae60;
    font-size: 16px;
    font-weight: 700;
    flex-shrink: 0;
}

/* ── Feedback wrapper (error + counter en misma fila) ── */
.dab-filters__feedback-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 18px;
}

/* ── Error ── */
.dab-filters__error {
    display: flex;
    align-items: center;
    gap: 4px;
    color: #e53e3e;
    font-size: 11px;
    font-weight: 500;
    animation: dab-shake 0.25s ease;
}

.dab-filters__error-icon {
    font-size: 12px;
}

/* ── Success ── */
.dab-filters__success {
    color: #27ae60;
    font-size: 11px;
    font-weight: 600;
}

/* ── Counter ── */
.dab-filters__counter {
    font-size: 10px;
    color: #bbbbbb;
    margin-left: auto;
    flex-shrink: 0;
}

.dab-filters__counter--ok {
    color: #27ae60;
    font-weight: 600;
}

/* ── Select ── */
.dab-filters__select {
    padding: 0 12px;
    border: 1px solid #d9d9d9;
    border-radius: 4px;
    font-size: 13px;
    color: #444444;
    background-color: white;
    height: 40px;
    transition: border-color 0.2s;
    outline: none;
}

.dab-filters__select:focus {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.10);
}

/* ── Actions ── */
.dab-filters__actions {
    display: flex;
    gap: 8px;
    align-items: flex-end;
    padding-bottom: 1px;
    flex-shrink: 0;
}

/* ── Buttons ── */
.dab-filters__btn {
    height: 40px;
    padding: 0 22px;
    border: none;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s, box-shadow 0.2s, opacity 0.2s;
    white-space: nowrap;
}

.dab-filters__btn--buscar {
    background-color: #c0392b;
    color: white;
    box-shadow: 0 2px 4px rgba(192, 57, 43, 0.30);
}

.dab-filters__btn--buscar:hover:not(:disabled) {
    background-color: #a93226;
    box-shadow: 0 3px 8px rgba(192, 57, 43, 0.35);
}

.dab-filters__btn--buscar:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    box-shadow: none;
}

.dab-filters__btn--limpiar {
    background-color: #ffffff;
    color: #555555;
    border: 1px solid #d9d9d9;
}

.dab-filters__btn--limpiar:hover {
    background-color: #f5f5f5;
}

/* ── Animación shake al error ── */
@keyframes dab-shake {
    0%   { transform: translateX(0); }
    25%  { transform: translateX(-4px); }
    50%  { transform: translateX(4px); }
    75%  { transform: translateX(-3px); }
    100% { transform: translateX(0); }
}

/* ── Responsive ── */
@media (max-width: 768px) {
    .dab-filters {
        margin: 16px 16px 0 16px;
    }

    .dab-filters__body {
        flex-direction: column;
        align-items: stretch;
    }

    .dab-filters__group,
    .dab-filters__group--wide {
        min-width: unset;
        width: 100%;
    }

    .dab-filters__actions {
        width: 100%;
        justify-content: flex-end;
    }
}