using ManageAdminDMS_UI.Models;
using ManageAdminDMS_UI.Services;
using Microsoft.AspNetCore.Components;

namespace ManageAdminDMS_UI.Components.Pages.Dashboard
{
    public partial class Dashboard
    {
        // ── Inyecciones ──────────────────────────────────────
        [Inject] private DabuenavidaService DabuenavidaService { get; set; } = default!;
        [Inject] private AuthService AuthService               { get; set; } = default!;
        [Inject] private FiltrosPermisosService FiltrosPermisosService { get; set; } = default!;
        [Inject] private NavigationManager Nav                 { get; set; } = default!;

        // ── Estado ───────────────────────────────────────────
        private string mensaje          = "Entrando...";
        private FiltrosBusqueda filtros = new();
        private PagedResult? resultado;
        private bool cargando           = false;
        private int paginaActual        = 1;
        private int tamañoPagina        = 20;
        private string? errorMessage;
        private FiltrosPermisosDto? _permisos;

        private enum Estado { Cargando, Denegado, Permitido }
        private Estado estado = Estado.Cargando;

        // ── Ciclo de vida ─────────────────────────────────────
        protected override async Task OnAfterRenderAsync(bool firstRender)
        {
            if (firstRender)
            {
                await AuthService.LoadTokenAsync();

                // Cargar permisos junto con los datos
                _permisos = await FiltrosPermisosService
                    .GetPermisosAsync(AuthService.Token ?? "");

                _permisos ??= new FiltrosPermisosDto
                {
                    MostrarCentroDeCosto = true,
                    MostrarDabuenavida   = true
                };

                await CargarDatos();
                estado = Estado.Permitido;
                StateHasChanged();
            }
        }

        // ── Métodos de paginación ─────────────────────────────
        private async Task IrAPagina(int pagina)
        {
            paginaActual = pagina;
            await CargarDatos();
        }

        private async Task PaginaAnterior()
        {
            if (paginaActual > 1)
            {
                paginaActual--;
                await CargarDatos();
            }
        }

        private async Task PaginaSiguiente()
        {
            if (paginaActual < resultado?.TotalPaginas)
            {
                paginaActual++;
                await CargarDatos();
            }
        }

        private async Task Buscar()
        {
            paginaActual = 1;
            await CargarDatos();
        }

        private async Task Limpiar()
        {
            filtros      = new();
            paginaActual = 1;
            await CargarDatos();
        }

        // ── Carga principal ───────────────────────────────────
        private async Task CargarDatos()
        {
            cargando = true;
            StateHasChanged();
            try
            {
                resultado = await DabuenavidaService.ObtenerDatos(
                    paginaActual, AuthService.Token ?? "", filtros);
            }
            catch (UnauthorizedAccessException)
            {
                Nav.NavigateTo("/unauthorized");
                return;
            }
            catch (Exception ex)
            {
                errorMessage = ex.Message;
            }
            finally
            {
                cargando = false;
                StateHasChanged();
            }
        }
    }
}