using Microsoft.AspNetCore.Components;

namespace LotesApp.Frontend.Panels;

/// <summary>
/// Panel de acción principal de la página de Lotes: contiene el botón para
/// refrescar el estado y el botón para iniciar una nueva generación de cronogramas.
/// Es un componente de presentación: no llama a servicios directamente, delega
/// ambas acciones al padre mediante EventCallbacks.
/// </summary>
public partial class AccionesPanel
{
    /// <summary>Indica si se está cargando el estado/historial inicial (deshabilita "Generar").</summary>
    [Parameter] public bool IsLoading { get; set; }

    /// <summary>Indica si hay un refresco manual en curso (deshabilita "Actualizar").</summary>
    [Parameter] public bool IsRefreshing { get; set; }

    /// <summary>Indica si hay una generación en progreso (deshabilita "Generar" y muestra spinner).</summary>
    [Parameter] public bool HayGeneracionEnProgreso { get; set; }

    /// <summary>Se dispara al hacer click en "Actualizar".</summary>
    [Parameter] public EventCallback OnRefrescar { get; set; }

    /// <summary>Se dispara al hacer click en "Generar cronogramas".</summary>
    [Parameter] public EventCallback OnGenerar { get; set; }

    private async Task HandleRefrescar() => await OnRefrescar.InvokeAsync();

    private async Task HandleGenerar() => await OnGenerar.InvokeAsync();
}

