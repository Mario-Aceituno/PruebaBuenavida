-----------------------------------------------------------------------
 ACCIONES PANEL CSS

/* — Panel de acciones ------------------------------------------------- */
.action-panel {
    background: #fff; border: 0.5px solid #e0e0e0;
    border-radius: 12px; padding: 1.5rem;
    margin-bottom: 1.5rem;
    display: flex; align-items: center;
    justify-content: space-between; gap: 1rem;
    flex-wrap: wrap;
}

.action-info h2 {
    font-size: 14px; font-weight: 600; color: #1a1a1a; margin: 0 0 4px;
}

.action-info p { font-size: 13px; color: #888; margin: 0 0 4px; }
.action-buttons { display: flex; gap: 8px; margin: 0; flex-shrink: 0; }

/* — Botones ------------------------------------------------- */
.btn {
    display: inline-flex; align-items: center; gap: 6px;
    border: none; border-radius: 7px; padding: 9px 18px;
    font-size: 13px; font-weight: 500; cursor: pointer;
    transition: all 0.15s ease; white-space: nowrap;
}

.btn:disabled { opacity: 0.5; cursor: not-allowed; }

.btn-primary {
    background: #df0000e8;
    color: #fff;
}

.btn-primary:hover:not(:disabled) {
    background: #bf0303;
}

.btn-secondary {
    background: #fff; color: #444;
    border: 0.5px solid #e0e0e0;
}

.btn-secondary:hover:not(:disabled) {
    background: #dfdfdf;
    border-color: #ccc;
    color: #000000;
}

/* — Spinner pequeño para el botón "Generando..." ------------------------------------------------- */
.lotes-spinner {
    width: 30px; height: 30px;
    border: 3px solid #f0f0f0; border-top-color: #C8102E;
    border-radius: 50%; animation: spin 0.7s linear infinite;
    margin: 0 auto 1rem;
}

@keyframes spin { to { transform: rotate(360deg); } }

