using Microsoft.AspNetCore.Components;
using LotesApp.Models;

namespace LotesApp.Frontend.Cards;

/// <summary>
/// Card individual del historial de lotes generados.
/// Es un componente de presentación: no navega ni descarga directamente,
/// delega ambas acciones al padre mediante EventCallbacks para mantener
/// la lógica de servicios (LoteService, navegación) centralizada.
/// </summary>
public partial class LoteCard
{
    /// <summary>Datos del lote a mostrar.</summary>
    [Parameter, EditorRequired] public BatchHistorialItemDto Batch { get; set; } = default!;

    /// <summary>Se dispara al hacer click en cualquier parte de la card (fuera del botón descargar).</summary>
    [Parameter] public EventCallback OnCardClick { get; set; }

    /// <summary>Se dispara al hacer click en "Descargar", con el nombre del archivo a descargar.</summary>
    [Parameter] public EventCallback<string> OnDescargar { get; set; }

    private async Task HandleClick() => await OnCardClick.InvokeAsync();

    private async Task HandleDescargar()
    {
        var archivo = Batch.ArchivosGenerados.First();
        await OnDescargar.InvokeAsync(archivo);
    }
}

