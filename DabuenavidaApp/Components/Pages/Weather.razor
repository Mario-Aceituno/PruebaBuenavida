@namespace LotesApp.Frontend.Modals
@using LotesApp.Models

@if (Lote is not null)
{
    <div class="lotes-modal-backdrop">
        <div class="lotes-modal">
            <div class="lotes-modal-header">
                <h2 class="lotes-modal-title">Confirmar envío a destino</h2>
                <button class="lotes-modal-close" @onclick="HandleCancel">x</button>
            </div>
            <div class="lotes-modal-body">
                <p>
                    ¿Deseas copiar los archivos del lote
                    <strong class="lot-id-modal">@Lote.Id</strong>
                    a la carpeta destino?
                </p>

                <div class="lotes-modal-meta">
                    <span>📁 Archivos: <strong>@Lote.ArchivosGenerados.Count archivo(s)</strong></span>
                    <span>📄 Generado: <strong>@Lote.Creado.ToString("dd/MM/yyyy HH:mm")</strong></span>
                    <span>💻 Ambiente: <strong>@Lote.Ambiente</strong></span>
                </div>

                <!-- Ruta destino override opcional -->
                <div class="modal-input-group">
                    <label class="modal-input-label">Carpeta destino</label>
                    <input class="modal-input"
                           value="@RutaDestinoOverride"
                           @oninput="HandleRutaChanged"
                           placeholder="@RutaDestinoPlaceholder" />
                    <p class="modal-input-hint">
                        Déjalo vacío para usar la ruta configurada en el servidor.
                        Admite rutas locales y de red (\\servidor\carpeta).
                    </p>
                </div>

                <div class="lotes-modal-warning">
                    ⚠ Los archivos se copiarán desde el servidor a la carpeta destino.
                    El proceso es irreversible pero no elimina los archivos de origen.
                </div>
            </div>
            <div class="lotes-modal-footer">
                <button class="btn-modal-cancel" @onclick="HandleCancel">Cancelar</button>
                <button class="btn-modal-confirm" @onclick="HandleConfirm" disabled="@IsEnviando">
                    @(IsEnviando ? "Enviando..." : "↑ Confirmar envío")
                </button>
            </div>
        </div>
    </div>
}

