<div class="cron-paginacion">
    <span class="cron-pag-info">
        Mostrando @(((PaginaActual - 1) * PorPagina) + 1)-@(Math.Min(PaginaActual * PorPagina, TotalRegistros)) de @TotalRegistros
    </span>
    <div class="cron-pag-btns">
        <button class="btn-pag" disabled="@(PaginaActual <= 1)" @onclick="() => OnPaginaAnterior.InvokeAsync()">← Anterior</button>
        @{
            var paginasVisibles = ObtenerPaginasVisibles();
            int? paginaAnteriorVisible = null;
            foreach (var pagNum in paginasVisibles)
            {
                if (paginaAnteriorVisible.HasValue && pagNum - paginaAnteriorVisible.Value > 1)
                {
                    <span class="btn-pag" style="cursor:default;border:none;color:#aaa;">…</span>
                }
                var p = pagNum;
                <button class="btn-pag @(p == PaginaActual ? "btn-pag-activo" : "")"
                        @onclick="() => OnIrAPagina.InvokeAsync(p)">
                    @p
                </button>
                paginaAnteriorVisible = pagNum;
            }
        }
        <button class="btn-pag" disabled="@(PaginaActual >= TotalPaginas)" @onclick="() => OnPaginaSiguiente.InvokeAsync()">Siguiente →</button>
    </div>
</div>

