using Microsoft.AspNetCore.Components;

namespace LotesApp.Frontend.Components.Panels;

public partial class CronogramaPaginacion
{
    [Parameter] public int PaginaActual { get; set; }
    [Parameter] public int TotalPaginas { get; set; }
    [Parameter] public int TotalRegistros { get; set; }
    [Parameter] public int PorPagina { get; set; }

    [Parameter] public EventCallback OnPaginaAnterior { get; set; }
    [Parameter] public EventCallback OnPaginaSiguiente { get; set; }
    [Parameter] public EventCallback<int> OnIrAPagina { get; set; }

    /// <summary>
    /// Retorna los números de página visibles con agrupación inteligente.
    /// Siempre muestra: primera, última, actual, y 1 vecino a cada lado.
    /// Los huecos se representan con "…" en la UI al detectar saltos > 1.
    /// </summary>
    private List<int> ObtenerPaginasVisibles()
    {
        var paginas = new SortedSet<int>();
        paginas.Add(1);
        paginas.Add(TotalPaginas);
        for (int i = PaginaActual - 1; i <= PaginaActual + 1; i++)
        {
            if (i >= 1 && i <= TotalPaginas)
                paginas.Add(i);
        }
        return paginas.ToList();
    }
}

