using LotesApp.Models;
using Microsoft.AspNetCore.Components;
using Microsoft.JSInterop;

namespace LotesApp.Frontend.Pages.Lotes;

public partial class Lotes
{
    // — Estado de la UI -------------------------------------------------

    private LoteModel? loteActual;
    private List<BatchHistorialItemDto> archivosHistorial = new();
    private bool isLoading = true;
    private bool isRefreshing = false;
    private bool isEnviando = false;
    private bool hayGeneracionEnProgreso =>
        loteActual?.Estado == "EnProgreso" || loteActual?.Estado == "Pendiente";
    private string? errorMessage;
    private string? ambienteActivo;

    // Toast
    private string? toastMessage;
    private string toastType = "success";
    private CancellationTokenSource? _toastCts;

    // Modal de envío
    private LoteModel? loteParaEnviar;
    private string? rutaDestinoOverride;

    // Timer de polling
    private Timer? _pollingTimer;

    // — Inicialización -------------------------------------------------

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await AuthService.LoadTokenAsync();

        if (!AuthService.IsAuthenticated)
        {
            Nav.NavigateTo("/not-permiso");
            return;
        }

        LoteService.SetAuthToken(AuthService.Token);
        await CargarDatosIniciales();
        StateHasChanged();
    }

    private async Task CargarDatosIniciales()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Consultar estado actual de la API
            loteActual = await LoteService.ConsultarEstadoAsync();
            ambienteActivo = loteActual?.Ambiente;

            // Cargar historial de archivos
            archivosHistorial = await LoteService.ListarHistorialAsync();

            // Si hay una generación en progreso, iniciar polling
            if (hayGeneracionEnProgreso)
                IniciarPolling();
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo conectar a la API: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // — Polling de progreso -------------------------------------------------

    /// <summary>
    /// Inicia el polling cada 2 segundos mientras la generación está en progreso.
    /// Se detiene automáticamente cuando el estado cambia a Completado o Error.
    /// </summary>
    private void IniciarPolling()
    {
        _pollingTimer?.Dispose();
        _pollingTimer = new Timer(async _ =>
        {
            try
            {
                var nuevoEstado = await LoteService.ConsultarEstadoAsync();
                await InvokeAsync(() =>
                {
                    loteActual = nuevoEstado;
                    if (nuevoEstado != null)
                        ambienteActivo = nuevoEstado.Ambiente;
                    StateHasChanged();
                });

                // Detener polling si terminó
                if (nuevoEstado?.Estado is "Completado" or "Error")
                {
                    _pollingTimer?.Dispose();

                    // Recargar historial de archivos
                    var archivos = await LoteService.ListarHistorialAsync();
                    await InvokeAsync(() =>
                    {
                        archivosHistorial = archivos;
                        StateHasChanged();
                    });

                    if (nuevoEstado.Estado == "Completado")
                        await InvokeAsync(() => MostrarToast(
                            $"Generación completada: {nuevoEstado.OrdenesCompletadas:N0} cronogramas en {nuevoEstado.ArchivosGenerados.Count} archivo(s).",
                            "success"));
                    else
                        await InvokeAsync(() => MostrarToast("La generación terminó con errores.", "danger"));
                }
            }
            catch
            {
                // Ignorar errores transitorios de red durante el polling
            }
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    // — Acciones del usuario -------------------------------------------------

    /// <summary>Inicia una nueva generación de cronogramas.</summary>
    private async Task IniciarGeneracion()
    {
        try
        {
            var response = await LoteService.IniciarGeneracionAsync();
            if (response == null) return;

            MostrarToast($"Generación iniciada. ID: {response.TareaId}", "info");

            // Actualizar estado inmediatamente y comenzar polling
            await Task.Delay(500);
            loteActual = await LoteService.ConsultarEstadoAsync();
            IniciarPolling();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            MostrarToast($"Error al iniciar: {ex.Message}", "danger");
        }
    }

    /// <summary>Refresca manualmente el estado y el historial.</summary>
    private async Task RefrescarEstado()
    {
        isRefreshing = true;
        try
        {
            loteActual = await LoteService.ConsultarEstadoAsync();
            archivosHistorial = await LoteService.ListarHistorialAsync();
            if (hayGeneracionEnProgreso) IniciarPolling();
        }
        catch (Exception ex)
        {
            MostrarToast($"Error al actualizar: {ex.Message}", "danger");
        }
        finally
        {
            isRefreshing = false;
        }
    }

    /// <summary>Descarga un archivo XML vía stream, enviando el token de autenticación.</summary>
    private async Task DescargarArchivo(string nombreArchivo)
    {
        var stream = await LoteService.DescargarArchivoStreamAsync(nombreArchivo);
        if (stream is null)
        {
            MostrarToast($"Error al descargar el archivo: {nombreArchivo}", "danger");
            return;
        }

        using var streamRef = new DotNetStreamReference(stream: stream, leaveOpen: false);
        await JS.InvokeVoidAsync("descargarArchivoStream", nombreArchivo, streamRef);
    }

    // — Flujo de envío (usado por EnvioLoteModal) -------------------------------------------------

    private void AbrirModalEnvio(LoteModel lote)
    {
        loteParaEnviar = lote;
        rutaDestinoOverride = null; // Limpiar campo
    }

    private void CancelarEnvio() => loteParaEnviar = null;

    private async Task EjecutarEnvio()
    {
        if (loteParaEnviar == null) return;
        isEnviando = true;
        var loteId = loteParaEnviar.TareaId;
        loteParaEnviar = null; // Cerrar modal

        try
        {
            var response = await LoteService.EnviarLoteAsync(loteId, rutaDestinoOverride);
            if (response == null) return;

            if (response.Exitoso)
            {
                var msg = $"✓ {response.ArchivosCopiados.Count} archivo(s) enviados a '{response.RutaDestino}'.";
                if (response.ArchivosFallidos.Count > 0)
                    msg += $" ({response.ArchivosFallidos.Count} fallidos)";
                MostrarToast(msg, "success");
            }
            else
            {
                MostrarToast($"Error al enviar: {response.Mensaje}", "danger");
            }
        }
        catch (Exception ex)
        {
            MostrarToast($"Error al enviar: {ex.Message}", "danger");
        }
        finally
        {
            isEnviando = false;
        }
    }

    // — Toast (usado por LoteToast) -------------------------------------------------

    private void MostrarToast(string mensaje, string tipo)
    {
        _toastCts?.Cancel();
        _toastCts = new CancellationTokenSource();

        toastMessage = mensaje;
        toastType = tipo;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(5000, _toastCts.Token);
                await InvokeAsync(() =>
                {
                    toastMessage = null;
                    StateHasChanged();
                });
            }
            catch (TaskCanceledException) { /* Se canceló porque llegó otro toast */ }
        });
    }

    // — Cleanup -------------------------------------------------

    public void Dispose()
    {
        _pollingTimer?.Dispose();
        _toastCts?.Cancel();
        _toastCts?.Dispose();
    }
}

