        </a>

        <button class="icon-btn icon-btn--ghost theme-toggle" onclick="corpWikiTheme.toggle(event)" title="Cambiar tema">
            <Icon Name="sun" Class="theme-toggle__icon theme-toggle__icon--sun" />
            <Icon Name="moon" Class="theme-toggle__icon theme-toggle__icon--moon" />
        </button>

