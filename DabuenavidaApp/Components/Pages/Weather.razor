export function toggleTheme() {
    const currentTheme = localStorage.getItem('theme') || getPreferredTheme();
    const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';

    // 1. Si el navegador NO soporta View Transitions (como navegadores viejos o Firefox estable), cambia el tema sin animación
    if (!document.startViewTransition) {
        executeThemeChange(nextTheme);
        return;
    }

    // 2. Intentar capturar la posición del botón que disparó el evento para usarlo como centro del círculo
    const button = document.querySelector('.topbar-theme-toggle') || document.querySelector('#theme-toggle-btn');
    
    let x = window.innerWidth - 40; // Coordenada X de respaldo (cerca de la esquina superior derecha)
    let y = 40;                      // Coordenada Y de respaldo

    if (button) {
        const rect = button.getBoundingClientRect();
        x = rect.left + rect.width / 2;
        y = rect.top + rect.height / 2;
    }

    // 3. Calcular el radio máximo exacto para que la onda circular cubra la esquina opuesta de la pantalla
    const endRadius = Math.hypot(
        Math.max(x, window.innerWidth - x),
        Math.max(y, window.innerHeight - y)
    );

    // 4. Pasar las coordenadas espaciales al CSS usando variables personalizadas (:root)
    const root = document.documentElement;
    root.style.setProperty('--transition-x', `${x}px`);
    root.style.setProperty('--transition-y', `${y}px`);
    root.style.setProperty('--transition-r', `${endRadius}px`);
    
    // Atributo auxiliar para el control de renderizado en CSS
    root.setAttribute('data-theme-changing', 'true');

    // 5. Ejecutar la View Transition nativa
    const transition = document.startViewTransition(() => {
        executeThemeChange(nextTheme);
    });

    // Limpiar el atributo de control cuando la animación termine por completo
    transition.finished.then(() => {
        root.removeAttribute('data-theme-changing');
    });
}

// Función auxiliar interna para centralizar la mutación del estado (basada en tu propio código)
function executeThemeChange(nextTheme) {
    localStorage.setItem('theme', nextTheme);
    setTheme(nextTheme);
    setThemeOnHtml(nextTheme);
    
    // Disparar evento personalizado por si tienes otros componentes Blazor escuchando
    const event = new CustomEvent('themeChanged', { detail: nextTheme });
    window.dispatchEvent(event);
}
