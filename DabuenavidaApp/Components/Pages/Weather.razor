@using LotesApp.Models

<div class="cron-table-wrapper">
    <table class="cron-table">
        <thead class="cron-table-header">
            <tr class="cron-table-header">
                <th>#</th>
                <th>Nombre del cliente</th>
                <th>Número de préstamo</th>
                <th>Teléfono</th>
                <th>Tasa</th>
                <th>Tipo</th>
                <th class="text-center">Acción</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Cronogramas.Count; i++)
            {
                var cronograma = Cronogramas[i];
                var numero = ((PaginaActual - 1) * PorPagina) + i + 1;
                <tr>
                    <td class="cron-num">@numero</td>
                    <td class="cron-nombre">@cronograma.NombreCliente</td>
                    <td class="cron-mono">@cronograma.NumeroPrestamo</td>
                    <td>@cronograma.NumeroTelefonico</td>
                    <td>@cronograma.Tasa.ToString("N3")%</td>
                    <td>
                        <span class="cron-tipo-badge @(cronograma.Tipo == "Libranza" ? "tipo-libranza" : "tipo-personal")">
                            @cronograma.Tipo
                        </span>
                    </td>
                    <td class="text-center">
                        <button class="btn-ver-detalles"
                                @onclick="() => OnVerDetalles.InvokeAsync(cronograma.NumeroPrestamo)">
                            Ver detalles
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

