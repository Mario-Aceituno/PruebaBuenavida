/// <summary>
/// Trae la lista de centros de costo disponibles desde CFP102 (DABUENAVIDA CONTROLLER BACKEND).
/// </summary>
[HttpGet("centros-costo")]
public async Task<IActionResult> ObtenerCentrosCosto()
{
    try
    {
        string driver = _configManager.GetString("AS400ODBC.driver");
        string server = _configManager.GetString("AS400ODBC.server");
        string uid = DecryptBase64(_configManager.GetString("AS400ODBC.user"));
        string pwd = DecryptBase64(_configManager.GetString("AS400ODBC.password"));
        string port = _configManager.GetString("AS400ODBC.port");
        string connectionString = $"Driver={{{driver}}};System={server};Uid={uid};Pwd={pwd};Port={port};";

        string sql = @"
            SELECT TRIM(CFPNCC) AS Codigo, TRIM(CFPNOMBRE) AS Nombre
            FROM BNKPRD01.CFP102
            ORDER BY CFPNCC";

        using var db = new OdbcConnection(connectionString);
        var result = await db.QueryAsync<CentroCostoDto>(sql);

        return Ok(result.ToList());
    }
    catch (Exception ex)
    {
        _logger.LogError(ex, "Error al obtener centros de costo");
        return StatusCode(500, new { error = ex.Message });
    }
}

------------------------------------------------------------------------------------------------------------------
DABUENAVIDA FILTERS
------------------------------------------------------------------------------------------------------------------
@using ManageAdminDMS_UI.Models
@using ManageAdminDMS_UI.Services
@inject DabuenavidaService ServicioDabuenavida

<div class="dab-filters">
    <div class="dab-filters__header">
        <span class="dab-filters__title">CRITERIOS DE BÚSQUEDA</span>
    </div>
    <div class="dab-filters__body">

        <div class="dab-filters__group">
            <label class="dab-filters__label">CENTRO DE COSTO</label>
            <input class="dab-filters__input-search"
                   @bind="textoCentro"
                   @bind:event="oninput"
                   @onfocus="MostrarLista"
                   @onblur="OcultarLista"
                   placeholder="Buscar o seleccionar centro de costo..." />

            @if (mostrarLista && centrosFiltrados.Any())
            {
                <div class="dab-filters__dropdown">
                    @foreach (var centro in centrosFiltrados)
                    {
                        <div class="dab-filters__dropdown-item"
                             @onmousedown="() => SeleccionarCentro(centro)">
                            @centro.Display
                        </div>
                    }
                </div>
            }
        </div>

        <div class="dab-filters__group dab-filters__group--wide">
            <label class="dab-filters__label">BUSCAR POR DNI O N° DABUENAVIDA</label>
            <div class="dab-filters__input-wrapper">
                <span class="dab-filters__input-icon">🔍</span>
                <input class="dab-filters__input"
                       @bind="Filtros.TextoBusqueda"
                       @onkeydown="@(e => { if (e.Key == "Enter") OnBuscar.InvokeAsync(); })"
                       placeholder="Ingrese DNI del cliente o número de Dabuenavida..." />
            </div>
        </div>

        <div class="dab-filters__actions">
            <button class="dab-filters__btn dab-filters__btn--buscar" @onclick="OnBuscar">
                Buscar
            </button>
            <button class="dab-filters__btn dab-filters__btn--limpiar" @onclick="HandleLimpiar">
                Limpiar
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public FiltrosBusqueda Filtros { get; set; } = new();
    [Parameter] public EventCallback OnBuscar { get; set; }
    [Parameter] public EventCallback OnLimpiar { get; set; }
    [Parameter] public string Token { get; set; } = "";

    private List<CentroCostoDto> centros = new();
    private List<CentroCostoDto> centrosFiltrados = new();
    private string textoCentro = "";
    private bool mostrarLista = false;

    protected override async Task OnInitializedAsync()
    {
        centros = await ServicioDabuenavida.ObtenerCentrosCostoAsync(Token);
        centrosFiltrados = centros;
    }

    private void MostrarLista()
    {
        FiltrarCentros();
        mostrarLista = true;
    }

    private void OcultarLista()
    {
        // Delay para permitir el click en el item antes de ocultar
        Task.Delay(200).ContinueWith(_ =>
        {
            mostrarLista = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private void FiltrarCentros()
    {
        if (string.IsNullOrWhiteSpace(textoCentro))
        {
            centrosFiltrados = centros;
        }
        else
        {
            centrosFiltrados = centros
                .Where(c => c.Display.Contains(textoCentro, 
                    StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void SeleccionarCentro(CentroCostoDto centro)
    {
        textoCentro = centro.Display;
        Filtros.CentroDeCosto = centro.Codigo;
        mostrarLista = false;
    }

    private async Task HandleLimpiar()
    {
        textoCentro = "";
        Filtros.TextoBusqueda = "";
        Filtros.CentroDeCosto = "";
        await OnLimpiar.InvokeAsync();
    }
}

