/// <summary>
/// Trae la lista de centros de costo disponibles desde CFP102 (DABUENAVIDA CONTROLLER BACKEND).
/// </summary>
[HttpGet("centros-costo")]
public async Task<IActionResult> ObtenerCentrosCosto()
{
    try
    {
        string driver = _configManager.GetString("AS400ODBC.driver");
        string server = _configManager.GetString("AS400ODBC.server");
        string uid = DecryptBase64(_configManager.GetString("AS400ODBC.user"));
        string pwd = DecryptBase64(_configManager.GetString("AS400ODBC.password"));
        string port = _configManager.GetString("AS400ODBC.port");
        string connectionString = $"Driver={{{driver}}};System={server};Uid={uid};Pwd={pwd};Port={port};";

        string sql = @"
            SELECT TRIM(CFPNCC) AS Codigo, TRIM(CFPNOMBRE) AS Nombre
            FROM BNKPRD01.CFP102
            ORDER BY CFPNCC";

        using var db = new OdbcConnection(connectionString);
        var result = await db.QueryAsync<CentroCostoDto>(sql);

        return Ok(result.ToList());
    }
    catch (Exception ex)
    {
        _logger.LogError(ex, "Error al obtener centros de costo");
        return StatusCode(500, new { error = ex.Message });
    }
}

