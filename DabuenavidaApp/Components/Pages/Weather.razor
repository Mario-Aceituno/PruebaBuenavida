@namespace LotesApp.Frontend.Sections
@using LotesApp.Models
@using LotesApp.Frontend.Cards

@if (IsLoading)
{
    <div class="lotes-center">
        <div class="lotes-spinner"></div>
        <p>Cargando historial...</p>
    </div>
}
else if (ErrorMessage is not null)
{
    <div class="lotes-error">⚠ @ErrorMessage</div>
}
else if (Archivos.Count > 0)
{
    <div class="lotes-section-label">Historial de Lotes Generados</div>
    <div class="lotes-grid">
        @foreach (var batch in Archivos)
        {
            <LoteCard Batch="batch"
                      OnCardClick="() => HandleCardClick(batch)"
                      OnDescargar="HandleDescargar" />
        }
    </div>
}

