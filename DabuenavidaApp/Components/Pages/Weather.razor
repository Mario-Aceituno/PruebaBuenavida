@page "/detalles/{NumeroPrestamo}"
@layout LotesLayout
@rendermode InteractiveServer
@using LotesApp.Models
@using LotesApp.Services
@using LotesApp.Frontend.Components.Sections
@using LotesApp.Frontend.Components.Tables
@using LotesApp.Frontend.Components.Panels
@inject CronogramaService CronogramaService
@inject NavigationManager Nav
@inject AuthService AuthService

<PageTitle>Detalles - @NumeroPrestamo</PageTitle>

<div class="lotes-page">

    <!-- NAVBAR -->
    <LotesApp.Frontend.Components.Navbars.BatchManagementNav />

    <div class="lotes-content">

        <!-- Encabezado con datos del cliente -->
        <DetalleClienteHeader Cronograma="cronograma" TotalRegistros="totalRegistros" />

        <!-- Filtro por fecha -->
        @* <div class="cron-filtro-row">
            <input class="cron-input"
                   type="month"
                   @oninput="OnFiltroChanged" />
            @if (!string.IsNullOrWhiteSpace(filtroFecha))
            {
                <button class="btn-limpiar" @onclick="LimpiarFiltro">✕ Limpiar</button>
            }
        </div> *@

        <!-- Tabla de detalles -->
        @if (isLoading)
        {
            <div class="lotes-center">
                <div class="lotes-spinner"></div>
                <p>Cargando detalles...</p>
            </div>
        }
        else if (errorMessage is not null)
        {
            <div class="lotes-error">⚠ @errorMessage</div>
        }
        else if (detalles is null || detalles.Count == 0)
        {
            <div class="lotes-center">No se encontraron detalles para este préstamo.</div>
        }
        else
        {
            <DetalleTabla Detalles="detalles"
                          PaginaActual="paginaActual"
                          PorPagina="porPagina" />

            <CronogramaPaginacion PaginaActual="paginaActual"
                                   TotalPaginas="totalPaginas"
                                   TotalRegistros="totalRegistros"
                                   PorPagina="porPagina"
                                   OnPaginaAnterior="PaginaAnterior"
                                   OnPaginaSiguiente="PaginaSiguiente"
                                   OnIrAPagina="IrAPagina" />
        }

    </div>

</div>

@code {
    [Parameter] public string NumeroPrestamo { get; set; } = string.Empty;

    private CronogramaModel?         cronograma;
    private List<DetallePrestamo>?   detalles;
    private bool                     isLoading       = true;
    private string?                  errorMessage;
    private string?                  filtroFecha;
    private int                      paginaActual    = 1;
    private int                      porPagina       = 12;
    private int                      totalRegistros  = 0;
    private int                      totalPaginas    => Math.Max(1, (int)Math.Ceiling((double)totalRegistros / porPagina));

    // Guardamos el loteId para poder volver
    private string? loteIdOrigen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await AuthService.LoadTokenAsync();

        if (!AuthService.IsAuthenticated)
        {
            Nav.NavigateTo("/not-permiso");
            return;
        }

        CronogramaService.SetAuthToken(AuthService.Token);
        cronograma   = await CronogramaService.GetCronogramaByPrestamoAsync(NumeroPrestamo);
        loteIdOrigen = cronograma?.LoteId;
        await CargarDatos();
        StateHasChanged();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading       = true;
            totalRegistros  = await CronogramaService.GetTotalDetallesAsync(NumeroPrestamo, filtroFecha);
            detalles        = await CronogramaService.GetDetallesByPrestamoAsync(NumeroPrestamo, paginaActual, porPagina, filtroFecha);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar los detalles: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnFiltroChanged(ChangeEventArgs e)
    {
        filtroFecha  = e.Value?.ToString();
        paginaActual = 1;
        await CargarDatos();
    }

    private async Task LimpiarFiltro()
    {
        filtroFecha  = null;
        paginaActual = 1;
        await CargarDatos();
    }

    private async Task PaginaAnterior()  { if (paginaActual > 1)             { paginaActual--; await CargarDatos(); } }
    private async Task PaginaSiguiente() { if (paginaActual < totalPaginas)  { paginaActual++; await CargarDatos(); } }
    private async Task IrAPagina(int p)  { paginaActual = p; await CargarDatos(); }

    private void Volver() => Nav.NavigateTo(loteIdOrigen is not null ? $"/cronogramas/{loteIdOrigen}" : "/lotes");
}

