/* — Card de lote ------------------------------------------------- */
.lot-card {
    background: #fff; border: 0.5px solid #e0e0e0;
    border-radius: 10px; padding: 1.1rem 1.4rem;
    display: grid;
    grid-template-columns: 160px 130px 1fr 130px auto;
    align-items: center; gap: 3.25rem;
    transition: border-color 0.15s ease;
    cursor: pointer;
}

.lot-card:hover { border-color: #C8102E; }

.field-label { font-size: 12px; color: #aaa; margin-bottom: 3px; }
.field-value { font-size: 14px; font-weight: 600; color: #1a1a1a; }

.lot-id {
    font-size: 14px; color: #C8102E; margin-top: 2px;
    font-family: 'Courier New', monospace; letter-spacing: 0.02em;
}

.lot-ambiente {
    font-size: 10px; color: #888; margin-top: 2px;
}

.lot-time { font-size: 11px; color: #aaa; }

.lot-total-registros { font-size: 11px; font-weight: normal; color: #aaa; }

.lot-archivos-count { font-size: 11px; color: #aaa; margin-top: 2px; }

/* — Acciones en card ------------------------------------------------- */
.card-actions { display: flex; flex-direction: column; gap: 6px; align-items: flex-end; }

.btn-descargar {
    background: #fff;
    color: #bf0303;
    border: 0.5px solid #bf0303;
    border-radius: 6px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
}

.btn-descargar:hover {
    background: #bf0303;
    color: #fff;
}

/* — Badges de estado ------------------------------------------------- */
.lot-badge {
    display: inline-flex; align-items: center;
    font-size: 12px; font-weight: 500; gap: 5px;
    border-radius: 99px; padding: 4px 11px;
    white-space: nowrap;
}

.lot-badge-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }

.badge-pending { background: #fff7ed; color: #92400e; border: 0.5px solid #fed7aa; }
.badge-pending .lot-badge-dot { background: #f59e0b; }

.badge-running { background: #eff6ff; color: #1d4ed8; border: 0.5px solid #bfdbfe; }
.badge-running .lot-badge-dot { background: #3b82f6; animation: pulse-dot 1s ease-in-out infinite; }

.badge-ready { background: #f0fdf4; color: #166534; border: 0.5px solid #bbf7d0; }
.badge-ready .lot-badge-dot { background: #22c55e; }

.badge-sent { background: #f5f3ff; color: #5b21b6; border: 0.5px solid #ddd6fe; }
.badge-sent .lot-badge-dot { background: #7c3aed; }

.badge-error { background: #fff5f5; color: #991b1b; border: 0.5px solid #fecaca; }
.badge-error .lot-badge-dot { background: #ef4444; }

@keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
}

