using Microsoft.AspNetCore.Components;
using LotesApp.Models;

namespace LotesApp.Frontend.Panels;

/// <summary>
/// Panel de progreso en vivo de la generación de cronogramas: muestra el estado,
/// el porcentaje de avance, mensajes/errores y la lista de archivos generados.
/// Es un componente de presentación: no llama a servicios directamente, delega
/// el envío y la descarga de archivos al padre mediante EventCallbacks.
/// </summary>
public partial class ProgresoPanel
{
    /// <summary>Estado actual del lote en generación.</summary>
    [Parameter, EditorRequired] public LoteModel Lote { get; set; } = default!;

    /// <summary>Indica si hay una generación en progreso (controla el badge de "Generando por").</summary>
    [Parameter] public bool HayGeneracionEnProgreso { get; set; }

    /// <summary>Indica si el envío a la carpeta destino está en curso (deshabilita el botón "Enviar").</summary>
    [Parameter] public bool IsEnviando { get; set; }

    /// <summary>Ruta destino configurada, mostrada como referencia junto al botón de envío.</summary>
    [Parameter] public string? RutaDestino { get; set; }

    /// <summary>Se dispara al hacer click en "Enviar a destino".</summary>
    [Parameter] public EventCallback OnEnviarClick { get; set; }

    /// <summary>Se dispara al hacer click en "Descargar" de un archivo generado.</summary>
    [Parameter] public EventCallback<string> OnDescargarArchivo { get; set; }

    private async Task HandleEnviarClick() => await OnEnviarClick.InvokeAsync();

    private async Task HandleDescargarArchivo(string archivo) => await OnDescargarArchivo.InvokeAsync(archivo);
}

