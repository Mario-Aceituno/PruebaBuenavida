using Microsoft.AspNetCore.Components;
using LotesApp.Models;

namespace LotesApp.Frontend.Modals;

/// <summary>
/// Modal de confirmación para enviar (copiar) los archivos de un lote a la carpeta destino.
/// Es un componente de presentación: no llama al servicio directamente, delega
/// la acción de confirmar/cancelar al padre mediante EventCallbacks.
/// </summary>
public partial class EnvioLoteModal
{
    /// <summary>Lote a enviar. Si es null, el modal no se muestra.</summary>
    [Parameter] public LoteModel? Lote { get; set; }

    /// <summary>Ruta destino configurada por defecto (se muestra como placeholder).</summary>
    [Parameter] public string? RutaDestinoPlaceholder { get; set; }

    /// <summary>Ruta destino override escrita por el usuario (soporta @bind-RutaDestinoOverride).</summary>
    [Parameter] public string? RutaDestinoOverride { get; set; }
    [Parameter] public EventCallback<string?> RutaDestinoOverrideChanged { get; set; }

    /// <summary>Indica si el envío está en curso (deshabilita el botón de confirmar).</summary>
    [Parameter] public bool IsEnviando { get; set; }

    /// <summary>Se dispara al cancelar / cerrar el modal.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>Se dispara al confirmar el envío.</summary>
    [Parameter] public EventCallback OnConfirm { get; set; }

    private async Task HandleRutaChanged(ChangeEventArgs e)
    {
        RutaDestinoOverride = e.Value?.ToString();
        await RutaDestinoOverrideChanged.InvokeAsync(RutaDestinoOverride);
    }

    private async Task HandleCancel() => await OnCancel.InvokeAsync();

    private async Task HandleConfirm() => await OnConfirm.InvokeAsync();
}

