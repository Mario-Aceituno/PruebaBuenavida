TOAST CSS

/* — Toast ------------------------------------------------- */
.lotes-toast {
    position: fixed; bottom: 1.5rem; right: 1.5rem;
    background: #1a1a1a; color: #fff; border-radius: 8px;
    padding: 0.75rem 1.25rem; font-size: 13px; font-weight: 500;
    display: flex; align-items: center; gap: 12px;
    z-index: 1000; box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    animation: slide-in 0.2s ease;
}

.lotes-toast.toast-success { border-left: 3px solid #22c55e; }
.lotes-toast.toast-danger  { border-left: 3px solid #C8102E; }
.lotes-toast.toast-info    { border-left: 3px solid #3b82f6; }

.lotes-toast-close {
    background: none; border: none; color: #888;
    cursor: pointer; font-size: 16px; line-height: 1; padding: 0;
}

@keyframes slide-in {
    from { transform: translateX(100%); opacity: 0; }
    to   { transform: translateX(0);    opacity: 1; }
}

