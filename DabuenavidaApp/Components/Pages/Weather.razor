@page "/cronogramas/{LoteId}"
@layout LotesLayout
@rendermode InteractiveServer
@using LotesApp.Models
@using LotesApp.Services
@using LotesApp.Frontend.Components.Sections
@using LotesApp.Frontend.Components.Filters
@using LotesApp.Frontend.Components.Tables
@using LotesApp.Frontend.Components.Panels
@inject CronogramaService CronogramaService
@inject NavigationManager Nav
@inject AuthService AuthService

<PageTitle>Cronogramas - @LoteId</PageTitle>

<div class="lotes-page">

    <!-- NAVBAR -->
    <LotesApp.Frontend.Components.Navbars.BatchManagementNav />

    <div class="lotes-content">

        <!-- Encabezado -->
        <CronogramaHeader LoteId="@LoteId" TotalRegistros="@totalRegistros" />

        <!-- Filtro -->
        <CronogramaFiltro OnFiltroChanged="OnFiltroChanged" />

        <!-- Contenido -->
        @if (isLoading)
        {
            <div class="lotes-center">
                <div class="lotes-spinner"></div>
                <p>Cargando cronogramas...</p>
            </div>
        }
        else if (errorMessage is not null)
        {
            <div class="lotes-error">⚠ @errorMessage</div>
        }
        else if (cronogramas is null || cronogramas.Count == 0)
        {
            <div class="lotes-center">No se encontraron cronogramas para este lote.</div>
        }
        else
        {
            <CronogramaTabla Cronogramas="cronogramas"
                              PaginaActual="paginaActual"
                              PorPagina="porPagina"
                              OnVerDetalles="VerDetalles" />

            <CronogramaPaginacion PaginaActual="paginaActual"
                                   TotalPaginas="totalPaginas"
                                   TotalRegistros="totalRegistros"
                                   PorPagina="porPagina"
                                   OnPaginaAnterior="PaginaAnterior"
                                   OnPaginaSiguiente="PaginaSiguiente"
                                   OnIrAPagina="IrAPagina" />
        }

    </div>

</div>

@code {
    [Parameter] public string LoteId { get; set; } = string.Empty;

    private List<CronogramaModel>? cronogramas;
    private bool     isLoading      = true;
    private string?  errorMessage;
    private string?  filtro;
    private int      paginaActual   = 1;
    private int      porPagina      = 15;
    private int      totalRegistros = 0;
    private int      totalPaginas   => Math.Max(1, (int)Math.Ceiling((double)totalRegistros / porPagina));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await AuthService.LoadTokenAsync();

        if (!AuthService.IsAuthenticated)
        {
            Nav.NavigateTo("/not-permiso");
            return;
        }

        CronogramaService.SetAuthToken(AuthService.Token);
        await CargarDatos();
        StateHasChanged();
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading       = true;
            totalRegistros  = await CronogramaService.GetTotalCronogramasAsync(LoteId, filtro);
            cronogramas     = await CronogramaService.GetCronogramasByLoteAsync(LoteId, paginaActual, porPagina, filtro);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar los cronogramas: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnFiltroChanged(ChangeEventArgs e)
    {
        filtro       = e.Value?.ToString();
        paginaActual = 1;
        await CargarDatos();
    }

    private async Task PaginaAnterior() { if (paginaActual > 1) { paginaActual--; await CargarDatos(); } }
    private async Task PaginaSiguiente() { if (paginaActual < totalPaginas) { paginaActual++; await CargarDatos(); } }
    private async Task IrAPagina(int p) { paginaActual = p; await CargarDatos(); }

    private void VerDetalles(string numeroPrestamo) => Nav.NavigateTo($"/detalles/{numeroPrestamo}");
}

