/* =========================================================================
   DARK MODE
   ========================================================================= */
[data-theme="dark"] {
    /* ... tus otras variables ... */

    /* Desarrollo .NET y C# (Un azul/morado vibrante pero amigable) */
    --cat-net-bg: rgba(99, 102, 241, 0.15);
    --cat-net-text: #818cf8;

    /* Seguridad de Aplicaciones (Ámbar/Amarillo de advertencia sutil) */
    --cat-seguridad-bg: rgba(245, 158, 11, 0.15);
    --cat-seguridad-text: #fbbf24;

    /* Core Bancario / Branding (Rojo Davivienda suavizado) */
    --cat-bancario-bg: rgba(218, 31, 61, 0.15);
    --cat-bancario-text: #f06070;
}

/* =========================================================================
   LIGHT MODE
   ========================================================================= */
[data-theme="light"] {
    /* ... tus otras variables ... */

    /* Desarrollo .NET y C# */
    --cat-net-bg: #e0e7ff;
    --cat-net-text: #4338ca;

    /* Seguridad de Aplicaciones */
    --cat-seguridad-bg: #fef3c7;
    --cat-seguridad-text: #b45309;

    /* Core Bancario / Branding */
    --cat-bancario-bg: #fff0f2;
    --cat-bancario-text: #da1f3d;
}

-----------------------

.category-card__icon-container {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    padding: var(--space-2);
    transition: background-color var(--transition-base), color var(--transition-base);
}

/* Mapeo de clases dinámicas */
.category-card__icon-container.is-desarrollo-net-csharp {
    background-color: var(--cat-net-bg);
    color: var(--cat-net-text);
}
.category-card__icon-container.is-seguridad-de-aplicaciones {
    background-color: var(--cat-seguridad-bg);
    color: var(--cat-seguridad-text);
}
.category-card__icon-container.is-core-bancario {
    background-color: var(--cat-bancario-bg);
    color: var(--cat-bancario-text);
}
