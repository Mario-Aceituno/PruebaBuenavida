@using ManageAdminDMS_UI.Models
@using ManageAdminDMS_UI.Services
@inject DabuenavidaService ServicioDabuenavida

<div class="dab-filters">
    <div class="dab-filters__header">
        <span class="dab-filters__title">CRITERIOS DE BÚSQUEDA</span>
    </div>
    <div class="dab-filters__body">

        @* CENTRO DE COSTO *@
        <div class="dab-filters__group">
            <label class="dab-filters__label">CENTRO DE COSTO</label>
            <div class="dab-filters__input-wrapper @(_errorCentro != "" ? "dab-filters__input-wrapper--error" : "")">
                <input class="dab-filters__input"
                       value="@_textoCentro"
                       @oninput="OnCentroDeCostoInput"
                       @onfocus="MostrarLista"
                       @onblur="OcultarLista"
                       placeholder="Buscar o seleccionar centro de costo..." />
            </div>

            @* Dropdown *@
            @if (_mostrarLista && _centrosFiltrados.Any())
            {
                <div class="dab-filters__dropdown">
                    @foreach (var centro in _centrosFiltrados)
                    {
                        <div class="dab-filters__dropdown-item"
                             @onmousedown="() => SeleccionarCentro(centro)">
                            @centro.Display
                        </div>
                    }
                </div>
            }

            @* Feedback *@
            <div class="dab-filters__feedback-wrapper">
                @if (_errorCentro != "")
                {
                    <span class="dab-filters__error">
                        <span class="dab-filters__error-icon">⚠</span>
                        @_errorCentro
                    </span>
                }
            </div>
        </div>

        @* BUSCAR POR DNI O N° DABUENAVIDA *@
        <div class="dab-filters__group dab-filters__group--wide">
            <label class="dab-filters__label">BUSCAR POR DNI O N° DABUENAVIDA</label>
            <div class="dab-filters__input-wrapper">
                <span class="dab-filters__input-icon">🔍</span>
                <input class="dab-filters__input"
                       value="@Filtros.TextoBusqueda"
                       @oninput="OnTextoBusquedaInput"
                       placeholder="Ingrese DNI (10 dígitos) o N° Dabuenavida (13 dígitos)..." />
            </div>
        </div>

        @* BOTONES *@
        <div class="dab-filters__actions">
            <button class="dab-filters__btn dab-filters__btn--buscar" @onclick="OnBuscar">
                Buscar
            </button>
            <button class="dab-filters__btn dab-filters__btn--limpiar" @onclick="HandleLimpiar">
                Limpiar
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public FiltrosBusqueda Filtros { get; set; } = new();
    [Parameter] public EventCallback OnBuscar { get; set; }
    [Parameter] public EventCallback OnLimpiar { get; set; }
    [Parameter] public string Token { get; set; } = "";

    private List<CentroCostoDto> _centros = new();
    private List<CentroCostoDto> _centrosFiltrados = new();
    private string _textoCentro = "";
    private string _errorCentro = "";
    private bool _mostrarLista = false;

    protected override async Task OnInitializedAsync()
    {
        _centros = await ServicioDabuenavida.ObtenerCentrosCostoAsync(Token);
        _centrosFiltrados = _centros;
    }

    private void OnCentroDeCostoInput(ChangeEventArgs e)
    {
        _textoCentro = e.Value?.ToString() ?? "";

        // Filtrar lista en tiempo real
        _centrosFiltrados = string.IsNullOrWhiteSpace(_textoCentro)
            ? _centros
            : _centros.Where(c => c.Display.Contains(_textoCentro,
                StringComparison.OrdinalIgnoreCase)).ToList();

        // Limpiar selección si el usuario edita manualmente
        Filtros.CentroDeCosto = "";
        _errorCentro = "";
        _mostrarLista = true;
    }

    private void SeleccionarCentro(CentroCostoDto centro)
    {
        _textoCentro = centro.Display;
        Filtros.CentroDeCosto = centro.Codigo;
        _errorCentro = "";
        _mostrarLista = false;
    }

    private void MostrarLista()
    {
        _centrosFiltrados = string.IsNullOrWhiteSpace(_textoCentro)
            ? _centros
            : _centros.Where(c => c.Display.Contains(_textoCentro,
                StringComparison.OrdinalIgnoreCase)).ToList();
        _mostrarLista = true;
    }

    private void OcultarLista()
    {
        Task.Delay(200).ContinueWith(_ =>
        {
            _mostrarLista = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private void OnTextoBusquedaInput(ChangeEventArgs e)
    {
        Filtros.TextoBusqueda = e.Value?.ToString() ?? "";
    }

    private async Task HandleLimpiar()
    {
        _textoCentro = "";
        _errorCentro = "";
        Filtros.CentroDeCosto = "";
        Filtros.TextoBusqueda = "";
        await OnLimpiar.InvokeAsync();
    }
}

