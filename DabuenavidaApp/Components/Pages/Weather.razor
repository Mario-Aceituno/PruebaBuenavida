using Microsoft.AspNetCore.Components;

namespace LotesApp.Frontend.Toast;

/// <summary>
/// Componente de notificación tipo "toast".
/// El estado (mensaje, tipo, tiempo de vida) lo controla el componente padre;
/// este componente solo se encarga de la presentación y de avisar cuándo debe cerrarse.
/// </summary>
public partial class LoteToast
{
    /// <summary>Mensaje a mostrar. Si es null, el toast no se renderiza.</summary>
    [Parameter] public string? Message { get; set; }

    /// <summary>Tipo de toast: "success", "danger" o "info".</summary>
    [Parameter] public string Type { get; set; } = "success";

    /// <summary>Se dispara cuando el usuario hace click en la "x" para cerrar el toast.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }
}

