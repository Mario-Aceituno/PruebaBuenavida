@namespace LotesApp.Frontend.Panels
@using LotesApp.Models
@using LotesApp.Frontend.Lists

<div class="progress-panel">
    <div class="progress-panel-header">
        <div>
            <div class="progress-title">
                @if (Lote.Estado == "EnProgreso" || Lote.Estado == "Pendiente")
                { <span>⚙ Generación en progreso</span> }
                else if (Lote.Estado == "Completado")
                { <span>✓ Generación completada</span> }
                else if (Lote.Estado == "Error")
                { <span>✗ Error en la generación</span> }
                else
                { <span>@Lote.Estado</span> }
            </div>
            <div class="progress-tarea-id">ID: @Lote.TareaId</div>
            @if (!string.IsNullOrEmpty(Lote.UsuarioGenerando) && HayGeneracionEnProgreso)
            {
                <div style="font-size: 12px; color: #92400e; margin-top: 4px;
                    border: 0.5px solid #fed7aa; border-radius: 6px;
                    padding: 4px 10px; display: inline-block; background: #fff7ed;">
                    👤 Generando por: <strong>@Lote.UsuarioGenerando</strong>
                </div>
            }
        </div>
        <div class="progress-pct">@Lote.PorcentajeProgreso%</div>
    </div>

    <div class="progress-track">
        <div class="progress-fill @(Lote.Estado == "Completado" ? "complete" : Lote.Estado == "Error" ? "error-fill" : "")"
             style="width: @Lote.PorcentajeProgreso%">
        </div>
    </div>

    <div class="progress-meta">
        <span>@Lote.MensajeProgreso</span>
        <span>@Lote.DocumentosPendientes</span>
    </div>

    @if (Lote.Estado == "Error" && Lote.Error != null)
    {
        <div class="progress-error-msg">⚠ @Lote.Error</div>
    }

    <!-- Botón de envío: solo disponible cuando está Completado -->
    @if (Lote.Estado == "Completado" && Lote.ArchivosGenerados.Count > 0)
    {
        <div style="margin-top: 1rem; display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
            <button class="btn btn-success"
                    @onclick="HandleEnviarClick"
                    disabled="@IsEnviando">
                @if (IsEnviando)
                { <span>Enviando...</span> }
                else
                { <span>↑ Enviar a destino (@Lote.ArchivosGenerados.Count archivo(s))</span> }
            </button>
            <span style="font-size: 12px; color: #888;">
                Destino: <code style="font-size:11px;">@RutaDestino</code>
            </span>
        </div>
    }

    <!-- Lista de archivos generados -->
    <ArchivosGeneradosList Archivos="Lote.ArchivosGenerados" OnDescargar="HandleDescargarArchivo" />
</div>

