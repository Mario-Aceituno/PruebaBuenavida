/* --- CATEGORÍAS DINÁMICAS (Cambio anterior) --- */
.category-card__icon-dynamic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: rgb(from var(--user-cat-color) r g b / var(--dynamic-badge-opacity));
    color: var(--user-cat-color);
    filter: var(--dynamic-badge-filter);
    transition: background-color var(--transition-base), color var(--transition-base), filter var(--transition-base);
}

.category-card__icon-dynamic svg {
    fill: currentColor;
    stroke: currentColor;
}

/* --- ANIMACIÓN DE BARRIDO CIRCULAR (Cambio nuevo) --- */
::view-transition-old(root),
::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
}

[data-theme-changing] ::view-transition-new(root) {
    animation: none; 
}

::view-transition-image-group(root) {
    isolation: auto;
}

@keyframes clip-to-corner {
    from {
        clip-path: circle(0px at var(--transition-x) var(--transition-y));
    }
    to {
        clip-path: circle(var(--transition-r) at var(--transition-x) var(--transition-y));
    }
}

::view-transition-new(root) {
    animation: 450ms cubic-bezier(0.4, 0, 0.2, 1) both clip-to-corner;
}







export function toggleTheme() {
    const currentTheme = localStorage.getItem('theme') || getPreferredTheme();
    const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';

    // 1. Si el navegador no soporta la animación, cambia el tema en seco
    if (!document.startViewTransition) {
        executeThemeChange(nextTheme);
        return;
    }

    // 2. Intentar buscar el botón de la barra superior para centrar el círculo
    const button = document.querySelector('.topbar-theme-toggle') || document.querySelector('#theme-toggle-btn');
    let x = window.innerWidth - 40; 
    let y = 40;                      

    if (button) {
        const rect = button.getBoundingClientRect();
        x = rect.left + rect.width / 2;
        y = rect.top + rect.height / 2;
    }

    // 3. Pasar coordenadas al CSS
    const root = document.documentElement;
    root.style.setProperty('--transition-x', `${x}px`);
    root.style.setProperty('--transition-y', `${y}px`);
    root.style.setProperty('--transition-r', `${Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y))}px`);
    
    root.setAttribute('data-theme-changing', 'true');

    // 4. Lanzar barrido circular animado
    const transition = document.startViewTransition(() => {
        executeThemeChange(nextTheme);
    });

    transition.finished.then(() => {
        root.removeAttribute('data-theme-changing');
    });
}

// Función interna auxiliar que usa tus métodos existentes
function executeThemeChange(nextTheme) {
    localStorage.setItem('theme', nextTheme);
    setTheme(nextTheme);
    setThemeOnHtml(nextTheme);
}





