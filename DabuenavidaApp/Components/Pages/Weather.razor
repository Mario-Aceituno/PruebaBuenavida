    --dynamic-badge-filter: saturate(1.5) brightness(1.3); 
}

/* Dentro de tu bloque [data-theme="light"] existente */
[data-theme="light"] {
    /* ... tus otras variables del modo claro ... */

    /* [NUEVO] Configuración para iconos con colores dinámicos */
    --dynamic-badge-opacity: 0.10;   
    --dynamic-badge-filter: none;       
}


