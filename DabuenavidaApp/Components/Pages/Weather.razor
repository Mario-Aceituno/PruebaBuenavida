/* =========================================================================
   SECCIÓN A: AGREGAR ESTOS TOKENS DINÁMICOS AL ARCHIVO GLOBAL
   Añade estas variables dentro de tus selectores de tema existentes.
   ========================================================================= */

/* Dentro de tu bloque [data-theme="dark"] existente */
[data-theme="dark"] {
    /* ... tus otras variables del modo oscuro ... */

    /* Configuración para colores dinámicos elegidos por el usuario */
    --dynamic-badge-opacity: 0.18;   /* Opacidad sutil para el fondo en modo oscuro */
    --dynamic-badge-filter: saturate(1.5) brightness(1.3); /* Resalta colores oscuros elegidos por el usuario */
}

/* Dentro de tu bloque [data-theme="light"] existente */
[data-theme="light"] {
    /* ... tus otras variables del modo claro ... */

    /* Configuración para colores dinámicos elegidos por el usuario */
    --dynamic-badge-opacity: 0.10;   /* El 10% de opacidad equivalente al antiguo truco '1a' */
    --dynamic-badge-filter: none;       /* En modo claro se respeta el color puro original */
}


/* =========================================================================
   SECCIÓN B: CLASE DE UTILIDAD ESTRUCTURAL (Añadir al final del CSS global)
   Esta clase procesa el color HEX dinámico que le inyectamos desde Blazor.
   ========================================================================= */

.category-card__icon-dynamic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    
    /* 1. Genera el fondo dinámico extrayendo los canales RGB del HEX del usuario y aplicando la opacidad del tema */
    background-color: rgb(from var(--user-cat-color) r g b / var(--dynamic-badge-opacity));
    
    /* 2. Aplica el color base al icono */
    color: var(--user-cat-color);
    
    /* 3. Ajusta brillo/saturación automáticamente solo si estamos en modo oscuro */
    filter: var(--dynamic-badge-filter);
    
    /* 4. Transición suave al alternar entre temas */
    transition: background-color var(--transition-base), color var(--transition-base), filter var(--transition-base);
}

/* Asegura que los vectores internos hereden correctamente el color calculado */
.category-card__icon-dynamic svg {
    fill: currentColor;
    stroke: currentColor;
}
