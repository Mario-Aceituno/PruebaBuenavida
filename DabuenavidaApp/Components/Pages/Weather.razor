using Microsoft.AspNetCore.Components;
using LotesApp.Models;

namespace LotesApp.Frontend.Sections;

/// <summary>
/// Sección de historial de lotes generados (desde /listar): maneja los tres
/// estados posibles (cargando, error, listado) y renderiza una <see cref="LoteCard"/>
/// por cada lote del historial.
/// Es un componente de presentación: no navega ni descarga directamente, delega
/// ambas acciones al padre mediante EventCallbacks.
/// </summary>
public partial class HistorialSection
{
    /// <summary>Indica si el historial se está cargando.</summary>
    [Parameter] public bool IsLoading { get; set; }

    /// <summary>Mensaje de error al consultar la API, si lo hubo.</summary>
    [Parameter] public string? ErrorMessage { get; set; }

    /// <summary>Historial de lotes generados a listar.</summary>
    [Parameter, EditorRequired] public List<BatchHistorialItemDto> Archivos { get; set; } = new();

    /// <summary>Se dispara al hacer click en una card del historial, con el lote seleccionado.</summary>
    [Parameter] public EventCallback<BatchHistorialItemDto> OnCardClick { get; set; }

    /// <summary>Se dispara al hacer click en "Descargar" de un archivo del historial.</summary>
    [Parameter] public EventCallback<string> OnDescargar { get; set; }

    private async Task HandleCardClick(BatchHistorialItemDto batch) => await OnCardClick.InvokeAsync(batch);

    private async Task HandleDescargar(string archivo) => await OnDescargar.InvokeAsync(archivo);
}

