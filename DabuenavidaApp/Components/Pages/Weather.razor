@namespace LotesApp.Frontend.Cards
@using LotesApp.Models

<div class="lot-card" @onclick="HandleClick">

    <!-- Nombre / ID -->
    <div>
        <div class="field-label">Lote</div>
        <div class="lot-id">@(Batch.NombreLote ?? Batch.TareaId)</div>
        <div class="lot-ambiente">@Batch.Ambiente</div>
    </div>

    <!-- Fecha -->
    <div>
        <div class="field-label">Fecha creación</div>
        <div class="field-value">@Batch.CreatedAt.ToString("dd/MM/yyyy")</div>
        <div class="lot-time">@Batch.CreatedAt.ToString("HH:mm")</div>
    </div>

    <!-- Tamaño / Progreso -->
    <div>
        <div class="field-label">Registros</div>
        <div class="field-value">
            @Batch.RegistrosProcesados.ToString("N0")
            <span class="lot-total-registros">de @Batch.TotalRegistros.ToString("N0")</span>
        </div>
        <div class="lot-archivos-count">@Batch.LotesArchivosGenerados archivos XML</div>
    </div>

    <!-- Estado badge -->
    <div>
        @if (Batch.Estado == "Completado")
        {
            <span class="lot-badge badge-ready">
                <span class="lot-badge-dot"></span> Completado
            </span>
        }
        else if (Batch.Estado == "Enviado")
        {
            <span class="lot-badge badge-sent">
                <span class="lot-badge-dot"></span> Enviado
            </span>
        }
        else if (Batch.Estado == "Error")
        {
            <span class="lot-badge badge-error">
                <span class="lot-badge-dot"></span> Error
            </span>
        }
        else if (Batch.Estado == "EnProgreso" || Batch.Estado == "Pendiente")
        {
            <span class="lot-badge badge-running">
                <span class="lot-badge-dot"></span> En Progreso
            </span>
        }
    </div>

    <!-- Acciones -->
    <div class="card-actions">
        @if (Batch.ArchivosGenerados.Count > 0)
        {
            <button class="btn-descargar"
                    @onclick="HandleDescargar"
                    @onclick:stopPropagation="true"
                    title="Descargar primer archivo XML del lote">
                ↓ Descargar
            </button>
        }
    </div>
</div>

