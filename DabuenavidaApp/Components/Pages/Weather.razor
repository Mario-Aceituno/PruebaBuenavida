@code {
    // ... tus parámetros existentes ...

    private string GetCategorySlug()
    {
        if (string.IsNullOrEmpty(Category.Name)) return "default";
        
        return Category.Name.ToLower()
            .Replace(".", "")
            .Replace("#", "sharp")
            .Replace(" y ", "-")
            .Replace(" ", "-");
    }
}

----------------------------
HTML 
----------------------------
<div class="category-card__icon-container is-@GetCategorySlug()">
    <Icon Name="@Category.Icon" />
</div>


