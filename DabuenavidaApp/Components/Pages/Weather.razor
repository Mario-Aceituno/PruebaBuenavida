@page "/lotes"
@layout LotesLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using LotesApp.Models
@using LotesApp.Services
@using Microsoft.Extensions.Options
@using LotesApp.Frontend.Toast
@using LotesApp.Frontend.Modals
@using LotesApp.Frontend.Cards
@using LotesApp.Frontend.Panels
@using LotesApp.Frontend.Sections
@inject LoteService LoteService
@inject IOptions<LotesConfig> Config
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject AuthService AuthService
@implements IDisposable

<PageTitle>Gestión de Lotes - Cronogramas de Pago</PageTitle>

<div class="lotes-page">
    <LotesApp.Frontend.Navbars.BatchManagementNav />
    <div class="lotes-content">

        <!-- ENCABEZADO -->
        <div class="lotes-page-header">
            <h1>Lotes de archivos</h1>
            @* <p>Generación de cronogramas de pago desde AS400 · API: @Config.Value.ApiBaseUrl</p> *@
        </div>

        <!-- PANEL DE ACCIÓN PRINCIPAL -->
        <AccionesPanel IsLoading="isLoading"
                       IsRefreshing="isRefreshing"
                       HayGeneracionEnProgreso="hayGeneracionEnProgreso"
                       OnRefrescar="RefrescarEstado"
                       OnGenerar="IniciarGeneracion" />

        <!-- PANEL DE PROGRESO EN VIVO (solo si hay tarea activa) -->
        @if (loteActual != null)
        {
            <ProgresoPanel Lote="loteActual"
                           HayGeneracionEnProgreso="hayGeneracionEnProgreso"
                           IsEnviando="isEnviando"
                           RutaDestino="@Config.Value.RutaDestino"
                           OnEnviarClick="() => AbrirModalEnvio(loteActual)"
                           OnDescargarArchivo="DescargarArchivo" />
        }

        <!-- HISTORIAL DE LOTES (desde /listar) -->
        <HistorialSection IsLoading="isLoading"
                           ErrorMessage="errorMessage"
                           Archivos="archivosHistorial"
                           OnCardClick="(batch) => Nav.NavigateTo($"/cronogramas/{batch.NombreLote}")"
                           OnDescargar="DescargarArchivo" />

        <!-- TOAST -->
        <LoteToast Message="@toastMessage"
                   Type="@toastType"
                   OnClose="() => toastMessage = null" />

        <!-- MODAL DE CONFIRMACIÓN DE ENVÍO -->
        <EnvioLoteModal Lote="loteParaEnviar"
                         RutaDestinoPlaceholder="@Config.Value.RutaDestino"
                         @bind-RutaDestinoOverride="rutaDestinoOverride"
                         IsEnviando="isEnviando"
                         OnCancel="CancelarEnvio"
                         OnConfirm="EjecutarEnvio" />
    </div>
</div>

