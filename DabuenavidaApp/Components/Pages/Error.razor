@using ManageAdminDMS_UI.Models
@using ManageAdminDMS_UI.Services
@inject DabuenavidaService ServicioDabuenavida

<div class="dab-filters">
    <div class="dab-filters__header">
        <span class="dab-filters__title">CRITERIOS DE BÚSQUEDA</span>
    </div>
    <div>
        <div class="dab-filters__body">
            @if (Permisos.MostrarCentroDeCosto)
            {
                <div class="dab-filters__group">
                    <label class="dab-filters__label">CENTRO DE COSTO</label>
                    <div class="dab-filters__input-wrapper @(_errorCentro != "" ? "dab-filters__input-wrapper--error" : "")">
                        <input class="dab-filters__input"
                               value="@Filtros.CentroDeCosto"
                               @oninput="OnCentroDeCostoInput"
                               maxlength="3"
                               placeholder="Ej: 001" />
                    </div>
                    <div class="dab-filters__feedback-wrapper">
                        @if (_errorCentro != "")
                        {
                            <span class="dab-filters__error">
                                <span class="dab-filters__error-icon">⚠</span>
                                @_errorCentro
                            </span>
                        }
                        <span class="dab-filters__counter @(Filtros.CentroDeCosto?.Length == 3 ? "dab-filters__counter--ok" : "")">
                            @(Filtros.CentroDeCosto?.Length ?? 0)/3
                        </span>
                    </div>
                </div>
            }

            <div class="dab-filters__group dab-filters__group--wide">
                <label class="dab-filters__label">BUSCAR POR DNI O N° DABUENAVIDA</label>
                <div class="dab-filters__input-wrapper @(_errorTexto != "" ? "dab-filters__input-wrapper--error" : _textoValido ? "dab-filters__input-wrapper--ok" : "")">
                    <span class="dab-filters__input-icon">🔍</span>
                    <input class="dab-filters__input"
                           value="@Filtros.TextoBusqueda"
                           @oninput="OnTextoBusquedaInput"
                           @onkeydown="@(async e => { if (e.Key == "Enter" && _textoValido) await OnBuscar.InvokeAsync(); })"
                           maxlength="@MaxLegthTexto"
                           placeholder="@PlaceholderTexto" />
                    @if (_textoValido)
                    {
                        <span class="dab-filters__valid-icon">✓</span>
                    }
                </div>
                <div class="dab-filters__feedback-wrapper">
                    @if (_errorTexto != "")
                    {
                        <span class="dab-filters__error">
                            <span class="dab-filters__error-icon">⚠</span>
                            @_errorTexto
                        </span>
                    }
                    else if (_textoValido)
                    {
                        <span class="dab-filters__success">
                            @_tipoTexto
                        </span>
                    }
                    @* AQUÍ SE MODIFICÓ: Cambiado /13 estático por /@MaxLegthTexto *@
                    <span class="dab-filters__counter @(_textoValido ? "dab-filters__counter--ok" : "")">
                        @(Filtros.TextoBusqueda?.Length ?? 0)/@MaxLegthTexto
                    </span>
                </div>
            </div>

            <div class="dab-filters__actions">
                <button class="dab-filters__btn dab-filters__btn--limpiar"
                        @onclick="HandleLimpiar">
                    Limpiar
                </button>
                <button class="dab-filters__btn dab-filters__btn--buscar"
                        @onclick="OnBuscar"
                        disabled="@(!EsFormularioValido())">
                    Buscar
                </button>
            </div>

        </div>
    </div>
</div>


_-------------

using ManageAdminDMS_UI.Models;
using Microsoft.AspNetCore.Components;
using Microsoft.Extensions.Configuration; // Asegúrate de incluir este namespace

namespace ManageAdminDMS_UI.Components.FrontendComponents.Filters
{
    public partial class DabuenavidaFilters
    {
        // Inyectamos IConfiguration para acceder al appsettings.json
        [Inject] private IConfiguration Configuration { get; set; }

        [Parameter] public FiltrosBusqueda Filtros { get; set; } = new();
        [Parameter] public EventCallback OnBuscar { get; set; }
        [Parameter] public EventCallback OnLimpiar { get; set; }
        [Parameter] public string Token { get; set; } = "";
        [Parameter]
        public FiltrosPermisosDto Permisos { get; set; } = new()
        {
            MostrarCentroDeCosto = true,
            MostrarDabuenavida = true,
            PermitirBusquedaDni = true
        };

        private string _errorCentro = "";
        private string _errorTexto = "";
        private bool _textoValido = false;
        private string _tipoTexto = "";

        // Propiedades dinámicas que leen desde appsettings con valores por defecto (fallback) por seguridad
        private int MaxLengthDni => 13;
        private int MaxLengthDabuenavida => 10;

        private int MaxLegthTexto => Permisos.PermitirBusquedaDni ? 13 : 10;

        private string PlaceholderTexto => Permisos.PermitirBusquedaDni
            ? $"Ingrese Dabuenavida ({MaxLengthDabuenavida} dígitos) o N# DNI ({MaxLengthDni} dígitos)..."
            : $"Ingrese N# Dabuenavida ({MaxLengthDabuenavida} dígitos)";

        private void OnCentroDeCostoInput(ChangeEventArgs e)
        {
            var raw = e.Value?.ToString() ?? "";
            var limpio = System.Text.RegularExpressions.Regex.Replace(raw, @"[^0-9]", "");

            if (limpio.Length > 3)
                limpio = limpio[..3];

            Filtros.CentroDeCosto = limpio;

            _errorCentro = limpio.Length switch
            {
                0 => "",
                3 => "",
                _ => $"El centro de costo debe tener exactamente 3 dígitos ({limpio.Length}/3)."
            };
        }

        private void OnTextoBusquedaInput(ChangeEventArgs e)
        {
            var raw = e.Value?.ToString() ?? "";
            var limpio = System.Text.RegularExpressions.Regex.Replace(raw, @"[^0-9]", "");

            if (limpio.Length > MaxLegthTexto)
                limpio = limpio[..MaxLegthTexto];

            Filtros.TextoBusqueda = limpio;
            _textoValido = false;
            _tipoTexto = "";

            // Validación adaptada a los parámetros configurados
            _errorTexto = limpio.Length switch
            {
                0 => "",
                var l when l == MaxLengthDabuenavida => "",
                var l when l == MaxLengthDni && Permisos.PermitirBusquedaDni => "",
                var l when l < MaxLengthDabuenavida => $"Mínimo {MaxLengthDabuenavida} dígitos para Dabuenavida ({l}/{MaxLengthDabuenavida}).",
                _ when !Permisos.PermitirBusquedaDni => $"Solo puede buscar por N# Dabuenavida ({MaxLengthDabuenavida}) dígitos",
                _ => $"Longitud inválida. Use {MaxLengthDabuenavida} dígitos (N Dabuenavida) o {MaxLengthDni} dígitos (Dni)."
            };

            if (limpio.Length == MaxLengthDabuenavida)
            {
                _textoValido = true;
                _tipoTexto = "✓ N° Dabuenavida válido";
            }
            else if (limpio.Length == MaxLengthDni && Permisos.PermitirBusquedaDni)
            {
                _textoValido = true;
                _tipoTexto = "✓ DNI válido";
            }
        }

        private bool EsFormularioValido()
        {
            var centroOk = string.IsNullOrEmpty(Filtros.CentroDeCosto) || Filtros.CentroDeCosto.Length == 3;
            var textoOk = string.IsNullOrEmpty(Filtros.TextoBusqueda) || _textoValido;
            var algoIngresado = !string.IsNullOrEmpty(Filtros.CentroDeCosto) || !string.IsNullOrEmpty(Filtros.TextoBusqueda);

            return centroOk && textoOk && algoIngresado &&
                   string.IsNullOrEmpty(_errorCentro) &&
                   string.IsNullOrEmpty(_errorTexto);
        }

        private async Task HandleLimpiar()
        {
            Filtros.TextoBusqueda = "";
            Filtros.CentroDeCosto = "";
            _errorCentro = "";
            _errorTexto = "";
            _textoValido = false;
            _tipoTexto = "";
            await OnLimpiar.InvokeAsync();
        }
    }
}