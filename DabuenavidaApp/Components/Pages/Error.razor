@using ManageAdminDMS_UI.Models
@using ManageAdminDMS_UI.Services
@inject DabuenavidaService ServicioDabuenavida

<div class="dab-filters">
    <div class="dab-filters__header">
        <span class="dab-filters__title">CRITERIOS DE BÚSQUEDA</span>
    </div>
    <div>
        <div class="dab-filters__body">

            @* CENTRO DE COSTO *@
            @if (Permisos.MostrarCentroDeCosto)
            {
                <div class="dab-filters__group">
                    <label class="dab-filters__label">CENTRO DE COSTO</label>
                    <div class="dab-filters__input-wrapper @(_errorCentro != "" ? "dab-filters__input-wrapper--error" : "")">
                        <input class="dab-filters__input"
                               value="@textoCentro"
                               @oninput="OnCentroDeCostoInput"
                               @onfocus="MostrarLista"
                               @onblur="OcultarLista"
                               placeholder="Buscar o seleccionar centro de costo..." />
                    </div>

                    @if (mostrarLista && centrosFiltrados.Any())
                    {
                        <div class="dab-filters__dropdown">
                            @foreach (var centro in centrosFiltrados)
                            {
                                <div class="dab-filters__dropdown-item"
                                     @onmousedown="() => SeleccionarCentro(centro)">
                                    @centro.Display
                                </div>
                            }
                        </div>
                    }

                    <div class="dab-filters__feedback-wrapper">
                        @if (_errorCentro != "")
                        {
                            <span class="dab-filters__error">
                                <span class="dab-filters__error-icon">⚠</span>
                                @_errorCentro
                            </span>
                        }
                        <span class="dab-filters__counter @(Filtros.CentroDeCosto?.Length == MaxLengthCentroCosto ? "dab-filters__counter--ok" : "")">
                            @(Filtros.CentroDeCosto?.Length ?? 0)/@MaxLengthCentroCosto
                        </span>
                    </div>
                </div>
            }

            @* BUSCAR POR DNI O N° DABUENAVIDA *@
            <div class="dab-filters__group dab-filters__group--wide">
                <label class="dab-filters__label">BUSCAR POR DNI O N° DABUENAVIDA</label>
                <div class="dab-filters__input-wrapper @(_errorTexto != "" ? "dab-filters__input-wrapper--error" : _textoValido ? "dab-filters__input-wrapper--ok" : "")">
                    <span class="dab-filters__input-icon">🔍</span>
                    <input class="dab-filters__input"
                           value="@Filtros.TextoBusqueda"
                           @oninput="OnTextoBusquedaInput"
                           @onkeydown="@(async e => { if (e.Key == "Enter" && _textoValido) await OnBuscar.InvokeAsync(); })"
                           maxlength="@MaxLegthTexto"
                           placeholder="@PlaceholderTexto" />
                    @if (_textoValido)
                    {
                        <span class="dab-filters__valid-icon">✓</span>
                    }
                </div>
                <div class="dab-filters__feedback-wrapper">
                    @if (_errorTexto != "")
                    {
                        <span class="dab-filters__error">
                            <span class="dab-filters__error-icon">⚠</span>
                            @_errorTexto
                        </span>
                    }
                    else if (_textoValido)
                    {
                        <span class="dab-filters__success">@(_tipoTexto)</span>
                    }
                    <span class="dab-filters__counter @(_textoValido ? "dab-filters__counter--ok" : "")">
                        @(Filtros.TextoBusqueda?.Length ?? 0)/@MaxLegthTexto
                    </span>
                </div>
            </div>

            @* BOTONES *@
            <div class="dab-filters__actions">
                <button class="dab-filters__btn dab-filters__btn--limpiar"
                        @onclick="HandleLimpiar">
                    Limpiar
                </button>
                <button class="dab-filters__btn dab-filters__btn--buscar"
                        @onclick="OnBuscar"
                        disabled="@(!EsFormularioValido())">
                    Buscar
                </button>
            </div>

        </div>
    </div>
</div>



