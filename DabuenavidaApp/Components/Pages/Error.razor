using ConfigLoader;
using Dapper;
using Microservices.Models;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using System.Data.Odbc;
using System.Text;

namespace Microservices.Controllers
{
    [ApiController]
    [Route("api/[controller]")]
    [Authorize]
    public class DaBuenaVidaController : ControllerBase
    {
        private readonly ILogger<DaBuenaVidaController> _logger;
        private readonly IConfigManager _configManager;

        public DaBuenaVidaController(ILogger<DaBuenaVidaController> logger, IConfigManager configManager)
        {
            _logger = logger;
            _configManager = configManager;
        }

        // — Método privado que construye la conexión ODBC —
        // Centraliza la lógica en un solo lugar. Si cambian las credenciales
        // o el driver, solo se toca aquí.
        private string BuildConnectionString()
        {
            string driver = _configManager.GetString("AS400ODBC.driver");
            string server = _configManager.GetString("AS400ODBC.server");
            string uid    = DecryptBase64(_configManager.GetString("AS400ODBC.user"));
            string pwd    = DecryptBase64(_configManager.GetString("AS400ODBC.password"));
            string port   = _configManager.GetString("AS400ODBC.port");

            _logger.LogWarning("DEBUG ODBC => Driver=[{0}], Server=[{1}], Port=[{2}]", driver, server, port);

            return $"Driver={{{driver}}};System={server};Uid={uid};Pwd={pwd};Port={port};";
        }

        /// <summary>
        /// Consulta paginada de registros DaBuenaVida con filtros opcionales.
        /// JOIN entre BCAH96DTA.TTLC001 (Titulos) y BNKPRD01.CUP00301 (Clientes).
        /// </summary>
        [HttpPost("consulta")]
        public async Task<IActionResult> ConsultarDaBuenaVida([FromBody] DaBuenaVidaRequest request)
        {
            try
            {
                var rol = User.Claims.FirstOrDefault(c => c.Type == "rol")?.Value ?? "";

                if (rol == "Analista Programador" && !string.IsNullOrEmpty(request.DniIdentidad))
                {
                    Console.WriteLine($"[Seguridad] Asesor intentó buscar por DNI");
                    return StatusCode(403, "No tienes permisos para buscar por dni");
                }

                _logger.LogInformation("Inicio de consulta DaBuenaVida.");

                var connectionString = BuildConnectionString();

                double timeoutMs = _configManager.GetDouble("token");
                using var cts = new CancellationTokenSource(
                    TimeSpan.FromMilliseconds(timeoutMs > 0 ? timeoutMs : 30000));

                // — Construir filtros dinámicos —
                var parameters   = new DynamicParameters();
                var whereClause  = new StringBuilder("WHERE 1=1");

                if (!string.IsNullOrWhiteSpace(request.NumeroDaBuenaVida))
                {
                    whereClause.Append(" AND T.TTLCCTA = ?");
                    parameters.Add("NumeroDaBuenaVida", decimal.Parse(request.NumeroDaBuenaVida));
                }

                if (!string.IsNullOrWhiteSpace(request.DniIdentidad))
                {
                    whereClause.Append(" AND TRIM(C.CUNTID) = ?");
                    parameters.Add("DniIdentidad", request.DniIdentidad.Trim());
                }

                if (!string.IsNullOrWhiteSpace(request.CentroDeCosto))
                {
                    whereClause.Append(" AND T.TTLCCC = ?");
                    parameters.Add("CentroDeCosto", decimal.Parse(request.CentroDeCosto));
                }

                // — Paginación —
                int pageSize   = request.PageSize > 0 ? Math.Min(request.PageSize, 100) : 20;
                int pageNumber = request.PageNumber > 0 ? request.PageNumber : 1;
                int offset     = (pageNumber - 1) * pageSize;

                // — SQL: Conteo total —
                string countSql = $@"
                    SELECT CAST(COUNT(*) AS INTEGER)
                    FROM BCAH96DTA.TTLC001 T
                    INNER JOIN BNKPRD01.CUP00301 C
                        ON TRIM(T.TTLCCIF) = TRIM(C.CUNBR)
                    LEFT JOIN BNKPRD01.CFP102 CC
                        ON T.TTLCCC = CC.CFBRCH
                    {whereClause}";

                // — SQL: Datos paginados —
                string dataSql = $@"
                    SELECT * FROM (
                        SELECT
                            T.TTLCCTA,
                            T.TTLCFAP,
                            T.TTLCFVEN,
                            T.TTLCSTAT,
                            T.TTLCMNT,
                            T.TTLCCC,
                            T.TTLCCANT,
                            C.CUNA1,
                            C.CUNTID,
                            CC.CFBRCH,
                            CC.CFBRNM,
                            CAST(ROW_NUMBER() OVER(ORDER BY T.TTLCCTA) AS INTEGER) AS ROWNUM
                        FROM BCAH96DTA.TTLC001 T
                        INNER JOIN BNKPRD01.CUP00301 C
                            ON TRIM(T.TTLCCIF) = TRIM(C.CUNBR)
                        LEFT JOIN BNKPRD01.CFP102 CC
                            ON T.TTLCCC = CC.CFBRCH
                        {whereClause}
                    ) AS RESULT
                    WHERE ROWNUM BETWEEN {offset + 1} AND {offset + pageSize}";

                // — Ejecutar consultas —
                int totalRegistros;
                List<DaBuenaVidaDto> registros;

                using (var db = new OdbcConnection(connectionString))
                {
                    await db.OpenAsync(cts.Token);
                    totalRegistros = await db.ExecuteScalarAsync<int>(countSql, parameters);
                    var result     = await db.QueryAsync<DaBuenaVidaDto>(dataSql, parameters);
                    registros      = result.ToList();
                }

                int totalPaginas = totalRegistros > 0
                    ? (int)Math.Ceiling((double)totalRegistros / pageSize)
                    : 0;

                // — Construir Response —
                var response = new DaBuenaVidaResponse
                {
                    TotalRegistros = totalRegistros,
                    PaginaActual   = pageNumber,
                    TotalPaginas   = totalPaginas
                };

                if (!registros.Any())
                {
                    response.MsgRespuesta = "NO HAY REGISTROS PARA ESTA CONSULTA";
                    return Ok(response);
                }

                foreach (var item in registros)
                {
                    var detalle = new DaBuenaVidaDetalleDto
                    {
                        NumeroDaBuenaVida = item.TTLCCTA.ToString("F0"),
                        NombreCliente     = item.CUNA1?.Trim() ?? string.Empty,
                        DniIdentidad      = item.CUNTID?.Trim() ?? string.Empty,
                        CentroDeCosto     = $"{item.TTLCCC.ToString("F0")} - {item.CFBRNM?.Trim() ?? "Sin Nombre"}",
                        FechaCreacion     = FormatearFechaDb2(item.TTLCFAP),
                        FechaVencimiento  = FormatearFechaDb2(item.TTLCFVEN),
                        ValorDab          = $"L {item.TTLCMNT:N2}",
                        NumeroTitulos     = (int)item.TTLCCANT,
                        EstadoImpresion   = item.TTLCSTAT?.Trim() ?? string.Empty
                    };

                    response.Registros.Add(detalle);
                }

                _logger.LogInformation(
                    "Consulta DaBuenaVida completada: {Total} registros, página {Page}/{Pages}.",
                    totalRegistros, pageNumber, totalPaginas);

                return Ok(response);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error crítico en consulta DaBuenaVida: {Message}", ex.Message);
                return StatusCode(500, new { error = "Internal Server Error", detalle = ex.Message });
            }
        }

        /// <summary>
        /// Trae la lista de centros de costo disponibles desde CFP102.
        /// </summary>
        [HttpGet("centros-costo")]
        public async Task<IActionResult> ObtenerCentrosCosto()
        {
            try
            {
                var connectionString = BuildConnectionString();

                string sql = @"
                    SELECT
                        TRIM(CHAR(CFBRCH)) AS Codigo,
                        TRIM(CFBRNM)       AS Nombre
                    FROM BNKPRD01.CFP102
                    ORDER BY CFBRCH";

                using var db = new OdbcConnection(connectionString);
                var result   = await db.QueryAsync<CentroCostoDto>(sql);

                return Ok(result.ToList());
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error al obtener centros de costo");
                return StatusCode(500, new { error = ex.Message });
            }
        }

        /// <summary>
        /// Convierte fecha DB2 formato yyyyMMdd a dd/MM/yyyy.
        /// </summary>
        private static string FormatearFechaDb2(string? fechaDb2)
        {
            if (string.IsNullOrWhiteSpace(fechaDb2) || fechaDb2.Length != 8)
                return string.Empty;

            return $"{fechaDb2[6..8]}/{fechaDb2[4..6]}/{fechaDb2[..4]}";
        }

        /// <summary>
        /// Decodifica credenciales almacenadas en Base64.
        /// </summary>
        private static string DecryptBase64(string value)
        {
            if (string.IsNullOrEmpty(value)) return string.Empty;
            byte[] bytes = Convert.FromBase64String(value);
            return Encoding.UTF8.GetString(bytes);
        }
    }
}