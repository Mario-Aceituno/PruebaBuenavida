/* ── Contenedor principal ── */
.dab-filters {
    background-color: #ffffff;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    margin: 20px 24px 0 24px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
}

/* ── Header ── */
.dab-filters__header {
    padding: 10px 18px;
    border-bottom: 1px solid #f0f0f0;
    background-color: #fafafa;
    border-radius: 6px 6px 0 0;
}

.dab-filters__title {
    font-size: 10px;
    font-weight: 700;
    color: #888888;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

/* ── Body con los filtros ── */
.dab-filters__body {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 16px 18px 12px 18px;
    flex-wrap: wrap;
}

/* ── Grupos de filtro ── */
.dab-filters__group {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
    min-width: 220px;
    position: relative;
}

.dab-filters__group--wide {
    flex: 2;
    min-width: 300px;
}

/* ── Labels ── */
.dab-filters__label {
    font-size: 10px;
    font-weight: 700;
    color: #666666;
    letter-spacing: 1px;
    text-transform: uppercase;
}

/* ── Input wrapper ── */
.dab-filters__input-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid #d9d9d9;
    border-radius: 4px;
    background-color: white;
    height: 40px;
    padding: 0 12px;
    gap: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.dab-filters__input-wrapper:focus-within {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.10);
}

.dab-filters__input-wrapper--error {
    border-color: #c0392b !important;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.10);
}

.dab-filters__input-wrapper--ok {
    border-color: #27ae60 !important;
    box-shadow: 0 0 0 3px rgba(39, 174, 96, 0.10);
}

/* ── Inputs ── */
.dab-filters__input {
    border: none;
    outline: none;
    font-size: 13px;
    color: #444444;
    width: 100%;
    background: transparent;
}

.dab-filters__input::placeholder {
    color: #bbbbbb;
}

/* ── Input de búsqueda de centro de costo (standalone sin wrapper) ── */
.dab-filters__input-search {
    padding: 0 12px;
    border: 1px solid #d9d9d9;
    border-radius: 4px;
    font-size: 13px;
    color: #444444;
    background-color: white;
    height: 40px;
    width: 100%;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
}

.dab-filters__input-search:focus {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.10);
}

/* ── Íconos dentro del input ── */
.dab-filters__input-icon {
    font-size: 14px;
    color: #aaaaaa;
    flex-shrink: 0;
}

.dab-filters__valid-icon {
    font-size: 15px;
    color: #27ae60;
    font-weight: bold;
    flex-shrink: 0;
}

/* ── Dropdown de centros de costo ── */
.dab-filters__dropdown {
    position: absolute;
    top: calc(100% - 22px);
    left: 0;
    right: 0;
    background: white;
    border: 1px solid #d9d9d9;
    border-top: none;
    border-radius: 0 0 4px 4px;
    max-height: 200px;
    overflow-y: auto;
    z-index: 200;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.10);
}

.dab-filters__dropdown-item {
    padding: 9px 12px;
    font-size: 13px;
    color: #444444;
    cursor: pointer;
    border-bottom: 1px solid #f5f5f5;
    transition: background-color 0.15s;
}

.dab-filters__dropdown-item:last-child {
    border-bottom: none;
}

.dab-filters__dropdown-item:hover {
    background-color: #fff0f0;
    color: #c0392b;
}

/* ── Feedback (errores, éxito, contador) ── */
.dab-filters__feedback-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 18px;
    padding: 0 2px;
}

.dab-filters__error {
    font-size: 11px;
    color: #c0392b;
    display: flex;
    align-items: center;
    gap: 4px;
}

.dab-filters__error-icon {
    font-size: 11px;
}

.dab-filters__success {
    font-size: 11px;
    color: #27ae60;
    font-weight: 600;
}

.dab-filters__counter {
    font-size: 11px;
    color: #bbbbbb;
    margin-left: auto;
}

.dab-filters__counter--ok {
    color: #27ae60;
    font-weight: 600;
}

/* ── Botones ── */
.dab-filters__actions {
    display: flex;
    gap: 8px;
    align-items: flex-end;
    padding-bottom: 24px;
    flex-shrink: 0;
}

.dab-filters__btn {
    height: 40px;
    padding: 0 22px;
    border: none;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s, box-shadow 0.2s;
    white-space: nowrap;
}

.dab-filters__btn--buscar {
    background-color: #c0392b;
    color: white;
    box-shadow: 0 2px 4px rgba(192, 57, 43, 0.30);
}

.dab-filters__btn--buscar:hover:not(:disabled) {
    background-color: #a93226;
    box-shadow: 0 3px 8px rgba(192, 57, 43, 0.35);
}

.dab-filters__btn--buscar:disabled {
    background-color: #e8a89e;
    box-shadow: none;
    cursor: not-allowed;
}

.dab-filters__btn--limpiar {
    background-color: #ffffff;
    color: #555555;
    border: 1px solid #d9d9d9;
}

.dab-filters__btn--limpiar:hover {
    background-color: #f5f5f5;
}

/* ── Responsive ── */
@media (max-width: 768px) {
    .dab-filters {
        margin: 16px 16px 0 16px;
    }

    .dab-filters__body {
        flex-direction: column;
        align-items: stretch;
    }

    .dab-filters__group,
    .dab-filters__group--wide {
        min-width: unset;
        width: 100%;
    }

    .dab-filters__actions {
        width: 100%;
        justify-content: flex-end;
        padding-bottom: 0;
    }
}