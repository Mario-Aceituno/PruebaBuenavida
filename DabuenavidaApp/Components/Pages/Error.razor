using ManageAdminDMS_UI.Models;
using Microsoft.AspNetCore.Components;
using Microsoft.Extensions.Configuration;

namespace ManageAdminDMS_UI.Components.FrontendComponents.Filters
{
    public partial class DabuenavidaFilters
    {
        [Inject] private IConfiguration Configuration { get; set; } = default!;

        [Parameter] public FiltrosBusqueda Filtros { get; set; } = new();
        [Parameter] public EventCallback OnBuscar { get; set; }
        [Parameter] public EventCallback OnLimpiar { get; set; }
        [Parameter] public string Token { get; set; } = "";
        [Parameter] public FiltrosPermisosDto Permisos { get; set; } = new()
        {
            MostrarCentroDeCosto = true,
            MostrarDabuenavida = true,
            PermitirBusquedaDni = true
        };

        // — Centro de costo —
        private List<CentroCostoDto> centros = new();
        private List<CentroCostoDto> centrosFiltrados = new();
        private string textoCentro = "";
        private bool mostrarLista = false;

        // — Validaciones —
        private string _errorCentro = "";
        private string _errorTexto = "";
        private bool _textoValido = false;
        private string _tipoTexto = "";

        // — Longitudes parametrizadas desde appsettings —
        private int MaxLengthDni => 13;
        private int MaxLengthDabuenavida => 10;
        private int MaxLengthCentroCosto => 3;

        private int MaxLegthTexto =>
            Permisos.PermitirBusquedaDni ? 13 : 10;

        private string PlaceholderTexto =>
            Permisos.PermitirBusquedaDni
                ? $"Ingrese Dabuenavida ({MaxLengthDabuenavida} dígitos) o N# DNI ({MaxLengthDni} dígitos)..."
                : $"Ingrese N# Dabuenavida ({MaxLengthDabuenavida} dígitos)";

        protected override async Task OnInitializedAsync()
        {
            centros = await ServicioDabuenavida.ObtenerCentrosCostoAsync(Token);
            centrosFiltrados = centros;
        }

        // — Centro de costo —

        private void OnCentroDeCostoInput(ChangeEventArgs e)
        {
            textoCentro = e.Value?.ToString() ?? "";
            Filtros.CentroDeCosto = "";
            _errorCentro = "";
            FiltrarCentros();
            mostrarLista = true;
            StateHasChanged();
        }

        private void MostrarLista()
        {
            FiltrarCentros();
            mostrarLista = true;
            StateHasChanged();
        }

        private void OcultarLista()
        {
            Task.Delay(200).ContinueWith(_ =>
            {
                mostrarLista = false;
                InvokeAsync(StateHasChanged);
            });
        }

        private void FiltrarCentros()
        {
            centrosFiltrados = string.IsNullOrWhiteSpace(textoCentro)
                ? centros
                : centros.Where(c => c.Display.Contains(textoCentro,
                    StringComparison.OrdinalIgnoreCase)).ToList();
        }

        private void SeleccionarCentro(CentroCostoDto centro)
        {
            textoCentro = centro.Display;
            Filtros.CentroDeCosto = centro.Codigo;
            _errorCentro = "";
            mostrarLista = false;
            StateHasChanged();
        }

        // — Texto búsqueda —

        private void OnTextoBusquedaInput(ChangeEventArgs e)
        {
            var raw = e.Value?.ToString() ?? "";
            var limpio = System.Text.RegularExpressions.Regex
                .Replace(raw, @"[^0-9]", "");

            if (limpio.Length > MaxLegthTexto)
                limpio = limpio[..MaxLegthTexto];

            Filtros.TextoBusqueda = limpio;
            _textoValido = false;
            _tipoTexto = "";

            _errorTexto = limpio.Length switch
            {
                0 => "",
                var l when l == MaxLengthDabuenavida => "",
                var l when l == MaxLengthDni && Permisos.PermitirBusquedaDni => "",
                var l when l < MaxLengthDabuenavida =>
                    $"Mínimo {MaxLengthDabuenavida} dígitos para Dabuenavida ({l}/{MaxLengthDabuenavida}).",
                _ when !Permisos.PermitirBusquedaDni =>
                    $"Solo puede buscar por N# Dabuenavida ({MaxLengthDabuenavida}) dígitos",
                _ => $"Longitud inválida. Use {MaxLengthDabuenavida} dígitos (N Dabuenavida) o {MaxLengthDni} dígitos (Dni)."
            };

            if (limpio.Length == MaxLengthDabuenavida)
            {
                _textoValido = true;
                _tipoTexto = "✓ N° Dabuenavida válido";
            }
            else if (limpio.Length == MaxLengthDni && Permisos.PermitirBusquedaDni)
            {
                _textoValido = true;
                _tipoTexto = "✓ DNI válido";
            }
        }

        // — Validación general —

        private bool EsFormularioValido()
        {
            var centroOk = string.IsNullOrEmpty(Filtros.CentroDeCosto) ||
                           Filtros.CentroDeCosto.Length == MaxLengthCentroCosto;
            var textoOk = string.IsNullOrEmpty(Filtros.TextoBusqueda) || _textoValido;
            var algoIngresado = !string.IsNullOrEmpty(Filtros.CentroDeCosto) ||
                                !string.IsNullOrEmpty(Filtros.TextoBusqueda);

            return centroOk && textoOk && algoIngresado &&
                   string.IsNullOrEmpty(_errorCentro) &&
                   string.IsNullOrEmpty(_errorTexto);
        }

        // — Limpiar —

        private async Task HandleLimpiar()
        {
            Filtros.TextoBusqueda = "";
            Filtros.CentroDeCosto = "";
            textoCentro = "";
            _errorCentro = "";
            _errorTexto = "";
            _textoValido = false;
            _tipoTexto = "";
            await OnLimpiar.InvokeAsync();
        }
    }
}

