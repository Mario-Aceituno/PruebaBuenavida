                        <TimelineStep Type="transfer" Actor="Juan Pérez" Time="14 jul, 13:20"
                                      AvatarColor="var(--inc-violet-500)" DelayMs="80"
                                      Description="Transfirió la incidencia indicando que el origen del problema está en la capa de infraestructura de red."
                                      ShowFlow="true" From="Desarrollo" FromIcon="cpu" To="Core" ToIcon="layers" Duration="4h activo" />

                        <TimelineStep Type="progress" Actor="María Gómez" Time="14 jul, 13:45"
                                      AvatarColor="var(--inc-warning-500)" DelayMs="160"
                                      Description="Tomó el caso y comenzó el diagnóstico del servicio de autenticación SSO." />

                        <TimelineStep Type="transfer" Actor="María Gómez" Time="14 jul, 21:50"
                                      AvatarColor="var(--inc-violet-500)" DelayMs="240"
                                      Description="Identificó que el problema está relacionado con la configuración del balanceador de carga."
                                      ShowFlow="true" From="Core" FromIcon="layers" To="Infraestructura" ToIcon="server" Duration="8h 05m activo" />

                        <TimelineStep Type="comment" Actor="Carlos Ruiz" Time="15 jul, 08:30"
                                      AvatarColor="var(--inc-n-500)" DelayMs="320"
                                      Description="Confirmó el diagnóstico y está aplicando un cambio de configuración en el balanceador principal." />
                    </div>
                </div>

                <!-- Tabs: Actividad / Comentarios / Archivos -->
                <div class="inc-card inc-card--pad-lg inc-anim-fade-up">
                    <div class="inc-tabs">
                        <button class="inc-tabs__btn @(activeTab == "comments" ? "inc-tabs__btn--active" : "")" @onclick='() => activeTab = "comments"'>
                            <IconSvg Name="message" /> Comentarios <span class="inc-tabs__badge">3</span>
                        </button>
                        <button class="inc-tabs__btn @(activeTab == "files" ? "inc-tabs__btn--active" : "")" @onclick='() => activeTab = "files"'>
                            <IconSvg Name="file" /> Archivos <span class="inc-tabs__badge">2</span>
                        </button>
                    </div>

                    @if (activeTab == "comments")
                    {
                        <div>
                            <div class="inc-comment">
                                <UserAvatar Name="Carlos Ruiz" Size="sm" />
                                <div class="inc-comment__body">
                                    <div class="inc-comment__head">
                                        <span class="inc-comment__author">Carlos Ruiz</span>
                                        <span class="inc-comment__time">hace 20m</span>
                                    </div>
                                    <div class="inc-comment__text">
                                        Aplicando el cambio de configuración en el balanceador. Estimamos resolución en los próximos 30 minutos.
                                    </div>
                                    <div class="inc-comment__actions">
                                        <span class="inc-comment__action"><IconSvg Name="message" /> Responder</span>
                                    </div>
                                </div>
                            </div>
                            <div class="inc-comment">
                                <UserAvatar Name="María Gómez" Size="sm" />
                                <div class="inc-comment__body">
                                    <div class="inc-comment__head">
                                        <span class="inc-comment__author">María Gómez</span>
                                        <span class="inc-comment__time">hace 11h</span>
                                    </div>
                                    <div class="inc-comment__text">
                                        Revisé los logs del servicio; el error apunta a un timeout en el balanceador de carga durante los handshakes SSO.
                                    </div>
                                    <div class="inc-comment__actions">
                                        <span class="inc-comment__action"><IconSvg Name="message" /> Responder</span>
                                    </div>
                                </div>
                            </div>
                            <div class="inc-comment">
                                <UserAvatar Name="Juan Pérez" Size="sm" />
                                <div class="inc-comment__body">
                                    <div class="inc-comment__head">
                                        <span class="inc-comment__author">Juan Pérez</span>
                                        <span class="inc-comment__time">hace 19h</span>
                                    </div>
                                    <div class="inc-comment__text">
                                        Confirmado con el equipo de finanzas: el 100% de sus usuarios están bloqueados desde las 09:00.
                                    </div>
                                    <div class="inc-comment__actions">
                                        <span class="inc-comment__action"><IconSvg Name="message" /> Responder</span>
                                    </div>
                                </div>
                            </div>

                            <div class="inc-composer">
                                <UserAvatar Name="Yo" Size="sm" />
                                <div class="inc-composer__box">
                                    <textarea class="inc-textarea" placeholder="Escribe un comentario..."></textarea>
                                    <div class="inc-composer__actions">
                                        <button class="inc-btn inc-btn--primary inc-btn--sm">Publicar comentario</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="display:flex; flex-direction:column; gap: var(--inc-s-3);">
                            <div class="inc-file-chip">
                                <div class="inc-file-chip__icon"><IconSvg Name="file" /></div>
                                <div style="flex:1;">
                                    <div class="inc-file-chip__name">logs-sso-14jul.txt</div>
                                    <div class="inc-file-chip__meta">248 KB · subido por María Gómez</div>
                                </div>
                            </div>
                            <div class="inc-file-chip">
                                <div class="inc-file-chip__icon"><IconSvg Name="file" /></div>
                                <div style="flex:1;">
                                    <div class="inc-file-chip__name">diagrama-balanceador.png</div>
                                    <div class="inc-file-chip__meta">1.1 MB · subido por Carlos Ruiz</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Columna lateral -->
            <div style="display:flex; flex-direction:column; gap: var(--inc-s-6);">

                <div class="inc-card inc-card--pad-md inc-anim-fade-up">
                    <SectionHeader Title="Acciones" Icon="layers" />
                    <ActionToolbar />
                </div>

                <div class="inc-card inc-card--pad-lg inc-anim-fade-up">
                    <SectionHeader Title="Artículos relacionados" Icon="book"
                                   Subtitle="Sugeridos según el contenido de la incidencia" />
                    <div style="display:flex; flex-direction:column; gap: 2px;">
                        <ArticleSuggestionCard Icon="book" Title="Configuración de SSO corporativo"
                                                Description="Guía paso a paso para configurar el proveedor de identidad." />
                        <ArticleSuggestionCard Icon="server" Title="Troubleshooting de balanceadores"
                                                Description="Checklist de diagnóstico ante caídas del servicio de balanceo." />
                        <ArticleSuggestionCard Icon="shield" Title="Política de accesos críticos"
                                                Description="Procedimiento de escalamiento para incidencias de seguridad." />
                    </div>
                </div>

                <div class="inc-card inc-card--pad-lg inc-anim-fade-up">
                    <SectionHeader Title="Historial de transferencias" Icon="repeat" />
                    <div class="inc-area-load">
                        <div class="inc-area-load__row">
                            <div class="inc-area-load__icon"><IconSvg Name="cpu" /></div>
                            <div class="inc-area-load__info">
                                <div class="inc-area-load__top">
                                    <span class="inc-area-load__name">Desarrollo</span>
                                    <span class="inc-area-load__count">4h 05m</span>
                                </div>
                            </div>
                        </div>
                        <div class="inc-area-load__row">
                            <div class="inc-area-load__icon"><IconSvg Name="layers" /></div>
                            <div class="inc-area-load__info">
                                <div class="inc-area-load__top">
                                    <span class="inc-area-load__name">Core</span>
                                    <span class="inc-area-load__count">8h 05m</span>
                                </div>
                            </div>
                        </div>
                        <div class="inc-area-load__row">
                            <div class="inc-area-load__icon"><IconSvg Name="server" /></div>
                            <div class="inc-area-load__info">
                                <div class="inc-area-load__top">
                                    <span class="inc-area-load__name">Infraestructura</span>
                                    <span class="inc-area-load__count">En curso</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<TransferModal @bind-IsOpen="transferOpen" IncidentId="@Id" IncidentTitle="Falla en autenticación SSO"
               CurrentArea="Infraestructura" CurrentAreaIcon="server" />

<ReactivateModal @bind-IsOpen="reactivateOpen" IncidentId="@Id" />

@code {
    [Parameter] public string Id { get; set; } = "INC-2041";

    private string activeTab = "comments";
