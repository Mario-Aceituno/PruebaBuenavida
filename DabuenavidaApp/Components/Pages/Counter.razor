CreateIncidentWizard.razor

@page "/incidencias/nueva"

<div class="inc-shell">
    <div class="inc-container">

        <div class="inc-pagehead inc-anim-fade-up">
            <div>
                <div class="inc-pagehead__eyebrow">
                    <IconSvg Name="plus" />
                    Nueva incidencia
                </div>
                <h1>Crear incidencia</h1>
                <p>Completa los siguientes pasos para registrar una nueva incidencia entre áreas de tecnología.</p>
            </div>
        </div>

        <div class="inc-wizard inc-anim-fade-up">

            <div class="inc-wizard-steps">
                @for (int i = 0; i < Steps.Count; i++)
                {
                    var index = i;
                    var state = index < currentStep ? "done" : index == currentStep ? "active" : "";
                    <div class="inc-wizard-step inc-wizard-step--@state">
                        <div class="inc-wizard-step__circle">
                            @if (index < currentStep)
                            {
                                <IconSvg Name="check-circle" />
                            }
                            else
                            {
                                @(index + 1)
                            }
                        </div>
                        <span class="inc-wizard-step__label">@Steps[index]</span>
                    </div>
                    @if (index < Steps.Count - 1)
                    {
                        <div class="inc-wizard-connector @(index < currentStep ? "inc-wizard-connector--done" : "")"></div>
                    }
                }
            </div>

            <div class="inc-card inc-wizard-panel">

                @if (currentStep == 0)
                {
                    <div class="inc-wizard-panel__head">
                        <h2>Información básica</h2>
                        <p>Describe brevemente el problema que estás reportando.</p>
                    </div>

                    <div style="display:flex; flex-direction:column; gap: var(--inc-s-5);">
                        <div>
                            <label class="inc-label">Título de la incidencia</label>
                            <input class="inc-input" type="text" placeholder="Ej. Falla en autenticación SSO" />
                        </div>
                        <div>
                            <label class="inc-label">Descripción</label>
                            <textarea class="inc-textarea" rows="5" placeholder="Describe el problema con el mayor detalle posible..."></textarea>
                        </div>
                        <div class="inc-wizard-field-grid">
                            <div>
                                <label class="inc-label">Prioridad</label>
                                <div class="inc-priority-select">
                                    @foreach (var p in Priorities)
                                    {
                                        <div class="inc-priority-option @(selectedPriority == p.Key ? "inc-priority-option--selected" : "")"
                                             style="color:@p.Color;" @onclick="() => selectedPriority = p.Key">
                                            <div class="inc-priority__bars"><span></span><span></span><span></span></div>
                                            <span class="inc-priority-option__label">@p.Label</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div>
                                <label class="inc-label">Categoría</label>
                                <select class="inc-select">
                                    <option>Falla de sistema</option>
                                    <option>Solicitud de acceso</option>
                                    <option>Rendimiento</option>
                                    <option>Seguridad</option>
                                </select>
                            </div>
                        </div>
                    </div>
                }
                else if (currentStep == 1)
                {
                    <div class="inc-wizard-panel__head">
                        <h2>Área afectada</h2>
                        <p>Selecciona el área de tecnología responsable de atender esta incidencia.</p>
                    </div>

                    <div class="inc-option-grid">
                        @foreach (var area in Areas)
                        {
                            <div class="inc-option-card @(selectedArea == area.Name ? "inc-option-card--selected" : "")"
                                 @onclick="() => selectedArea = area.Name">
                                <div class="inc-option-card__icon"><IconSvg Name="@area.Icon" /></div>
                                <span class="inc-option-card__title">@area.Name</span>
                                <span class="inc-option-card__desc">@area.Description</span>
                            </div>
                        }
                    </div>
                }
                else if (currentStep == 2)
                {
                    <div class="inc-wizard-panel__head">
                        <h2>Responsable</h2>
                        <p>Asigna un responsable dentro del área seleccionada, o deja que el sistema lo haga automáticamente.</p>
                    </div>

                    <div class="inc-responsible-list">
                        @foreach (var person in Responsibles)
                        {
                            <div class="inc-responsible-option @(selectedResponsible == person.Name ? "inc-responsible-option--selected" : "")"
                                 @onclick="() => selectedResponsible = person.Name">
                                <UserAvatar Name="@person.Name" Size="md" />
                                <div class="inc-responsible-option__info">
                                    <div class="inc-responsible-option__name">@person.Name</div>
                                    <div class="inc-responsible-option__role">@person.Role</div>
                                </div>
                                <span class="inc-responsible-option__load">@person.Load carga</span>
                                <div class="inc-responsible-option__check"><IconSvg Name="check-circle" /></div>
                            </div>
                        }
                    </div>
                }
                else if (currentStep == 3)
                {
                    <div class="inc-wizard-panel__head">
                        <div class="inc-success-check"><IconSvg Name="check-circle" /></div>
                        <h2>Confirma los datos</h2>
                        <p>Revisa la información antes de crear la incidencia.</p>
                    </div>

                    <div class="inc-summary-review">
                        <div class="inc-summary-row">
                            <span class="inc-summary-row__label">Título</span>
                            <span class="inc-summary-row__value">Falla en autenticación SSO</span>
                        </div>
                        <div class="inc-summary-row">
                            <span class="inc-summary-row__label">Prioridad</span>
                            <span class="inc-summary-row__value">@Priorities.First(p => p.Key == selectedPriority).Label</span>
                        </div>
                        <div class="inc-summary-row">
                            <span class="inc-summary-row__label">Área</span>
                            <span class="inc-summary-row__value">@selectedArea</span>
                        </div>
                        <div class="inc-summary-row">
                            <span class="inc-summary-row__label">Responsable</span>
                            <span class="inc-summary-row__value">@selectedResponsible</span>
                        </div>
                        <div class="inc-summary-row">
                            <span class="inc-summary-row__label">Fecha de creación</span>
                            <span class="inc-summary-row__value">@DateTime.Now.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                    </div>
                }

                <div class="inc-wizard-footer">
                    <span class="inc-wizard-footer__progress">Paso @(currentStep + 1) de @Steps.Count</span>
                    <div class="inc-flex inc-gap-3">
                        @if (currentStep > 0)
                        {
                            <button class="inc-btn inc-btn--secondary" @onclick="PrevStep">Atrás</button>
                        }
                        @if (currentStep < Steps.Count - 1)
                        {
                            <button class="inc-btn inc-btn--primary" @onclick="NextStep">
                                Continuar <IconSvg Name="arrow-right" />
                            </button>
                        }
                        else
                        {
                            <button class="inc-btn inc-btn--primary">
                                <IconSvg Name="check-circle" /> Crear incidencia
                            </button>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    private int currentStep = 0;
    private readonly List<string> Steps = new() { "Básico", "Área", "Responsable", "Confirmación" };

    private string selectedPriority = "alta";
    private string selectedArea = "Infraestructura";
    private string selectedResponsible = "Carlos Ruiz";

    private record PriorityOption(string Key, string Label, string Color);
    private readonly List<PriorityOption> Priorities = new()
    {
        new("critica", "Crítica", "var(--inc-danger-500)"),
        new("alta", "Alta", "var(--inc-warning-500)"),
        new("media", "Media", "var(--inc-info-500)"),
        new("baja", "Baja", "var(--inc-success-500)"),
    };

    private record AreaOption(string Name, string Icon, string Description);
    private readonly List<AreaOption> Areas = new()
    {
        new("Desarrollo", "cpu", "Aplicaciones y sistemas internos"),
        new("Core", "layers", "Plataforma y servicios base"),
        new("Infraestructura", "server", "Redes, servidores y despliegues"),
        new("Seguridad", "shield", "Accesos y protección de datos"),
    };

    private record ResponsibleOption(string Name, string Role, string Load);
    private readonly List<ResponsibleOption> Responsibles = new()
    {
        new("Carlos Ruiz", "Infraestructura", "Baja"),
        new("María Gómez", "Core Platform", "Media"),
        new("Juan Pérez", "Desarrollo", "Alta"),
        new("Ana Torres", "Seguridad", "Baja"),
    };

    private void NextStep() { if (currentStep < Steps.Count - 1) currentStep++; }
    private void PrevStep() { if (currentStep > 0) currentStep--; }
}

