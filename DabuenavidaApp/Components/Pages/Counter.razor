/* ---------- Journey stepper: nodo interactivo ---------- */
.journey-stepper__node {
    border: none;
    font: inherit;
    -webkit-appearance: none;
}

.journey-stepper__node--interactive {
    cursor: pointer;
    transition: box-shadow var(--transition-fast), transform var(--transition-fast);
}

    .journey-stepper__node--interactive:hover,
    .journey-stepper__node--interactive:focus-visible {
        box-shadow: 0 0 0 2px var(--bg-surface), 0 0 0 4px currentColor;
        transform: translateY(-1px);
        outline: none;
    }

/* ---------- Modal de área: personas involucradas ---------- */
.involved-users-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
}

.involved-user-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px 6px 6px;
    border-radius: var(--radius-full);
    background: var(--bg-surface-2);
}

.involved-user-chip__info {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
}

.involved-user-chip__name {
    font-size: var(--fs-xs);
    font-weight: 700;
    color: var(--text-primary);
}

.involved-user-chip__role {
    font-size: 10px;
    color: var(--text-tertiary);
}

<button type="button"
        class="journey-stepper__node journey-stepper__node--interactive"
        style="background:@ColorUtils.ToRgba(node.Color,0.12); color:@node.Color; @ringStyle"
        title="Ver participación de @node.AreaName"
        @onclick="() => OpenAreaModal(node.AreaName)">
    <span class="journey-stepper__icon" style="background:@node.Color;">
        <Icon Name="@node.Icon" Class="journey-stepper__icon-svg" />
    </span>
    @node.AreaName
</button>

<h4 class="widget__title" style="font-size:var(--fs-sm); margin-bottom:var(--space-2);">
    <Icon Name="users" /> Personas involucradas (@_selectedAreaInvolvedUsers.Count)
</h4>
@if (_selectedAreaInvolvedUsers.Count == 0)
{
    <p class="section-header__subtitle">No se identificaron personas específicas de este equipo en el historial.</p>
}
else
{
    <div class="involved-users-row">
        @foreach (var u in _selectedAreaInvolvedUsers)
        {
            <div class="involved-user-chip">
                <span class="avatar avatar--sm">@InitialsOf(u.FullName)</span>
                <span class="involved-user-chip__info">
                    <span class="involved-user-chip__name">@u.FullName</span>
                    <span class="involved-user-chip__role">@u.Role</span>
                </span>
            </div>
        }
    </div>
}


private void OpenAreaModal(string areaName)
{
    if (_detail is null) return;
    _selectedAreaName = areaName;

    var areaId = _areas.FirstOrDefault(a => a.Name == areaName)?.Id;
    var areaUsers = areaId.HasValue
        ? Incidents.GetUsersByArea(areaId.Value).ToList()
        : new List<IncidentUser>();
    var areaUserNames = areaUsers.Select(u => u.FullName).ToHashSet();

    var segs = _detail.TimeSegments.Where(s => s.AreaName == areaName).ToList();
    _selectedAreaActiveHours = Math.Round(segs.Where(s => s.IsActiveWork).Sum(s => s.DurationHours), 1);
    _selectedAreaDeadHours = Math.Round(segs.Where(s => !s.IsActiveWork).Sum(s => s.DurationHours), 1);

    _selectedAreaActivity = _detail.Activity.Where(a => areaUserNames.Contains(a.ActorName)).OrderByDescending(a => a.OccurredAt).ToList();
    _selectedAreaComments = _detail.Comments.Where(c => areaUserNames.Contains(c.AuthorName)).OrderByDescending(c => c.CreatedAt).ToList();
    _selectedAreaTransfers = _detail.Transfers.Where(t => t.FromAreaName == areaName || t.ToAreaName == areaName).OrderByDescending(t => t.TransferredAt).ToList();

    // Personas del equipo que efectivamente participaron: actuaron en el
    // historial, comentaron, o recibieron la incidencia por transferencia
    // hacia esta área. Mismo cruce por FullName que ya usa el resto del modal.
    var involvedNames = _selectedAreaActivity.Select(a => a.ActorName)
        .Concat(_selectedAreaComments.Select(c => c.AuthorName))
        .Concat(_selectedAreaTransfers.Where(t => t.ToAreaName == areaName).Select(t => t.ToUserName))
        .ToHashSet();

    _selectedAreaInvolvedUsers = areaUsers.Where(u => involvedNames.Contains(u.FullName)).ToList();

    _showAreaModal = true;
}

private static string InitialsOf(string fullName)
{
    var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    return string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
}