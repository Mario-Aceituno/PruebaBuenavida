                <div class="field-grid field-grid--3" style="margin-top:var(--space-4)">
                    <div class="meta-block">
                        <span class="meta-block__label">Categoría</span>
                        <span class="meta-block__value">@_incident.Category</span>
                    </div>
                    <div class="meta-block">
