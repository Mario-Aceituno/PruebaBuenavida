        public bool MaintenanceMode { get; set; }
        public bool AllowComments { get; set; }
        public bool AllowPublicRegistration { get; set; }
    }

    private class SystemStats
    {
        public int TotalArticles { get; set; }
        public int TotalCategories { get; set; }
        public int TotalTags { get; set; }
        public int TotalMediaFiles { get; set; }
        public int TotalAuthors { get; set; }
        public int TotalViews { get; set; }
    }

    private record RoleDef(string Name, string Description, int UserCount, string Icon, string Color, List<string> Permissions);
    private record PermissionDef(string Key, string Label);
    private record UserRow(string FullName, string Email, string Role, string Team, string LastSeen, bool Active, string Initials, string AvatarColor)
    {
        public bool Active { get; set; } = Active;
    }
    private record TeamMember(string Name, string Initials, string Color);
    private record TeamDef(string Name, string Description, string Icon, string Lead, string LeadInitials, string LeadColor, int OpenIncidents, List<TeamMember> Members);
    private record AuditRow(string Actor, string Action, string Time, string Icon, string Kind);
}






/* =========================================================================
   CorpWiki — Administración: Tabs, Usuarios, Roles, Equipos, Seguridad
   Extiende las clases ya existentes de modal-forms.css
   (.admin-grid, .admin-section, .switch, .admin-toggle-row, .admin-stat-grid)
   ========================================================================= */

@keyframes adminFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
}
.admin-fade-in { animation: adminFadeIn 0.25s ease both; }

/* ---------- Tabs ---------- */
.admin-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-subtle);
    overflow-x: auto;
}
.admin-tabs__btn {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: var(--space-3) var(--space-4);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text-tertiary);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    white-space: nowrap;
    transition: color var(--transition-fast), border-color var(--transition-fast);
}
.admin-tabs__btn .icon { width: 15px; height: 15px; }
.admin-tabs__btn:hover { color: var(--text-primary); }
.admin-tabs__btn--active { color: var(--brand-500); border-bottom-color: var(--brand-500); }
.admin-tabs__count {
    background: var(--bg-surface-3);
    color: var(--text-tertiary);
    font-size: 10px;
    font-weight: 800;
    padding: 1px 7px;
    border-radius: var(--radius-full);
}
.admin-tabs__btn--active .admin-tabs__count { background: rgba(218,31,61,0.12); color: var(--brand-500); }

/* ---------- Section head row (título + acción) ---------- */
.admin-section__head-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
}

/* ---------- Search row (Usuarios) ---------- */
.admin-search-row {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
}
.admin-search {
    position: relative;
    flex: 1;
    min-width: 220px;
}
.admin-search .icon {
    position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
    width: 15px; height: 15px; color: var(--text-tertiary);
}
.admin-search input {
    width: 100%; height: 40px;
    padding: 0 var(--space-4) 0 38px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-default);
    background: var(--bg-surface);
    font-size: var(--fs-sm);
    color: var(--text-primary);
}
.admin-search input:focus { outline: none; border-color: var(--brand-500); }
.admin-search__select { width: 220px; }

/* ---------- Table ---------- */
.admin-table-wrap { overflow-x: auto; }
.admin-table { width: 100%; border-collapse: collapse; }
.admin-table thead th {
    text-align: left;
    font-size: var(--fs-xs);
    font-weight: 700;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0 var(--space-3) var(--space-3);
    border-bottom: 1px solid var(--border-subtle);
}
.admin-table tbody td {
    padding: var(--space-3);
    border-bottom: 1px solid var(--border-subtle);
    font-size: var(--fs-sm);
    vertical-align: middle;
}
.admin-table tbody tr:last-child td { border-bottom: none; }
.admin-table tbody tr:hover { background: var(--bg-hover); }
.admin-table__muted { color: var(--text-tertiary); font-size: var(--fs-xs); }

.admin-user-cell { display: flex; align-items: center; gap: var(--space-3); }
.admin-user-cell__name { font-size: var(--fs-sm); font-weight: 700; color: var(--text-primary); }
.admin-user-cell__email { font-size: var(--fs-xs); color: var(--text-tertiary); }

.admin-status { display: inline-flex; align-items: center; gap: 6px; font-size: var(--fs-xs); font-weight: 700; }
.admin-status__dot { width: 7px; height: 7px; border-radius: 50%; }
.admin-status--active { color: #10b981; }
.admin-status--active .admin-status__dot { background: #10b981; }
.admin-status--inactive { color: var(--text-tertiary); }
.admin-status--inactive .admin-status__dot { background: var(--border-strong); }

.admin-empty {
    display: flex; flex-direction: column; align-items: center; gap: var(--space-2);
    padding: var(--space-8) var(--space-4);
    color: var(--text-tertiary);
    text-align: center;
}
.admin-empty .icon { width: 28px; height: 28px; opacity: 0.5; }
.admin-empty p { font-size: var(--fs-sm); }

/* ---------- Modal invitar usuario ---------- */
.admin-modal-overlay {
    position: fixed; inset: 0; z-index: var(--z-modal, 1000);
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    padding: var(--space-4);
    animation: adminFadeIn 0.18s ease both;
}
.admin-modal { width: 100%; max-width: 440px; padding: var(--space-6); }
.admin-modal__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-5); }
.admin-modal__head h3 { display: flex; align-items: center; gap: 8px; font-size: var(--fs-md); margin: 0; }

/* ---------- Roles grid ---------- */
.admin-roles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: var(--space-5);
}
.admin-role-card { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-4); }
.admin-role-card__head { display: flex; align-items: center; gap: var(--space-3); }
.admin-role-card__icon {
    width: 42px; height: 42px; border-radius: var(--radius-md); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: white;
}
.admin-role-card__icon .icon { width: 19px; height: 19px; }
.admin-role-card__name { font-size: var(--fs-md); font-weight: 700; color: var(--text-primary); }
.admin-role-card__count { font-size: var(--fs-xs); color: var(--text-tertiary); font-weight: 600; }
.admin-role-card__desc { font-size: var(--fs-xs); color: var(--text-secondary); line-height: 1.6; }

.admin-permission-list { display: flex; flex-direction: column; gap: 2px; border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); padding: var(--space-2) 0; }
.admin-permission-row { display: flex; align-items: center; justify-content: space-between; padding: 6px 2px; }
.admin-permission-row__label { font-size: var(--fs-xs); color: var(--text-secondary); font-weight: 500; }
.admin-permission-row__icon {
    width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
}
.admin-permission-row__icon .icon { width: 11px; height: 11px; }
.admin-permission-row__icon--granted { background: rgba(16,185,129,0.14); color: #10b981; }
.admin-permission-row__icon--denied { background: var(--bg-surface-3); color: var(--text-tertiary); }

/* ---------- Equipos grid ---------- */
.admin-teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: var(--space-5);
}
.admin-team-card { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); }
.admin-team-card__head { display: flex; align-items: center; justify-content: space-between; }
.admin-team-card__icon {
    width: 38px; height: 38px; border-radius: var(--radius-md);
    background: var(--bg-surface-3); color: var(--brand-500);
    display: flex; align-items: center; justify-content: center;
}
.admin-team-card__icon .icon { width: 17px; height: 17px; }
.admin-team-card__name { font-size: var(--fs-md); font-weight: 700; color: var(--text-primary); margin: 0; }
.admin-team-card__desc { font-size: var(--fs-xs); color: var(--text-secondary); line-height: 1.6; min-height: 36px; }

.admin-team-card__lead {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3);
    background: var(--bg-surface-2);
    border-radius: var(--radius-md);
}
.admin-team-card__lead-name { font-size: var(--fs-xs); font-weight: 700; color: var(--text-primary); }
.admin-team-card__lead-role { font-size: 11px; color: var(--text-tertiary); }

.admin-team-card__footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
}
.admin-avatar-stack { display: flex; align-items: center; }
.admin-avatar-stack .avatar { border: 2px solid var(--bg-elevated); margin-left: -8px; }
.admin-avatar-stack .avatar:first-child { margin-left: 0; }
.admin-avatar-stack__more {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--bg-surface-3); color: var(--text-tertiary);
    font-size: 9px; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    margin-left: -8px; border: 2px solid var(--bg-elevated);
}
.admin-team-card__members { font-size: 11px; color: var(--text-tertiary); font-weight: 600; }

/* ---------- Seguridad: audit log ---------- */
.admin-audit-list { display: flex; flex-direction: column; }
.admin-audit-row { display: flex; gap: var(--space-3); padding: var(--space-3) 0; border-bottom: 1px solid var(--border-subtle); }
.admin-audit-row:last-child { border-bottom: none; padding-bottom: 0; }
.admin-audit-row__icon {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
}
.admin-audit-row__icon .icon { width: 13px; height: 13px; }
.admin-audit-row__icon--success { background: rgba(16,185,129,0.12); color: #10b981; }
.admin-audit-row__icon--warning { background: rgba(245,158,11,0.14); color: #b45309; }
.admin-audit-row__icon--danger { background: rgba(218,31,61,0.12); color: var(--brand-500); }
.admin-audit-row__icon--info { background: rgba(14,165,233,0.12); color: #0ea5e9; }
.admin-audit-row__text { font-size: var(--fs-xs); color: var(--text-secondary); line-height: 1.5; }
.admin-audit-row__text strong { color: var(--text-primary); font-weight: 700; }
.admin-audit-row__time { font-size: 10.5px; color: var(--text-tertiary); font-weight: 600; margin-top: 2px; }

/* ---------- Responsive ---------- */
@media (max-width: 1000px) {
    .admin-grid { grid-template-columns: 1fr; }
    .admin-roles-grid, .admin-teams-grid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
    .admin-search-row { flex-direction: column; }
    .admin-search__select { width: 100%; }
    .admin-tabs__btn span, .admin-tabs__btn .admin-tabs__count { display: none; }
}