/* Wrapper del botón de campana */
.topbar__notifications-wrap {
    position: relative;
}

/* Fondo invisible que cierra el dropdown al hacer click fuera */
.notifications-backdrop {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: transparent;
}

/* Panel del dropdown */
.notifications-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: 340px;
    max-height: 420px;
    overflow-y: auto;
    background: #1A1A2E;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.45);
    z-index: 101;
    animation: notif-fade-in .15s ease-out;
}

@keyframes notif-fade-in {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* Header del dropdown */
.notifications-dropdown__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}

.notifications-dropdown__header span {
    font-weight: 600;
    font-size: 14px;
    color: #fff;
}

.notifications-dropdown__header .link-btn {
    background: none;
    border: none;
    color: #C41230;
    font-size: 12.5px;
    font-weight: 500;
    cursor: pointer;
    padding: 0;
}

.notifications-dropdown__header .link-btn:hover {
    text-decoration: underline;
}

/* Cada notificación */
.notifications-dropdown__item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 12px 16px;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: background .15s;
}

.notifications-dropdown__item:last-child {
    border-bottom: none;
}

.notifications-dropdown__item:hover {
    background: rgba(255,255,255,0.04);
}

.notifications-dropdown__item.is-unread {
    background: rgba(196,18,48,0.08);
}

.notifications-dropdown__item.is-unread:hover {
    background: rgba(196,18,48,0.13);
}

/* Icono dentro de cada item */
.notifications-dropdown__item svg,
.notifications-dropdown__item .icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 2px;
    color: #8B0E25;
}

.notifications-dropdown__item.is-unread svg,
.notifications-dropdown__item.is-unread .icon {
    color: #C41230;
}

.notifications-dropdown__item strong {
    display: block;
    font-size: 13.5px;
    color: #fff;
    font-weight: 600;
    margin-bottom: 2px;
}

.notifications-dropdown__item p {
    font-size: 12.5px;
    color: rgba(255,255,255,0.55);
    margin: 0;
    line-height: 1.4;
}

/* Estado vacío (opcional, ver abajo) */
.notifications-dropdown__empty {
    padding: 32px 16px;
    text-align: center;
    color: rgba(255,255,255,0.4);
    font-size: 13px;
}

/* Scrollbar discreto */
.notifications-dropdown::-webkit-scrollbar {
    width: 6px;
}
.notifications-dropdown::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.15);
    border-radius: 3px;
}