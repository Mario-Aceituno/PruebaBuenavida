    private void InsertSnippet(string snippet)
    {
        _undoStack.Push(_model.Content);
        _redoStack.Clear();
        _model.Content = string.IsNullOrEmpty(_model.Content)
            ? snippet
            : _model.Content.TrimEnd('\n') + "\n\n" + snippet + "\n";
        RecomputeDerived();
    }

    private void Undo()
    {
        if (_undoStack.Count == 0) return;
        _redoStack.Push(_model.Content);
        _model.Content = _undoStack.Pop();
        RecomputeDerived();
    }

    private void Redo()
    {
        if (_redoStack.Count == 0) return;
        _undoStack.Push(_model.Content);
        _model.Content = _redoStack.Pop();
        RecomputeDerived();
    }

    private void RecomputeDerived()
    {
        var words = string.IsNullOrWhiteSpace(_model.Content)
            ? 0
            : _model.Content.Split(new[] { ' ', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Length;
        _readingTime = Math.Max(1, (int)Math.Ceiling(words / 200.0));

        _toc = (_model.Content ?? string.Empty)
            .Split('\n')
            .Where(l => l.TrimStart().StartsWith("#"))
            .Select(l =>
            {
                var trimmedLine = l.TrimStart();
                var level = trimmedLine.TakeWhile(c => c == '#').Count();
                var text = trimmedLine.TrimStart('#').Trim();
                return new TocItem(Math.Clamp(level, 1, 4), text);
            })
            .Where(t => !string.IsNullOrWhiteSpace(t.Text))
            .ToList();

        _previewHtml = MarkdownRenderer.Render(_model.Content);
    }

    private bool ValidateBasics()
    {
        if (string.IsNullOrWhiteSpace(_model.Title) || string.IsNullOrWhiteSpace(_model.Summary))
        {
            _error = "El título y el resumen son obligatorios.";
            return false;
        }
        if (!Guid.TryParse(_model.CategoryId, out _))
        {
            _error = "Seleccioná una categoría.";
            return false;
        }
        if (!Guid.TryParse(_model.AuthorId, out _))
        {
            _error = "Seleccioná un autor.";
            return false;
        }
        _error = null;
        return true;
    }

    private void SaveAsDraft()
    {
        if (!ValidateBasics()) return;
        _model.Estado = "Borrador";
        Persist(ArticleStatus.Draft);
    }

    private void SendToReview()
    {
        if (!ValidateBasics()) return;
        _model.Estado = "En revisión";
        Persist(ArticleStatus.InReview);
    }

    private void Publish()
    {
        if (!ValidateBasics()) return;
        _model.Estado = "Publicado";
        Persist(ArticleStatus.Published);
    }

    private void Persist(ArticleStatus status)
    {
        var categoryId = Guid.Parse(_model.CategoryId);
        var authorId = Guid.Parse(_model.AuthorId);

        var created = Data.CreateArticle(
            _model.Title,
            _model.Summary,
            categoryId,
            authorId,
            new List<Guid>(),
            string.Empty,
            false,
            status);

        Nav.NavigateTo($"/articulo/{created.Slug}");
    }

