UserAvatar.razor

@* Size: xs | sm | md | lg | xl *@

<span class="inc-avatar inc-avatar--@Size" style="background:@Background;">
    @Initials
</span>

@code {
    [Parameter] public string Name { get; set; } = "Usuario";
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public string? Color { get; set; }

    private static readonly string[] Palette =
    {
        "#c41230", "#2f7fe0", "#6c4fd6", "#16a672", "#d99a17", "#4b5261", "#a80f29", "#2568bd"
    };

    private string Background => Color ?? Palette[Math.Abs(Name.GetHashCode()) % Palette.Length];

    private string Initials
    {
        get
        {
            var parts = Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 0) return "?";
            if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
            return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
        }
    }
}

MetricCard.razor

<div class="inc-card inc-card--hover inc-card--pad-md inc-metric">
    <div class="inc-metric__top">
        <div class="inc-metric__icon" style="background:@IconBg22; color:@IconColor;">
            <IconSvg Name="@Icon" />
        </div>
        @if (TrendValue is not null)
        {
            <span class="inc-metric__trend inc-metric__trend--@(TrendUp ? "up" : "down")">
                <IconSvg Name="@(TrendUp ? "trending-up" : "trending-down")" />
                @TrendValue
            </span>
        }
    </div>
    <div class="inc-metric__value">@Value</div>
    <div class="inc-metric__label">@Label</div>
    @if (!string.IsNullOrWhiteSpace(Sub))
    {
        <div class="inc-metric__sub">@Sub</div>
    }
</div>

