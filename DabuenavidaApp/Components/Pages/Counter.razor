                    </div>
                    <div class="editor-toolbar__group">
                        <button type="button" class="editor-toolbar__btn" title="Negrita" @onclick='() => InsertSnippet("**texto en negrita**")'><Icon Name="bold" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Cursiva" @onclick='() => InsertSnippet("*texto en cursiva*")'><Icon Name="italic" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Subrayado" @onclick='() => InsertSnippet("<u>texto subrayado</u>")'><Icon Name="underline" /></button>
                    </div>
                    <div class="editor-toolbar__group">
                        <button type="button" class="editor-toolbar__btn" title="Lista numerada" @onclick='() => InsertSnippet("1. Elemento uno\n2. Elemento dos")'><Icon Name="list-ordered" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Lista con viñetas" @onclick='() => InsertSnippet("- Elemento\n- Elemento")'><Icon Name="list" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Checklist" @onclick='() => InsertSnippet("- [ ] Tarea pendiente\n- [x] Tarea realizada")'><Icon Name="check-square" /></button>
                    </div>
                    <div class="editor-toolbar__group">
                        <button type="button" class="editor-toolbar__btn" title="Tabla" @onclick='() => InsertSnippet("| Columna 1 | Columna 2 |\n|---|---|\n| Valor | Valor |")'><Icon Name="table" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Bloque de código" @onclick='() => InsertSnippet("```csharp\nvar x = 1;\n```")'><Icon Name="code" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Cita" @onclick='() => InsertSnippet("> Cita textual")'><Icon Name="quote" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Hipervínculo" @onclick='() => InsertSnippet("[texto del enlace](https://)")'><Icon Name="link" /></button>
                    </div>
                    <div class="editor-toolbar__group">
                        <button type="button" class="editor-toolbar__btn" title="Imagen" @onclick='() => InsertSnippet("

![descripción](url-de-imagen)

")'><Icon Name="image" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Separador" @onclick='() => InsertSnippet("---")'><Icon Name="minus" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Expandible" @onclick='() => InsertSnippet("<details><summary>Ver más</summary>\nContenido oculto\n</details>")'><Icon Name="chevron-down" /></button>
                    </div>
                    <div class="editor-toolbar__group">
                        <button type="button" class="editor-toolbar__btn" title="Nota" @onclick='() => InsertSnippet(":::note\nEsto es una nota.\n:::")'><Icon Name="sticky-note" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Advertencia" @onclick='() => InsertSnippet(":::warning\nEsto es una advertencia.\n:::")'><Icon Name="alert-triangle" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Información" @onclick='() => InsertSnippet(":::info\nEsto es información adicional.\n:::")'><Icon Name="info" /></button>
                    </div>
                    <div class="editor-toolbar__group">
                        <button type="button" class="editor-toolbar__btn" title="Color de texto" @onclick='() => InsertSnippet("{color:#C41230}texto en color{/color}")'><Icon Name="palette" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Resaltar" @onclick='() => InsertSnippet("==texto resaltado==")'><Icon Name="highlighter" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Alinear al centro" @onclick='() => InsertSnippet(":::center\ntexto centrado\n:::")'><Icon Name="align-center" /></button>
                    </div>
                    <div class="editor-toolbar__group">
                        <button type="button" class="editor-toolbar__btn" title="Deshacer" @onclick="Undo" disabled="@(_undoStack.Count == 0)"><Icon Name="undo-2" /></button>
                        <button type="button" class="editor-toolbar__btn" title="Rehacer" @onclick="Redo" disabled="@(_redoStack.Count == 0)"><Icon Name="redo-2" /></button>
                    </div>
                </div>

                <textarea class="editor-canvas" rows="18" placeholder="Escribí la documentación técnica acá. Usá la barra de herramientas para insertar bloques de formato."
                          @bind="_model.Content" @bind:event="oninput" @oninput="OnContentChanged"></textarea>
                <p class="form-hint">El índice lateral y la vista previa se generan automáticamente a partir de lo que escribas.</p>
            }
            else
            {
                <div class="editor-preview">
                    @((MarkupString)_previewHtml)
                </div>
            }
        </div>





private bool _showPreview = false;
    private string _previewHtml = string.Empty;


private void RecomputeDerived()
    {
        var words = string.IsNullOrWhiteSpace(_model.Content)
            ? 0
            : _model.Content.Split(new[] { ' ', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Length;
        _readingTime = Math.Max(1, (int)Math.Ceiling(words / 200.0));

        _toc = (_model.Content ?? string.Empty)
            .Split('\n')
            .Where(l => l.TrimStart().StartsWith("#"))
            .Select(l =>
            {
                var trimmedLine = l.TrimStart();
                var level = trimmedLine.TakeWhile(c => c == '#').Count();
                var text = trimmedLine.TrimStart('#').Trim();
                return new TocItem(Math.Clamp(level, 1, 4), text);
            })
            .Where(t => !string.IsNullOrWhiteSpace(t.Text))
            .ToList();

        _previewHtml = MarkdownRenderer.Render(_model.Content);
    }





/* ---------- Tabs Editar / Vista previa ---------- */
.editor-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-subtle);
}
.editor-tabs__btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: var(--space-2) var(--space-4);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text-tertiary);
    border-bottom: 2px solid transparent;
    transform: translateY(1px);
}
.editor-tabs__btn .icon { width: 15px; height: 15px; }
.editor-tabs__btn:hover { color: var(--text-primary); }
.editor-tabs__btn--active { color: var(--brand-500); border-bottom-color: var(--brand-500); }

/* ---------- Vista previa renderizada ---------- */
.editor-preview {
    min-height: 420px;
    padding: var(--space-5);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-surface);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
}
.editor-preview__empty { color: var(--text-tertiary); font-size: var(--fs-sm); font-style: italic; }

.editor-preview__list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-left: var(--space-6);
    font-size: var(--fs-base);
    color: var(--text-primary);
}
.editor-preview__list li { line-height: 1.7; }

.editor-preview__checklist {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0;
    list-style: none;
}
.editor-preview__check-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--fs-base);
}
.editor-preview__checkbox {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
    border-radius: 4px;
    border: 1.5px solid var(--border-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: white;
}
.editor-preview__checkbox--checked { background: var(--brand-500); border-color: var(--brand-500); }

.editor-preview__highlight { background: rgba(245,158,11,0.35); padding: 0 3px; border-radius: 3px; color: inherit; }
.editor-preview__inline-code {
    background: var(--bg-surface-2);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.9em;
}
.editor-preview__center { text-align: center; font-size: var(--fs-base); }
.editor-preview__details {
    padding: var(--space-4);
    border: 1px dashed var(--border-default);
    border-radius: var(--radius-md);
    background: var(--bg-surface-2);
    font-size: var(--fs-sm);
}
.editor-preview__details summary { cursor: pointer; font-weight: 700; color: var(--text-primary); }

.callout__glyph { font-size: var(--fs-md); line-height: 1; flex-shrink: 0; }