                </div>
                <div class="inc-time-metric__value">6h 55m</div>
                <div class="inc-time-metric__label">Tiempo total</div>
            </div>
        </div>

        <div class="inc-detail-grid">

            <!-- Columna principal -->
            <div>
                <!-- Timeline -->
                <div class="inc-card inc-card--pad-lg inc-anim-fade-up" style="margin-bottom: var(--inc-s-6);">
