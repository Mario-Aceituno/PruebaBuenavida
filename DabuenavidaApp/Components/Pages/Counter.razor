@page "/login"
@rendermode InteractiveServer

<PageTitle>Iniciar sesión · DaviWiki</PageTitle>

<div class="login-screen">

    <div class="login-background" aria-hidden="true">
        <div class="grid-pattern"></div>
    </div>

    <main class="login-card" role="main">

        <section class="visual-panel" aria-hidden="true">
            <div class="visual-panel__ghost-mark">
                <div class="ghost-mark__shape"></div>
            </div>

            <svg class="visual-panel__graph" viewBox="0 0 320 400" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g class="graph-lines" stroke="rgba(255,255,255,0.28)" stroke-width="1">
                    <line x1="60" y1="70" x2="140" y2="40" />
                    <line x1="140" y1="40" x2="230" y2="90" />
                    <line x1="230" y1="90" x2="270" y2="180" />
                    <line x1="140" y1="40" x2="190" y2="150" />
                    <line x1="190" y1="150" x2="110" y2="160" />
                    <line x1="60" y1="70" x2="110" y2="160" />
                    <line x1="190" y1="150" x2="270" y2="180" />
                    <line x1="110" y1="160" x2="70" y2="240" />
                    <line x1="70" y1="240" x2="160" y2="260" />
                    <line x1="160" y1="260" x2="240" y2="300" />
                    <line x1="160" y1="260" x2="190" y2="150" />
                    <line x1="70" y1="240" x2="130" y2="340" />
                    <line x1="130" y1="340" x2="50" y2="330" />
                    <line x1="240" y1="300" x2="130" y2="340" />
                    <line x1="110" y1="160" x2="160" y2="260" />
                </g>
                <g class="graph-nodes" fill="#FFFFFF">
                    <circle class="node node--a" cx="60" cy="70" r="4" />
                    <circle class="node node--b" cx="140" cy="40" r="3" />
                    <circle class="node node--c" cx="230" cy="90" r="5" />
                    <circle class="node node--d" cx="270" cy="180" r="3.5" />
                    <circle class="node node--e" cx="190" cy="150" r="4.5" />
                    <circle class="node node--f" cx="110" cy="160" r="3.5" />
                    <circle class="node node--g" cx="70" cy="240" r="4" />
                    <circle class="node node--h" cx="160" cy="260" r="5" />
                    <circle class="node node--i" cx="240" cy="300" r="3.5" />
                    <circle class="node node--j" cx="130" cy="340" r="4" />
                    <circle class="node node--k" cx="50" cy="330" r="3" />
                </g>
                <g class="graph-citations" font-family="ui-monospace, SFMono-Regular, Menlo, Consolas, monospace">
                    <line x1="230" y1="90" x2="252" y2="76" stroke="rgba(255,255,255,0.35)" stroke-width="1" />
                    <text x="255" y="79" font-size="10" fill="rgba(255,255,255,0.75)">[1]</text>

                    <line x1="190" y1="150" x2="212" y2="136" stroke="rgba(255,255,255,0.35)" stroke-width="1" />
                    <text x="215" y="139" font-size="10" fill="rgba(255,255,255,0.75)">[2]</text>

                    <line x1="160" y1="260" x2="184" y2="248" stroke="rgba(255,255,255,0.35)" stroke-width="1" />
                    <text x="187" y="251" font-size="10" fill="rgba(255,255,255,0.75)">[3]</text>

                    <line x1="130" y1="340" x2="152" y2="352" stroke="rgba(255,255,255,0.35)" stroke-width="1" />
                    <text x="155" y="356" font-size="10" fill="rgba(255,255,255,0.75)">[4]</text>
                </g>
            </svg>

            <div class="visual-panel__mark">
                <div class="brand__mark" aria-hidden="true"></div>
            </div>

            <span class="visual-panel__rev">rev. 2026.07</span>
        </section>

        <section class="form-panel">

            <div class="brand">
                <h1 class="brand__title">DaviWiki</h1>
                <p class="brand__subtitle">Plataforma interna de conocimiento del Área de Tecnología</p>
            </div>

            <EditForm Model="@_model" OnValidSubmit="HandleLoginAsync" class="login-form">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert--error" role="alert">
                        <span class="icon icon-alert" aria-hidden="true"></span>
                        <span>@ErrorMessage</span>
                    </div>
                }

                <div class="field">
                    <label for="username">
                        <span class="icon icon-user" aria-hidden="true">
                            <span class="icon-user__head"></span>
                            <span class="icon-user__body"></span>
                        </span>
                        <span>Usuario</span>
                    </label>
                    <div class="field__frame">
                        <span class="corner corner--nw"></span>
                        <span class="corner corner--ne"></span>
                        <span class="corner corner--sw"></span>
                        <span class="corner corner--se"></span>
                        <InputText id="username"
                                   @bind-Value="_model.Username"
                                   placeholder="Tu usuario corporativo"
                                   autocomplete="username"
                                   disabled="@IsLoading"
                                   class="@FieldClass()" />
                    </div>
                    <ValidationMessage For="@(() => _model.Username)" class="field__error" />
                </div>

                <div class="field">
                    <label for="password">
                        <span class="icon icon-lock" aria-hidden="true">
                            <span class="icon-lock__shackle"></span>
                            <span class="icon-lock__body">
                                <span class="icon-lock__hole"></span>
                            </span>
                        </span>
                        <span>Contraseña</span>
                    </label>
                    <div class="field__frame">
                        <span class="corner corner--nw"></span>
                        <span class="corner corner--ne"></span>
                        <span class="corner corner--sw"></span>
                        <span class="corner corner--se"></span>
                        <div class="field__control">
                            <InputText id="password"
                                       @bind-Value="_model.Password"
                                       type="@(_showPassword ? "text" : "password")"
                                       placeholder="Tu contraseña"
                                       autocomplete="current-password"
                                       disabled="@IsLoading"
                                       class="@FieldClass()" />
                            <button type="button"
                                    class="field__toggle"
                                    @onclick="TogglePasswordVisibility"
                                    disabled="@IsLoading"
                                    aria-label="@(_showPassword ? "Ocultar contraseña" : "Mostrar contraseña")">
                                <span class="icon icon-eye @(_showPassword ? "icon-eye--off" : "")" aria-hidden="true">
                                    <span class="icon-eye__outer"></span>
                                    <span class="icon-eye__pupil"></span>
                                    <span class="icon-eye__slash"></span>
                                </span>
                            </button>
                        </div>
                    </div>
                    <ValidationMessage For="@(() => _model.Password)" class="field__error" />
                </div>

                <div class="field field--inline">
                    <label class="checkbox">
                        <input type="checkbox" @bind="_model.RememberMe" disabled="@IsLoading" />
                        <span class="checkbox__box" aria-hidden="true"></span>
                        <span>Recordar sesión</span>
                    </label>
                </div>

                <button type="submit" class="btn-primary" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="spinner" aria-hidden="true"></span>
                        <span>Validando…</span>
                    }
                    else
                    {
                        <span>Ingresar</span>
                    }
                </button>
            </EditForm>

            <a href="#" class="help-link">¿Necesitás ayuda?</a>

            <span class="secure-badge">
                <span class="icon-shield" aria-hidden="true"></span>
                <span>Conexión segura y cifrada</span>
            </span>

            <p class="footer-note">© Davivienda · Área de Tecnología</p>
        </section>
    </main>
</div>




*, *::before, *::after {
    box-sizing: border-box;
}

:root {
    --davi-red: #C8102E;
    --davi-red-dark: #9E0C24;
    --davi-magenta: #9C1457;

    --gray-50: #FAFAFA;
    --gray-100: #F4F4F6;
    --gray-200: #E8E8EC;
    --gray-300: #D5D5DC;
    --gray-500: #8C8D97;
    --gray-700: #4B4C55;
    --gray-900: #23242A;

    --radius-lg: 22px;
    --radius-sm: 5px;

    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;

    --shadow-card: 0 40px 90px -35px rgba(24, 24, 40, 0.28), 0 2px 8px rgba(24, 24, 40, 0.05);
    --shadow-btn: 0 12px 24px -10px rgba(200, 16, 46, 0.45);

    --transition-fast: 200ms ease;
    --transition-med: 300ms ease;
}

html, body {
    background: var(--gray-50);
    margin: 0;
}

/* ---------- Screen & background ---------- */

.login-screen {
    position: relative;
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-50);
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    padding: 24px;
}

.login-background {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: var(--gray-50);
}

.grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(to right, rgba(35, 36, 42, 0.035) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(35, 36, 42, 0.035) 1px, transparent 1px);
    background-size: 42px 42px;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 0%, transparent 75%);
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 0%, transparent 75%);
}

/* ---------- Card shell: split into visual panel + form panel ---------- */

.login-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 860px;
    background: #FFFFFF;
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    display: flex;
    overflow: hidden;
    animation: card-in var(--transition-med) ease both;
}

@keyframes card-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ---------- Visual panel (brand + knowledge graph) ---------- */

.visual-panel {
    position: relative;
    flex: 0 0 42%;
    min-height: 560px;
    background: linear-gradient(160deg, var(--davi-red) 0%, var(--davi-red-dark) 55%, var(--davi-magenta) 100%);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

.visual-panel__graph {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
}

.graph-lines line {
    stroke-dasharray: 4;
    animation: line-fade 5s ease-in-out infinite;
}

.graph-nodes .node {
    opacity: 0.55;
    transform-origin: center;
    animation: node-pulse 3.6s ease-in-out infinite;
}

.graph-citations text {
    letter-spacing: 0.02em;
}

.node--a { animation-delay: 0s; }
.node--b { animation-delay: 0.3s; }
.node--c { animation-delay: 0.6s; }
.node--d { animation-delay: 0.9s; }
.node--e { animation-delay: 1.2s; }
.node--f { animation-delay: 1.5s; }
.node--g { animation-delay: 1.8s; }
.node--h { animation-delay: 2.1s; }
.node--i { animation-delay: 2.4s; }
.node--j { animation-delay: 2.7s; }
.node--k { animation-delay: 3s; }

@keyframes node-pulse {
    0%, 100% { opacity: 0.45; transform: scale(1); }
    50% { opacity: 0.95; transform: scale(1.25); }
}

@keyframes line-fade {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0.9; }
}

/* Marca fantasma: el glifo del logo, enorme y translúcido, como textura de fondo */
.visual-panel__ghost-mark {
    position: absolute;
    right: -40px;
    bottom: -60px;
    width: 320px;
    height: 320px;
    opacity: 0.07;
    pointer-events: none;
}

.ghost-mark__shape {
    width: 100%;
    height: 100%;
    background: #FFFFFF;
    border-radius: 64px;
    position: relative;
}

.ghost-mark__shape::before {
    content: "";
    position: absolute;
    inset: 22%;
    background: var(--davi-red-dark);
    clip-path: polygon(50% 6%, 100% 20%, 100% 94%, 50% 100%, 0 94%, 0 20%);
}

.visual-panel__mark {
    position: relative;
    z-index: 2;
}

.brand__mark {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(2px);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
}

.brand__mark::before {
    content: "";
    width: 24px;
    height: 24px;
    background: linear-gradient(90deg,
        rgba(255, 255, 255, 0.95) 0%,
        rgba(255, 255, 255, 0.95) 50%,
        rgba(255, 255, 255, 0.6) 50%,
        rgba(255, 255, 255, 0.6) 100%);
    clip-path: polygon(50% 6%, 100% 20%, 100% 94%, 50% 100%, 0 94%, 0 20%);
}

/* Sello de revisión, como el historial de versiones de una página wiki */
.visual-panel__rev {
    position: absolute;
    left: 24px;
    bottom: 20px;
    z-index: 2;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.55);
}

/* ---------- Form panel ---------- */

.form-panel {
    flex: 1;
    min-width: 0;
    padding: 44px 44px 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-bottom: 26px;
}

.brand__title {
    margin: 0;
    font-size: 24px;
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--gray-900);
}

.brand__subtitle {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--gray-500);
    max-width: 300px;
}

/* ---------- Form layout ---------- */

.login-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 22px;
    text-align: left;
}

.field {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.field label {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-700);
}

.field > label .icon {
    color: var(--gray-500);
    opacity: 0.85;
}

/* ---------- "Visor" frame: reemplaza el marco redondeado por marcas en L ---------- */

.field__frame {
    position: relative;
    margin: 5px 6px;
}

.corner {
    position: absolute;
    width: 9px;
    height: 9px;
    pointer-events: none;
    border-color: var(--gray-300);
    transition: border-color var(--transition-fast);
}

.corner--nw { top: -5px; left: -6px; border-top: 1.5px solid; border-left: 1.5px solid; }
.corner--ne { top: -5px; right: -6px; border-top: 1.5px solid; border-right: 1.5px solid; }
.corner--sw { bottom: -5px; left: -6px; border-bottom: 1.5px solid; border-left: 1.5px solid; }
.corner--se { bottom: -5px; right: -6px; border-bottom: 1.5px solid; border-right: 1.5px solid; }

.field__frame:focus-within .corner {
    border-color: var(--davi-red);
}

.field__control {
    position: relative;
    display: flex;
    align-items: center;
}

.field__toggle {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    border-radius: 999px;
    cursor: pointer;
    color: var(--gray-500);
    opacity: 0.75;
    transition: opacity var(--transition-fast), background var(--transition-fast), color var(--transition-fast);
}

.field__toggle:hover {
    opacity: 1;
    background: var(--gray-100);
}

.field__toggle:focus-visible {
    opacity: 1;
    color: var(--davi-red);
}

.field__toggle:disabled {
    cursor: not-allowed;
    opacity: 0.3;
}

.field__error {
    font-size: 12.5px;
    color: var(--davi-red-dark);
}

/* ---------- Inputs: esquinas casi rectas ---------- */

.input {
    width: 100%;
    height: 52px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--gray-200);
    background: var(--gray-50);
    padding: 0 16px;
    font-size: 14.5px;
    color: var(--gray-900);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
}

.input::placeholder { color: var(--gray-500); }

.input:hover:not(:disabled) {
    border-color: var(--gray-300);
    background: #FFFFFF;
}

.input:focus {
    border-color: var(--davi-red);
    background: #FFFFFF;
    box-shadow: 0 0 0 3px rgba(200, 16, 46, 0.08);
}

.input:disabled {
    background: var(--gray-100);
    color: var(--gray-500);
    cursor: not-allowed;
}

.input--error {
    border-color: rgba(200, 16, 46, 0.55);
    background: rgba(200, 16, 46, 0.03);
}

#password { padding-right: 46px; }

/* ---------- Checkbox ---------- */

.field--inline { flex-direction: row; align-items: center; }

.checkbox {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    color: var(--gray-700);
    cursor: pointer;
    user-select: none;
    position: relative;
}

.checkbox input {
    position: absolute;
    opacity: 0;
    width: 18px;
    height: 18px;
    margin: 0;
    cursor: pointer;
}

.checkbox__box {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1.5px solid var(--gray-300);
    background: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition-fast), border-color var(--transition-fast);
    flex: none;
}

.checkbox input:checked + .checkbox__box {
    background: var(--davi-red);
    border-color: var(--davi-red);
}

.checkbox input:checked + .checkbox__box::after {
    content: "";
    width: 5px;
    height: 9px;
    border: solid white;
    border-width: 0 1.6px 1.6px 0;
    transform: rotate(45deg) translate(-1px, -1px);
}

.checkbox input:focus-visible + .checkbox__box {
    outline: 2px solid var(--davi-red);
    outline-offset: 2px;
}

/* ---------- Primary button ---------- */

.btn-primary {
    height: 52px;
    border: none;
    border-radius: var(--radius-sm);
    background: linear-gradient(180deg, var(--davi-red) 0%, var(--davi-red-dark) 100%);
    color: #fff;
    font-size: 15px;
    font-weight: 650;
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    box-shadow: var(--shadow-btn);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), filter var(--transition-fast);
    width: 100%;
}

.btn-primary:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 16px 30px -10px rgba(200, 16, 46, 0.5);
}

.btn-primary:active:not(:disabled) {
    transform: translateY(0);
    filter: brightness(0.96);
    box-shadow: 0 8px 16px -8px rgba(200, 16, 46, 0.45);
}

.btn-primary:disabled { cursor: not-allowed; opacity: 0.85; }

.btn-primary:focus-visible {
    outline: 2px solid var(--davi-red-dark);
    outline-offset: 3px;
}

.spinner {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-top-color: #fff;
    animation: spin 700ms linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ---------- Alert (inline error) ---------- */

.alert {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    animation: fade-in var(--transition-fast) ease both;
}

.alert--error {
    background: rgba(200, 16, 46, 0.06);
    color: var(--davi-red-dark);
    border: 1px solid rgba(200, 16, 46, 0.18);
}

@keyframes fade-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ---------- Footer ---------- */

.help-link {
    margin-top: 22px;
    font-size: 13px;
    color: var(--gray-500);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.help-link:hover { color: var(--davi-red); }

.secure-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 18px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--gray-500);
}

.secure-badge .icon-shield {
    width: 13px;
    height: 14px;
    position: relative;
    flex: none;
    color: var(--gray-500);
    opacity: 0.8;
}

.icon-shield::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 1.4px solid currentColor;
    clip-path: polygon(50% 0%, 100% 18%, 100% 55%, 50% 100%, 0 55%, 0 18%);
    border-radius: 2px;
}

.icon-shield::after {
    content: "";
    position: absolute;
    top: 45%;
    left: 50%;
    width: 3.5px;
    height: 5.5px;
    border: solid currentColor;
    border-width: 0 1.3px 1.3px 0;
    transform: translate(-50%, -60%) rotate(45deg);
}

.footer-note {
    margin: 10px 0 0;
    font-size: 11.5px;
    color: var(--gray-300);
}

/* ============================================================
   CSS-only icons — construidos con spans/divs usando bordes,
   border-radius y clip-path. Sin SVG externo, sin imágenes.
   ============================================================ */

.icon {
    position: relative;
    width: 18px;
    height: 18px;
    display: inline-block;
    flex: none;
}

.icon-user__head {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 7px;
    height: 7px;
    border: 1.6px solid currentColor;
    border-radius: 50%;
}

.icon-user__body {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 15px;
    height: 8px;
    border: 1.6px solid currentColor;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
}

.icon-lock__shackle {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 9px;
    border: 1.6px solid currentColor;
    border-bottom: none;
    border-radius: 6px 6px 0 0;
}

.icon-lock__body {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 10px;
    border: 1.6px solid currentColor;
    border-radius: 3px;
}

.icon-lock__hole {
    position: absolute;
    top: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 2.4px;
    height: 2.4px;
    border-radius: 50%;
    background: currentColor;
}

.icon-eye__outer {
    position: absolute;
    inset: 2px 0;
    border: 1.6px solid currentColor;
    border-radius: 50% / 60%;
}

.icon-eye__pupil {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    transform: translate(-50%, -50%);
}

.icon-eye__slash {
    display: none;
    position: absolute;
    top: 50%;
    left: -1px;
    width: 20px;
    height: 1.6px;
    background: currentColor;
    border-radius: 2px;
    transform: translateY(-50%) rotate(-40deg);
}

.icon-eye--off .icon-eye__outer { opacity: 0.45; }
.icon-eye--off .icon-eye__slash { display: block; }

.icon-alert {
    border-radius: 50%;
    border: 1.6px solid currentColor;
    flex: none;
}

.icon-alert::before {
    content: "";
    position: absolute;
    top: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 1.6px;
    height: 6px;
    background: currentColor;
    border-radius: 1px;
}

.icon-alert::after {
    content: "";
    position: absolute;
    bottom: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 1.6px;
    height: 1.6px;
    border-radius: 50%;
    background: currentColor;
}

/* ---------- Responsive ---------- */

@media (max-width: 760px) {
    .login-card {
        flex-direction: column;
        max-width: 440px;
    }

    .visual-panel {
        flex: none;
        min-height: 150px;
    }

    .visual-panel__ghost-mark {
        width: 200px;
        height: 200px;
    }

    .visual-panel__rev {
        left: 20px;
        bottom: 14px;
    }

    .form-panel {
        padding: 36px 28px 26px;
    }
}

/* ---------- Reduced motion ---------- */

@media (prefers-reduced-motion: reduce) {
    .login-card, .alert, .btn-primary, .spinner, .node, .graph-lines line {
        animation: none !important;
        transition: none !important;
    }
}
