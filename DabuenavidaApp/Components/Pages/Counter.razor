/* =========================================================================
   Incidents Design System — Design Tokens
   Sistema de diseño autocontenido, prefijo --inc- para evitar colisiones.
   ========================================================================= */

:root {
    /* ---------- Neutral scale ---------- */
    --inc-n-0: #ffffff;
    --inc-n-25: #fbfbfc;
    --inc-n-50: #f6f7f9;
    --inc-n-100: #eef0f3;
    --inc-n-150: #e4e7ec;
    --inc-n-200: #d8dce3;
    --inc-n-300: #b9bfca;
    --inc-n-400: #8b93a3;
    --inc-n-500: #666f80;
    --inc-n-600: #4b5261;
    --inc-n-700: #363c48;
    --inc-n-800: #22262f;
    --inc-n-900: #14161b;

    /* ---------- Accent: graphite + banking red ---------- */
    --inc-accent-50: #fdf1f2;
    --inc-accent-100: #fbdfe2;
    --inc-accent-300: #e88a95;
    --inc-accent-500: #c41230;
    --inc-accent-600: #a80f29;
    --inc-accent-700: #8b0e25;

    /* ---------- Semantic ---------- */
    --inc-success-50: #eafbf3;
    --inc-success-500: #16a672;
    --inc-success-600: #0f8f61;

    --inc-warning-50: #fff8ea;
    --inc-warning-500: #d99a17;
    --inc-warning-600: #b8810e;

    --inc-danger-50: #fdf1f1;
    --inc-danger-500: #d8324a;
    --inc-danger-600: #b8253b;

    --inc-info-50: #eef6ff;
    --inc-info-500: #2f7fe0;
    --inc-info-600: #2568bd;

    --inc-violet-50: #f4f1fe;
    --inc-violet-500: #6c4fd6;
    --inc-violet-600: #5a3fc0;

    /* ---------- Surfaces ---------- */
    --inc-surface: var(--inc-n-0);
    --inc-surface-canvas: #f7f8fa;
    --inc-surface-raised: var(--inc-n-0);
    --inc-surface-sunken: var(--inc-n-50);
    --inc-border: var(--inc-n-150);
    --inc-border-strong: var(--inc-n-200);

    /* ---------- Text ---------- */
    --inc-text-primary: var(--inc-n-900);
    --inc-text-secondary: var(--inc-n-600);
    --inc-text-tertiary: var(--inc-n-400);
    --inc-text-inverse: var(--inc-n-0);

    /* ---------- Typography ---------- */
    --inc-font: "Segoe UI Variable", "Segoe UI", -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
    --inc-font-mono: "Cascadia Code", "SFMono-Regular", Consolas, monospace;

    --inc-fs-2xs: 11px;
    --inc-fs-xs: 12.5px;
    --inc-fs-sm: 13.5px;
    --inc-fs-base: 14.5px;
    --inc-fs-md: 16px;
    --inc-fs-lg: 19px;
    --inc-fs-xl: 24px;
    --inc-fs-2xl: 32px;
    --inc-fs-3xl: 40px;

    /* ---------- Spacing (4px scale) ---------- */
    --inc-s-1: 4px;
    --inc-s-2: 8px;
    --inc-s-3: 12px;
    --inc-s-4: 16px;
    --inc-s-5: 20px;
    --inc-s-6: 24px;
    --inc-s-8: 32px;
    --inc-s-10: 40px;
    --inc-s-12: 48px;
    --inc-s-16: 64px;

    /* ---------- Radius ---------- */
    --inc-r-sm: 6px;
    --inc-r-md: 10px;
    --inc-r-lg: 14px;
    --inc-r-xl: 20px;
    --inc-r-full: 999px;

    /* ---------- Shadows (muy sutiles) ---------- */
    --inc-shadow-xs: 0 1px 2px rgba(20, 22, 27, 0.04);
    --inc-shadow-sm: 0 2px 6px rgba(20, 22, 27, 0.05), 0 1px 2px rgba(20, 22, 27, 0.04);
    --inc-shadow-md: 0 8px 24px rgba(20, 22, 27, 0.07), 0 2px 6px rgba(20, 22, 27, 0.05);
    --inc-shadow-lg: 0 16px 48px rgba(20, 22, 27, 0.12), 0 4px 12px rgba(20, 22, 27, 0.06);
    --inc-shadow-focus: 0 0 0 3px rgba(196, 18, 48, 0.14);

    /* ---------- Motion ---------- */
    --inc-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --inc-fast: 120ms;
    --inc-normal: 200ms;
    --inc-slow: 340ms;
}

[data-theme="dark"] {
    --inc-surface: #1b1e24;
    --inc-surface-canvas: #14161a;
    --inc-surface-raised: #21252c;
    --inc-surface-sunken: #191c22;
    --inc-border: #2c313b;
    --inc-border-strong: #3a4049;
    --inc-text-primary: #f2f3f5;
    --inc-text-secondary: #a6adba;
    --inc-text-tertiary: #6b7280;
}

base.css

/* =========================================================================
   Incidents — Base / Shell / Layout utilities
   ========================================================================= */

.inc-shell {
    font-family: var(--inc-font);
    color: var(--inc-text-primary);
    background: var(--inc-surface-canvas);
    -webkit-font-smoothing: antialiased;
}

.inc-shell * { box-sizing: border-box; }

.inc-container {
    max-width: 1360px;
    margin: 0 auto;
    padding: var(--inc-s-8) var(--inc-s-8) var(--inc-s-16);
}

@media (max-width: 900px) {
    .inc-container { padding: var(--inc-s-5) var(--inc-s-4) var(--inc-s-12); }
}

/* ---------- Page head ---------- */
.inc-pagehead {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--inc-s-6);
    margin-bottom: var(--inc-s-8);
    flex-wrap: wrap;
}

.inc-pagehead__eyebrow {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--inc-fs-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--inc-accent-500);
    margin-bottom: var(--inc-s-2);
}

.inc-pagehead h1 {
    font-size: var(--inc-fs-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 6px;
    color: var(--inc-text-primary);
}

.inc-pagehead p {
    font-size: var(--inc-fs-base);
    color: var(--inc-text-secondary);
    margin: 0;
    max-width: 640px;
}

.inc-pagehead__actions { display: flex; gap: var(--inc-s-3); align-items: center; }

/* ---------- Card base ---------- */
.inc-card {
    background: var(--inc-surface-raised);
    border: 1px solid var(--inc-border);
    border-radius: var(--inc-r-lg);
    box-shadow: var(--inc-shadow-xs);
    transition: box-shadow var(--inc-normal) var(--inc-ease), border-color var(--inc-normal) var(--inc-ease), transform var(--inc-normal) var(--inc-ease);
}
.inc-card--hover:hover {
    box-shadow: var(--inc-shadow-md);
    border-color: var(--inc-border-strong);
    transform: translateY(-2px);
}
.inc-card--pad-sm { padding: var(--inc-s-4); }
.inc-card--pad-md { padding: var(--inc-s-6); }
.inc-card--pad-lg { padding: var(--inc-s-8); }

/* ---------- Buttons ---------- */
.inc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    height: 38px;
    padding: 0 var(--inc-s-4);
    border-radius: var(--inc-r-md);
    font-size: var(--inc-fs-sm);
    font-weight: 600;
    font-family: var(--inc-font);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--inc-fast) var(--inc-ease);
    white-space: nowrap;
    line-height: 1;
}
.inc-btn .icon { width: 15px; height: 15px; }
.inc-btn:active { transform: scale(0.97); }

.inc-btn--primary {
    background: linear-gradient(180deg, var(--inc-accent-500), var(--inc-accent-600));
    color: white;
    box-shadow: 0 1px 2px rgba(196,18,48,0.25), inset 0 1px 0 rgba(255,255,255,0.15);
}
.inc-btn--primary:hover { background: linear-gradient(180deg, var(--inc-accent-600), var(--inc-accent-700)); box-shadow: 0 4px 12px rgba(196,18,48,0.28); }

.inc-btn--secondary {
    background: var(--inc-surface);
    color: var(--inc-text-primary);
    border-color: var(--inc-border-strong);
}
.inc-btn--secondary:hover { background: var(--inc-n-50); border-color: var(--inc-n-300); }

.inc-btn--ghost { background: transparent; color: var(--inc-text-secondary); }
.inc-btn--ghost:hover { background: var(--inc-n-100); color: var(--inc-text-primary); }

.inc-btn--danger-ghost { background: transparent; color: var(--inc-danger-500); }
.inc-btn--danger-ghost:hover { background: var(--inc-danger-50); }

.inc-btn--sm { height: 32px; padding: 0 var(--inc-s-3); font-size: var(--inc-fs-xs); }
.inc-btn--lg { height: 44px; padding: 0 var(--inc-s-6); font-size: var(--inc-fs-base); }
.inc-btn--icon { width: 38px; padding: 0; }
.inc-btn--full { width: 100%; }
.inc-btn:disabled { opacity: 0.45; cursor: not-allowed; }

/* ---------- Inputs ---------- */
.inc-input, .inc-select, .inc-textarea {
    width: 100%;
    height: 40px;
    padding: 0 var(--inc-s-4);
    border-radius: var(--inc-r-md);
    border: 1px solid var(--inc-border-strong);
    background: var(--inc-surface);
    font-family: var(--inc-font);
    font-size: var(--inc-fs-sm);
    color: var(--inc-text-primary);
    transition: border-color var(--inc-fast), box-shadow var(--inc-fast);
}
.inc-textarea { height: auto; padding: var(--inc-s-3) var(--inc-s-4); resize: vertical; line-height: 1.6; }
.inc-input:focus, .inc-select:focus, .inc-textarea:focus {
    outline: none;
    border-color: var(--inc-accent-500);
    box-shadow: var(--inc-shadow-focus);
}
.inc-input::placeholder, .inc-textarea::placeholder { color: var(--inc-text-tertiary); }

.inc-label {
    display: block;
    font-size: var(--inc-fs-xs);
    font-weight: 700;
    color: var(--inc-text-secondary);
    margin-bottom: 7px;
    letter-spacing: 0.01em;
}

/* ---------- Utility ---------- */
.inc-scroll-fade { position: relative; }
.inc-divider { height: 1px; background: var(--inc-border); border: none; margin: var(--inc-s-6) 0; }
.inc-muted { color: var(--inc-text-tertiary); }
.inc-flex { display: flex; align-items: center; }
.inc-flex-between { display: flex; align-items: center; justify-content: space-between; }
.inc-gap-2 { gap: var(--inc-s-2); }
.inc-gap-3 { gap: var(--inc-s-3); }
.inc-gap-4 { gap: var(--inc-s-4); }

/* ---------- Animations ---------- */
@keyframes incFadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}
@keyframes incFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}
@keyframes incScaleIn {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: scale(1); }
}
@keyframes incPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
}
.inc-anim-fade-up { animation: incFadeUp var(--inc-slow) var(--inc-ease) both; }
.inc-anim-fade-in { animation: incFadeIn var(--inc-normal) var(--inc-ease) both; }
.inc-anim-scale-in { animation: incScaleIn var(--inc-normal) var(--inc-ease) both; }

/* ---------- Scrollbar ---------- */
.inc-shell ::-webkit-scrollbar { width: 8px; height: 8px; }
.inc-shell ::-webkit-scrollbar-thumb { background: var(--inc-n-300); border-radius: var(--inc-r-full); }
.inc-shell ::-webkit-scrollbar-track { background: transparent; }

components.css

/* =========================================================================
   Incidents — Componentes reutilizables:
   Badges, Avatar, MetricCard, StatCard, SectionHeader, SearchBar, FilterBar,
   IncidentCard, ArticleSuggestionCard, ActionToolbar, QuickActions
   ========================================================================= */

/* ---------- Status Badge ---------- */
.inc-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 26px;
    padding: 0 11px;
    border-radius: var(--inc-r-full);
    font-size: var(--inc-fs-2xs);
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border: 1px solid transparent;
    white-space: nowrap;
}
.inc-badge .inc-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

.inc-badge--open        { background: var(--inc-info-50);    color: var(--inc-info-600); }
.inc-badge--open .inc-dot        { background: var(--inc-info-500); }
.inc-badge--progress     { background: var(--inc-warning-50); color: var(--inc-warning-600); }
.inc-badge--progress .inc-dot    { background: var(--inc-warning-500); animation: incPulse 1.8s ease-in-out infinite; }
.inc-badge--transferred  { background: var(--inc-violet-50);  color: var(--inc-violet-600); }
.inc-badge--transferred .inc-dot { background: var(--inc-violet-500); }
.inc-badge--resolved     { background: var(--inc-success-50); color: var(--inc-success-600); }
.inc-badge--resolved .inc-dot    { background: var(--inc-success-500); }
.inc-badge--closed       { background: var(--inc-n-100);      color: var(--inc-n-500); }
.inc-badge--closed .inc-dot      { background: var(--inc-n-400); }

/* ---------- Priority Badge ---------- */
.inc-priority {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 24px;
    padding: 0 10px;
    border-radius: var(--inc-r-sm);
    font-size: var(--inc-fs-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
}
.inc-priority--critica { background: var(--inc-danger-50); color: var(--inc-danger-600); }
.inc-priority--alta    { background: var(--inc-warning-50); color: var(--inc-warning-600); }
.inc-priority--media    { background: var(--inc-info-50); color: var(--inc-info-600); }
.inc-priority--baja     { background: var(--inc-success-50); color: var(--inc-success-600); }
.inc-priority__bars { display: flex; align-items: flex-end; gap: 1.5px; height: 10px; }
.inc-priority__bars span { width: 2.5px; border-radius: 1px; background: currentColor; opacity: 0.35; }
.inc-priority__bars span:nth-child(1) { height: 40%; }
.inc-priority__bars span:nth-child(2) { height: 65%; }
.inc-priority__bars span:nth-child(3) { height: 100%; }
.inc-priority--critica .inc-priority__bars span,
.inc-priority--alta .inc-priority__bars span:nth-child(-n+2) { opacity: 1; }
.inc-priority--media .inc-priority__bars span:nth-child(-n+1) { opacity: 1; }

/* ---------- Area Badge ---------- */
.inc-area {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--inc-fs-xs);
    font-weight: 600;
    color: var(--inc-text-secondary);
    padding: 4px 10px 4px 4px;
    border-radius: var(--inc-r-full);
    background: var(--inc-surface-sunken);
    border: 1px solid var(--inc-border);
}
.inc-area__icon {
    width: 20px; height: 20px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: var(--inc-n-800);
    color: white;
    flex-shrink: 0;
}
.inc-area__icon .icon { width: 11px; height: 11px; }

/* ---------- User Avatar ---------- */
.inc-avatar {
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
    font-family: var(--inc-font);
    letter-spacing: -0.02em;
}
.inc-avatar--xs { width: 22px; height: 22px; font-size: 9px; }
.inc-avatar--sm { width: 28px; height: 28px; font-size: 10.5px; }
.inc-avatar--md { width: 36px; height: 36px; font-size: 13px; }
.inc-avatar--lg { width: 48px; height: 48px; font-size: 16px; }
.inc-avatar--xl { width: 64px; height: 64px; font-size: 22px; }
.inc-avatar-group { display: flex; }
.inc-avatar-group .inc-avatar { border: 2px solid var(--inc-surface); margin-left: -8px; }
.inc-avatar-group .inc-avatar:first-child { margin-left: 0; }

/* ---------- Metric Card (dashboard KPI) ---------- */
.inc-metric {
    padding: var(--inc-s-6);
    position: relative;
    overflow: hidden;
}
.inc-metric__top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: var(--inc-s-4); }
.inc-metric__icon {
    width: 40px; height: 40px;
    border-radius: var(--inc-r-md);
    display: flex; align-items: center; justify-content: center;
}
.inc-metric__icon .icon { width: 19px; height: 19px; }
.inc-metric__trend {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: var(--inc-fs-2xs); font-weight: 700;
    padding: 3px 8px; border-radius: var(--inc-r-full);
}
.inc-metric__trend--up { background: var(--inc-success-50); color: var(--inc-success-600); }
.inc-metric__trend--down { background: var(--inc-danger-50); color: var(--inc-danger-600); }
.inc-metric__trend .icon { width: 11px; height: 11px; }
.inc-metric__value { font-size: var(--inc-fs-2xl); font-weight: 800; letter-spacing: -0.03em; color: var(--inc-text-primary); line-height: 1; margin-bottom: 6px; }
.inc-metric__label { font-size: var(--inc-fs-sm); color: var(--inc-text-secondary); font-weight: 600; }
.inc-metric__sub { font-size: var(--inc-fs-xs); color: var(--inc-text-tertiary); margin-top: 4px; }

/* ---------- Stat Card (small, compact) ---------- */
.inc-stat {
    display: flex;
    align-items: center;
    gap: var(--inc-s-4);
    padding: var(--inc-s-5);
}
.inc-stat__icon {
    width: 44px; height: 44px; flex-shrink: 0;
    border-radius: var(--inc-r-md);
    display: flex; align-items: center; justify-content: center;
}
.inc-stat__icon .icon { width: 20px; height: 20px; }
.inc-stat__value { font-size: var(--inc-fs-lg); font-weight: 800; color: var(--inc-text-primary); line-height: 1.1; }
.inc-stat__label { font-size: var(--inc-fs-xs); color: var(--inc-text-tertiary); font-weight: 600; margin-top: 2px; }

/* ---------- Section Header ---------- */
.inc-section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--inc-s-4);
}
.inc-section-head__title {
    display: flex; align-items: center; gap: 9px;
    font-size: var(--inc-fs-md);
    font-weight: 700;
    color: var(--inc-text-primary);
    letter-spacing: -0.01em;
}
.inc-section-head__title .icon { width: 17px; height: 17px; color: var(--inc-accent-500); }
.inc-section-head__sub { font-size: var(--inc-fs-xs); color: var(--inc-text-tertiary); margin-top: 3px; font-weight: 500; }
.inc-section-head__link {
    font-size: var(--inc-fs-xs);
    font-weight: 700;
    color: var(--inc-accent-500);
    display: inline-flex; align-items: center; gap: 4px;
}
.inc-section-head__link .icon { width: 13px; height: 13px; transition: transform var(--inc-fast); }
.inc-section-head__link:hover .icon { transform: translateX(2px); }

/* ---------- Search Bar ---------- */
.inc-searchbar {
    position: relative;
    flex: 1;
    min-width: 240px;
}
.inc-searchbar .icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    width: 16px; height: 16px; color: var(--inc-text-tertiary);
    pointer-events: none;
}
.inc-searchbar input {
    width: 100%; height: 42px;
    padding: 0 var(--inc-s-4) 0 40px;
    border-radius: var(--inc-r-md);
    border: 1px solid var(--inc-border-strong);
    background: var(--inc-surface);
    font-size: var(--inc-fs-sm);
    font-family: var(--inc-font);
    transition: all var(--inc-fast);
}
.inc-searchbar input:focus { outline: none; border-color: var(--inc-accent-500); box-shadow: var(--inc-shadow-focus); }
.inc-searchbar__kbd {
    position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
    font-size: 10px; font-weight: 700; color: var(--inc-text-tertiary);
    background: var(--inc-n-100); border: 1px solid var(--inc-border);
    padding: 2px 6px; border-radius: 4px;
}

/* ---------- Filter Bar ---------- */
.inc-filterbar {
    display: flex;
    align-items: center;
    gap: var(--inc-s-3);
    flex-wrap: wrap;
    padding: var(--inc-s-4);
    margin-bottom: var(--inc-s-5);
}
.inc-filter-chip {
    display: inline-flex; align-items: center; gap: 6px;
    height: 34px; padding: 0 var(--inc-s-3);
    border-radius: var(--inc-r-md);
    border: 1px solid var(--inc-border-strong);
    background: var(--inc-surface);
    font-size: var(--inc-fs-xs); font-weight: 600;
    color: var(--inc-text-secondary);
    cursor: pointer;
    transition: all var(--inc-fast);
}
.inc-filter-chip .icon { width: 13px; height: 13px; }
.inc-filter-chip:hover { border-color: var(--inc-n-300); color: var(--inc-text-primary); }
.inc-filter-chip--active { background: var(--inc-n-900); border-color: var(--inc-n-900); color: white; }
.inc-filter-chip__count {
    background: rgba(255,255,255,0.2);
    border-radius: var(--inc-r-full);
    font-size: 10px;
    padding: 1px 6px;
}
.inc-filter-chip--active .inc-filter-chip__count { background: rgba(255,255,255,0.25); }
.inc-filterbar__spacer { flex: 1; }
.inc-view-toggle { display: flex; border: 1px solid var(--inc-border-strong); border-radius: var(--inc-r-md); overflow: hidden; }
.inc-view-toggle button {
    width: 36px; height: 34px; display: flex; align-items: center; justify-content: center;
    background: var(--inc-surface); color: var(--inc-text-tertiary); border: none; cursor: pointer;
    transition: all var(--inc-fast);
}
.inc-view-toggle button + button { border-left: 1px solid var(--inc-border-strong); }
.inc-view-toggle button.active { background: var(--inc-n-900); color: white; }
.inc-view-toggle .icon { width: 15px; height: 15px; }

/* ---------- Incident Card ---------- */
.inc-incident-card {
    display: flex;
    flex-direction: column;
    gap: var(--inc-s-3);
    padding: var(--inc-s-5);
    cursor: pointer;
    position: relative;
}
.inc-incident-card::before {
    content: "";
    position: absolute; left: 0; top: var(--inc-s-3); bottom: var(--inc-s-3);
    width: 3px; border-radius: var(--inc-r-full);
    background: var(--inc-border);
    transition: background var(--inc-fast);
}
.inc-incident-card--critica::before { background: var(--inc-danger-500); }
.inc-incident-card--alta::before { background: var(--inc-warning-500); }
.inc-incident-card--media::before { background: var(--inc-info-500); }
.inc-incident-card--baja::before { background: var(--inc-success-500); }

.inc-incident-card__top { display: flex; align-items: center; justify-content: space-between; gap: var(--inc-s-3); }
.inc-incident-card__id { font-family: var(--inc-font-mono); font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-tertiary); }
.inc-incident-card__title { font-size: var(--inc-fs-base); font-weight: 700; color: var(--inc-text-primary); line-height: 1.4; margin: 0; }
.inc-incident-card__desc { font-size: var(--inc-fs-xs); color: var(--inc-text-secondary); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.inc-incident-card__badges { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
.inc-incident-card__footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: var(--inc-s-3); margin-top: var(--inc-s-1);
    border-top: 1px solid var(--inc-border);
}
.inc-incident-card__meta { display: flex; align-items: center; gap: var(--inc-s-3); }
.inc-incident-card__meta-item { display: flex; align-items: center; gap: 5px; font-size: var(--inc-fs-2xs); font-weight: 600; color: var(--inc-text-tertiary); }
.inc-incident-card__meta-item .icon { width: 12px; height: 12px; }
.inc-incident-card__sla { display: flex; align-items: center; gap: 5px; font-size: var(--inc-fs-2xs); font-weight: 700; }
.inc-incident-card__sla--ok { color: var(--inc-success-600); }
.inc-incident-card__sla--warn { color: var(--inc-warning-600); }
.inc-incident-card__sla--over { color: var(--inc-danger-600); }
.inc-incident-card__sla .icon { width: 12px; height: 12px; }

/* ---------- Article Suggestion Card ---------- */
.inc-article-suggestion {
    display: flex;
    gap: var(--inc-s-3);
    padding: var(--inc-s-3);
    border-radius: var(--inc-r-md);
    transition: background var(--inc-fast);
    cursor: pointer;
}
.inc-article-suggestion:hover { background: var(--inc-surface-sunken); }
.inc-article-suggestion__icon {
    width: 34px; height: 34px; flex-shrink: 0;
    border-radius: var(--inc-r-sm);
    background: var(--inc-info-50); color: var(--inc-info-600);
    display: flex; align-items: center; justify-content: center;
}
.inc-article-suggestion__icon .icon { width: 15px; height: 15px; }
.inc-article-suggestion__title { font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-primary); line-height: 1.4; margin-bottom: 2px; }
.inc-article-suggestion__desc { font-size: 11px; color: var(--inc-text-tertiary); line-height: 1.5; }
.inc-article-suggestion__arrow { color: var(--inc-text-tertiary); flex-shrink: 0; align-self: center; opacity: 0; transition: all var(--inc-fast); transform: translateX(-4px); }
.inc-article-suggestion:hover .inc-article-suggestion__arrow { opacity: 1; transform: translateX(0); color: var(--inc-accent-500); }
.inc-article-suggestion__arrow .icon { width: 14px; height: 14px; }

/* ---------- Action Toolbar ---------- */
.inc-toolbar {
    display: flex;
    align-items: center;
    gap: var(--inc-s-2);
    padding: var(--inc-s-3);
    background: var(--inc-surface);
    border: 1px solid var(--inc-border);
    border-radius: var(--inc-r-lg);
    box-shadow: var(--inc-shadow-sm);
}
.inc-toolbar__group { display: flex; align-items: center; gap: 4px; padding-right: var(--inc-s-2); border-right: 1px solid var(--inc-border); }
.inc-toolbar__group:last-child { border-right: none; padding-right: 0; }

/* ---------- Quick Actions ---------- */
.inc-quick-actions { display: flex; flex-wrap: wrap; gap: var(--inc-s-2); }
.inc-quick-action {
    display: flex; align-items: center; gap: 8px;
    padding: 9px 14px;
    border-radius: var(--inc-r-full);
    border: 1px solid var(--inc-border-strong);
    background: var(--inc-surface);
    font-size: var(--inc-fs-xs);
    font-weight: 700;
    color: var(--inc-text-primary);
    cursor: pointer;
    transition: all var(--inc-fast);
}
.inc-quick-action:hover { border-color: var(--inc-n-900); background: var(--inc-n-900); color: white; transform: translateY(-1px); box-shadow: var(--inc-shadow-sm); }
.inc-quick-action .icon { width: 14px; height: 14px; }

/* ---------- Skeleton shimmer (para demostrar estado de carga) ---------- */
@keyframes incShimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
.inc-skeleton {
    background: linear-gradient(90deg, var(--inc-n-100) 25%, var(--inc-n-150) 37%, var(--inc-n-100) 63%);
    background-size: 400% 100%;
    animation: incShimmer 1.6s ease infinite;
    border-radius: var(--inc-r-sm);
}

dashboard.css

/* =========================================================================
   Incidents — Dashboard
   ========================================================================= */

.inc-dash-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--inc-s-5);
    margin-bottom: var(--inc-s-6);
}

.inc-dash-body {
    display: grid;
    grid-template-columns: 2.1fr 1fr;
    gap: var(--inc-s-6);
    align-items: start;
}

/* ---------- Chart: Donut (CSS conic-gradient, 100% estático) ---------- */
.inc-donut-wrap { display: flex; align-items: center; gap: var(--inc-s-6); padding: var(--inc-s-2) 0; }
.inc-donut {
    width: 148px; height: 148px;
    border-radius: 50%;
    background: conic-gradient(
        var(--inc-danger-500) 0% 18%,
        var(--inc-warning-500) 18% 46%,
        var(--inc-info-500) 46% 78%,
        var(--inc-success-500) 78% 100%
    );
    position: relative;
    flex-shrink: 0;
    animation: incScaleIn var(--inc-slow) var(--inc-ease) both;
}
.inc-donut::after {
    content: "";
    position: absolute; inset: 22px;
    background: var(--inc-surface-raised);
    border-radius: 50%;
}
.inc-donut__center {
    position: absolute; inset: 22px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    z-index: 1;
}
.inc-donut__center strong { font-size: var(--inc-fs-xl); font-weight: 800; color: var(--inc-text-primary); line-height: 1; }
.inc-donut__center span { font-size: 10px; color: var(--inc-text-tertiary); font-weight: 700; text-transform: uppercase; margin-top: 3px; }

.inc-legend { display: flex; flex-direction: column; gap: var(--inc-s-3); flex: 1; }
.inc-legend__row { display: flex; align-items: center; gap: var(--inc-s-2); }
.inc-legend__dot { width: 9px; height: 9px; border-radius: 3px; flex-shrink: 0; }
.inc-legend__label { font-size: var(--inc-fs-xs); font-weight: 600; color: var(--inc-text-secondary); flex: 1; }
.inc-legend__value { font-size: var(--inc-fs-xs); font-weight: 800; color: var(--inc-text-primary); }

/* ---------- Chart: Bars (estático) ---------- */
.inc-bars {
    display: flex;
    align-items: flex-end;
    gap: var(--inc-s-4);
    height: 180px;
    padding: 0 var(--inc-s-2);
}
.inc-bars__col { display: flex; flex-direction: column; align-items: center; gap: var(--inc-s-2); flex: 1; height: 100%; justify-content: flex-end; }
.inc-bars__track { width: 100%; max-width: 34px; display: flex; flex-direction: column-reverse; border-radius: 8px 8px 4px 4px; overflow: hidden; }
.inc-bars__seg { width: 100%; }
.inc-bars__label { font-size: 10.5px; font-weight: 700; color: var(--inc-text-tertiary); text-transform: uppercase; }
.inc-bars__value { font-size: var(--inc-fs-xs); font-weight: 800; color: var(--inc-text-primary); }

/* ---------- Chart: Line sparkline (SVG estático) ---------- */
.inc-sparkline { width: 100%; height: 90px; }
.inc-sparkline path.fill { fill: url(#incSparkGradient); opacity: 0.5; }
.inc-sparkline path.line { fill: none; stroke: var(--inc-accent-500); stroke-width: 2.4; stroke-linecap: round; stroke-linejoin: round; }
.inc-sparkline circle { fill: var(--inc-accent-500); stroke: var(--inc-surface); stroke-width: 2; }

/* ---------- Área más ocupada ---------- */
.inc-area-load { display: flex; flex-direction: column; gap: var(--inc-s-4); }
.inc-area-load__row { display: flex; align-items: center; gap: var(--inc-s-3); }
.inc-area-load__icon {
    width: 36px; height: 36px; border-radius: var(--inc-r-md); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: var(--inc-n-900); color: white;
}
.inc-area-load__icon .icon { width: 16px; height: 16px; }
.inc-area-load__info { flex: 1; min-width: 0; }
.inc-area-load__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
.inc-area-load__name { font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-primary); }
.inc-area-load__count { font-size: var(--inc-fs-2xs); font-weight: 700; color: var(--inc-text-tertiary); }
.inc-area-load__bar { height: 6px; border-radius: var(--inc-r-full); background: var(--inc-n-100); overflow: hidden; }
.inc-area-load__fill { height: 100%; border-radius: var(--inc-r-full); background: linear-gradient(90deg, var(--inc-accent-500), var(--inc-accent-700)); }

/* ---------- Feed de actividad reciente ---------- */
.inc-feed { display: flex; flex-direction: column; }
.inc-feed__item {
    display: flex; gap: var(--inc-s-3);
    padding: var(--inc-s-3) 0;
    border-bottom: 1px solid var(--inc-border);
}
.inc-feed__item:last-child { border-bottom: none; padding-bottom: 0; }
.inc-feed__icon {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
}
.inc-feed__icon .icon { width: 13px; height: 13px; }
.inc-feed__text { font-size: var(--inc-fs-xs); color: var(--inc-text-primary); line-height: 1.5; }
.inc-feed__text strong { font-weight: 700; }
.inc-feed__time { font-size: 10.5px; color: var(--inc-text-tertiary); font-weight: 600; margin-top: 2px; }

/* ---------- Responsables destacados ---------- */
.inc-responsibles { display: flex; flex-direction: column; gap: var(--inc-s-3); }
.inc-responsible-row { display: flex; align-items: center; gap: var(--inc-s-3); }
.inc-responsible-row__info { flex: 1; min-width: 0; }
.inc-responsible-row__name { font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-primary); }
.inc-responsible-row__role { font-size: 11px; color: var(--inc-text-tertiary); }
.inc-responsible-row__stat { text-align: right; }
.inc-responsible-row__stat strong { display: block; font-size: var(--inc-fs-sm); font-weight: 800; color: var(--inc-text-primary); }
.inc-responsible-row__stat span { font-size: 10px; color: var(--inc-text-tertiary); font-weight: 600; }

@media (max-width: 1200px) {
    .inc-dash-grid { grid-template-columns: repeat(2, 1 ); }
    .inc-dash-body { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
    .inc-dash-grid { grid-template-columns: 1fr; }
}

list.css

/* =========================================================================
   Incidents — Lista
   ========================================================================= */

.inc-list-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--inc-s-4);
}

.inc-list-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
}
.inc-list-table thead th {
    text-align: left;
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--inc-text-tertiary);
    padding: 0 var(--inc-s-4) var(--inc-s-3);
    border-bottom: 1px solid var(--inc-border);
}
.inc-list-table tbody tr {
    transition: background var(--inc-fast);
    cursor: pointer;
}
.inc-list-table tbody tr:hover { background: var(--inc-surface-sunken); }
.inc-list-table tbody td {
    padding: var(--inc-s-4);
    border-bottom: 1px solid var(--inc-border);
    font-size: var(--inc-fs-xs);
    vertical-align: middle;
}
.inc-list-table tbody tr:last-child td { border-bottom: none; }
.inc-list-table__id { font-family: var(--inc-font-mono); font-weight: 700; color: var(--inc-text-tertiary); }
.inc-list-table__title { font-weight: 700; color: var(--inc-text-primary); }
.inc-list-table__title-sub { font-weight: 500; color: var(--inc-text-tertiary); font-size: 11px; margin-top: 2px; }

.inc-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--inc-s-16) var(--inc-s-6);
    gap: var(--inc-s-3);
}
.inc-empty-state__icon {
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--inc-surface-sunken);
    display: flex; align-items: center; justify-content: center;
    color: var(--inc-text-tertiary);
    margin-bottom: var(--inc-s-2);
}
.inc-empty-state__icon .icon { width: 28px; height: 28px; }
.inc-empty-state h3 { font-size: var(--inc-fs-md); font-weight: 700; color: var(--inc-text-primary); margin: 0; }
.inc-empty-state p { font-size: var(--inc-fs-sm); color: var(--inc-text-tertiary); margin: 0; max-width: 320px; }

@media (max-width: 1100px) {
    .inc-list-grid { grid-template-columns: 1fr; }
}

wizard.css

/* =========================================================================
   Incidents — Wizard de creación (guiado por pasos)
   ========================================================================= */

.inc-wizard {
    max-width: 760px;
    margin: 0 auto;
}

.inc-wizard-steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: var(--inc-s-10);
}
.inc-wizard-step {
    display: flex;
    align-items: center;
    gap: var(--inc-s-3);
}
.inc-wizard-step__circle {
    width: 38px; height: 38px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: var(--inc-fs-sm); font-weight: 800;
    border: 2px solid var(--inc-border-strong);
    background: var(--inc-surface);
    color: var(--inc-text-tertiary);
    transition: all var(--inc-normal) var(--inc-ease);
    flex-shrink: 0;
}
.inc-wizard-step__circle .icon { width: 16px; height: 16px; }
.inc-wizard-step--done .inc-wizard-step__circle { background: var(--inc-success-500); border-color: var(--inc-success-500); color: white; }
.inc-wizard-step--active .inc-wizard-step__circle { background: var(--inc-accent-500); border-color: var(--inc-accent-500); color: white; box-shadow: 0 0 0 5px var(--inc-accent-50); }
.inc-wizard-step__label { font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-tertiary); white-space: nowrap; }
.inc-wizard-step--active .inc-wizard-step__label, .inc-wizard-step--done .inc-wizard-step__label { color: var(--inc-text-primary); }
.inc-wizard-connector { width: 56px; height: 2px; background: var(--inc-border-strong); margin: 0 var(--inc-s-2); transition: background var(--inc-normal); }
.inc-wizard-connector--done { background: var(--inc-success-500); }

.inc-wizard-panel {
    padding: var(--inc-s-10);
    animation: incFadeUp var(--inc-normal) var(--inc-ease) both;
}
.inc-wizard-panel__head { text-align: center; margin-bottom: var(--inc-s-8); }
.inc-wizard-panel__head h2 { font-size: var(--inc-fs-xl); font-weight: 800; letter-spacing: -0.02em; margin: 0 0 8px; }
.inc-wizard-panel__head p { font-size: var(--inc-fs-sm); color: var(--inc-text-secondary); margin: 0; }

.inc-wizard-field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--inc-s-5); }

.inc-option-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--inc-s-3); }
.inc-option-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--inc-s-2);
    text-align: center;
    padding: var(--inc-s-5) var(--inc-s-3);
    border-radius: var(--inc-r-lg);
    border: 1.5px solid var(--inc-border);
    background: var(--inc-surface);
    cursor: pointer;
    transition: all var(--inc-fast) var(--inc-ease);
}
.inc-option-card:hover { border-color: var(--inc-n-300); transform: translateY(-2px); box-shadow: var(--inc-shadow-sm); }
.inc-option-card--selected { border-color: var(--inc-accent-500); background: var(--inc-accent-50); box-shadow: 0 0 0 3px rgba(196,18,48,0.08); }
.inc-option-card__icon {
    width: 42px; height: 42px; border-radius: var(--inc-r-md);
    display: flex; align-items: center; justify-content: center;
    background: var(--inc-n-900); color: white;
    transition: all var(--inc-fast);
}
.inc-option-card--selected .inc-option-card__icon { background: var(--inc-accent-500); }
.inc-option-card__icon .icon { width: 19px; height: 19px; }
.inc-option-card__title { font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-primary); }
.inc-option-card__desc { font-size: 10.5px; color: var(--inc-text-tertiary); line-height: 1.5; }

.inc-priority-select { display: flex; gap: var(--inc-s-3); }
.inc-priority-option {
    flex: 1; text-align: center;
    padding: var(--inc-s-4) var(--inc-s-2);
    border-radius: var(--inc-r-md);
    border: 1.5px solid var(--inc-border);
    cursor: pointer;
    transition: all var(--inc-fast);
}
.inc-priority-option:hover { transform: translateY(-2px); }
.inc-priority-option--selected { border-color: currentColor; box-shadow: 0 0 0 3px currentColor; }
.inc-priority-option .inc-priority__bars { justify-content: center; margin: 0 auto 8px; }
.inc-priority-option__label { font-size: var(--inc-fs-2xs); font-weight: 800; text-transform: uppercase; }

.inc-responsible-list { display: flex; flex-direction: column; gap: var(--inc-s-2); }
.inc-responsible-option {
    display: flex; align-items: center; gap: var(--inc-s-3);
    padding: var(--inc-s-3) var(--inc-s-4);
    border-radius: var(--inc-r-md);
    border: 1.5px solid var(--inc-border);
    cursor: pointer;
    transition: all var(--inc-fast);
}
.inc-responsible-option:hover { border-color: var(--inc-n-300); background: var(--inc-surface-sunken); }
.inc-responsible-option--selected { border-color: var(--inc-accent-500); background: var(--inc-accent-50); }
.inc-responsible-option__info { flex: 1; }
.inc-responsible-option__name { font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-primary); }
.inc-responsible-option__role { font-size: 11px; color: var(--inc-text-tertiary); }
.inc-responsible-option__load { font-size: 10.5px; font-weight: 700; padding: 3px 9px; border-radius: var(--inc-r-full); background: var(--inc-n-100); color: var(--inc-text-secondary); }
.inc-responsible-option__check {
    width: 20px; height: 20px; border-radius: 50%;
    border: 1.5px solid var(--inc-border-strong);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: all var(--inc-fast);
}
.inc-responsible-option__check .icon { width: 11px; height: 11px; color: white; opacity: 0; transition: opacity var(--inc-fast); }
.inc-responsible-option--selected .inc-responsible-option__check { background: var(--inc-accent-500); border-color: var(--inc-accent-500); }
.inc-responsible-option--selected .inc-responsible-option__check .icon { opacity: 1; }

.inc-summary-review { display: flex; flex-direction: column; gap: 0; }
.inc-summary-row { display: flex; align-items: center; justify-content: space-between; padding: var(--inc-s-3) 0; border-bottom: 1px solid var(--inc-border); }
.inc-summary-row:last-child { border-bottom: none; }
.inc-summary-row__label { font-size: var(--inc-fs-xs); color: var(--inc-text-tertiary); font-weight: 600; }
.inc-summary-row__value { font-size: var(--inc-fs-xs); color: var(--inc-text-primary); font-weight: 700; text-align: right; }

.inc-wizard-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--inc-s-8);
    padding-top: var(--inc-s-6);
    border-top: 1px solid var(--inc-border);
}
.inc-wizard-footer__progress { font-size: var(--inc-fs-2xs); font-weight: 700; color: var(--inc-text-tertiary); text-transform: uppercase; letter-spacing: 0.04em; }

.inc-success-check {
    width: 76px; height: 76px; border-radius: 50%;
    background: var(--inc-success-50);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto var(--inc-s-5);
    animation: incScaleIn var(--inc-slow) var(--inc-ease) both;
}
.inc-success-check .icon { width: 34px; height: 34px; color: var(--inc-success-500); }

@media (max-width: 720px) {
    .inc-wizard-field-grid, .inc-option-grid { grid-template-columns: 1fr; }
    .inc-wizard-panel { padding: var(--inc-s-6) var(--inc-s-4); }
    .inc-wizard-step__label { display: none; }
    .inc-wizard-connector { width: 24px; }
}

detail.css

/* =========================================================================
   Incidents — Detalle de incidencia (header, timeline, actividad, comments)
   ========================================================================= */

.inc-detail-grid {
    display: grid;
    grid-template-columns: 2.2fr 1fr;
    gap: var(--inc-s-6);
    align-items: start;
}

/* ---------- Header ---------- */
.inc-detail-header {
    padding: var(--inc-s-6) var(--inc-s-8);
    background: linear-gradient(135deg, var(--inc-n-900) 0%, #2a2e37 100%);
    border-radius: var(--inc-r-xl);
    color: white;
    margin-bottom: var(--inc-s-6);
    position: relative;
    overflow: hidden;
}
.inc-detail-header::before {
    content: "";
    position: absolute; inset: 0;
    background: radial-gradient(600px circle at 90% -10%, rgba(196,18,48,0.35), transparent 60%);
    pointer-events: none;
}
.inc-detail-header__top { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--inc-s-5); position: relative; margin-bottom: var(--inc-s-5); }
.inc-detail-header__id { font-family: var(--inc-font-mono); font-size: var(--inc-fs-xs); font-weight: 700; color: rgba(255,255,255,0.55); margin-bottom: 8px; }
.inc-detail-header__title { font-size: var(--inc-fs-xl); font-weight: 800; letter-spacing: -0.02em; margin: 0 0 var(--inc-s-3); max-width: 620px; }
.inc-detail-header__badges { display: flex; gap: 8px; flex-wrap: wrap; }
.inc-detail-header__badges .inc-badge, .inc-detail-header__badges .inc-priority { border: 1px solid rgba(255,255,255,0.14); }

.inc-detail-header__meta { display: flex; gap: var(--inc-s-8); flex-wrap: wrap; position: relative; padding-top: var(--inc-s-5); border-top: 1px solid rgba(255,255,255,0.12); }
.inc-detail-header__meta-item { display: flex; flex-direction: column; gap: 4px; }
.inc-detail-header__meta-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(255,255,255,0.45); }
.inc-detail-header__meta-value { font-size: var(--inc-fs-sm); font-weight: 700; color: white; display: flex; align-items: center; gap: 6px; }
.inc-detail-header__meta-value .icon { width: 14px; height: 14px; opacity: 0.7; }

/* ---------- Time metrics strip ---------- */
.inc-time-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--inc-s-4);
    margin-bottom: var(--inc-s-6);
}
.inc-time-metric { padding: var(--inc-s-5); text-align: center; }
.inc-time-metric__icon {
    width: 38px; height: 38px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto var(--inc-s-3);
}
.inc-time-metric__icon .icon { width: 17px; height: 17px; }
.inc-time-metric__value { font-size: var(--inc-fs-lg); font-weight: 800; color: var(--inc-text-primary); line-height: 1; }
.inc-time-metric__label { font-size: 10.5px; font-weight: 700; color: var(--inc-text-tertiary); text-transform: uppercase; letter-spacing: 0.04em; margin-top: 6px; }

/* ---------- TIMELINE (lo más importante) ---------- */
.inc-timeline {
    position: relative;
    padding: var(--inc-s-4) 0 var(--inc-s-2);
}
.inc-timeline::before {
    content: "";
    position: absolute;
    left: 27px; top: 8px; bottom: 8px;
    width: 2px;
    background: linear-gradient(var(--inc-border-strong), var(--inc-border-strong));
    background-size: 2px 10px;
    background-repeat: repeat-y;
    -webkit-mask-image: linear-gradient(black, black);
}

.inc-timeline-node {
    display: flex;
    gap: var(--inc-s-5);
    position: relative;
    padding-bottom: var(--inc-s-6);
    animation: incFadeUp var(--inc-normal) var(--inc-ease) both;
}
.inc-timeline-node:last-child { padding-bottom: 0; }

.inc-timeline-node__marker {
    width: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
}
.inc-timeline-node__avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 14px; color: white;
    border: 3px solid var(--inc-surface-canvas);
    box-shadow: var(--inc-shadow-sm);
}

.inc-timeline-node__card {
    flex: 1;
    background: var(--inc-surface-raised);
    border: 1px solid var(--inc-border);
    border-radius: var(--inc-r-lg);
    padding: var(--inc-s-5);
    transition: box-shadow var(--inc-normal), border-color var(--inc-normal);
}
.inc-timeline-node__card:hover { box-shadow: var(--inc-shadow-sm); border-color: var(--inc-border-strong); }

.inc-timeline-node__head { display: flex; align-items: center; justify-content: space-between; gap: var(--inc-s-3); margin-bottom: var(--inc-s-2); flex-wrap: wrap; }
.inc-timeline-node__actor { font-size: var(--inc-fs-sm); font-weight: 700; color: var(--inc-text-primary); }
.inc-timeline-node__time { font-size: 10.5px; font-weight: 600; color: var(--inc-text-tertiary); }
.inc-timeline-node__desc { font-size: var(--inc-fs-xs); color: var(--inc-text-secondary); line-height: 1.6; margin-bottom: var(--inc-s-3); }

.inc-timeline-node__flow {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    padding-top: var(--inc-s-3);
    border-top: 1px dashed var(--inc-border);
}
.inc-flow-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px;
    border-radius: var(--inc-r-full);
    background: var(--inc-surface-sunken);
    border: 1px solid var(--inc-border);
    font-size: var(--inc-fs-2xs);
    font-weight: 700;
    color: var(--inc-text-secondary);
}
.inc-flow-pill .icon { width: 12px; height: 12px; }
.inc-flow-arrow { color: var(--inc-text-tertiary); flex-shrink: 0; }
.inc-flow-arrow .icon { width: 15px; height: 15px; }
.inc-flow-duration {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: var(--inc-fs-2xs); font-weight: 800;
    color: var(--inc-accent-600);
    background: var(--inc-accent-50);
    padding: 6px 12px;
    border-radius: var(--inc-r-full);
}
.inc-flow-duration .icon { width: 12px; height: 12px; }

.inc-timeline-node--transfer .inc-timeline-node__avatar { background: var(--inc-violet-500); }
.inc-timeline-node--created .inc-timeline-node__avatar { background: var(--inc-info-500); }
.inc-timeline-node--progress .inc-timeline-node__avatar { background: var(--inc-warning-500); }
.inc-timeline-node--comment .inc-timeline-node__avatar { background: var(--inc-n-500); }
.inc-timeline-node--resolved .inc-timeline-node__avatar { background: var(--inc-success-500); }

.inc-timeline-node__type-icon {
    position: absolute; bottom: -3px; right: -3px;
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--inc-surface-raised);
    border: 2px solid var(--inc-surface-canvas);
    display: flex; align-items: center; justify-content: center;
}
.inc-timeline-node__type-icon .icon { width: 9px; height: 9px; }

/* ---------- Actividad / Comentarios ---------- */
.inc-tabs { display: flex; gap: var(--inc-s-1); margin-bottom: var(--inc-s-5); border-bottom: 1px solid var(--inc-border); }
.inc-tabs__btn {
    display: flex; align-items: center; gap: 7px;
    padding: var(--inc-s-3) var(--inc-s-4);
    font-size: var(--inc-fs-xs); font-weight: 700;
    color: var(--inc-text-tertiary);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    transition: all var(--inc-fast);
    background: none; border-top: none; border-left: none; border-right: none;
}
.inc-tabs__btn .icon { width: 14px; height: 14px; }
.inc-tabs__btn:hover { color: var(--inc-text-primary); }
.inc-tabs__btn--active { color: var(--inc-accent-500); border-bottom-color: var(--inc-accent-500); }
.inc-tabs__badge { background: var(--inc-n-100); color: var(--inc-text-secondary); font-size: 10px; font-weight: 800; padding: 1px 6px; border-radius: var(--inc-r-full); }
.inc-tabs__btn--active .inc-tabs__badge { background: var(--inc-accent-50); color: var(--inc-accent-600); }

.inc-comment { display: flex; gap: var(--inc-s-3); padding: var(--inc-s-4) 0; border-bottom: 1px solid var(--inc-border); }
.inc-comment:last-child { border-bottom: none; }
.inc-comment__body { flex: 1; }
.inc-comment__head { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
.inc-comment__author { font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-primary); }
.inc-comment__time { font-size: 10.5px; color: var(--inc-text-tertiary); font-weight: 600; }
.inc-comment__text { font-size: var(--inc-fs-xs); color: var(--inc-text-secondary); line-height: 1.65; }
.inc-comment__actions { display: flex; gap: var(--inc-s-4); margin-top: 8px; }
.inc-comment__action { display: flex; align-items: center; gap: 4px; font-size: 10.5px; font-weight: 700; color: var(--inc-text-tertiary); cursor: pointer; }
.inc-comment__action:hover { color: var(--inc-accent-500); }
.inc-comment__action .icon { width: 12px; height: 12px; }

.inc-composer { display: flex; gap: var(--inc-s-3); padding-top: var(--inc-s-4); border-top: 1px solid var(--inc-border); margin-top: var(--inc-s-2); }
.inc-composer__box { flex: 1; }
.inc-composer textarea { min-height: 70px; }
.inc-composer__actions { display: flex; justify-content: flex-end; margin-top: var(--inc-s-2); }

/* ---------- Files ---------- */
.inc-file-chip {
    display: flex; align-items: center; gap: var(--inc-s-3);
    padding: var(--inc-s-3);
    border: 1px solid var(--inc-border);
    border-radius: var(--inc-r-md);
    transition: border-color var(--inc-fast), background var(--inc-fast);
}
.inc-file-chip:hover { border-color: var(--inc-border-strong); background: var(--inc-surface-sunken); }
.inc-file-chip__icon {
    width: 36px; height: 36px; border-radius: var(--inc-r-sm); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: var(--inc-info-50); color: var(--inc-info-600);
}
.inc-file-chip__icon .icon { width: 16px; height: 16px; }
.inc-file-chip__name { font-size: var(--inc-fs-xs); font-weight: 700; color: var(--inc-text-primary); }
.inc-file-chip__meta { font-size: 10.5px; color: var(--inc-text-tertiary); }

@media (max-width: 1150px) {
    .inc-detail-grid { grid-template-columns: 1fr; }
    .inc-time-strip { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
    .inc-detail-header { padding: var(--inc-s-5); }
    .inc-time-strip { grid-template-columns: 1fr; }
    .inc-timeline::before { left: 21px; }
    .inc-timeline-node__marker { width: 44px; }
    .inc-timeline-node__avatar { width: 34px; height: 34px; font-size: 11px; }
}

modals.css

/* =========================================================================
   Incidents — Transfer Drawer + Reactivate Modal
   ========================================================================= */

.inc-overlay {
    position: fixed; inset: 0;
    background: rgba(15, 17, 21, 0.55);
    backdrop-filter: blur(3px);
    z-index: 1000;
    animation: incFadeIn var(--inc-normal) var(--inc-ease) both;
}

/* ---------- Drawer (transferencia) ---------- */
.inc-drawer {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 460px;
    max-width: 92vw;
    background: var(--inc-surface-raised);
    box-shadow: var(--inc-shadow-lg);
    z-index: 1001;
    display: flex;
    flex-direction: column;
    animation: incDrawerIn var(--inc-slow) var(--inc-ease) both;
}
@keyframes incDrawerIn { from { transform: translateX(100%); } to { transform: translateX(0); } }

.inc-drawer__header {
    display: flex; align-items: flex-start; justify-content: space-between;
    padding: var(--inc-s-6); border-bottom: 1px solid var(--inc-border);
}
.inc-drawer__title { font-size: var(--inc-fs-lg); font-weight: 800; letter-spacing: -0.01em; margin: 0 0 4px; }
.inc-drawer__subtitle { font-size: var(--inc-fs-xs); color: var(--inc-text-tertiary); margin: 0; }
.inc-drawer__close {
    width: 32px; height: 32px; border-radius: var(--inc-r-md);
    display: flex; align-items: center; justify-content: center;
    color: var(--inc-text-tertiary); flex-shrink: 0;
    transition: all var(--inc-fast);
}
.inc-drawer__close:hover { background: var(--inc-n-100); color: var(--inc-text-primary); }
.inc-drawer__close .icon { width: 16px; height: 16px; }

.inc-drawer__body { flex: 1; overflow-y: auto; padding: var(--inc-s-6); display: flex; flex-direction: column; gap: var(--inc-s-5); }

.inc-drawer__current {
    display: flex; align-items: center; gap: var(--inc-s-3);
    padding: var(--inc-s-4);
    background: var(--inc-surface-sunken);
    border-radius: var(--inc-r-md);
    border: 1px solid var(--inc-border);
}
.inc-drawer__current-arrow { color: var(--inc-text-tertiary); flex-shrink: 0; }
.inc-drawer__current-arrow .icon { width: 16px; height: 16px; }

.inc-target-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--inc-s-2); }
.inc-target-option {
    display: flex; align-items: center; gap: var(--inc-s-2);
    padding: var(--inc-s-3);
    border-radius: var(--inc-r-md);
    border: 1.5px solid var(--inc-border);
    cursor: pointer;
    transition: all var(--inc-fast);
}
.inc-target-option:hover { border-color: var(--inc-n-300); }
.inc-target-option--selected { border-color: var(--inc-accent-500); background: var(--inc-accent-50); }
.inc-target-option__icon {
    width: 30px; height: 30px; border-radius: var(--inc-r-sm); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: var(--inc-n-900); color: white;
}
.inc-target-option__icon .icon { width: 14px; height: 14px; }
.inc-target-option__label { font-size: 11.5px; font-weight: 700; color: var(--inc-text-primary); }

.inc-drawer__footer {
    padding: var(--inc-s-5) var(--inc-s-6);
    border-top: 1px solid var(--inc-border);
    display: flex; gap: var(--inc-s-3);
    background: var(--inc-surface-sunken);
}

/* ---------- Modal (reactivación) ---------- */
.inc-modal-center {
    position: fixed; inset: 0; z-index: 1001;
    display: flex; align-items: center; justify-content: center;
    padding: var(--inc-s-4);
    pointer-events: none;
}
.inc-modal {
    width: 100%; max-width: 460px;
    background: var(--inc-surface-raised);
    border-radius: var(--inc-r-xl);
    box-shadow: var(--inc-shadow-lg);
    padding: var(--inc-s-8);
    pointer-events: auto;
    animation: incScaleIn var(--inc-normal) var(--inc-ease) both;
    text-align: center;
}
.inc-modal__icon {
    width: 60px; height: 60px; border-radius: 50%;
    background: var(--inc-warning-50); color: var(--inc-warning-600);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto var(--inc-s-5);
}
.inc-modal__icon .icon { width: 26px; height: 26px; }
.inc-modal h3 { font-size: var(--inc-fs-lg); font-weight: 800; margin: 0 0 var(--inc-s-2); }
.inc-modal p { font-size: var(--inc-fs-sm); color: var(--inc-text-secondary); line-height: 1.6; margin: 0 0 var(--inc-s-5); }
.inc-modal__warning {
    display: flex; gap: var(--inc-s-3); text-align: left;
    padding: var(--inc-s-4);
    background: var(--inc-warning-50);
    border: 1px solid rgba(217,154,23,0.25);
    border-radius: var(--inc-r-md);
    margin-bottom: var(--inc-s-5);
}
.inc-modal__warning .icon { width: 16px; height: 16px; color: var(--inc-warning-600); flex-shrink: 0; margin-top: 1px; }
.inc-modal__warning p { margin: 0; font-size: var(--inc-fs-2xs); color: var(--inc-warning-600); font-weight: 600; }
.inc-modal__actions { display: flex; gap: var(--inc-s-3); }

@media (max-width: 560px) {
    .inc-target-grid { grid-template-columns: 1fr; }
}
