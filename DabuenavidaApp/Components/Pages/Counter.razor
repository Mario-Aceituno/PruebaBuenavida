        i4.Timeline.Add(new(){ Type=IncidentEventType.Cerrada, Team="Infraestructura", Author="Ana Torres", Note="Confirmado por el solicitante.", Timestamp=t4.AddHours(26) });
        _incidents.Add(i4);

        _seq = 1005;
    }
}

builder.Services.AddSingleton<IncidentDataService>();

@page "/incidencias"
@inject IncidentDataService IncidentData
@using CorpWiki.Models

<PageTitle>CorpWiki — Incidencias</PageTitle>

<div class="page-header">
    <div>
        <h1>Gestión de Incidencias</h1>
        <p>Seguimiento de incidencias por equipo, con trazabilidad de tiempos muertos y tiempos activos.</p>
    </div>
    <a class="btn btn--primary" href="/incidencias/nueva"><Icon Name="plus" /> Nueva incidencia</a>
</div>

<div class="admin-stat-grid incident-stat-grid">
    <div class="card stat-card">
        <span class="stat-card__value">@_all.Count(i => i.Status is IncidentStatus.Abierta or IncidentStatus.EnProgreso or IncidentStatus.Transferida)</span>
        <span class="stat-card__label">Incidencias activas</span>
    </div>
    <div class="card stat-card">
        <span class="stat-card__value">@_all.Count(i => i.Status == IncidentStatus.Resuelta)</span>
        <span class="stat-card__label">Resueltas</span>
    </div>
    <div class="card stat-card">
        <span class="stat-card__value stat-card__value--danger">@_all.Count(i => i.Priority == IncidentPriority.Critica && i.Status != IncidentStatus.Cerrada)</span>
        <span class="stat-card__label">Críticas abiertas</span>
    </div>
    <div class="card stat-card">
        <span class="stat-card__value">@FormatSpan(AvgDeadTime())</span>
        <span class="stat-card__label">Tiempo muerto promedio</span>
    </div>
</div>

<div class="widget card filter-bar">
    <div class="form-group" style="margin:0">
        <label class="form-label">Equipo</label>
        <select class="input" @bind="_filterTeam">
            <option value="">Todos</option>
            @foreach (var team in IncidentData.Teams)
            {
                <option value="@team">@team</option>
            }
        </select>
    </div>
    <div class="form-group" style="margin:0">
        <label class="form-label">Categoría</label>
        <select class="input" @bind="_filterCategory">
            <option value="">Todas</option>
            @foreach (var cat in IncidentData.Categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>
    <div class="form-group" style="margin:0">
        <label class="form-label">Prioridad</label>
        <select class="input" @bind="_filterPriority">
            <option value="">Todas</option>
            @foreach (var p in Enum.GetValues<IncidentPriority>())
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>
</div>

<div class="kanban">
    @foreach (var status in new[] { IncidentStatus.Abierta, IncidentStatus.EnProgreso, IncidentStatus.Transferida, IncidentStatus.Resuelta, IncidentStatus.Cerrada })
    {
        var items = Filtered().Where(i => i.Status == status).ToList();
        <div class="kanban__column">
            <div class="kanban__column-header">
                <span>@StatusLabel(status)</span>
                <span class="kanban__count">@items.Count</span>
            </div>
            <div class="kanban__cards">
                @foreach (var inc in items)
                {
                    <a class="card incident-card" href="@($"/incidencia/{inc.Code}")">
                        <div class="incident-card__top">
                            <span class="incident-card__code">@inc.Code</span>
                            <span class="@PriorityBadgeClass(inc.Priority)">@inc.Priority</span>
                        </div>
                        <p class="incident-card__title">@inc.Title</p>
                        <div class="incident-card__meta">
                            <span><Icon Name="folder" /> @inc.Category</span>
                            <span><Icon Name="users" /> @inc.CurrentTeam</span>
                        </div>
                        <div class="incident-card__footer">
                            <span class="incident-card__elapsed"><Icon Name="clock" /> @FormatSpan(DateTime.Now - inc.CreatedAt)</span>
                            @{ var deadNow = CurrentDeadTime(inc); }
                            @if (deadNow is not null)
                            {
                                <span class="incident-card__dead @(IsOverSla(inc) ? "incident-card__dead--over" : "")">
                                    <Icon Name="alert-triangle" /> @FormatSpan(deadNow.Value) muerto
                                </span>
                            }
                        </div>
                    </a>
                }
                @if (items.Count == 0)
                {
                    <p class="kanban__empty">Sin incidencias</p>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Incident> _all = new();
    private string _filterTeam = "";
    private string _filterCategory = "";
    private string _filterPriority = "";

    protected override void OnInitialized()
    {
        _all = IncidentData.GetAll().ToList();
    }

    private List<Incident> Filtered() => _all.Where(i =>
        (string.IsNullOrEmpty(_filterTeam) || i.CurrentTeam == _filterTeam) &&
        (string.IsNullOrEmpty(_filterCategory) || i.Category == _filterCategory) &&
        (string.IsNullOrEmpty(_filterPriority) || i.Priority.ToString() == _filterPriority)
    ).ToList();

    private static string StatusLabel(IncidentStatus s) => s switch
    {
        IncidentStatus.Abierta => "Abiertas",
        IncidentStatus.EnProgreso => "En progreso",
        IncidentStatus.Transferida => "Transferidas",
        IncidentStatus.Resuelta => "Resueltas",
        _ => "Cerradas"
    };

    private static string PriorityBadgeClass(IncidentPriority p) => p switch
    {
        IncidentPriority.Critica => "badge badge--priority badge--priority-critica",
        IncidentPriority.Alta => "badge badge--priority badge--priority-alta",
        IncidentPriority.Media => "badge badge--priority badge--priority-media",
        _ => "badge badge--priority badge--priority-baja"
    };

    /// Tiempo muerto vigente: si el tramo actual todavía no fue "tomado" por el equipo.
    private static TimeSpan? CurrentDeadTime(Incident inc)
    {
        var legs = IncidentDataService.ComputeLegs(inc);
        var last = legs.LastOrDefault();
        if (last is null || last.StartedAt is not null) return null;
        return DateTime.Now - last.AssignedAt;
    }

    private static bool IsOverSla(Incident inc)
    {
        var dead = CurrentDeadTime(inc);
        return dead is not null && dead.Value.TotalHours > IncidentDataService.SlaHours(inc.Priority);
    }

    private TimeSpan AvgDeadTime()
    {
        var allDead = _all
            .SelectMany(i => IncidentDataService.ComputeLegs(i))
            .Where(l => l.StartedAt is not null)
            .Select(l => l.DeadTime)
            .ToList();
        if (allDead.Count == 0) return TimeSpan.Zero;
        return TimeSpan.FromMinutes(allDead.Average(d => d.TotalMinutes));
    }

    private static string FormatSpan(TimeSpan span)
    {
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours}h {span.Minutes}m";
        return $"{(int)span.TotalMinutes}m";
    }
}

@page "/incidencia/{Codigo}"
@inject IncidentDataService IncidentData
@using CorpWiki.Models

<PageTitle>CorpWiki — @Codigo</PageTitle>

@if (_incident is null)
{
