Dashboard.razor

@page "/incidencias"
@page "/incidencias/dashboard"

<div class="inc-shell">
    <div class="inc-container">

        <div class="inc-pagehead inc-anim-fade-up">
            <div>
                <div class="inc-pagehead__eyebrow">
                    <IconSvg Name="layers" />
                    Módulo de Incidencias
                </div>
                <h1>Dashboard ejecutivo</h1>
                <p>Resumen general del estado de las incidencias entre áreas de tecnología, actividad reciente y carga de trabajo por equipo.</p>
            </div>
            <div class="inc-pagehead__actions">
                <button class="inc-btn inc-btn--secondary">
                    <IconSvg Name="file" /> Exportar
                </button>
                <button class="inc-btn inc-btn--primary">
                    <IconSvg Name="plus" /> Nueva incidencia
                </button>
            </div>
        </div>

        <!-- KPIs -->
        <div class="inc-dash-grid inc-anim-fade-up">
            <MetricCard Icon="layers" Value="128" Label="Incidencias totales" Sub="Últimos 30 días"
                        IconColor="var(--inc-accent-500)" IconBg22="var(--inc-accent-50)"
                        TrendValue="12%" TrendUp="true" />
            <MetricCard Icon="alert" Value="34" Label="Abiertas" Sub="Requieren atención"
                        IconColor="var(--inc-info-600)" IconBg22="var(--inc-info-50)"
                        TrendValue="4%" TrendUp="false" />
            <MetricCard Icon="clock" Value="6.4h" Label="Tiempo promedio resolución" Sub="vs. 7.1h mes anterior"
                        IconColor="var(--inc-warning-600)" IconBg22="var(--inc-warning-50)"
                        TrendValue="9%" TrendUp="true" />
            <MetricCard Icon="check-circle" Value="94.2%" Label="SLA cumplido" Sub="Meta: 90%"
                        IconColor="var(--inc-success-600)" IconBg22="var(--inc-success-50)"
                        TrendValue="2.1%" TrendUp="true" />
        </div>

        <div class="inc-dash-body">

            <!-- Columna principal -->
            <div style="display:flex; flex-direction:column; gap: var(--inc-s-6);">

                <!-- Distribución por prioridad + estado -->
                <div class="inc-card inc-card--pad-lg inc-anim-fade-up">
                    <SectionHeader Title="Distribución por prioridad" Icon="alert"
                                   Subtitle="Incidencias activas agrupadas por nivel de criticidad" />
                    <div class="inc-donut-wrap">
                        <div class="inc-donut">
                            <div class="inc-donut__center">
                                <strong>128</strong>
                                <span>Total</span>
                            </div>
                        </div>
                        <div class="inc-legend">
                            <div class="inc-legend__row">
                                <span class="inc-legend__dot" style="background:var(--inc-danger-500);"></span>
                                <span class="inc-legend__label">Crítica</span>
                                <span class="inc-legend__value">23</span>
                            </div>
                            <div class="inc-legend__row">
                                <span class="inc-legend__dot" style="background:var(--inc-warning-500);"></span>
                                <span class="inc-legend__label">Alta</span>
                                <span class="inc-legend__value">36</span>
                            </div>
                            <div class="inc-legend__row">
                                <span class="inc-legend__dot" style="background:var(--inc-info-500);"></span>
                                <span class="inc-legend__label">Media</span>
                                <span class="inc-legend__value">41</span>
                            </div>
                            <div class="inc-legend__row">
                                <span class="inc-legend__dot" style="background:var(--inc-success-500);"></span>
                                <span class="inc-legend__label">Baja</span>
                                <span class="inc-legend__value">28</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Incidencias por semana (barras) + tendencia (sparkline) -->
                <div class="inc-card inc-card--pad-lg inc-anim-fade-up">
                    <SectionHeader Title="Incidencias por día" Icon="trending-up"
                                   Subtitle="Últimos 7 días" LinkText="Ver reporte completo" LinkHref="#" />
                    <div class="inc-bars">
                        @foreach (var bar in WeekBars)
                        {
                            <div class="inc-bars__col">
                                <span class="inc-bars__value">@bar.Value</span>
                                <div class="inc-bars__track" style="height:@(bar.Height)%;">
                                    <div class="inc-bars__seg" style="height:100%; background:@bar.Color;"></div>
                                </div>
                                <span class="inc-bars__label">@bar.Label</span>
                            </div>
                        }
                    </div>

                    <hr class="inc-divider" />

                    <svg class="inc-sparkline" viewBox="0 0 400 90" preserveAspectRatio="none">
                        <defs>
                            <linearGradient id="incSparkGradient" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="var(--inc-accent-500)" />
                                <stop offset="100%" stop-color="var(--inc-accent-500)" stop-opacity="0" />
                            </linearGradient>
                        </defs>
                        <path class="fill" d="M0,70 L40,55 L80,60 L120,40 L160,45 L200,25 L240,35 L280,20 L320,30 L360,15 L400,22 L400,90 L0,90 Z" />
                        <path class="line" d="M0,70 L40,55 L80,60 L120,40 L160,45 L200,25 L240,35 L280,20 L320,30 L360,15 L400,22" />
                        <circle cx="400" cy="22" r="4" />
                    </svg>
                </div>

                <!-- Incidencias recientes -->
                <div class="inc-anim-fade-up">
                    <SectionHeader Title="Incidencias recientes" Icon="layers"
                                   LinkText="Ver todas" LinkHref="/incidencias/lista" />
                    <div class="inc-list-grid">
                        @foreach (var inc in RecentIncidents)
                        {
                            <IncidentCard Id="@inc.Id" Title="@inc.Title" Description="@inc.Description"
                                          Priority="@inc.Priority" PriorityLabel="@inc.PriorityLabel"
                                          Status="@inc.Status" StatusLabel="@inc.StatusLabel"
                                          Area="@inc.Area" AreaIcon="@inc.AreaIcon"
                                          Responsible="@inc.Responsible" TimeAgo="@inc.TimeAgo"
                                          SlaState="@inc.SlaState" SlaLabel="@inc.SlaLabel" />
                        }
                    </div>
                </div>

            </div>

            <!-- Columna lateral -->
            <div style="display:flex; flex-direction:column; gap: var(--inc-s-6);">

                <div class="inc-card inc-card--pad-lg inc-anim-fade-up">
                    <SectionHeader Title="Áreas más ocupadas" Icon="server" />
                    <div class="inc-area-load">
                        @foreach (var area in AreaLoad)
                        {
                            <div class="inc-area-load__row">
                                <div class="inc-area-load__icon"><IconSvg Name="@area.Icon" /></div>
                                <div class="inc-area-load__info">
                                    <div class="inc-area-load__top">
                                        <span class="inc-area-load__name">@area.Name</span>
                                        <span class="inc-area-load__count">@area.Count incidencias</span>
                                    </div>
                                    <div class="inc-area-load__bar">
                                        <div class="inc-area-load__fill" style="width:@(area.Percent)%;"></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="inc-card inc-card--pad-lg inc-anim-fade-up">
                    <SectionHeader Title="Responsables destacados" Icon="users" />
                    <div class="inc-responsibles">
                        @foreach (var person in TopResponsibles)
                        {
                            <div class="inc-responsible-row">
                                <UserAvatar Name="@person.Name" Size="md" />
                                <div class="inc-responsible-row__info">
                                    <div class="inc-responsible-row__name">@person.Name</div>
                                    <div class="inc-responsible-row__role">@person.Role</div>
                                </div>
                                <div class="inc-responsible-row__stat">
                                    <strong>@person.Resolved</strong>
                                    <span>resueltas</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="inc-card inc-card--pad-lg inc-anim-fade-up">
                    <SectionHeader Title="Actividad reciente" Icon="clock" />
                    <div class="inc-feed">
                        @foreach (var item in ActivityFeed)
                        {
                            <div class="inc-feed__item">
                                <div class="inc-feed__icon" style="background:@item.IconBg; color:@item.IconColor;">
                                    <IconSvg Name="@item.Icon" />
                                </div>
                                <div>
                                    <div class="inc-feed__text">@((MarkupString)item.Text)</div>
                                    <div class="inc-feed__time">@item.Time</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

