:root {
    --davi-red: #C8102E;
    --davi-red-dark: #9E0C24;
    --davi-magenta: #9C1457;

    --gray-50: #FAFAFA;
    --gray-100: #F4F4F6;
    --gray-200: #E8E8EC;
    --gray-300: #D5D5DC;
    --gray-500: #8C8D97;
    --gray-700: #4B4C55;
    --gray-900: #23242A;

    --radius-lg: 24px;
    --radius-sm: 14px;

    --shadow-card: 0 30px 70px -30px rgba(24, 24, 40, 0.20), 0 2px 8px rgba(24, 24, 40, 0.04);
    --shadow-btn: 0 12px 24px -10px rgba(200, 16, 46, 0.45);

    --transition-fast: 200ms ease;
    --transition-med: 300ms ease;
}

/* ---------- Screen & background ---------- */

.login-screen {
    position: relative;
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-50);
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    padding: 24px;
}

.login-background {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
}

.blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.5;
}

.blob--top {
    width: 520px;
    height: 520px;
    top: -180px;
    left: -160px;
    background: radial-gradient(circle at 30% 30%, rgba(200, 16, 46, 0.16), rgba(200, 16, 46, 0) 70%);
}

.blob--bottom {
    width: 620px;
    height: 620px;
    bottom: -220px;
    right: -180px;
    background: radial-gradient(circle at 70% 70%, rgba(156, 20, 87, 0.14), rgba(156, 20, 87, 0) 70%);
}

/* Signature "ribbon" — banda difusa de fondo (antes se veía como una línea fina) */
.ribbon {
    position: absolute;
    width: 160%;
    height: 140px;
    left: -30%;
    top: 50%;
    background: linear-gradient(90deg,
        rgba(200, 16, 46, 0) 0%,
        rgba(200, 16, 46, 0.10) 35%,
        rgba(156, 20, 87, 0.07) 65%,
        rgba(156, 20, 87, 0) 100%);
    transform: rotate(-5deg) translateY(-50%);
    filter: blur(45px);
}

/* ---------- Card ---------- */

.login-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 440px;
    background: #FFFFFF;
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 44px 40px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    animation: card-in var(--transition-med) ease both;
}

@keyframes card-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ---------- Brand ---------- */

.brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-bottom: 30px;
}

.brand__mark {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--davi-red);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
}

.brand__mark::before {
    content: "";
    width: 20px;
    height: 20px;
    background: linear-gradient(90deg,
        rgba(255, 255, 255, 0.95) 0%,
        rgba(255, 255, 255, 0.95) 50%,
        rgba(255, 255, 255, 0.65) 50%,
        rgba(255, 255, 255, 0.65) 100%);
    clip-path: polygon(50% 6%, 100% 20%, 100% 94%, 50% 100%, 0 94%, 0 20%);
}

.brand__title {
    margin: 0;
    font-size: 24px;
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--gray-900);
}

.brand__subtitle {
    margin: 6px 0 0;
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--gray-500);
    max-width: 300px;
}

/* ---------- Form layout ---------- */

.login-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-align: left;
}

.field {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.field label {
    font-size: 13px;
    font-weight: 600;
    color: var(--gray-700);
}

.field__control {
    position: relative;
    display: flex;
    align-items: center;
}

/* Ícono centrado verticalmente de forma explícita y con más aire respecto al borde */
.field__icon {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gray-500);
    opacity: 0.7;
    pointer-events: none;
    z-index: 1;
    transition: color var(--transition-fast), opacity var(--transition-fast);
}

/* Detalle sutil: el ícono se tiñe de rojo cuando el campo tiene foco */
.field__control:focus-within .field__icon {
    color: var(--davi-red);
    opacity: 1;
}

.field__toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    border-radius: 999px;
    cursor: pointer;
    color: var(--gray-500);
    opacity: 0.75;
    transition: opacity var(--transition-fast), background var(--transition-fast);
}

.field__toggle:hover {
    opacity: 1;
    background: var(--gray-100);
}

.field__toggle:disabled {
    cursor: not-allowed;
    opacity: 0.3;
}

.field__error {
    font-size: 12.5px;
    color: var(--davi-red-dark);
}

/* ---------- Inputs ---------- */

.input {
    width: 100%;
    height: 52px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--gray-200);
    background: var(--gray-50);
    padding: 0 16px 0 50px;
    font-size: 14.5px;
    color: var(--gray-900);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
}

.input::placeholder { color: var(--gray-500); }

.input:hover:not(:disabled) {
    border-color: var(--gray-300);
    background: #FFFFFF;
}

.input:focus {
    border-color: var(--davi-red);
    background: #FFFFFF;
    box-shadow: 0 0 0 4px rgba(200, 16, 46, 0.10);
}

.input:disabled {
    background: var(--gray-100);
    color: var(--gray-500);
    cursor: not-allowed;
}

.input--error {
    border-color: rgba(200, 16, 46, 0.55);
    background: rgba(200, 16, 46, 0.03);
}

#password { padding-right: 46px; }

/* ---------- Checkbox ---------- */

.field--inline { flex-direction: row; align-items: center; }

.checkbox {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    color: var(--gray-700);
    cursor: pointer;
    user-select: none;
    position: relative;
}

.checkbox input {
    position: absolute;
    opacity: 0;
    width: 18px;
    height: 18px;
    margin: 0;
    cursor: pointer;
}

.checkbox__box {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    border: 1.5px solid var(--gray-300);
    background: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition-fast), border-color var(--transition-fast);
    flex: none;
}

.checkbox input:checked + .checkbox__box {
    background: var(--davi-red);
    border-color: var(--davi-red);
}

.checkbox input:checked + .checkbox__box::after {
    content: "";
    width: 5px;
    height: 9px;
    border: solid white;
    border-width: 0 1.6px 1.6px 0;
    transform: rotate(45deg) translate(-1px, -1px);
}

.checkbox input:focus-visible + .checkbox__box {
    outline: 2px solid var(--davi-red);
    outline-offset: 2px;
}

/* ---------- Primary button ---------- */

.btn-primary {
    height: 52px;
    border: none;
    border-radius: var(--radius-sm);
    background: linear-gradient(180deg, var(--davi-red) 0%, var(--davi-red-dark) 100%);
    color: #fff;
    font-size: 15px;
    font-weight: 650;
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    box-shadow: var(--shadow-btn);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), filter var(--transition-fast);
    width: 100%;
}

.btn-primary:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 16px 30px -10px rgba(200, 16, 46, 0.5);
}

.btn-primary:active:not(:disabled) {
    transform: translateY(0);
    filter: brightness(0.96);
    box-shadow: 0 8px 16px -8px rgba(200, 16, 46, 0.45);
}

.btn-primary:disabled { cursor: not-allowed; opacity: 0.85; }

.btn-primary:focus-visible {
    outline: 2px solid var(--davi-red-dark);
    outline-offset: 3px;
}

.spinner {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-top-color: #fff;
    animation: spin 700ms linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ---------- Alert (inline error) ---------- */

.alert {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    animation: fade-in var(--transition-fast) ease both;
}

.alert--error {
    background: rgba(200, 16, 46, 0.06);
    color: var(--davi-red-dark);
    border: 1px solid rgba(200, 16, 46, 0.18);
}

@keyframes fade-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ---------- Footer ---------- */

.help-link {
    margin-top: 22px;
    font-size: 13px;
    color: var(--gray-500);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.help-link:hover { color: var(--davi-red); }

/* Badge "Conexión segura" — detalle nuevo, mismo lenguaje visual que el resto */
.secure-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 18px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--gray-500);
}

.secure-badge .icon-shield {
    width: 13px;
    height: 14px;
    position: relative;
    flex: none;
    color: var(--gray-500);
    opacity: 0.8;
}

.icon-shield::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 1.4px solid currentColor;
    clip-path: polygon(50% 0%, 100% 18%, 100% 55%, 50% 100%, 0 55%, 0 18%);
    border-radius: 2px;
}

.icon-shield::after {
    content: "";
    position: absolute;
    top: 45%;
    left: 50%;
    width: 3.5px;
    height: 5.5px;
    border: solid currentColor;
    border-width: 0 1.3px 1.3px 0;
    transform: translate(-50%, -60%) rotate(45deg);
}

.footer-note {
    margin: 10px 0 0;
    font-size: 11.5px;
    color: var(--gray-300);
}

/* ============================================================
   CSS-only icons (no SVG, no images) — built from spans/divs
   using borders, border-radius and clip-path.
   ============================================================ */

.icon {
    position: relative;
    width: 18px;
    height: 18px;
    display: inline-block;
    flex: none;
}

.icon-user__head {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 7px;
    height: 7px;
    border: 1.6px solid currentColor;
    border-radius: 50%;
}

.icon-user__body {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 15px;
    height: 8px;
    border: 1.6px solid currentColor;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
}

.icon-lock__shackle {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 9px;
    border: 1.6px solid currentColor;
    border-bottom: none;
    border-radius: 6px 6px 0 0;
}

.icon-lock__body {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 10px;
    border: 1.6px solid currentColor;
    border-radius: 3px;
}

.icon-lock__hole {
    position: absolute;
    top: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 2.4px;
    height: 2.4px;
    border-radius: 50%;
    background: currentColor;
}

.icon-eye__outer {
    position: absolute;
    inset: 2px 0;
    border: 1.6px solid currentColor;
    border-radius: 50% / 60%;
}

.icon-eye__pupil {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    transform: translate(-50%, -50%);
}

.icon-eye__slash {
    display: none;
    position: absolute;
    top: 50%;
    left: -1px;
    width: 20px;
    height: 1.6px;
    background: currentColor;
    border-radius: 2px;
    transform: translateY(-50%) rotate(-40deg);
}

.icon-eye--off .icon-eye__outer { opacity: 0.45; }
.icon-eye--off .icon-eye__slash { display: block; }

.icon-alert {
    border-radius: 50%;
    border: 1.6px solid currentColor;
    flex: none;
}

.icon-alert::before {
    content: "";
    position: absolute;
    top: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 1.6px;
    height: 6px;
    background: currentColor;
    border-radius: 1px;
}

.icon-alert::after {
    content: "";
    position: absolute;
    bottom: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 1.6px;
    height: 1.6px;
    border-radius: 50%;
    background: currentColor;
}

/* ---------- Responsive ---------- */

@media (max-width: 480px) {
    .login-card { padding: 36px 24px 26px; border-radius: 20px; }
    .brand__subtitle { max-width: 100%; }
}

/* ---------- Reduced motion ---------- */

@media (prefers-reduced-motion: reduce) {
    .login-card, .alert, .btn-primary, .spinner {
        animation: none !important;
        transition: none !important;
    }
}
