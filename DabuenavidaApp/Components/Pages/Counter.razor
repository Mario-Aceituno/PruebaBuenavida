private bool _editingContent;
private List<ArticleContentBlock> _contentDraft = new();

private void StartEditContent()
{
    if (_detail is null) return;
    _contentDraft = _detail.Content.Select(b => new ArticleContentBlock
    {
        Id = b.Id, Type = b.Type, Order = b.Order, Text = b.Text, Meta = b.Meta,
        Urls = new List<string>(b.Urls),
        TableRows = b.TableRows.Select(r => new List<string>(r)).ToList()
    }).ToList();
    _editingContent = true;
}

private void SaveContent()
{
    if (_detail is null) return;
    Incidents.UpdateIncidentContent(_detail.Id, _contentDraft, ActorId);
    _editingContent = false;
    LoadDetail();
}

private void CancelEditContent()
{
    _editingContent = false;
}

<div class="card" style="padding: var(--space-6); margin-bottom: var(--space-6);">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: var(--space-3);">
        <h4 class="widget__title"><Icon Name="file-text" />Descripción</h4>
        @if (!_editingContent)
        {
            <button class="btn btn--secondary btn--sm" @onclick="StartEditContent">
                <Icon Name="pencil" /> Editar
            </button>
        }
    </div>

    @if (_editingContent)
    {
        <Editra @bind-Blocks="_contentDraft" />
        <div class="form-actions" style="margin-top: var(--space-3);">
            <button class="btn btn--secondary btn--sm" @onclick="CancelEditContent">Cancelar</button>
            <button class="btn btn--primary btn--sm" @onclick="SaveContent">
                <Icon Name="check-circle" /> Guardar
            </button>
        </div>
    }
    else if (_detail.Content is { Count: > 0 })
    {
        <ArticleBody Blocks="_detail.Content" />
    }
    else
    {
        <p>@_detail.Description</p>
    }
</div>