    private record IncidentItem(string Id, string Title, string Description, string Priority, string PriorityLabel,
        string Status, string StatusLabel, string Area, string AreaIcon, string Responsible, string TimeAgo,
        string SlaState, string SlaLabel);
    private record AreaLoadItem(string Name, string Icon, int Count, int Percent);
    private record ResponsibleItem(string Name, string Role, int Resolved);
    private record FeedItem(string Icon, string IconBg, string IconColor, string Text, string Time);

    private readonly List<BarItem> WeekBars = new()
