@page "/perfil"
@inject IWikiDataService Data

<PageTitle>Wiki — Mi Perfil</PageTitle>

<div class="profile-page">
    <div class="profile-header card">
        <div class="profile-header__avatar">
            <span class="avatar avatar--xl" style="background:linear-gradient(135deg,#C41230,#8B0E25)">CM</span>
        </div>
        <div class="profile-header__info">
            <h1>Hiavert Maldonado</h1>
            <p class="profile-header__role">DEV Jr · Desarrollador Jr de Blazor</p>
            <p class="profile-header__bio">
                Desarrollador Junior del área de Tecnología del banco. Técnico en diseño de soluciones
                empresariales con .NET y Blazor. Contribuidor activo a la documentación interna desde 2026.
            </p>
            <div class="profile-header__badges">
                <span class="badge badge--brand">Desarrollador</span>
                <span class="badge badge--brand">Practicante</span>
                <span class="badge badge--brand">Buena Onda</span>
            </div>
        </div>
        <div class="profile-header__stats">
            <div class="author-stat">
                <span class="author-stat__value">@_myArticles.Count</span>
                <span class="author-stat__label">Artículos</span>
            </div>
            <div class="author-stat">
                <span class="author-stat__value">@_totalViews</span>
                <span class="author-stat__label">Vistas</span>
            </div>
            <div class="author-stat">
                <span class="author-stat__value">@_favorites.Count</span>
                <span class="author-stat__label">Favoritos</span>
            </div>
            <div class="author-stat">
                <span class="author-stat__value">@_history.Count</span>
                <span class="author-stat__label">Leídos</span>
            </div>
        </div>
    </div>

    @* ===================================================================
       SECCIÓN: BORRADORES
       Ubicada debajo de la info de perfil y antes de cualquier otra
       sección de la página (artículos, favoritos, actividad, etc).
       =================================================================== *@
    <section class="section drafts-section">
        <SectionHeader Title="Borradores" Subtitle="Artículos que empezaste y todavía no publicaste" />

        @if (_drafts.Count == 0)
        {
            <div class="card drafts-empty">
                <div class="drafts-empty__icon">
                    <Icon Name="file-x" />
                </div>
                <p class="drafts-empty__text">No tienes borradores guardados.</p>
                <a class="btn btn--primary" href="/articulos/nuevo">
                    <Icon Name="plus" /> Crear nuevo artículo
                </a>
            </div>
        }
        else
        {
            <div class="drafts-grid">
                @foreach (var draft in _drafts)
                {
                    <div class="card draft-card">
                        <div class="draft-card__top">
                            <span class="draft-card__icon"><Icon Name="file-edit" /></span>
                            <span class="badge badge--amber">Borrador</span>
                        </div>

                        <h3 class="draft-card__title">@draft.Title</h3>

                        <div class="draft-card__meta">
                            <span><Icon Name="folder" /> @draft.Category</span>
                            <span><Icon Name="calendar" /> Editado @Relative(draft.LastEdited)</span>
                        </div>

                        <p class="draft-card__summary">@draft.Summary</p>

                        <div class="draft-progress">
                            <div class="draft-progress__bar">
                                <div class="draft-progress__fill" style="width:@(draft.Progress)%"></div>
                            </div>
                            <span class="draft-progress__label">@draft.Progress% completado</span>
                        </div>

                        <div class="draft-card__actions">
                            <a class="btn btn--primary btn--sm" href="/articulos/nuevo">
                                <Icon Name="pencil" /> Continuar editando
                            </a>
                            <button type="button" class="btn btn--ghost btn--sm btn--danger" @onclick="() => RemoveDraft(draft)">
                                <Icon Name="trash-2" /> Eliminar
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <div class="profile-body">
        <div>
            <section class="section">
                <SectionHeader Title="Mis artículos" Subtitle="Documentación que he publicado" LinkHref="/explorar" />
                <div class="widget card">
                    @foreach (var dto in _myCards.Take(6))
                    {
                        <ArticleListItem Article="dto.Article"
                                         Icon="file-text"
                                         MetaText="@($"{dto.Article.ViewCount} vistas · {dto.Article.ReadingTimeMinutes} min")" />
                    }
                </div>
            </section>

            <section class="section">
                <SectionHeader Title="Artículos favoritos" LinkHref="/favoritos" />
                @if (_favCards.Count > 0)
                {
                    <div class="article-grid">
                        @foreach (var dto in _favCards.Take(3))
                        {
                            <ArticleCard Dto="dto" />
                        }
                    </div>
                }
                else
                {
                    <p style="color:var(--text-tertiary); font-size:var(--fs-sm);">Sin favoritos guardados.</p>
                }
            </section>
        </div>

        <aside>
            <section class="section">
                <h4 class="widget__title"><Icon Name="activity" /> Actividad reciente</h4>
                <div class="widget card">
                    @foreach (var item in _activity)
                    {
                        <div class="activity-row">
                            <span class="activity-row__avatar">CM</span>
                            <div>
                                <p class="activity-row__text">@item.Description</p>
                                <p class="activity-row__time">@Relative(item.OccurredAt)</p>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section class="section">
                <h4 class="widget__title"><Icon Name="history" /> Historial reciente</h4>
                <div class="widget card">
                    @foreach (var dto in _history.Take(5))
                    {
                        <ArticleListItem Article="dto.Article" Icon="clock"
                                         MetaText="@Relative(dto.Article.UpdatedAt)"
                                         ShowChevron="false" />
                    }
                </div>
            </section>
        </aside>
    </div>
</div>

@code {
    private List<ArticleCardDto> _myCards  = new();
    private List<Article>        _myArticles = new();
    private List<ArticleCardDto> _favCards  = new();
    private List<ArticleCardDto> _history   = new();
    private List<Article>        _favorites = new();
    private List<ActivityItem>   _activity  = new();
    private string _totalViews = "0";

    // ---- Borradores (hardcoded, sin persistencia real) ----
    private List<DraftArticle> _drafts = new();

    protected override void OnInitialized()
    {
        var me = Data.GetAuthors().FirstOrDefault();
        if (me is null) return;

        _myArticles = Data.GetArticlesByAuthor(me.Id).ToList();
        _myCards    = Data.ToCardDtos(_myArticles).ToList();
        _favorites  = Data.GetFavoriteArticles().ToList();
        _favCards   = Data.ToCardDtos(_favorites).ToList();
        _history    = Data.ToCardDtos(Data.GetHistoryArticles(10)).ToList();
        _activity   = Data.GetRecentActivity(20)
                          .Where(a => a.AuthorId == me.Id)
                          .Take(6).ToList();

        var views = _myArticles.Sum(a => a.ViewCount);
        _totalViews = views >= 1000 ? $"{views / 1000.0:0.#}k" : views.ToString();

        _drafts = BuildDrafts()
            .OrderByDescending(d => d.LastEdited)
            .ToList();
    }

    private static List<DraftArticle> BuildDrafts() => new()
    {
        new DraftArticle
        {
            Title = "Procedimiento de recuperación de credenciales Active Directory",
            Category = "Seguridad de la Información",
            LastEdited = DateTime.UtcNow.AddHours(-3),
            Summary = "Pasos para restablecer contraseñas y desbloquear cuentas de usuario en AD cuando el autoservicio no está disponible.",
            Progress = 85
        },
        new DraftArticle
        {
            Title = "Guía de despliegue de aplicaciones internas",
            Category = "Desarrollo",
            LastEdited = DateTime.UtcNow.AddDays(-1),
            Summary = "Checklist y buenas prácticas para publicar nuevas versiones en los ambientes de staging y producción.",
            Progress = 60
        },
        new DraftArticle
        {
            Title = "Configuración de VPN corporativa",
            Category = "Redes",
            LastEdited = DateTime.UtcNow.AddDays(-2),
            Summary = "Instrucciones para instalar y configurar el cliente de VPN institucional en equipos Windows y macOS.",
            Progress = 45
        },
        new DraftArticle
        {
            Title = "Administración de permisos en SharePoint",
            Category = "Infraestructura",
            LastEdited = DateTime.UtcNow.AddDays(-4),
            Summary = "Cómo asignar, heredar y auditar permisos sobre sitios y bibliotecas de documentos corporativos.",
            Progress = 30
        },
        new DraftArticle
        {
            Title = "Protocolo de atención de incidencias críticas",
            Category = "Soporte Técnico",
            LastEdited = DateTime.UtcNow.AddDays(-6),
            Summary = "Flujo de escalamiento, tiempos de respuesta y responsables durante un incidente de severidad 1.",
            Progress = 20
        }
    };

    private void RemoveDraft(DraftArticle draft)
    {
        // Demo visual: solo remueve de la lista en memoria.
        _drafts.Remove(draft);
    }

    private static string Relative(DateTime d)
    {
        var diff = DateTime.UtcNow - d;
        if (diff.TotalHours < 1)  return "hace minutos";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours}h";
        if (diff.TotalDays < 30)  return $"hace {(int)diff.TotalDays}d";
        return d.ToString("d MMM yyyy");
    }

    private class DraftArticle
    {
        public string Title { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public DateTime LastEdited { get; set; }
        public string Summary { get; set; } = string.Empty;
        public int Progress { get; set; }
    }
}









/* =========================================================================
   CorpWiki — Sección Borradores (Perfil)
   ========================================================================= */

.drafts-section { margin-bottom: var(--space-2); }

.drafts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
}

.draft-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    border: 1px solid var(--border-subtle);
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
}
.draft-card:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.draft-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.draft-card__icon {
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    background: var(--bg-surface-2);
    color: var(--brand-500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.draft-card__title {
    font-size: var(--fs-md);
    line-height: 1.35;
    margin: 0;
}

.draft-card__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
}
.draft-card__meta span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--fs-xs);
    color: var(--text-tertiary);
}
.draft-card__meta .icon { width: 13px; height: 13px; }

.draft-card__summary {
    font-size: var(--fs-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Badge ámbar (estado Borrador) */
.badge--amber {
    background: rgba(245, 158, 11, 0.14);
    color: #b45309;
    border: 1px solid rgba(245, 158, 11, 0.35);
    font-weight: 700;
    font-size: var(--fs-xs);
    padding: 3px 10px;
    border-radius: var(--radius-full);
}
[data-theme="dark"] .badge--amber { color: #f59e0b; }

/* Progreso */
.draft-progress { display: flex; flex-direction: column; gap: 6px; }
.draft-progress__bar {
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--bg-surface-3);
    overflow: hidden;
}
.draft-progress__fill {
    height: 100%;
    border-radius: var(--radius-full);
    background: linear-gradient(90deg, var(--accent-amber), #f97316);
    transition: width 0.3s ease;
}
.draft-progress__label {
    font-size: var(--fs-xs);
    color: var(--text-tertiary);
    font-weight: 600;
}

.draft-card__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: var(--space-1);
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-subtle);
}
.draft-card__actions .btn--sm {
    padding: 6px 12px;
    font-size: var(--fs-xs);
}
.btn--danger { color: var(--brand-500); }
.btn--danger:hover { background: rgba(218,31,61,0.1); }

/* Estado vacío */
.drafts-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-3);
    padding: var(--space-8) var(--space-6);
}
.drafts-empty__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--bg-surface-2);
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
}
.drafts-empty__icon .icon { width: 26px; height: 26px; }
.drafts-empty__text {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
}

@media (max-width: 640px) {
    .drafts-grid { grid-template-columns: 1fr; }
    .draft-card__actions { flex-direction: column; align-items: stretch; }
    .draft-card__actions .btn { width: 100%; justify-content: center; }
}









@page "/articulos/nuevo"
@inject IWikiDataService Data
@inject NavigationManager Nav

<PageTitle>CorpWiki — Nuevo Artículo</PageTitle>

<Breadcrumb Items="_breadcrumb" />

<div class="page-header">
    <div>
        <h1>Nuevo Artículo</h1>
        <p>Documentación técnica para el área de Tecnología. Completá los metadatos, escribí el contenido y enviá a revisión.</p>
    </div>
    <span class="badge badge--amber">@_model.Estado</span>
</div>

<EditForm Model="_model" OnSubmit="() => {}">
<DataAnnotationsValidator />

<div class="article-layout">
    <div class="article-main article-main--form">

        @* ============================= METADATOS ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="file-text" /> Información general</h3>

            <div class="form-group">
                <label class="form-label" for="art-title">Título <span class="form-required">*</span></label>
                <InputText id="art-title" class="input" @bind-Value="_model.Title" placeholder="Ej: Cómo solicitar acceso a la VPN corporativa" />
                <ValidationMessage For="() => _model.Title" class="form-hint form-hint--error" />
            </div>

            <div class="form-group">
                <label class="form-label" for="art-summary">Resumen <span class="form-required">*</span></label>
                <textarea id="art-summary" class="input" rows="3" @bind="_model.Summary"
                          placeholder="Resumen breve que aparece en las tarjetas y en resultados de búsqueda"></textarea>
            </div>

            <div class="field-grid field-grid--3">
                <div class="form-group">
                    <label class="form-label">Categoría <span class="form-required">*</span></label>
                    <select class="input" @bind="_model.CategoryId">
                        <option value="">Seleccioná</option>
                        @foreach (var category in _categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Subcategoría</label>
                    <select class="input" @bind="_model.Subcategory">
                        <option value="">Seleccioná</option>
                        @foreach (var sub in _subcategories)
                        {
                            <option value="@sub">@sub</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Área responsable</label>
                    <select class="input" @bind="_model.AreaResponsable">
                        <option value="">Seleccioná</option>
                        @foreach (var area in _areas)
                        {
                            <option value="@area">@area</option>
                        }
                    </select>
                </div>
            </div>

            <div class="field-grid field-grid--3">
                <div class="form-group">
                    <label class="form-label">Autor <span class="form-required">*</span></label>
                    <select class="input" @bind="_model.AuthorId">
                        <option value="">Seleccioná</option>
                        @foreach (var author in _authors)
                        {
                            <option value="@author.Id">@author.FullName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Nivel de acceso</label>
                    <select class="input" @bind="_model.NivelAcceso">
                        @foreach (var nivel in _nivelesAcceso)
                        {
                            <option value="@nivel">@nivel</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Prioridad</label>
                    <select class="input" @bind="_model.Prioridad">
                        @foreach (var p in _prioridades)
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>
            </div>

            <div class="field-grid field-grid--3">
                <div class="form-group">
                    <label class="form-label">Fecha de creación</label>
                    <input type="date" class="input" @bind="_model.FechaCreacion" />
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha de actualización</label>
                    <input type="date" class="input" @bind="_model.FechaActualizacion" />
                </div>
                <div class="form-group">
                    <label class="form-label">Versión del documento</label>
                    <input type="text" class="input" @bind="_model.Version" placeholder="v1.0" />
                </div>
            </div>

            <div class="field-grid field-grid--2">
                <div class="form-group">
                    <label class="form-label">Estado</label>
                    <select class="input" @bind="_model.Estado">
                        <option value="Borrador">Borrador</option>
                        <option value="En revisión">En revisión</option>
                        <option value="Publicado">Publicado</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Tiempo estimado de lectura</label>
                    <input type="text" class="input readonly-field" value="@_readingTime min" readonly />
                    <p class="form-hint">Calculado automáticamente en base al contenido del cuerpo del artículo.</p>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Sistemas relacionados</label>
                <div class="tag-cloud">
                    @foreach (var sistema in _sistemasDisponibles)
                    {
                        var active = _model.SistemasRelacionados.Contains(sistema);
                        <button type="button" class="chip @(active ? "chip--active" : "")" @onclick="() => ToggleSistema(sistema)">
                            @sistema
                        </button>
                    }
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Palabras clave (tags)</label>
                <div class="tag-input-row">
                    <input class="input" @bind="_newTag" @bind:event="oninput" @onkeydown="OnTagKeyDown" placeholder="Escribí una palabra clave y presioná Enter" />
                    <button type="button" class="btn btn--secondary btn--sm" @onclick="AddTag"><Icon Name="plus" /> Agregar</button>
                </div>
                @if (_model.Tags.Count > 0)
                {
                    <div class="tag-cloud">
                        @foreach (var tag in _model.Tags)
                        {
                            <span class="chip chip--active">
                                @tag
                                <button type="button" class="chip__remove" @onclick="() => _model.Tags.Remove(tag)">×</button>
                            </span>
                        }
                    </div>
                }
            </div>
        </div>

        @* ============================= ADJUNTOS ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="paperclip" /> Adjuntos y referencias</h3>

            <div class="field-grid field-grid--2">
                <div class="form-group">
                    <label class="form-label">Archivos adjuntos</label>
                    <div class="attachment-list">
                        @foreach (var file in _model.ArchivosAdjuntos)
                        {
                            <div class="file-row">
                                <span class="file-row__icon"><Icon Name="file" /></span>
                                <div class="file-row__info">
                                    <span class="file-row__name">@file</span>
                                    <span class="file-row__meta">Adjunto</span>
                                </div>
                                <button type="button" class="icon-btn icon-btn--danger" @onclick="() => _model.ArchivosAdjuntos.Remove(file)">
                                    <Icon Name="x" />
                                </button>
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn--secondary btn--sm" @onclick='() => _model.ArchivosAdjuntos.Add($"documento-{_model.ArchivosAdjuntos.Count + 1}.pdf")'>
                        <Icon Name="upload" /> Subir archivo
                    </button>
                </div>

                <div class="form-group">
                    <label class="form-label">Imágenes</label>
                    <div class="attachment-list">
                        @foreach (var img in _model.Imagenes)
                        {
                            <div class="file-row">
                                <span class="file-row__icon"><Icon Name="image" /></span>
                                <div class="file-row__info">
                                    <span class="file-row__name">@img</span>
                                    <span class="file-row__meta">Imagen</span>
                                </div>
                                <button type="button" class="icon-btn icon-btn--danger" @onclick="() => _model.Imagenes.Remove(img)">
                                    <Icon Name="x" />
                                </button>
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn--secondary btn--sm" @onclick='() => _model.Imagenes.Add($"imagen-{_model.Imagenes.Count + 1}.png")'>
                        <Icon Name="upload" /> Subir imagen
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Enlaces relacionados</label>
                <div class="link-row">
                    <input class="input" @bind="_newLinkLabel" placeholder="Texto del enlace" />
                    <input class="input" @bind="_newLinkUrl" placeholder="https://..." />
                    <button type="button" class="btn btn--secondary btn--sm" @onclick="AddLink"><Icon Name="plus" /></button>
                </div>
                @foreach (var link in _model.EnlacesRelacionados)
                {
                    <div class="external-link-row">
                        <Icon Name="link" />
                        <span style="flex:1">@link.Label</span>
                        <button type="button" class="icon-btn icon-btn--danger" @onclick="() => _model.EnlacesRelacionados.Remove(link)">
                            <Icon Name="x" />
                        </button>
                    </div>
                }
            </div>

            <div class="form-group">
                <label class="form-label">Referencias</label>
                <textarea class="input" rows="3" @bind="_model.Referencias" placeholder="Manuales, normativas o documentos fuente utilizados"></textarea>
            </div>
        </div>

        @* ============================= EDITOR ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="edit-3" /> Cuerpo del artículo</h3>

            <div class="editor-toolbar">
                <div class="editor-toolbar__group">
                    <button type="button" class="editor-toolbar__btn" title="Encabezado 1" @onclick='() => InsertSnippet("# Título")'><Icon Name="heading-1" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Encabezado 2" @onclick='() => InsertSnippet("## Subtítulo")'><Icon Name="heading-2" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Encabezado 3" @onclick='() => InsertSnippet("### Sección")'><Icon Name="heading-3" /></button>
                </div>
                <div class="editor-toolbar__group">
                    <button type="button" class="editor-toolbar__btn" title="Negrita" @onclick='() => InsertSnippet("**texto en negrita**")'><Icon Name="bold" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Cursiva" @onclick='() => InsertSnippet("*texto en cursiva*")'><Icon Name="italic" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Subrayado" @onclick='() => InsertSnippet("<u>texto subrayado</u>")'><Icon Name="underline" /></button>
                </div>
                <div class="editor-toolbar__group">
                    <button type="button" class="editor-toolbar__btn" title="Lista numerada" @onclick='() => InsertSnippet("1. Elemento uno\n2. Elemento dos")'><Icon Name="list-ordered" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Lista con viñetas" @onclick='() => InsertSnippet("- Elemento\n- Elemento")'><Icon Name="list" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Checklist" @onclick='() => InsertSnippet("- [ ] Tarea pendiente\n- [x] Tarea realizada")'><Icon Name="check-square" /></button>
                </div>
                <div class="editor-toolbar__group">
                    <button type="button" class="editor-toolbar__btn" title="Tabla" @onclick='() => InsertSnippet("| Columna 1 | Columna 2 |\n|---|---|\n| Valor | Valor |")'><Icon Name="table" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Bloque de código" @onclick='() => InsertSnippet("```\nvar x = 1;\n```")'><Icon Name="code" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Cita" @onclick='() => InsertSnippet("> Cita textual")'><Icon Name="quote" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Hipervínculo" @onclick='() => InsertSnippet("[texto del enlace](https://)")'><Icon Name="link" /></button>
                </div>
                <div class="editor-toolbar__group">
                    <button type="button" class="editor-toolbar__btn" title="Imagen" @onclick='() => InsertSnippet("

![descripción](url-de-imagen)

")'><Icon Name="image" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Separador" @onclick='() => InsertSnippet("---")'><Icon Name="minus" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Expandible" @onclick='() => InsertSnippet("<details><summary>Ver más</summary>\nContenido oculto\n</details>")'><Icon Name="chevron-down" /></button>
                </div>
                <div class="editor-toolbar__group">
                    <button type="button" class="editor-toolbar__btn" title="Nota" @onclick='() => InsertSnippet(":::note\nEsto es una nota.\n:::")'><Icon Name="sticky-note" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Advertencia" @onclick='() => InsertSnippet(":::warning\nEsto es una advertencia.\n:::")'><Icon Name="alert-triangle" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Información" @onclick='() => InsertSnippet(":::info\nEsto es información adicional.\n:::")'><Icon Name="info" /></button>
                </div>
                <div class="editor-toolbar__group">
                    <button type="button" class="editor-toolbar__btn" title="Color de texto" @onclick='() => InsertSnippet("{color:#C41230}texto en color{/color}")'><Icon Name="palette" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Resaltar" @onclick='() => InsertSnippet("==texto resaltado==")'><Icon Name="highlighter" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Alinear" @onclick='() => InsertSnippet(":::center\ntexto centrado\n:::")'><Icon Name="align-center" /></button>
                </div>
                <div class="editor-toolbar__group">
                    <button type="button" class="editor-toolbar__btn" title="Deshacer" @onclick="Undo" disabled="@(_undoStack.Count == 0)"><Icon Name="undo-2" /></button>
                    <button type="button" class="editor-toolbar__btn" title="Rehacer" @onclick="Redo" disabled="@(_redoStack.Count == 0)"><Icon Name="redo-2" /></button>
                </div>
            </div>

            <textarea class="editor-canvas" rows="18" placeholder="Escribí la documentación técnica acá. Usá la barra de herramientas para insertar bloques de formato."
                      @bind="_model.Content" @bind:event="oninput" @oninput="OnContentChanged"></textarea>
            <p class="form-hint">El índice lateral se genera automáticamente a partir de los encabezados (#, ##, ###).</p>
        </div>

        @* ============================= HISTORIAL ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="history" /> Historial de cambios</h3>
            <div class="version-timeline">
                @foreach (var v in _history)
                {
                    <div class="version-row">
                        <span class="version-row__dot"></span>
                        <div>
                            <p class="version-row__label">@v.Label — @v.Author</p>
                            <p class="version-row__summary">@v.Summary</p>
                            <p class="version-row__date">@v.Date.ToString("d MMM yyyy, HH:mm")</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ============================= REVISORES ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="users" /> Revisores</h3>
            @foreach (var r in _reviewers)
            {
                <div class="reviewer-row">
                    <span class="avatar avatar--sm">@r.Initials</span>
                    <div class="reviewer-row__info">
                        <span class="reviewer-row__name">@r.Name</span>
                        <span class="reviewer-row__role">@r.Role</span>
                    </div>
                    <span class="badge @(r.StatusClass)">@r.Status</span>
                </div>
            }
        </div>

        @* ============================= APROBACIONES ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="check-circle" /> Aprobaciones</h3>
            <div class="approval-steps">
                @foreach (var step in _approvalSteps)
                {
                    <div class="approval-step approval-step--@step.State">
                        <span class="approval-step__icon">
                            <Icon Name="@(step.State == "done" ? "check" : step.State == "current" ? "clock" : "circle")" />
                        </span>
                        <span class="approval-step__label">@step.Label</span>
                    </div>
                }
            </div>
        </div>

        @* ============================= RELACIONADOS ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="folder-open" /> Documentación relacionada</h3>
            @foreach (var doc in _relatedDocs)
            {
                <div class="file-row">
                    <span class="file-row__icon"><Icon Name="file-text" /></span>
                    <div class="file-row__info">
                        <span class="file-row__name">@doc.Title</span>
                        <span class="file-row__meta">@doc.Category</span>
                    </div>
                    <Icon Name="chevron-right" Class="file-row__download" />
                </div>
            }
        </div>

        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="link-2" /> Artículos relacionados</h3>
            @foreach (var art in _relatedArticles)
            {
                <div class="file-row">
                    <span class="file-row__icon"><Icon Name="file-text" /></span>
                    <div class="file-row__info">
                        <span class="file-row__name">@art.Title</span>
                        <span class="file-row__meta">@art.Views vistas · @art.ReadingTime min</span>
                    </div>
                    <Icon Name="chevron-right" Class="file-row__download" />
                </div>
            }
        </div>

        @* ============================= OBSERVACIONES ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="lock" /> Observaciones internas</h3>
            <p class="form-hint" style="margin-bottom:var(--space-2)">Visibles solo para el equipo editorial. No se muestran en la vista pública del artículo.</p>
            <textarea class="input" rows="3" @bind="_model.ObservacionesInternas" placeholder="Notas para revisores, pendientes o contexto adicional..."></textarea>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="callout callout--danger">
                <Icon Name="alert-triangle" />
                <p>@_error</p>
            </div>
        }

        <div class="form-actions form-actions--triple">
            <button type="button" class="btn btn--secondary" @onclick="SaveAsDraft"><Icon Name="save" /> Guardar como borrador</button>
            <button type="button" class="btn btn--secondary" @onclick="SendToReview"><Icon Name="send" /> Enviar a revisión</button>
            <button type="button" class="btn btn--primary" @onclick="Publish"><Icon Name="check" /> Publicar</button>
        </div>
    </div>

    @* ============================= SIDEBAR ============================= *@
    <aside class="article-sidebar">
        <div class="toc">
            <p class="toc__title"><Icon Name="list" /> Índice del artículo</p>
            @if (_toc.Count == 0)
            {
                <p class="form-hint">Agregá encabezados en el cuerpo del artículo para generar el índice.</p>
            }
            else
            {
                @foreach (var item in _toc)
                {
                    <a class="toc__link toc__link--lvl@(item.Level)">@item.Text</a>
                }
            }
        </div>

        <div class="widget card">
            <h4 class="widget__title"><Icon Name="lightbulb" /> Consejos</h4>
            <p class="form-hint">Un buen título es específico y usa el mismo vocabulario que la gente busca ("Cómo..." o "Guía de...").</p>
            <p class="form-hint">Usá encabezados H2/H3 para dividir procedimientos largos en pasos claros.</p>
            <p class="form-hint">Marcá el nivel de acceso correcto antes de publicar información sensible.</p>
        </div>

        <div class="widget card">
            <h4 class="widget__title"><Icon Name="info" /> Resumen de metadatos</h4>
            <div class="meta-quickview">
                <span>Estado</span><strong>@_model.Estado</strong>
                <span>Versión</span><strong>@_model.Version</strong>
                <span>Prioridad</span><strong>@_model.Prioridad</strong>
                <span>Lectura</span><strong>@_readingTime min</strong>
            </div>
        </div>
    </aside>
</div>
</EditForm>

@code {
    private List<Category> _categories = new();
    private List<Author> _authors = new();
    private List<BreadcrumbItem> _breadcrumb = new()
    {
        new("Inicio", "/"),
        new("Artículos", "/articulos"),
        new("Nuevo", null)
    };

    private readonly List<string> _subcategories = new()
    {
        "Accesos y Credenciales", "Infraestructura", "Aplicaciones Internas",
        "Seguridad", "Redes", "Bases de Datos", "Soporte al Usuario"
    };
    private readonly List<string> _areas = new()
    {
        "Infraestructura", "Seguridad de la Información", "Soporte Técnico",
        "Desarrollo", "Redes", "Operaciones TI"
    };
    private readonly List<string> _nivelesAcceso = new()
    {
        "Público interno", "Confidencial", "Restringido", "Alta confidencialidad"
    };
    private readonly List<string> _prioridades = new() { "Baja", "Media", "Alta", "Crítica" };
    private readonly List<string> _sistemasDisponibles = new()
    {
        "Active Directory", "SharePoint", "VPN Corporativa", "Core Bancario", "ServiceNow", "Office 365"
    };

    private readonly ArticleFormModel _model = new();
    private string? _error;
    private string _newTag = string.Empty;
    private string _newLinkLabel = string.Empty;
    private string _newLinkUrl = string.Empty;
    private int _readingTime = 1;
    private List<TocItem> _toc = new();

    private readonly Stack<string> _undoStack = new();
    private readonly Stack<string> _redoStack = new();

    // ---- Hardcoded demo data ----
    private List<HistoryEntry> _history = new();
    private List<Reviewer> _reviewers = new();
    private List<ApprovalStep> _approvalSteps = new();
    private List<RelatedDoc> _relatedDocs = new();
    private List<RelatedArticle> _relatedArticles = new();

    protected override void OnInitialized()
    {
        _categories = Data.GetCategories().OrderBy(c => c.Name).ToList();
        _authors = Data.GetAuthors().OrderBy(a => a.FullName).ToList();

        _model.FechaCreacion = DateTime.Today;
        _model.FechaActualizacion = DateTime.Today;
        _model.Version = "v1.0";

        _history = new()
        {
            new("Creación del documento", "Hiavert Maldonado", "Se creó la estructura inicial del artículo.", DateTime.Now.AddDays(-3)),
            new("Revisión de contenido", "Lucía Fernández", "Se corrigieron los pasos de configuración de red.", DateTime.Now.AddDays(-2)),
            new("Actualización menor", "Hiavert Maldonado", "Se agregaron capturas de pantalla y referencias.", DateTime.Now.AddDays(-1)),
        };

        _reviewers = new()
        {
            new("Lucía Fernández", "Referente Técnica — Redes", "LF", "Aprobado", "badge--success"),
            new("Martín Ibarra", "Seguridad de la Información", "MI", "Pendiente", "badge--amber"),
            new("Sofía Ramos", "Responsable de Documentación", "SR", "En revisión", "badge--brand"),
        };

        _approvalSteps = new()
        {
            new("Autor", "done"),
            new("Revisión técnica", "current"),
            new("Responsable de área", "pending"),
            new("Publicación", "pending"),
        };

        _relatedDocs = new()
        {
            new("Política de Seguridad de la Información v3", "Seguridad"),
            new("Manual de Onboarding de Tecnología", "Recursos Humanos / TI"),
            new("Estándares de Nomenclatura de Servidores", "Infraestructura"),
        };

        _relatedArticles = new()
        {
            new("Cómo restablecer tu contraseña de dominio", 1240, 4),
            new("Buenas prácticas de seguridad para equipos remotos", 860, 6),
            new("Checklist de alta de usuario nuevo", 530, 3),
        };

        RecomputeDerived();
    }

    private void ToggleSistema(string sistema)
    {
        if (!_model.SistemasRelacionados.Remove(sistema))
            _model.SistemasRelacionados.Add(sistema);
    }

    private void AddTag()
    {
        var value = _newTag.Trim();
        if (!string.IsNullOrEmpty(value) && !_model.Tags.Contains(value))
        {
            _model.Tags.Add(value);
        }
        _newTag = string.Empty;
    }

    private void OnTagKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddTag();
    }

    private void AddLink()
    {
        if (!string.IsNullOrWhiteSpace(_newLinkLabel) && !string.IsNullOrWhiteSpace(_newLinkUrl))
        {
            _model.EnlacesRelacionados.Add(new RelatedLink(_newLinkLabel, _newLinkUrl));
            _newLinkLabel = string.Empty;
            _newLinkUrl = string.Empty;
        }
    }

    private void InsertSnippet(string snippet)
    {
        _undoStack.Push(_model.Content);
        _redoStack.Clear();
        _model.Content = string.IsNullOrEmpty(_model.Content)
            ? snippet
            : _model.Content.TrimEnd('\n') + "\n\n" + snippet + "\n";
        RecomputeDerived();
    }

    private void OnContentChanged(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        RecomputeDerived();
    }

    private void Undo()
    {
        if (_undoStack.Count == 0) return;
        _redoStack.Push(_model.Content);
        _model.Content = _undoStack.Pop();
        RecomputeDerived();
    }

    private void Redo()
    {
        if (_redoStack.Count == 0) return;
        _undoStack.Push(_model.Content);
        _model.Content = _redoStack.Pop();
        RecomputeDerived();
    }

    private void RecomputeDerived()
    {
        var words = string.IsNullOrWhiteSpace(_model.Content)
            ? 0
            : _model.Content.Split(new[] { ' ', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Length;
        _readingTime = Math.Max(1, (int)Math.Ceiling(words / 200.0));

        _toc = (_model.Content ?? string.Empty)
            .Split('\n')
            .Where(l => l.TrimStart().StartsWith("#"))
            .Select(l =>
            {
                var trimmed = l.TrimStart();
                var level = trimmed.TakeWhile(c => c == '#').Count();
                var text = trimmed.TrimStart('#').Trim();
                return new TocItem(Math.Clamp(level, 1, 4), text);
            })
            .Where(t => !string.IsNullOrWhiteSpace(t.Text))
            .ToList();
    }

    private bool ValidateBasics()
    {
        if (string.IsNullOrWhiteSpace(_model.Title) || string.IsNullOrWhiteSpace(_model.Summary))
        {
            _error = "El título y el resumen son obligatorios.";
            return false;
        }
        if (!Guid.TryParse(_model.CategoryId, out _))
        {
            _error = "Seleccioná una categoría.";
            return false;
        }
        if (!Guid.TryParse(_model.AuthorId, out _))
        {
            _error = "Seleccioná un autor.";
            return false;
        }
        _error = null;
        return true;
    }

    private void SaveAsDraft()
    {
        if (!ValidateBasics()) return;
        _model.Estado = "Borrador";
        Persist(ArticleStatus.Draft);
    }

    private void SendToReview()
    {
        if (!ValidateBasics()) return;
        _model.Estado = "En revisión";
        Persist(ArticleStatus.InReview);
    }

    private void Publish()
    {
        if (!ValidateBasics()) return;
        _model.Estado = "Publicado";
        Persist(ArticleStatus.Published);
    }

    private void Persist(ArticleStatus status)
    {
        var categoryId = Guid.Parse(_model.CategoryId);
        var authorId = Guid.Parse(_model.AuthorId);

        var created = Data.CreateArticle(
            _model.Title,
            _model.Summary,
            categoryId,
            authorId,
            new List<Guid>(),
            string.Empty,
            false,
            status);

        Nav.NavigateTo($"/articulo/{created.Slug}");
    }

    private class ArticleFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Title { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public string CategoryId { get; set; } = string.Empty;
        public string Subcategory { get; set; } = string.Empty;
        public string AreaResponsable { get; set; } = string.Empty;
        public string NivelAcceso { get; set; } = "Público interno";
        public string AuthorId { get; set; } = string.Empty;
        public DateTime FechaCreacion { get; set; }
        public DateTime FechaActualizacion { get; set; }
        public string Version { get; set; } = "v1.0";
        public string Estado { get; set; } = "Borrador";
        public string Prioridad { get; set; } = "Media";
        public string Referencias { get; set; } = string.Empty;
        public string ObservacionesInternas { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public List<string> Tags { get; set; } = new();
        public List<string> SistemasRelacionados { get; set; } = new();
        public List<string> ArchivosAdjuntos { get; set; } = new();
        public List<string> Imagenes { get; set; } = new();
        public List<RelatedLink> EnlacesRelacionados { get; set; } = new();
    }

    private record RelatedLink(string Label, string Url);
    private record TocItem(int Level, string Text);
    private record HistoryEntry(string Label, string Author, string Summary, DateTime Date);
    private record Reviewer(string Name, string Role, string Initials, string Status, string StatusClass);
    private record ApprovalStep(string Label, string State);
    private record RelatedDoc(string Title, string Category);
    private record RelatedArticle(string Title, int Views, int ReadingTime);
}









/* =========================================================================
   CorpWiki — Editor completo de Nuevo Artículo
   ========================================================================= */

.article-main--form { max-width: 100%; }

.form-section-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-md);
    margin-bottom: var(--space-4);
}
.form-section-title .icon { color: var(--brand-500); width: 18px; height: 18px; }

.field-grid {
    display: grid;
    gap: var(--space-4);
    margin-bottom: var(--space-1);
}
.field-grid--2 { grid-template-columns: 1fr 1fr; }
.field-grid--3 { grid-template-columns: 1fr 1fr 1fr; }

.readonly-field {
    background: var(--bg-surface-2);
    color: var(--text-tertiary);
    cursor: default;
}

/* ---------- Tag / link inputs ---------- */
.tag-input-row, .link-row {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
}
.tag-input-row .input { flex: 1; }
.link-row { flex-wrap: wrap; }
.link-row .input { flex: 1; min-width: 160px; }

.chip__remove {
    margin-left: 6px;
    font-weight: 700;
    color: inherit;
    opacity: 0.7;
}
.chip__remove:hover { opacity: 1; }

/* ---------- Attachments ---------- */
.attachment-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
}

/* ---------- Toolbar ---------- */
.editor-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: var(--space-3);
    margin-bottom: var(--space-3);
    background: var(--bg-surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
}
.editor-toolbar__group {
    display: flex;
    gap: 2px;
    padding-right: var(--space-3);
    border-right: 1px solid var(--border-subtle);
}
.editor-toolbar__group:last-child { border-right: none; padding-right: 0; }

.editor-toolbar__btn {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: background var(--transition-fast), color var(--transition-fast);
}
.editor-toolbar__btn .icon { width: 15px; height: 15px; }
.editor-toolbar__btn:hover:not(:disabled) { background: var(--bg-hover); color: var(--brand-500); }
.editor-toolbar__btn:disabled { opacity: 0.35; cursor: default; }

.editor-canvas {
    width: 100%;
    min-height: 420px;
    padding: var(--space-4);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: var(--bg-surface);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    line-height: 1.8;
    resize: vertical;
}

/* ---------- Reviewers ---------- */
.reviewer-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-subtle);
}
.reviewer-row:last-child { border-bottom: none; }
.reviewer-row__info { flex: 1; display: flex; flex-direction: column; }
.reviewer-row__name { font-size: var(--fs-sm); font-weight: 700; color: var(--text-primary); }
.reviewer-row__role { font-size: var(--fs-xs); color: var(--text-tertiary); }

.badge--success {
    background: rgba(16,185,129,0.12);
    color: #10b981;
    border: 1px solid rgba(16,185,129,0.3);
    font-size: var(--fs-xs);
    font-weight: 700;
    padding: 3px 10px;
    border-radius: var(--radius-full);
}

/* ---------- Approvals ---------- */
.approval-steps {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
}
.approval-step {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    border: 1px solid var(--border-subtle);
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--text-tertiary);
}
.approval-step__icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-surface-3);
}
.approval-step__icon .icon { width: 12px; height: 12px; }

.approval-step--done { border-color: rgba(16,185,129,0.35); color: #10b981; }
.approval-step--done .approval-step__icon { background: #10b981; color: white; }

.approval-step--current { border-color: rgba(245,158,11,0.4); color: #b45309; }
.approval-step--current .approval-step__icon { background: var(--accent-amber); color: white; }

.approval-step--pending { color: var(--text-tertiary); }

/* ---------- Quick metadata ---------- */
.meta-quickview {
    display: grid;
    grid-template-columns: 1fr auto;
    row-gap: var(--space-2);
    column-gap: var(--space-3);
    font-size: var(--fs-sm);
}
.meta-quickview span { color: var(--text-tertiary); }
.meta-quickview strong { color: var(--text-primary); text-align: right; }

/* ---------- Triple form actions ---------- */
.form-actions--triple {
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: var(--space-3);
}

/* ---------- Responsive ---------- */
@media (max-width: 1100px) {
    .field-grid--2, .field-grid--3 { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
    .editor-toolbar { gap: var(--space-2); }
    .editor-toolbar__group { padding-right: var(--space-2); }
    .form-actions--triple { flex-direction: column; align-items: stretch; }
    .form-actions--triple .btn { width: 100%; justify-content: center; }
}