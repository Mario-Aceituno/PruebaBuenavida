using System.Text;
using System.Text.RegularExpressions;

namespace CorpWiki.Services;

/// <summary>
/// Renderer liviano tipo Markdown + extensiones propias de CorpWiki.
/// Cubre exactamente los bloques que inserta la barra de herramientas del
/// editor de "Nuevo Artículo": encabezados, negrita/cursiva/subrayado,
/// listas, checklists, tablas, código, citas, callouts, imágenes, enlaces,
/// separadores, expandibles, resaltado, color y alineación centrada.
/// </summary>
public static class MarkdownRenderer
{
    public static string Render(string? source)
    {
        if (string.IsNullOrWhiteSpace(source))
            return "<p class=\"editor-preview__empty\">La vista previa aparecerá acá a medida que escribas.</p>";

        var lines = source.Replace("\r\n", "\n").Split('\n');
        var html = new StringBuilder();
        int i = 0;

        while (i < lines.Length)
        {
            var trimmed = lines[i].Trim();

            if (trimmed.Length == 0) { i++; continue; }

            // ---- Bloques de código ```lenguaje ... ``` ----
            if (trimmed.StartsWith("```"))
            {
                var lang = trimmed.Length > 3 ? trimmed[3..].Trim() : "texto";
                var code = new StringBuilder();
                i++;
                while (i < lines.Length && !lines[i].Trim().StartsWith("```"))
                {
                    code.AppendLine(System.Net.WebUtility.HtmlEncode(lines[i]));
                    i++;
                }
                i++; // cierre ```
                html.Append("<div class=\"code-block\">")
                    .Append($"<div class=\"code-block__header\">{System.Net.WebUtility.HtmlEncode(string.IsNullOrEmpty(lang) ? "texto" : lang)}</div>")
                    .Append($"<pre class=\"code-block__pre\"><code>{code}</code></pre>")
                    .Append("</div>");
                continue;
            }

            // ---- Callouts :::note / :::warning / :::info / :::center ----
            var calloutMatch = Regex.Match(trimmed, "^:::(note|warning|info|center)$", RegexOptions.IgnoreCase);
            if (calloutMatch.Success)
            {
                var kind = calloutMatch.Groups[1].Value.ToLowerInvariant();
                var body = new List<string>();
                i++;
                while (i < lines.Length && lines[i].Trim() != ":::")
                {
                    body.Add(lines[i]);
                    i++;
                }
                i++; // cierre :::

                if (kind == "center")
                {
                    html.Append("<div class=\"editor-preview__center\">")
                        .Append(InlineFormat(string.Join(" ", body)))
                        .Append("</div>");
                }
                else
                {
                    var (calloutClass, glyph) = kind switch
                    {
                        "warning" => ("callout--warning", "⚠"),
                        "info" => ("callout--note", "ℹ"),
                        _ => ("callout--tip", "✎")
                    };
                    html.Append($"<div class=\"callout {calloutClass}\">")
                        .Append($"<span class=\"callout__glyph\">{glyph}</span>")
                        .Append($"<p>{InlineFormat(string.Join(" ", body))}</p>")
                        .Append("</div>");
                }
                continue;
            }

            // ---- Expandible <details>...</details> ----
            if (trimmed.StartsWith("<details>"))
            {
                var block = new StringBuilder();
                while (i < lines.Length && !lines[i].Contains("</details>"))
                {
                    block.AppendLine(lines[i]);
                    i++;
                }
                if (i < lines.Length) { block.AppendLine(lines[i]); i++; }
                html.Append("<div class=\"editor-preview__details\">").Append(block).Append("</div>");
                continue;
            }

            // ---- Tabla | col | col | ----
            if (trimmed.StartsWith("|"))
            {
                var tableLines = new List<string>();
                while (i < lines.Length && lines[i].Trim().StartsWith("|"))
                {
                    tableLines.Add(lines[i].Trim());
                    i++;
                }
                html.Append(RenderTable(tableLines));
                continue;
            }

            // ---- Encabezados ----
            if (trimmed.StartsWith("### ")) { html.Append($"<h3 class=\"article-body__heading\">{InlineFormat(trimmed[4..])}</h3>"); i++; continue; }
            if (trimmed.StartsWith("## "))  { html.Append($"<h2 class=\"article-body__heading\">{InlineFormat(trimmed[3..])}</h2>"); i++; continue; }
            if (trimmed.StartsWith("# "))   { html.Append($"<h1 class=\"article-body__heading\">{InlineFormat(trimmed[2..])}</h1>"); i++; continue; }

            // ---- Separador ----
            if (Regex.IsMatch(trimmed, "^-{3,}$")) { html.Append("<hr class=\"article-body__divider\" />"); i++; continue; }

            // ---- Imagen sola en la línea ----
            var imgMatch = Regex.Match(trimmed, @"^!\[(.*?)\]\((.*?)\)$");
            if (imgMatch.Success)
            {
                html.Append("<figure class=\"article-body__figure\">")
                    .Append($"<img src=\"{imgMatch.Groups[2].Value}\" alt=\"{imgMatch.Groups[1].Value}\" loading=\"lazy\" />")
                    .Append("</figure>");
                i++; continue;
            }

            // ---- Checklist ----
            if (Regex.IsMatch(trimmed, @"^-\s*\[[ xX]\]\s*"))
            {
                html.Append("<ul class=\"editor-preview__checklist\">");
                while (i < lines.Length && Regex.IsMatch(lines[i].Trim(), @"^-\s*\[[ xX]\]\s*"))
                {
                    var m = Regex.Match(lines[i].Trim(), @"^-\s*\[([ xX])\]\s*(.*)$");
                    var isChecked = m.Groups[1].Value.Equals("x", StringComparison.OrdinalIgnoreCase);
                    html.Append("<li class=\"editor-preview__check-item\">")
                        .Append($"<span class=\"editor-preview__checkbox {(isChecked ? "editor-preview__checkbox--checked" : "")}\">{(isChecked ? "✓" : "")}</span>")
                        .Append($"<span>{InlineFormat(m.Groups[2].Value)}</span>")
                        .Append("</li>");
                    i++;
                }
                html.Append("</ul>");
                continue;
            }

            // ---- Lista con viñetas ----
            if (trimmed.StartsWith("- "))
            {
                html.Append("<ul class=\"editor-preview__list\">");
                while (i < lines.Length && lines[i].Trim().StartsWith("- ") && !Regex.IsMatch(lines[i].Trim(), @"^-\s*\[[ xX]\]"))
                {
                    html.Append($"<li>{InlineFormat(lines[i].Trim()[2..])}</li>");
                    i++;
                }
                html.Append("</ul>");
                continue;
            }

            // ---- Lista numerada ----
            if (Regex.IsMatch(trimmed, @"^\d+\.\s"))
            {
                html.Append("<ol class=\"editor-preview__list\">");
                while (i < lines.Length && Regex.IsMatch(lines[i].Trim(), @"^\d+\.\s"))
                {
                    var text = Regex.Replace(lines[i].Trim(), @"^\d+\.\s*", "");
                    html.Append($"<li>{InlineFormat(text)}</li>");
                    i++;
                }
                html.Append("</ol>");
                continue;
            }

            // ---- Cita ----
            if (trimmed.StartsWith(">"))
            {
                var quoteLines = new List<string>();
                while (i < lines.Length && lines[i].Trim().StartsWith(">"))
                {
                    quoteLines.Add(lines[i].Trim().TrimStart('>').Trim());
                    i++;
                }
                html.Append("<div class=\"article-body__quote\"><span>❝</span><p>")
                    .Append(InlineFormat(string.Join(" ", quoteLines)))
                    .Append("</p></div>");
                continue;
            }

            // ---- Párrafo ----
            var paragraphLines = new List<string>();
            while (i < lines.Length && lines[i].Trim().Length > 0 && !IsBlockStart(lines[i].Trim()))
            {
                paragraphLines.Add(lines[i].Trim());
                i++;
            }
            html.Append($"<p class=\"article-body__paragraph\">{InlineFormat(string.Join(" ", paragraphLines))}</p>");
        }

        return html.ToString();
    }

    private static bool IsBlockStart(string t) =>
        t.StartsWith("```") || t.StartsWith(":::") || t.StartsWith("<details>") || t.StartsWith("|") ||
        t.StartsWith("# ") || t.StartsWith("## ") || t.StartsWith("### ") ||
        Regex.IsMatch(t, "^-{3,}$") || Regex.IsMatch(t, @"^!\[(.*?)\]\((.*?)\)$") ||
        Regex.IsMatch(t, @"^-\s*\[[ xX]\]") || t.StartsWith("- ") ||
        Regex.IsMatch(t, @"^\d+\.\s") || t.StartsWith(">");

    private static string RenderTable(List<string> rawLines)
    {
        var rows = rawLines
            .Select(l => l.Trim('|').Split('|').Select(c => c.Trim()).ToList())
            .ToList();

        if (rows.Count == 0) return string.Empty;

        var header = rows[0];
        var body = rows.Skip(1)
            .Where(r => !r.All(c => Regex.IsMatch(c, "^-+$")))
            .ToList();

        var sb = new StringBuilder();
        sb.Append("<div class=\"article-body__table-wrap\"><table class=\"article-body__table\"><thead><tr>");
        foreach (var h in header) sb.Append($"<th>{InlineFormat(h)}</th>");
        sb.Append("</tr></thead><tbody>");
        foreach (var row in body)
        {
            sb.Append("<tr>");
            foreach (var cell in row) sb.Append($"<td>{InlineFormat(cell)}</td>");
            sb.Append("</tr>");
        }
        sb.Append("</tbody></table></div>");
        return sb.ToString();
    }

    private static string InlineFormat(string text)
    {
        if (string.IsNullOrEmpty(text)) return string.Empty;

        var result = text;

        // Código inline `texto`
        result = Regex.Replace(result, "`(.+?)`", "<code class=\"editor-preview__inline-code\">$1</code>");

        // Negrita **texto**
        result = Regex.Replace(result, @"\*\*(.+?)\*\*", "<strong>$1</strong>");

        // Cursiva *texto* (evita chocar con **negrita** ya reemplazada)
        result = Regex.Replace(result, @"(?<!\*)\*(?!\*)(.+?)(?<!\*)\*(?!\*)", "<em>$1</em>");

        // Resaltado ==texto==
        result = Regex.Replace(result, "==(.+?)==", "<mark class=\"editor-preview__highlight\">$1</mark>");

        // Color {color:#hex}texto{/color}
        result = Regex.Replace(result, @"\{color:(#[0-9a-fA-F]{3,6})\}(.+?)\{/color\}", "<span style=\"color:$1\">$2</span>");

        // Enlaces [texto](url)
        result = Regex.Replace(result, @"\[(.+?)\]\((.+?)\)", "<a href=\"$2\" target=\"_blank\" rel=\"noopener\">$1</a>");

        return result;
    }
}





@* ============================= EDITOR ============================= *@
        <div class="card article-form">
            <h3 class="form-section-title"><Icon Name="edit-3" /> Cuerpo del artículo</h3>

            <div class="editor-tabs">
                <button type="button" class="editor-tabs__btn @(!_showPreview ? "editor-tabs__btn--active" : "")" @onclick='() => _showPreview = false'>
                    <Icon Name="pencil" /> Editar
                </button>
                <button type="button" class="editor-tabs__btn @(_showPreview ? "editor-tabs__btn--active" : "")" @onclick='() => _showPreview = true'>
                    <Icon Name="eye" /> Vista previa
                </button>
            </div>

            @if (!_showPreview)
            {
                <div class="editor-toolbar">
                    <div class="editor-toolbar__group">
