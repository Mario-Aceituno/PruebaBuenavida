    private void ToggleSistema(string sistema)
    {
        if (!_model.SistemasRelacionados.Remove(sistema))
            _model.SistemasRelacionados.Add(sistema);
    }

    private void AddTag()
    {
        var value = _newTag.Trim();
        if (!string.IsNullOrEmpty(value) && !_model.Tags.Contains(value))
        {
            _model.Tags.Add(value);
        }
        _newTag = string.Empty;
    }

    private void OnTagKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddTag();
    }

    private void AddLink()
    {
        if (!string.IsNullOrWhiteSpace(_newLinkLabel) && !string.IsNullOrWhiteSpace(_newLinkUrl))
        {
            _model.EnlacesRelacionados.Add(new RelatedLink(_newLinkLabel, _newLinkUrl));
            _newLinkLabel = string.Empty;
            _newLinkUrl = string.Empty;
        }
    }

