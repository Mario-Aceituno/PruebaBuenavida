/* ---------- SuccessModal: check animado ---------- */
.success-modal__icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(16,185,129,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-5);
}

.success-modal__check {
    width: 32px;
    height: 32px;
}

.success-modal__check-circle {
    stroke: var(--status-resuelta);
    stroke-width: 3;
    fill: none;
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    animation: successCircle 0.5s var(--ease) forwards;
}

.success-modal__check-mark {
    stroke: var(--status-resuelta);
    stroke-width: 3;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: successMark 0.3s var(--ease) 0.45s forwards;
}

@keyframes successCircle {
    to { stroke-dashoffset: 0; }
}

@keyframes successMark {
    to { stroke-dashoffset: 0; }
}

.success-modal__body {
    text-align: center;
    padding: var(--space-6) var(--space-4);
}

.success-modal__title {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
}

.success-modal__desc {
    font-size: var(--fs-sm);
    color: var(--text-tertiary);
}

@* Modal de confirmación con check animado. Se auto-cierra a los N ms
   (default 1600) o el usuario puede cerrarlo con el botón. *@

<InfoModal Show="Show" ShowChanged="ShowChanged" Title="">
    <div class="success-modal__body">
        <div class="success-modal__icon-wrap">
            <svg class="success-modal__check" viewBox="0 0 52 52">
                <circle class="success-modal__check-circle" cx="26" cy="26" r="23" />
                <path class="success-modal__check-mark" d="M15 27l7 7 16-16" />
            </svg>
        </div>
        <p class="success-modal__title">@Title</p>
        @if (!string.IsNullOrEmpty(Description))
        {
            <p class="success-modal__desc">@Description</p>
        }
    </div>
</InfoModal>

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public EventCallback<bool> ShowChanged { get; set; }
    [Parameter] public string Title { get; set; } = "¡Listo!";
    [Parameter] public string? Description { get; set; }
    [Parameter] public int AutoCloseMs { get; set; } = 1600;

    private CancellationTokenSource? _cts;

    protected override void OnParametersSet()
    {
        if (Show && AutoCloseMs > 0)
        {
            _cts?.Cancel();
            _cts = new CancellationTokenSource();
            _ = AutoClose(_cts.Token);
        }
    }

    private async Task AutoClose(CancellationToken token)
    {
        try
        {
            await Task.Delay(AutoCloseMs, token);
            if (!token.IsCancellationRequested)
            {
                Show = false;
                await ShowChanged.InvokeAsync(false);
            }
        }
        catch (TaskCanceledException) { }
    }
}

private bool _showSuccess;
private string _successTitle = "";
private string? _successDesc;

private void ShowSuccess(string title, string? desc = null)
{
    _successTitle = title;
    _successDesc = desc;
    _showSuccess = true;
}

<SuccessModal Show="_showSuccess" ShowChanged="v => _showSuccess = v"
              Title="@_successTitle" Description="_successDesc" />