@page "/login"
@rendermode InteractiveServer

<PageTitle>Iniciar sesión · DaviWiki</PageTitle>

<div class="login-screen">

    <div class="login-background" aria-hidden="true">
        <div class="shard shard--1"></div>
        <div class="shard shard--2"></div>
        <div class="shard shard--3"></div>
        <div class="scanline"></div>
    </div>

    <main class="login-card" role="main">

        <div class="brand-orbit" aria-hidden="true">
            <div class="orbit-ring">
                <span class="orbit-node orbit-node--1"></span>
                <span class="orbit-node orbit-node--2"></span>
            </div>
            <div class="orbit-ring orbit-ring--reverse">
                <span class="orbit-node orbit-node--3"></span>
            </div>
            <div class="brand__mark"></div>
        </div>

        <div class="brand">
            <h1 class="brand__title">DaviWiki</h1>
            <p class="brand__subtitle">Plataforma interna de conocimiento del Área de Tecnología</p>
        </div>

        <EditForm Model="@_model" OnValidSubmit="HandleLoginAsync" class="login-form">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert--error" role="alert">
                    <span class="icon icon-alert" aria-hidden="true"></span>
                    <span>@ErrorMessage</span>
                </div>
            }

            <div class="field field--1">
                <div class="field__control">
                    <InputText id="username"
                               @bind-Value="_model.Username"
                               placeholder=" "
                               autocomplete="username"
                               disabled="@IsLoading"
                               class="@FieldClass()" />
                    <label for="username" class="floating-label">
                        <span class="icon icon-user" aria-hidden="true">
                            <span class="icon-user__head"></span>
                            <span class="icon-user__body"></span>
                        </span>
                        <span>Usuario</span>
                    </label>
                </div>
                <ValidationMessage For="@(() => _model.Username)" class="field__error" />
            </div>

            <div class="field field--2">
                <div class="field__control">
                    <InputText id="password"
                               @bind-Value="_model.Password"
                               type="@(_showPassword ? "text" : "password")"
                               placeholder=" "
                               autocomplete="current-password"
                               disabled="@IsLoading"
                               class="@FieldClass()" />
                    <label for="password" class="floating-label">
                        <span class="icon icon-lock" aria-hidden="true">
                            <span class="icon-lock__shackle"></span>
                            <span class="icon-lock__body">
                                <span class="icon-lock__hole"></span>
                            </span>
                        </span>
                        <span>Contraseña</span>
                    </label>
                    <button type="button"
                            class="field__toggle"
                            @onclick="TogglePasswordVisibility"
                            disabled="@IsLoading"
                            aria-label="@(_showPassword ? "Ocultar contraseña" : "Mostrar contraseña")">
                        <span class="icon icon-eye @(_showPassword ? "icon-eye--off" : "")" aria-hidden="true">
                            <span class="icon-eye__outer"></span>
                            <span class="icon-eye__pupil"></span>
                            <span class="icon-eye__slash"></span>
                        </span>
                    </button>
                </div>
                <ValidationMessage For="@(() => _model.Password)" class="field__error" />
            </div>

            <div class="field field--inline field--3">
                <label class="checkbox">
                    <input type="checkbox" @bind="_model.RememberMe" disabled="@IsLoading" />
                    <span class="checkbox__box" aria-hidden="true"></span>
                    <span>Recordar sesión</span>
                </label>
                <span class="rev-tag">rev. 2026.07</span>
            </div>

            <button type="submit" class="btn-primary field--4" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="spinner" aria-hidden="true"></span>
                    <span>Validando…</span>
                }
                else
                {
                    <span>Ingresar</span>
                }
            </button>
        </EditForm>

        <div class="card-footer">
            <a href="#" class="help-link">¿Necesitás ayuda?</a>
            <span class="secure-badge">
                <span class="icon-shield" aria-hidden="true"></span>
                <span>Conexión segura y cifrada</span>
            </span>
        </div>
    </main>
</div>


*, *::before, *::after {
    box-sizing: border-box;
}

:root {
    --davi-red: #C8102E;
    --davi-red-dark: #9E0C24;
    --davi-magenta: #9C1457;

    --gray-50: #FAFAFA;
    --gray-100: #F4F4F6;
    --gray-200: #E8E8EC;
    --gray-300: #D5D5DC;
    --gray-500: #8C8D97;
    --gray-700: #4B4C55;
    --gray-900: #17181C;

    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;

    --shadow-card: 0 50px 110px -40px rgba(10, 10, 20, 0.55), 0 4px 12px rgba(10, 10, 20, 0.15);

    --transition-fast: 180ms ease;
    --transition-med: 320ms ease;
}

html, body {
    background: var(--gray-900);
    margin: 0;
}

/* ---------- Screen & background: placas diagonales + scanline ---------- */

.login-screen {
    position: relative;
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-900);
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    padding: 24px;
}

.login-background {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
}

.shard {
    position: absolute;
    opacity: 0.85;
    animation: shard-drift 16s ease-in-out infinite;
}

.shard--1 {
    width: 900px;
    height: 900px;
    top: -420px;
    left: -320px;
    background: linear-gradient(135deg, var(--davi-red) 0%, var(--davi-red-dark) 100%);
    clip-path: polygon(0 0, 65% 0, 40% 100%, 0% 100%);
    animation-delay: 0s;
}

.shard--2 {
    width: 700px;
    height: 900px;
    bottom: -400px;
    right: -260px;
    background: linear-gradient(135deg, var(--davi-magenta) 0%, var(--davi-red-dark) 100%);
    clip-path: polygon(40% 0, 100% 0, 100% 100%, 15% 100%);
    animation-delay: -6s;
}

.shard--3 {
    width: 420px;
    height: 420px;
    top: 40%;
    left: 46%;
    background: linear-gradient(135deg, rgba(200, 16, 46, 0.5), rgba(156, 20, 87, 0));
    clip-path: polygon(50% 0, 100% 50%, 50% 100%, 0 50%);
    opacity: 0.18;
    animation-delay: -3s;
}

@keyframes shard-drift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(18px, -14px) rotate(2deg); }
}

.scanline {
    position: absolute;
    left: 0;
    width: 100%;
    height: 140px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.05) 50%, rgba(255, 255, 255, 0) 100%);
    animation: scan-sweep 7s linear infinite;
}

@keyframes scan-sweep {
    from { top: -140px; }
    to { top: 100%; }
}

/* ---------- Card: esquina cortada en diagonal, sin radios ---------- */

.login-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 440px;
    background: #FFFFFF;
    box-shadow: var(--shadow-card);
    padding: 46px 40px 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    clip-path: polygon(0 32px, 32px 0, 100% 0, 100% 100%, 0 100%);
    animation: card-in 500ms ease both;
}

@keyframes card-in {
    from { opacity: 0; transform: translateY(14px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
}

/* Filete diagonal en el corte, como una etiqueta de acceso */
.login-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 46px;
    height: 46px;
    background: linear-gradient(135deg, var(--davi-red) 0%, var(--davi-magenta) 100%);
    clip-path: polygon(0 32px, 32px 0, 46px 0, 46px 46px, 0 46px);
    z-index: 2;
}

/* ---------- Marca con nodos orbitando ---------- */

.brand-orbit {
    position: relative;
    width: 130px;
    height: 130px;
    margin: 4px 0 6px;
}

.orbit-ring {
    position: absolute;
    inset: 0;
    animation: spin-cw 15s linear infinite;
}

.orbit-ring--reverse {
    inset: 18px;
    animation: spin-ccw 10s linear infinite;
}

@keyframes spin-cw { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
@keyframes spin-ccw { from { transform: rotate(0deg); } to { transform: rotate(-360deg); } }

.orbit-node {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 7px;
    height: 7px;
    margin: -3.5px;
    border-radius: 50%;
    background: var(--davi-red);
    box-shadow: 0 0 10px rgba(200, 16, 46, 0.55);
}

.orbit-node--1 { transform: rotate(0deg) translateX(63px); }
.orbit-node--2 { transform: rotate(150deg) translateX(63px); background: var(--davi-magenta); box-shadow: 0 0 10px rgba(156, 20, 87, 0.5); }
.orbit-node--3 { transform: rotate(40deg) translateX(46px); width: 5px; height: 5px; margin: -2.5px; }

.brand__mark {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 54px;
    height: 54px;
    background: linear-gradient(160deg, var(--davi-red) 0%, var(--davi-red-dark) 100%);
    clip-path: polygon(0 0, 100% 0, 100% 100%, 14px 100%, 0 calc(100% - 14px));
}

.brand__mark::before {
    content: "";
    position: absolute;
    inset: 0;
    margin: auto;
    width: 22px;
    height: 22px;
    background: linear-gradient(90deg,
        rgba(255, 255, 255, 0.95) 0%,
        rgba(255, 255, 255, 0.95) 50%,
        rgba(255, 255, 255, 0.6) 50%,
        rgba(255, 255, 255, 0.6) 100%);
    clip-path: polygon(50% 6%, 100% 20%, 100% 94%, 50% 100%, 0 94%, 0 20%);
}

/* ---------- Brand text ---------- */

.brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-bottom: 28px;
    animation: field-in 420ms 80ms ease both;
}

.brand__title {
    margin: 0;
    font-size: 23px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--gray-900);
}

.brand__subtitle {
    margin: 0;
    font-size: 13px;
    line-height: 1.4;
    color: var(--gray-500);
    max-width: 280px;
}

/* ---------- Form layout ---------- */

.login-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 26px;
    text-align: left;
}

@keyframes field-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    animation: field-in 420ms ease both;
}

.field--1 { animation-delay: 140ms; }
.field--2 { animation-delay: 210ms; }
.field--3 { animation-delay: 280ms; }
.btn-primary.field--4 { animation: field-in 420ms 350ms ease both; }

/* ---------- Inputs subrayados con label flotante ---------- */

.field__control {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 1.5px solid var(--gray-200);
}

.field__control::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1.5px;
    width: 100%;
    height: 2px;
    background: var(--davi-red);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--transition-med);
}

.field__control:focus-within::after {
    transform: scaleX(1);
}

.input {
    width: 100%;
    height: 48px;
    border: none;
    border-radius: 0;
    background: transparent;
    padding: 4px 34px 0 30px;
    font-size: 15px;
    color: var(--gray-900);
    outline: none;
}

.input::placeholder { color: transparent; }

.input:disabled {
    color: var(--gray-500);
    cursor: not-allowed;
}

.input--error ~ .floating-label { color: var(--davi-red-dark); }

#password { padding-right: 40px; }

.floating-label {
    position: absolute;
    left: 30px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    color: var(--gray-500);
    pointer-events: none;
    transition: top var(--transition-fast), font-size var(--transition-fast), color var(--transition-fast), left var(--transition-fast);
}

.floating-label .icon { opacity: 0.8; }

.input:focus ~ .floating-label,
.input:not(:placeholder-shown) ~ .floating-label {
    top: -2px;
    left: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--davi-red);
}

.input:focus ~ .floating-label .icon,
.input:not(:placeholder-shown) ~ .floating-label .icon {
    display: none;
}

.field__toggle {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: none;
    background: transparent;
    cursor: pointer;
    color: var(--gray-500);
    opacity: 0.75;
    transition: opacity var(--transition-fast), color var(--transition-fast);
}

.field__toggle:hover { opacity: 1; }
.field__toggle:focus-visible { opacity: 1; color: var(--davi-red); }
.field__toggle:disabled { cursor: not-allowed; opacity: 0.3; }

.field__error {
    font-size: 12px;
    color: var(--davi-red-dark);
}

/* ---------- Checkbox + rev tag ---------- */

.field--inline {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
}

.checkbox {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 13px;
    color: var(--gray-700);
    cursor: pointer;
    user-select: none;
    position: relative;
}

.checkbox input {
    position: absolute;
    opacity: 0;
    width: 16px;
    height: 16px;
    margin: 0;
    cursor: pointer;
}

.checkbox__box {
    width: 16px;
    height: 16px;
    border-radius: 0;
    border: 1.5px solid var(--gray-300);
    background: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition-fast), border-color var(--transition-fast);
    flex: none;
}

.checkbox input:checked + .checkbox__box {
    background: var(--davi-red);
    border-color: var(--davi-red);
}

.checkbox input:checked + .checkbox__box::after {
    content: "";
    width: 4px;
    height: 8px;
    border: solid white;
    border-width: 0 1.5px 1.5px 0;
    transform: rotate(45deg) translate(-1px, -1px);
}

.checkbox input:focus-visible + .checkbox__box {
    outline: 2px solid var(--davi-red);
    outline-offset: 2px;
}

.rev-tag {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--gray-300);
    letter-spacing: 0.03em;
}

/* ---------- Primary button: punta de flecha, sin radio ---------- */

.btn-primary {
    height: 50px;
    border: none;
    border-radius: 0;
    background: linear-gradient(90deg, var(--davi-red) 0%, var(--davi-red-dark) 60%, var(--davi-magenta) 100%);
    background-size: 200% 100%;
    color: #fff;
    font-size: 14.5px;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 50%, calc(100% - 18px) 100%, 0 100%);
    transition: background-position var(--transition-med), filter var(--transition-fast);
    width: 100%;
}

.btn-primary:hover:not(:disabled) {
    background-position: 100% 0;
}

.btn-primary:active:not(:disabled) {
    filter: brightness(0.94);
}

.btn-primary:disabled { cursor: not-allowed; opacity: 0.85; }

.btn-primary:focus-visible {
    outline: 2px solid var(--davi-red-dark);
    outline-offset: 3px;
}

.spinner {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-top-color: #fff;
    animation: spin 700ms linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ---------- Alert ---------- */

.alert {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 14px;
    background: rgba(200, 16, 46, 0.06);
    color: var(--davi-red-dark);
    border-left: 3px solid var(--davi-red);
    font-size: 12.5px;
    animation: fade-in var(--transition-fast) ease both;
}

@keyframes fade-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ---------- Footer ---------- */

.card-footer {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    animation: field-in 420ms 420ms ease both;
}

.help-link {
    font-size: 13px;
    color: var(--gray-500);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.help-link:hover { color: var(--davi-red); }

.secure-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--gray-500);
}

.secure-badge .icon-shield {
    width: 13px;
    height: 14px;
    position: relative;
    flex: none;
    color: var(--gray-500);
    opacity: 0.8;
}

.icon-shield::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 1.4px solid currentColor;
    clip-path: polygon(50% 0%, 100% 18%, 100% 55%, 50% 100%, 0 55%, 0 18%);
}

.icon-shield::after {
    content: "";
    position: absolute;
    top: 45%;
    left: 50%;
    width: 3.5px;
    height: 5.5px;
    border: solid currentColor;
    border-width: 0 1.3px 1.3px 0;
    transform: translate(-50%, -60%) rotate(45deg);
}

/* ============================================================
   CSS-only icons
   ============================================================ */

.icon {
    position: relative;
    width: 17px;
    height: 17px;
    display: inline-block;
    flex: none;
}

.icon-user__head {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 7px;
    height: 7px;
    border: 1.6px solid currentColor;
    border-radius: 50%;
}

.icon-user__body {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 15px;
    height: 8px;
    border: 1.6px solid currentColor;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
}

.icon-lock__shackle {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 9px;
    border: 1.6px solid currentColor;
    border-bottom: none;
    border-radius: 6px 6px 0 0;
}

.icon-lock__body {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 10px;
    border: 1.6px solid currentColor;
    border-radius: 3px;
}

.icon-lock__hole {
    position: absolute;
    top: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 2.4px;
    height: 2.4px;
    border-radius: 50%;
    background: currentColor;
}

.icon-eye__outer {
    position: absolute;
    inset: 2px 0;
    border: 1.6px solid currentColor;
    border-radius: 50% / 60%;
}

.icon-eye__pupil {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    transform: translate(-50%, -50%);
}

.icon-eye__slash {
    display: none;
    position: absolute;
    top: 50%;
    left: -1px;
    width: 20px;
    height: 1.6px;
    background: currentColor;
    border-radius: 2px;
    transform: translateY(-50%) rotate(-40deg);
}

.icon-eye--off .icon-eye__outer { opacity: 0.45; }
.icon-eye--off .icon-eye__slash { display: block; }

.icon-alert {
    border-radius: 50%;
    border: 1.6px solid currentColor;
    flex: none;
}

.icon-alert::before {
    content: "";
    position: absolute;
    top: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 1.6px;
    height: 6px;
    background: currentColor;
    border-radius: 1px;
}

.icon-alert::after {
    content: "";
    position: absolute;
    bottom: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 1.6px;
    height: 1.6px;
    border-radius: 50%;
    background: currentColor;
}

/* ---------- Responsive ---------- */

@media (max-width: 480px) {
    .login-card { padding: 40px 26px 26px; }
    .brand-orbit { width: 108px; height: 108px; }
    .orbit-node--1, .orbit-node--2 { transform-origin: center; }
}

/* ---------- Reduced motion ---------- */

@media (prefers-reduced-motion: reduce) {
    .login-card, .alert, .btn-primary, .spinner, .shard, .scanline,
    .orbit-ring, .orbit-ring--reverse, .field, .brand, .card-footer {
        animation: none !important;
        transition: none !important;
    }
}
