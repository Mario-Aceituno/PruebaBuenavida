                        <span class="meta-block__value">@_incident.CreatedBy</span>
                    </div>
                    <div class="meta-block">
                        <span class="meta-block__label">Fecha de creación</span>
                        <span class="meta-block__value">@_incident.CreatedAt.ToString("d MMM yyyy, HH:mm")</span>
                    </div>
                    <div class="meta-block">
                        <span class="meta-block__label">SLA de referencia</span>
                        <span class="meta-block__value">@IncidentDataService.SlaHours(_incident.Priority)h</span>
                    </div>
                    <div class="meta-block">
                        <span class="meta-block__label">Tiempo muerto total</span>
                        <span class="meta-block__value meta-block__value--danger">@FormatSpan(TotalDeadTime())</span>
                    </div>
                </div>
            </div>

            @* ---- Tramos por equipo: tiempo muerto vs tiempo activo ---- *@
            <div class="card article-form">
                <h3 class="form-section-title"><Icon Name="activity" /> Tiempos por equipo</h3>
                <div class="team-legs">
                    @foreach (var leg in _legs)
                    {
                        var overSla = leg.DeadTime.TotalHours > IncidentDataService.SlaHours(_incident.Priority);
                        <div class="team-leg">
                            <div class="team-leg__head">
                                <span class="team-leg__team"><Icon Name="users" /> @leg.Team</span>
                                <span class="team-leg__status">@(string.IsNullOrEmpty(leg.EndReason) ? "En curso" : leg.EndReason)</span>
                            </div>
                            <div class="team-leg__bars">
                                <div class="team-leg__bar-row">
                                    <span class="team-leg__bar-label">Tiempo muerto</span>
                                    <div class="team-leg__bar">
                                        <div class="team-leg__bar-fill team-leg__bar-fill--dead @(overSla ? "team-leg__bar-fill--over" : "")"
                                             style="width:@(BarWidth(leg.DeadTime))%"></div>
                                    </div>
                                    <span class="team-leg__bar-value @(overSla ? "team-leg__bar-value--over" : "")">@FormatSpan(leg.DeadTime)</span>
                                </div>
                                @if (leg.ActiveTime is not null)
                                {
                                    <div class="team-leg__bar-row">
                                        <span class="team-leg__bar-label">Tiempo activo</span>
                                        <div class="team-leg__bar">
                                            <div class="team-leg__bar-fill team-leg__bar-fill--active" style="width:@(BarWidth(leg.ActiveTime.Value))%"></div>
                                        </div>
                                        <span class="team-leg__bar-value">@FormatSpan(leg.ActiveTime.Value)</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            @* ---- Timeline detallado ---- *@
            <div class="card article-form">
                <h3 class="form-section-title"><Icon Name="history" /> Historial detallado</h3>
                <div class="version-timeline">
                    @foreach (var ev in _incident.Timeline.OrderByDescending(e => e.Timestamp))
                    {
                        <div class="version-row">
                            <span class="version-row__dot version-row__dot--@EventDotClass(ev.Type)"></span>
                            <div>
                                <p class="version-row__label">@EventLabel(ev) — @ev.Author</p>
                                @if (!string.IsNullOrEmpty(ev.Note))
                                {
                                    <p class="version-row__summary">@ev.Note</p>
                                }
                                <p class="version-row__date">@ev.Timestamp.ToString("d MMM yyyy, HH:mm")</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <aside class="article-sidebar">
            @if (_incident.Status is not (IncidentStatus.Resuelta or IncidentStatus.Cerrada))
            {
                <div class="widget card">
                    <h4 class="widget__title"><Icon Name="check-circle" /> Acciones</h4>

                    @if (_incident.Timeline.LastOrDefault()?.Type != IncidentEventType.TomaEnCurso || _incident.Status == IncidentStatus.Transferida)
                    {
                        <button class="btn btn--secondary" style="width:100%; margin-bottom:var(--space-3)" @onclick="TakeIncident">
                            <Icon Name="check" /> Tomar incidencia
                        </button>
                    }

                    <div class="form-group">
                        <label class="form-label">Transferir a equipo</label>
                        <select class="input" @bind="_transferTeam">
                            <option value="">Seleccioná</option>
                            @foreach (var team in IncidentData.Teams.Where(t => t != _incident.CurrentTeam))
                            {
                                <option value="@team">@team</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <textarea class="input" rows="2" @bind="_transferNote" placeholder="Motivo de la transferencia"></textarea>
                    </div>
                    <button class="btn btn--primary" style="width:100%; margin-bottom:var(--space-3)" @onclick="TransferIncident">
                        <Icon Name="send" /> Transferir
                    </button>

                    <button class="btn btn--secondary" style="width:100%" @onclick="ResolveIncident">
                        <Icon Name="check-circle" /> Marcar como resuelta
                    </button>
                </div>
            }

            <div class="widget card">
                <h4 class="widget__title"><Icon Name="lightbulb" /> Comentario interno</h4>
                <textarea class="input" rows="3" @bind="_commentNote" placeholder="Agregar una nota al historial..."></textarea>
                <button class="btn btn--secondary" style="width:100%; margin-top:var(--space-3)" @onclick="AddComment">
                    <Icon Name="plus" /> Agregar comentario
                </button>
            </div>
        </aside>
    </div>
}

@code {
    [Parameter] public string Codigo { get; set; } = string.Empty;

    private Incident? _incident;
    private List<TeamLeg> _legs = new();
    private List<BreadcrumbItem> _breadcrumb = new();

    private string _transferTeam = "";
    private string _transferNote = "";
    private string _commentNote = "";
    private const string CurrentUser = "Hiavert Maldonado";

    protected override void OnParametersSet()
    {
        Load();
    }

    private void Load()
    {
        _incident = IncidentData.GetByCode(Codigo);
        if (_incident is null) return;

        _legs = IncidentDataService.ComputeLegs(_incident);
        _breadcrumb = new()
        {
            new("Inicio", "/"),
            new("Incidencias", "/incidencias"),
            new(_incident.Code, null)
        };
    }

    private void TakeIncident()
    {
        IncidentData.StartProgress(Codigo, CurrentUser);
        Load();
    }

    private void TransferIncident()
    {
        if (string.IsNullOrEmpty(_transferTeam)) return;
        IncidentData.Transfer(Codigo, _transferTeam, _transferNote, CurrentUser);
        _transferTeam = ""; _transferNote = "";
        Load();
    }

    private void ResolveIncident()
    {
        IncidentData.Resolve(Codigo, CurrentUser, "");
        Load();
    }

    private void AddComment()
    {
        if (string.IsNullOrWhiteSpace(_commentNote)) return;
        IncidentData.AddComment(Codigo, CurrentUser, _commentNote);
        _commentNote = "";
        Load();
    }

    private TimeSpan TotalDeadTime() =>
        _legs.Aggregate(TimeSpan.Zero, (acc, l) => acc + l.DeadTime);

    private double BarWidth(TimeSpan span)
    {
        var maxMinutes = Math.Max(1, _legs.SelectMany(l => new[] { l.DeadTime.TotalMinutes, l.ActiveTime?.TotalMinutes ?? 0 }).Max());
        return Math.Min(100, span.TotalMinutes / maxMinutes * 100);
    }

    private static string StatusLabel(IncidentStatus s) => s switch
    {
        IncidentStatus.Abierta => "Abierta",
        IncidentStatus.EnProgreso => "En progreso",
        IncidentStatus.Transferida => "Transferida",
        IncidentStatus.Resuelta => "Resuelta",
        _ => "Cerrada"
    };

    private static string PriorityBadgeClass(IncidentPriority p) => p switch
    {
        IncidentPriority.Critica => "badge badge--priority badge--priority-critica",
        IncidentPriority.Alta => "badge badge--priority badge--priority-alta",
        IncidentPriority.Media => "badge badge--priority badge--priority-media",
        _ => "badge badge--priority badge--priority-baja"
    };

    private static string EventDotClass(IncidentEventType type) => type switch
    {
        IncidentEventType.Creada => "created",
        IncidentEventType.Transferida => "transfer",
        IncidentEventType.TomaEnCurso => "progress",
        IncidentEventType.Resuelta or IncidentEventType.Cerrada => "done",
        _ => "default"
    };

    private static string EventLabel(IncidentEvent ev) => ev.Type switch
    {
        IncidentEventType.Creada => "Incidencia creada",
        IncidentEventType.Asignada => $"Ingresó a la cola de {ev.Team}",
        IncidentEventType.TomaEnCurso => $"{ev.Team} tomó la incidencia",
        IncidentEventType.Transferida => $"Transferida de {ev.FromTeam} a {ev.ToTeam}",
        IncidentEventType.Comentario => "Comentario",
        IncidentEventType.Resuelta => "Incidencia resuelta",
        IncidentEventType.Reabierta => "Incidencia reabierta",
        IncidentEventType.Cerrada => "Incidencia cerrada",
        _ => ev.Type.ToString()
    };

    private static string FormatSpan(TimeSpan span)
    {
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours}h {span.Minutes}m";
        return $"{(int)span.TotalMinutes}m";
    }
}

/* =========================================================================
   CorpWiki — Módulo de Incidencias
   ========================================================================= */

/* ---------- Stat cards ---------- */
.incident-stat-grid { grid-template-columns: repeat(4, 1fr); margin-bottom: var(--space-6); }
.stat-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-5);
}
.stat-card__value { font-size: var(--fs-xl); font-weight: 800; color: var(--text-primary); }
.stat-card__value--danger { color: var(--brand-500); }
.stat-card__label { font-size: var(--fs-xs); color: var(--text-tertiary); }

/* ---------- Filter bar ---------- */
.filter-bar {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    padding: var(--space-5);
    margin-bottom: var(--space-6);
}

/* ---------- Priority badges ---------- */
.badge--priority { font-size: var(--fs-xs); font-weight: 700; padding: 3px 10px; border-radius: var(--radius-full); border: 1px solid transparent; }
.badge--priority-critica { background: rgba(218,31,61,0.12); color: var(--brand-500); border-color: rgba(218,31,61,0.3); }
.badge--priority-alta   { background: rgba(245,158,11,0.14); color: #b45309; border-color: rgba(245,158,11,0.35); }
.badge--priority-media  { background: rgba(14,165,233,0.12); color: #0ea5e9; border-color: rgba(14,165,233,0.3); }
.badge--priority-baja   { background: rgba(16,185,129,0.12); color: #10b981; border-color: rgba(16,185,129,0.3); }

/* ---------- Kanban ---------- */
.kanban {
    display: grid;
    grid-template-columns: repeat(5, minmax(240px, 1fr));
    gap: var(--space-4);
    overflow-x: auto;
    padding-bottom: var(--space-2);
}
.kanban__column {
    background: var(--bg-surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-3);
    min-width: 240px;
}
.kanban__column-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--text-primary);
    padding: var(--space-2) var(--space-1) var(--space-3);
}
.kanban__count {
    background: var(--bg-surface-3);
    color: var(--text-tertiary);
    font-size: var(--fs-xs);
    padding: 1px 8px;
    border-radius: var(--radius-full);
}
.kanban__cards { display: flex; flex-direction: column; gap: var(--space-3); }
.kanban__empty { font-size: var(--fs-xs); color: var(--text-tertiary); text-align: center; padding: var(--space-4) 0; }

.incident-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    transition: box-shadow var(--transition-fast), transform var(--transition-fast), border-color var(--transition-fast);
}
.incident-card:hover { border-color: var(--border-strong); box-shadow: var(--shadow-md); transform: translateY(-2px); }

.incident-card__top { display: flex; align-items: center; justify-content: space-between; }
.incident-card__code { font-size: var(--fs-xs); font-weight: 700; color: var(--text-tertiary); font-family: var(--font-mono); }
.incident-card__title { font-size: var(--fs-sm); font-weight: 600; color: var(--text-primary); line-height: 1.4; }

.incident-card__meta { display: flex; flex-direction: column; gap: 2px; }
.incident-card__meta span { display: flex; align-items: center; gap: 6px; font-size: var(--fs-xs); color: var(--text-tertiary); }
.incident-card__meta .icon { width: 12px; height: 12px; }

.incident-card__footer {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: var(--space-2);
    border-top: 1px solid var(--border-subtle);
}
.incident-card__elapsed, .incident-card__dead {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: var(--fs-xs);
    color: var(--text-tertiary);
}
.incident-card__dead { color: #b45309; font-weight: 600; }
.incident-card__dead--over { color: var(--brand-500); }
.incident-card__elapsed .icon, .incident-card__dead .icon { width: 12px; height: 12px; }

/* ---------- Detail header ---------- */
.incident-detail__title-row { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }

/* ---------- Meta blocks ---------- */
.meta-block { display: flex; flex-direction: column; gap: 2px; }
.meta-block__label { font-size: var(--fs-xs); color: var(--text-tertiary); }
.meta-block__value { font-size: var(--fs-sm); font-weight: 700; color: var(--text-primary); }
.meta-block__value--danger { color: var(--brand-500); }

/* ---------- Team legs (tiempo muerto vs activo) ---------- */
.team-legs { display: flex; flex-direction: column; gap: var(--space-5); }
.team-leg { padding-bottom: var(--space-4); border-bottom: 1px solid var(--border-subtle); }
.team-leg:last-child { border-bottom: none; padding-bottom: 0; }

.team-leg__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-3); }
.team-leg__team { display: flex; align-items: center; gap: 6px; font-size: var(--fs-sm); font-weight: 700; color: var(--text-primary); }
.team-leg__team .icon { width: 14px; height: 14px; color: var(--brand-500); }
.team-leg__status { font-size: var(--fs-xs); color: var(--text-tertiary); }

.team-leg__bars { display: flex; flex-direction: column; gap: var(--space-2); }
.team-leg__bar-row { display: grid; grid-template-columns: 90px 1fr 70px; align-items: center; gap: var(--space-3); }
.team-leg__bar-label { font-size: var(--fs-xs); color: var(--text-tertiary); }
.team-leg__bar { height: 8px; border-radius: var(--radius-full); background: var(--bg-surface-3); overflow: hidden; }
.team-leg__bar-fill { height: 100%; border-radius: var(--radius-full); transition: width 0.3s ease; }
.team-leg__bar-fill--dead { background: linear-gradient(90deg, var(--accent-amber), #f97316); }
.team-leg__bar-fill--dead.team-leg__bar-fill--over { background: linear-gradient(90deg, var(--brand-500), #8B0E25); }
.team-leg__bar-fill--active { background: linear-gradient(90deg, #10b981, #0ea5e9); }
.team-leg__bar-value { font-size: var(--fs-xs); font-weight: 700; color: var(--text-secondary); text-align: right; }
.team-leg__bar-value--over { color: var(--brand-500); }

/* ---------- Timeline dot variants ---------- */
.version-row__dot--created { background: #0ea5e9; }
.version-row__dot--transfer { background: var(--accent-amber); }
.version-row__dot--progress { background: var(--brand-500); }
.version-row__dot--done { background: #10b981; }
.version-row__dot--default { background: var(--border-strong); }

/* ---------- Responsive ---------- */
@media (max-width: 1200px) {
    .kanban { grid-template-columns: repeat(3, minmax(240px,1fr)); }
}
@media (max-width: 900px) {
    .filter-bar, .incident-stat-grid { grid-template-columns: 1fr 1fr; }
    .kanban { grid-template-columns: repeat(2, minmax(220px,1fr)); }
}
@media (max-width: 640px) {
    .kanban { grid-template-columns: 1fr; }
    .filter-bar, .incident-stat-grid { grid-template-columns: 1fr; }
    .team-leg__bar-row { grid-template-columns: 70px 1fr 55px; }
}