        };
        var t4 = i4.CreatedAt;
        i4.Timeline.Add(new(){ Type=IncidentEventType.Creada, Team="Mesa de Ayuda", Author="Ana Torres", Timestamp=t4 });
        i4.Timeline.Add(new(){ Type=IncidentEventType.Transferida, Team="Mesa de Ayuda", FromTeam="Mesa de Ayuda", ToTeam="Infraestructura", Author="Ana Torres", Timestamp=t4.AddHours(2) });
        i4.Timeline.Add(new(){ Type=IncidentEventType.Asignada, Team="Infraestructura", Author="Ana Torres", Timestamp=t4.AddHours(2) });
        i4.Timeline.Add(new(){ Type=IncidentEventType.TomaEnCurso, Team="Infraestructura", Author="Rocío Paz", Timestamp=t4.AddHours(20) });
