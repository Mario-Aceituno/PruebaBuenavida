@page "/admin"

<PageTitle>CorpWiki — Administración</PageTitle>

<div class="page-header">
    <div>
        <h1>Panel de Administración</h1>
        <p>Configuración global del sitio, usuarios, roles y equipos. Estos ajustes aplican a todos los usuarios.</p>
    </div>
</div>

<div class="admin-tabs">
    <button type="button" class="admin-tabs__btn @(_tab == "general" ? "admin-tabs__btn--active" : "")" @onclick='() => _tab = "general"'>
        <Icon Name="settings" /> General
    </button>
    <button type="button" class="admin-tabs__btn @(_tab == "usuarios" ? "admin-tabs__btn--active" : "")" @onclick='() => _tab = "usuarios"'>
        <Icon Name="users" /> Usuarios
        <span class="admin-tabs__count">@_users.Count</span>
    </button>
    <button type="button" class="admin-tabs__btn @(_tab == "roles" ? "admin-tabs__btn--active" : "")" @onclick='() => _tab = "roles"'>
        <Icon Name="shield-alert" /> Roles y Permisos
    </button>
    <button type="button" class="admin-tabs__btn @(_tab == "equipos" ? "admin-tabs__btn--active" : "")" @onclick='() => _tab = "equipos"'>
        <Icon Name="network" /> Equipos y Áreas
    </button>
    <button type="button" class="admin-tabs__btn @(_tab == "seguridad" ? "admin-tabs__btn--active" : "")" @onclick='() => _tab = "seguridad"'>
        <Icon Name="lock" /> Seguridad
    </button>
</div>

@* ============================================================ GENERAL ============================================================ *@
@if (_tab == "general")
{
    <div class="admin-grid admin-fade-in">
        <div>
            <div class="card admin-section">
                <h3 class="admin-section__title"><Icon Name="settings" /> General</h3>
                <p class="admin-section__desc">Nombre del sitio, lema y comportamiento por defecto de los listados.</p>

                <div class="field-grid field-grid--2">
                    <div class="form-group">
                        <label class="form-label" for="site-name">Nombre del sitio</label>
                        <input id="site-name" class="input" type="text" @bind="_form.SiteName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="site-tagline">Lema / descripción corta</label>
                        <input id="site-tagline" class="input" type="text" @bind="_form.Tagline" />
                    </div>
                </div>

                <div class="field-grid field-grid--2">
                    <div class="form-group">
                        <label class="form-label" for="page-size">Elementos por página (listados)</label>
                        <input id="page-size" class="input" type="number" min="4" max="60" @bind="_form.DefaultPageSize" />
                        <p class="form-hint">Se aplica a Artículos, Categorías, Etiquetas, Colecciones, Multimedia, Autores y Buscar.</p>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="default-theme">Tema por defecto para nuevas sesiones</label>
                        <select id="default-theme" class="input" @bind="_form.DefaultTheme">
                            <option value="dark">Oscuro</option>
                            <option value="light">Claro</option>
                        </select>
                    </div>
                </div>

                <div class="admin-toggle-row">
                    <div>
                        <p class="admin-toggle-row__label">Modo mantenimiento</p>
                        <p class="admin-toggle-row__hint">Muestra un aviso visible en todas las páginas para todos los usuarios.</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="_form.MaintenanceMode" />
                        <span class="switch__track"></span>
                    </label>
                </div>

                <div class="admin-toggle-row">
                    <div>
                        <p class="admin-toggle-row__label">Permitir comentarios</p>
                        <p class="admin-toggle-row__hint">Habilita el cuadro de comentarios al pie de cada artículo.</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="_form.AllowComments" />
                        <span class="switch__track"></span>
                    </label>
                </div>

                <div class="admin-toggle-row">
                    <div>
                        <p class="admin-toggle-row__label">Permitir registro público</p>
                        <p class="admin-toggle-row__hint">Reservado para cuando exista autenticación real (fuera de este alcance).</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="_form.AllowPublicRegistration" />
                        <span class="switch__track"></span>
                    </label>
                </div>

                @if (_saved)
                {
                    <div class="callout callout--tip">
                        <Icon Name="check-circle" />
                        <p>Configuración guardada. Ya aplica para todos los usuarios conectados.</p>
                    </div>
                }

                <div class="form-actions">
                    <button type="button" class="btn btn--primary" @onclick="SaveGeneral"><Icon Name="check-circle" /> Guardar configuración</button>
                </div>
            </div>
        </div>

        <div>
            <div class="card admin-section">
                <h3 class="admin-section__title"><Icon Name="bar-chart-3" /> Resumen del sistema</h3>
                <div class="admin-stat-grid">
                    <StatCard Label="Artículos" Value="@_stats.TotalArticles.ToString()" Icon="file-text" AccentColor="#c41230" />
                    <StatCard Label="Categorías" Value="@_stats.TotalCategories.ToString()" Icon="folder-tree" AccentColor="#2f7fe0" />
                    <StatCard Label="Etiquetas" Value="@_stats.TotalTags.ToString()" Icon="tag" AccentColor="#10b981" />
                    <StatCard Label="Archivos" Value="@_stats.TotalMediaFiles.ToString()" Icon="image" AccentColor="#f59e0b" />
                    <StatCard Label="Autores" Value="@_stats.TotalAuthors.ToString()" Icon="users" AccentColor="#8b5cf6" />
                    <StatCard Label="Vistas totales" Value="@_stats.TotalViews.ToString("N0")" Icon="eye" AccentColor="#0ea5e9" />
                </div>
            </div>
        </div>
    </div>
}

@* ============================================================ USUARIOS ============================================================ *@
@if (_tab == "usuarios")
{
    <div class="admin-fade-in">
        <div class="card admin-section">
            <div class="admin-section__head-row">
                <div>
                    <h3 class="admin-section__title"><Icon Name="users" /> Usuarios</h3>
                    <p class="admin-section__desc">Cuentas con acceso a la wiki, su rol y su equipo asignado.</p>
                </div>
                <button type="button" class="btn btn--primary" @onclick="() => _showNewUser = true">
                    <Icon Name="plus" /> Invitar usuario
                </button>
            </div>

            <div class="admin-search-row">
                <div class="admin-search">
                    <Icon Name="search" />
                    <input type="text" placeholder="Buscar por nombre, email o equipo..." @bind="_userSearch" @bind:event="oninput" />
                </div>
                <select class="input admin-search__select" @bind="_userRoleFilter">
                    <option value="">Todos los roles</option>
                    @foreach (var role in _roles)
                    {
                        <option value="@role.Name">@role.Name</option>
                    }
                </select>
            </div>

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Rol</th>
                            <th>Equipo</th>
                            <th>Último acceso</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in FilteredUsers())
                        {
                            <tr>
                                <td>
                                    <div class="admin-user-cell">
                                        <span class="avatar avatar--sm" style="background:@user.AvatarColor">@user.Initials</span>
                                        <div>
                                            <p class="admin-user-cell__name">@user.FullName</p>
                                            <p class="admin-user-cell__email">@user.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="@RoleBadgeClass(user.Role)">@user.Role</span></td>
                                <td class="admin-table__muted">@user.Team</td>
                                <td class="admin-table__muted">@user.LastSeen</td>
                                <td>
                                    <span class="admin-status admin-status--@(user.Active ? "active" : "inactive")">
                                        <span class="admin-status__dot"></span>
                                        @(user.Active ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td>
                                    <div class="row-actions">
                                        <button type="button" class="icon-btn" title="Editar"><Icon Name="pencil" /></button>
                                        <button type="button" class="icon-btn icon-btn--danger" title="Suspender" @onclick="() => user.Active = !user.Active">
                                            <Icon Name="@(user.Active ? "x-circle" : "check-circle")" />
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (FilteredUsers().Count == 0)
                {
                    <div class="admin-empty">
                        <Icon Name="users" />
                        <p>No se encontraron usuarios con ese filtro.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (_showNewUser)
    {
        <div class="admin-modal-overlay" @onclick="() => _showNewUser = false">
            <div class="card admin-modal" @onclick:stopPropagation="true">
                <div class="admin-modal__head">
                    <h3><Icon Name="user" /> Invitar usuario</h3>
                    <button type="button" class="icon-btn" @onclick="() => _showNewUser = false"><Icon Name="x" /></button>
                </div>
                <div class="form-group">
                    <label class="form-label">Nombre completo</label>
                    <input class="input" type="text" placeholder="Ej: María González" />
                </div>
                <div class="form-group">
                    <label class="form-label">Email corporativo</label>
                    <input class="input" type="email" placeholder="nombre.apellido@banco.com" />
                </div>
                <div class="field-grid field-grid--2">
                    <div class="form-group">
                        <label class="form-label">Rol</label>
                        <select class="input">
                            @foreach (var role in _roles)
                            {
                                <option value="@role.Name">@role.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Equipo</label>
                        <select class="input">
                            @foreach (var team in _teams)
                            {
                                <option value="@team.Name">@team.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="form-actions">
                    <button type="button" class="btn btn--secondary" @onclick="() => _showNewUser = false">Cancelar</button>
                    <button type="button" class="btn btn--primary" @onclick="() => _showNewUser = false"><Icon Name="plus" /> Enviar invitación</button>
                </div>
            </div>
        </div>
    }
}

@* ============================================================ ROLES Y PERMISOS ============================================================ *@
@if (_tab == "roles")
{
    <div class="admin-fade-in">
        <div class="admin-section__head-row" style="margin-bottom:var(--space-5)">
            <div>
                <h3 class="admin-section__title" style="margin-bottom:2px"><Icon Name="shield-alert" /> Roles y Permisos</h3>
                <p class="admin-section__desc" style="margin-bottom:0">Definí qué puede hacer cada rol dentro de la wiki.</p>
            </div>
            <button type="button" class="btn btn--primary"><Icon Name="plus" /> Nuevo rol</button>
        </div>

        <div class="admin-roles-grid">
            @foreach (var role in _roles)
            {
                <div class="card admin-role-card">
                    <div class="admin-role-card__head">
                        <span class="admin-role-card__icon" style="background:@role.Color">
                            <Icon Name="@role.Icon" />
                        </span>
                        <div>
                            <p class="admin-role-card__name">@role.Name</p>
                            <p class="admin-role-card__count">@role.UserCount usuarios</p>
                        </div>
                    </div>
                    <p class="admin-role-card__desc">@role.Description</p>
                    <div class="admin-permission-list">
                        @foreach (var perm in _permissions)
                        {
                            var granted = role.Permissions.Contains(perm.Key);
                            <div class="admin-permission-row">
                                <span class="admin-permission-row__label">@perm.Label</span>
                                <span class="admin-permission-row__icon @(granted ? "admin-permission-row__icon--granted" : "admin-permission-row__icon--denied")">
                                    <Icon Name="@(granted ? "check" : "x")" />
                                </span>
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn--secondary btn--sm" style="width:100%">
                        <Icon Name="pencil" /> Editar permisos
                    </button>
                </div>
            }
        </div>
    </div>
}

@* ============================================================ EQUIPOS Y ÁREAS ============================================================ *@
@if (_tab == "equipos")
{
    <div class="admin-fade-in">
        <div class="admin-section__head-row" style="margin-bottom:var(--space-5)">
            <div>
                <h3 class="admin-section__title" style="margin-bottom:2px"><Icon Name="network" /> Equipos y Áreas</h3>
                <p class="admin-section__desc" style="margin-bottom:0">Áreas de Tecnología, sus responsables y carga de trabajo.</p>
            </div>
            <button type="button" class="btn btn--primary"><Icon Name="plus" /> Nueva área</button>
        </div>

        <div class="admin-teams-grid">
            @foreach (var team in _teams)
            {
                <div class="card admin-team-card">
                    <div class="admin-team-card__head">
                        <span class="admin-team-card__icon"><Icon Name="@team.Icon" /></span>
                        <span class="badge badge--brand">@team.OpenIncidents activas</span>
                    </div>
                    <p class="admin-team-card__name">@team.Name</p>
                    <p class="admin-team-card__desc">@team.Description</p>

                    <div class="admin-team-card__lead">
                        <span class="avatar avatar--xs" style="background:@team.LeadColor">@team.LeadInitials</span>
                        <div>
                            <p class="admin-team-card__lead-name">@team.Lead</p>
                            <p class="admin-team-card__lead-role">Responsable de área</p>
                        </div>
                    </div>

                    <div class="admin-team-card__footer">
                        <div class="admin-avatar-stack">
                            @foreach (var m in team.Members.Take(4))
                            {
                                <span class="avatar avatar--xs" style="background:@m.Color" title="@m.Name">@m.Initials</span>
                            }
                            @if (team.Members.Count > 4)
                            {
                                <span class="admin-avatar-stack__more">+@(team.Members.Count - 4)</span>
                            }
                        </div>
                        <span class="admin-team-card__members">@team.Members.Count integrantes</span>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ============================================================ SEGURIDAD ============================================================ *@
@if (_tab == "seguridad")
{
    <div class="admin-grid admin-fade-in">
        <div>
            <div class="card admin-section">
                <h3 class="admin-section__title"><Icon Name="lock" /> Políticas de sesión</h3>
                <p class="admin-section__desc">Reglas de acceso y autenticación para todos los usuarios.</p>

                <div class="admin-toggle-row">
                    <div>
                        <p class="admin-toggle-row__label">Autenticación en dos pasos (2FA)</p>
                        <p class="admin-toggle-row__hint">Obligatoria para roles Administrador y Editor.</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked />
                        <span class="switch__track"></span>
                    </label>
                </div>

                <div class="admin-toggle-row">
                    <div>
                        <p class="admin-toggle-row__label">Cierre de sesión automático</p>
                        <p class="admin-toggle-row__hint">Cierra la sesión luego de 30 minutos de inactividad.</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked />
                        <span class="switch__track"></span>
                    </label>
                </div>

                <div class="admin-toggle-row">
                    <div>
                        <p class="admin-toggle-row__label">Restricción por red corporativa</p>
                        <p class="admin-toggle-row__hint">Solo permite acceso desde IPs dentro de la VPN del banco.</p>
                    </div>
                    <label class="switch">
                        <input type="checkbox" />
                        <span class="switch__track"></span>
                    </label>
                </div>

                <div class="form-group" style="margin-top:var(--space-4)">
                    <label class="form-label">Política de contraseñas</label>
                    <select class="input">
                        <option>Estándar (8+ caracteres, mayúsculas y números)</option>
                        <option>Reforzada (12+ caracteres, símbolos, rotación 90 días)</option>
                    </select>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn--primary"><Icon Name="check-circle" /> Guardar políticas</button>
                </div>
            </div>
        </div>

        <div>
            <div class="card admin-section">
                <h3 class="admin-section__title"><Icon Name="history" /> Actividad reciente</h3>
                <div class="admin-audit-list">
                    @foreach (var log in _auditLog)
                    {
                        <div class="admin-audit-row">
                            <span class="admin-audit-row__icon admin-audit-row__icon--@log.Kind">
                                <Icon Name="@log.Icon" />
                            </span>
                            <div>
                                <p class="admin-audit-row__text"><strong>@log.Actor</strong> @log.Action</p>
                                <p class="admin-audit-row__time">@log.Time</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

