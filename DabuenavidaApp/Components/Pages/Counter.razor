@* Type: created | progress | transfer | comment | resolved *@

<div class="inc-timeline-node inc-timeline-node--@Type" style="animation-delay:@(DelayMs)ms;">
    <div class="inc-timeline-node__marker">
        <div class="inc-timeline-node__avatar" style="background:@AvatarColor;">
            @Initials
        </div>
    </div>
    <div class="inc-timeline-node__card">
        <div class="inc-timeline-node__head">
            <span class="inc-timeline-node__actor">@Actor</span>
            <span class="inc-timeline-node__time">@Time</span>
        </div>
        <div class="inc-timeline-node__desc">@((MarkupString)Description)</div>

        @if (ShowFlow)
        {
            <div class="inc-timeline-node__flow">
                <span class="inc-flow-pill">
                    <IconSvg Name="@FromIcon" /> @From
                </span>
                <span class="inc-flow-arrow"><IconSvg Name="arrow-right" /></span>
                <span class="inc-flow-pill">
                    <IconSvg Name="@ToIcon" /> @To
                </span>
                <span class="inc-flow-duration">
                    <IconSvg Name="clock" /> @Duration
                </span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Type { get; set; } = "created";
    [Parameter] public string Actor { get; set; } = "Sistema";
    [Parameter] public string Time { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string AvatarColor { get; set; } = "var(--inc-info-500)";
    [Parameter] public int DelayMs { get; set; } = 0;

    [Parameter] public bool ShowFlow { get; set; } = false;
    [Parameter] public string From { get; set; } = "";
    [Parameter] public string FromIcon { get; set; } = "cpu";
    [Parameter] public string To { get; set; } = "";
    [Parameter] public string ToIcon { get; set; } = "layers";
    [Parameter] public string Duration { get; set; } = "";

    private string Initials
    {
        get
        {
            var parts = Actor.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 0) return "?";
            if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
            return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
        }
    }
}

