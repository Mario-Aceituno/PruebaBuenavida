namespace CorpWiki.Models;

public enum IncidentPriority { Baja, Media, Alta, Critica }

public enum IncidentStatus { Abierta, EnProgreso, Transferida, Resuelta, Cerrada }

public enum IncidentEventType
{
    Creada,
    Asignada,      // pasa a la cola de un equipo
    TomaEnCurso,   // el equipo empieza a trabajarla (fin del tiempo muerto)
    Comentario,
    Transferida,   // se manda a otro equipo, arrastrando categoría/prioridad
    Resuelta,
    Reabierta,
    Cerrada
}

public class IncidentEvent
{
    public Guid Id { get; set; } = Guid.NewGuid();
    public IncidentEventType Type { get; set; }
    public string Team { get; set; } = string.Empty;
    public string? FromTeam { get; set; }
    public string? ToTeam { get; set; }
    public string Author { get; set; } = string.Empty;
    public string Note { get; set; } = string.Empty;
    public DateTime Timestamp { get; set; }
}

public class Incident
{
    public Guid Id { get; set; } = Guid.NewGuid();
    public string Code { get; set; } = string.Empty;
    public string Title { get; set; } = string.Empty;
    public string Description { get; set; } = string.Empty;
    public string Category { get; set; } = string.Empty;
    public IncidentPriority Priority { get; set; }
    public IncidentStatus Status { get; set; }
    public string CreatedBy { get; set; } = string.Empty;
    public DateTime CreatedAt { get; set; }
    public string CurrentTeam { get; set; } = string.Empty;
    public List<IncidentEvent> Timeline { get; set; } = new();
}

/// <summary>
/// Tramo calculado: el paso de la incidencia por un equipo determinado,
/// con el desglose entre tiempo muerto (esperando que alguien la tome)
/// y tiempo activo (trabajándola).
/// </summary>
public class TeamLeg
{
    public string Team { get; set; } = string.Empty;
    public DateTime AssignedAt { get; set; }
    public DateTime? StartedAt { get; set; }
    public DateTime? EndedAt { get; set; }
    public string EndReason { get; set; } = string.Empty; // "Transferida" | "Resuelta" | "En curso"

    public TimeSpan DeadTime => (StartedAt ?? DateTime.Now) - AssignedAt;
    public TimeSpan? ActiveTime => StartedAt.HasValue
        ? (EndedAt ?? DateTime.Now) - StartedAt.Value
        : null;
}

using CorpWiki.Models;

namespace CorpWiki.Services;

public class IncidentDataService
{
    public List<string> Teams { get; } = new()
    {
        "Mesa de Ayuda", "Infraestructura", "Redes",
        "Seguridad de la Información", "Desarrollo", "Base de Datos"
    };

    public List<string> Categories { get; } = new()
    {
        "Accesos y Credenciales", "Infraestructura", "Redes",
        "Seguridad", "Aplicaciones Internas", "Base de Datos"
    };

    private readonly List<Incident> _incidents = new();
    private int _seq = 1042;

    public IncidentDataService()
    {
        Seed();
    }

    public IReadOnlyList<Incident> GetAll() =>
        _incidents.OrderByDescending(i => i.CreatedAt).ToList();

    public Incident? GetByCode(string code) =>
        _incidents.FirstOrDefault(i => i.Code == code);

    public Incident CreateIncident(string title, string description, string category,
        IncidentPriority priority, string team, string createdBy)
    {
        var now = DateTime.Now;
        var incident = new Incident
        {
            Code = $"INC-{_seq++:0000}",
            Title = title,
            Description = description,
            Category = category,
            Priority = priority,
            Status = IncidentStatus.Abierta,
            CreatedBy = createdBy,
            CreatedAt = now,
            CurrentTeam = team
        };
        incident.Timeline.Add(new IncidentEvent
        {
            Type = IncidentEventType.Creada,
            Team = team,
            Author = createdBy,
            Note = $"Incidencia creada y asignada a {team}.",
            Timestamp = now
        });
        incident.Timeline.Add(new IncidentEvent
        {
            Type = IncidentEventType.Asignada,
            Team = team,
            Author = createdBy,
            Timestamp = now
        });
        _incidents.Insert(0, incident);
        return incident;
    }

    public void StartProgress(string code, string author)
    {
        var inc = GetByCode(code);
        if (inc is null || inc.Status is IncidentStatus.Resuelta or IncidentStatus.Cerrada) return;

        inc.Status = IncidentStatus.EnProgreso;
        inc.Timeline.Add(new IncidentEvent
        {
            Type = IncidentEventType.TomaEnCurso,
            Team = inc.CurrentTeam,
            Author = author,
            Note = $"{inc.CurrentTeam} tomó la incidencia.",
            Timestamp = DateTime.Now
        });
    }

    public void Transfer(string code, string toTeam, string note, string author)
    {
        var inc = GetByCode(code);
        if (inc is null) return;

        var fromTeam = inc.CurrentTeam;
        inc.Timeline.Add(new IncidentEvent
        {
            Type = IncidentEventType.Transferida,
            Team = fromTeam,
            FromTeam = fromTeam,
            ToTeam = toTeam,
            Author = author,
            Note = note,
            Timestamp = DateTime.Now
        });

        inc.CurrentTeam = toTeam;
        inc.Status = IncidentStatus.Transferida;

        // La categoría y prioridad viajan con la incidencia (no se resetean).
        inc.Timeline.Add(new IncidentEvent
        {
            Type = IncidentEventType.Asignada,
            Team = toTeam,
            Author = author,
            Note = $"Ingresa a la cola de {toTeam} · Categoría: {inc.Category} · Prioridad: {inc.Priority}",
            Timestamp = DateTime.Now
        });
    }

    public void AddComment(string code, string author, string note)
    {
        var inc = GetByCode(code);
        if (inc is null || string.IsNullOrWhiteSpace(note)) return;

        inc.Timeline.Add(new IncidentEvent
        {
            Type = IncidentEventType.Comentario,
            Team = inc.CurrentTeam,
            Author = author,
            Note = note,
            Timestamp = DateTime.Now
        });
    }

    public void Resolve(string code, string author, string note)
    {
        var inc = GetByCode(code);
        if (inc is null) return;

        inc.Status = IncidentStatus.Resuelta;
        inc.Timeline.Add(new IncidentEvent
        {
            Type = IncidentEventType.Resuelta,
            Team = inc.CurrentTeam,
            Author = author,
            Note = string.IsNullOrWhiteSpace(note) ? "Incidencia resuelta." : note,
            Timestamp = DateTime.Now
        });
    }

    /// <summary>SLA de referencia en horas según prioridad, para comparar contra el tiempo muerto real.</summary>
    public static double SlaHours(IncidentPriority p) => p switch
    {
        IncidentPriority.Critica => 1,
        IncidentPriority.Alta => 4,
        IncidentPriority.Media => 8,
        _ => 24
    };

    /// <summary>Calcula los tramos por equipo (tiempo muerto + tiempo activo) a partir del timeline.</summary>
    public static List<TeamLeg> ComputeLegs(Incident incident)
    {
        var legs = new List<TeamLeg>();
        TeamLeg? current = null;

        foreach (var ev in incident.Timeline.OrderBy(e => e.Timestamp))
        {
            switch (ev.Type)
            {
                case IncidentEventType.Asignada:
                    current = new TeamLeg { Team = ev.Team, AssignedAt = ev.Timestamp };
                    legs.Add(current);
                    break;

                case IncidentEventType.TomaEnCurso:
                    if (current is not null && current.Team == ev.Team)
                        current.StartedAt = ev.Timestamp;
                    break;

                case IncidentEventType.Transferida:
                    if (current is not null && current.Team == ev.FromTeam)
                    {
                        current.EndedAt = ev.Timestamp;
                        current.EndReason = "Transferida";
                        if (current.StartedAt is null) current.StartedAt = ev.Timestamp;
                    }
                    break;

                case IncidentEventType.Resuelta:
                    if (current is not null)
                    {
                        current.EndedAt = ev.Timestamp;
                        current.EndReason = "Resuelta";
                        if (current.StartedAt is null) current.StartedAt = ev.Timestamp;
                    }
                    break;
            }
        }

        if (current is not null && current.EndedAt is null)
            current.EndReason = "En curso";

        return legs;
    }

    private void Seed()
    {
        // ---- Incidencia 1: multi-equipo, con tiempo muerto marcado entre Redes -> Seguridad ----
        var i1 = new Incident
        {
            Code = "INC-1001",
            Title = "Caída intermitente de VPN corporativa en sucursales",
            Description = "Usuarios de sucursales reportan desconexiones frecuentes de la VPN durante la mañana.",
            Category = "Redes",
            Priority = IncidentPriority.Alta,
            Status = IncidentStatus.EnProgreso,
            CreatedBy = "Mesa de Ayuda — Ana Torres",
            CreatedAt = DateTime.Now.AddHours(-30),
            CurrentTeam = "Seguridad de la Información"
        };
        var t = i1.CreatedAt;
        i1.Timeline.Add(new(){ Type=IncidentEventType.Creada, Team="Mesa de Ayuda", Author="Ana Torres", Note="Incidencia creada desde reporte de usuarios.", Timestamp=t });
        i1.Timeline.Add(new(){ Type=IncidentEventType.Asignada, Team="Mesa de Ayuda", Author="Ana Torres", Timestamp=t });
        i1.Timeline.Add(new(){ Type=IncidentEventType.TomaEnCurso, Team="Mesa de Ayuda", Author="Ana Torres", Note="Se valida y escala a Redes.", Timestamp=t.AddMinutes(20) });
        i1.Timeline.Add(new(){ Type=IncidentEventType.Transferida, Team="Mesa de Ayuda", FromTeam="Mesa de Ayuda", ToTeam="Redes", Author="Ana Torres", Note="Se descarta problema de usuario, es de infraestructura de red.", Timestamp=t.AddHours(1) });
        i1.Timeline.Add(new(){ Type=IncidentEventType.Asignada, Team="Redes", Author="Ana Torres", Timestamp=t.AddHours(1) });
        i1.Timeline.Add(new(){ Type=IncidentEventType.TomaEnCurso, Team="Redes", Author="Diego Salas", Note="Se revisan logs del concentrador VPN.", Timestamp=t.AddHours(3.5) }); // 2.5h de tiempo muerto
        i1.Timeline.Add(new(){ Type=IncidentEventType.Transferida, Team="Redes", FromTeam="Redes", ToTeam="Seguridad de la Información", Author="Diego Salas", Note="Se detecta bloqueo de certificados, requiere revisión de Seguridad.", Timestamp=t.AddHours(6) });
        i1.Timeline.Add(new(){ Type=IncidentEventType.Asignada, Team="Seguridad de la Información", Author="Diego Salas", Timestamp=t.AddHours(6) });
        // Sin TomaEnCurso todavía -> tiempo muerto actual corriendo (demuestra el caso "en espera")
        _incidents.Add(i1);

        // ---- Incidencia 2: resuelta rápido, sin tiempos muertos relevantes ----
        var i2 = new Incident
        {
            Code = "INC-1002",
            Title = "Usuario bloqueado en Active Directory tras varios intentos fallidos",
            Description = "El usuario jgomez no puede iniciar sesión, la cuenta figura bloqueada en AD.",
            Category = "Accesos y Credenciales",
            Priority = IncidentPriority.Media,
            Status = IncidentStatus.Resuelta,
            CreatedBy = "Mesa de Ayuda — Ana Torres",
            CreatedAt = DateTime.Now.AddHours(-5),
            CurrentTeam = "Infraestructura"
        };
        var t2 = i2.CreatedAt;
        i2.Timeline.Add(new(){ Type=IncidentEventType.Creada, Team="Mesa de Ayuda", Author="Ana Torres", Timestamp=t2 });
        i2.Timeline.Add(new(){ Type=IncidentEventType.Transferida, Team="Mesa de Ayuda", FromTeam="Mesa de Ayuda", ToTeam="Infraestructura", Author="Ana Torres", Note="Requiere desbloqueo directo en el controlador de dominio.", Timestamp=t2.AddMinutes(5) });
        i2.Timeline.Add(new(){ Type=IncidentEventType.Asignada, Team="Infraestructura", Author="Ana Torres", Timestamp=t2.AddMinutes(5) });
        i2.Timeline.Add(new(){ Type=IncidentEventType.TomaEnCurso, Team="Infraestructura", Author="Rocío Paz", Timestamp=t2.AddMinutes(12) });
        i2.Timeline.Add(new(){ Type=IncidentEventType.Resuelta, Team="Infraestructura", Author="Rocío Paz", Note="Cuenta desbloqueada y contraseña restablecida.", Timestamp=t2.AddMinutes(28) });
        _incidents.Add(i2);

        // ---- Incidencia 3: crítica, con tiempo muerto grave (fuera de SLA) ----
        var i3 = new Incident
        {
            Code = "INC-1003",
            Title = "Caída del portal de Banca en Línea",
            Description = "El portal de Banca en Línea no responde para clientes externos.",
            Category = "Aplicaciones Internas",
            Priority = IncidentPriority.Critica,
            Status = IncidentStatus.EnProgreso,
            CreatedBy = "Mesa de Ayuda — Julián Reyes",
            CreatedAt = DateTime.Now.AddHours(-8),
            CurrentTeam = "Desarrollo"
        };
        var t3 = i3.CreatedAt;
        i3.Timeline.Add(new(){ Type=IncidentEventType.Creada, Team="Mesa de Ayuda", Author="Julián Reyes", Timestamp=t3 });
        i3.Timeline.Add(new(){ Type=IncidentEventType.Asignada, Team="Mesa de Ayuda", Author="Julián Reyes", Timestamp=t3 });
        i3.Timeline.Add(new(){ Type=IncidentEventType.TomaEnCurso, Team="Mesa de Ayuda", Author="Julián Reyes", Timestamp=t3.AddMinutes(5) });
        i3.Timeline.Add(new(){ Type=IncidentEventType.Transferida, Team="Mesa de Ayuda", FromTeam="Mesa de Ayuda", ToTeam="Infraestructura", Author="Julián Reyes", Note="Escalada inmediata por caída total del servicio.", Timestamp=t3.AddMinutes(10) });
        i3.Timeline.Add(new(){ Type=IncidentEventType.Asignada, Team="Infraestructura", Author="Julián Reyes", Timestamp=t3.AddMinutes(10) });
        i3.Timeline.Add(new(){ Type=IncidentEventType.TomaEnCurso, Team="Infraestructura", Author="Rocío Paz", Timestamp=t3.AddMinutes(25) });
        i3.Timeline.Add(new(){ Type=IncidentEventType.Transferida, Team="Infraestructura", FromTeam="Infraestructura", ToTeam="Desarrollo", Author="Rocío Paz", Note="El servidor está arriba, el error es de la aplicación (excepción 500).", Timestamp=t3.AddHours(1.5) });
        i3.Timeline.Add(new(){ Type=IncidentEventType.Asignada, Team="Desarrollo", Author="Rocío Paz", Timestamp=t3.AddHours(1.5) });
        i3.Timeline.Add(new(){ Type=IncidentEventType.TomaEnCurso, Team="Desarrollo", Author="Martín Ibarra", Note="Se identifica el deploy que rompió el servicio.", Timestamp=t3.AddHours(5) }); // 3.5h muerto sobre SLA de 1h (crítica)
        _incidents.Add(i3);

        // ---- Incidencia 4: baja prioridad, cerrada ----
        var i4 = new Incident
        {
            Code = "INC-1004",
            Title = "Solicitud de permisos en biblioteca de SharePoint",
            Description = "El equipo de Riesgos solicita acceso de edición a la biblioteca 'Normativas 2026'.",
